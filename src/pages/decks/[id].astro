---
// src/pages/decks/[id].astro — PUBLIC deck viewer (unguessable id; noindex).
// Prerendered → static HTML on the CDN (off the serverless function), so adding
// decks never grows the function. The catalog that links here is gated at
// /internal/decks. Renders a fixed 16:9 stage; embeds deck.pdf or index.html.
import { decks, getDeckById } from '../../data/decks-meta';

export const prerender = true;
export function getStaticPaths() {
  return decks.map((d) => ({ params: { id: d.id } }));
}

const { id } = Astro.params;
const deck = getDeckById(id!);
if (!deck) return Astro.redirect('/tools');

// Deck content lives under /deck-files/ (NOT /decks/ — that namespace is the
// prerendered viewer route, whose index.html would collide with an HTML deck's).
// If deck.srcUrl is set (e.g. a Supabase Storage-hosted PDF), embed it directly.
const base = deck.srcUrl
  ?? (deck.format === 'pdf' ? `/deck-files/${deck.id}/deck.pdf` : `/deck-files/${deck.id}/index.html`);
const src = deck.format === 'pdf' ? `${base}#toolbar=1&view=FitH` : base;
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{deck.title}</title>
  <style>
    :root { --bar: 44px; --ink: #042f24; }
    * { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; background: #0b0f0e; color: #e8efec; font-family: Inter, system-ui, sans-serif; }
    .deck-bar {
      height: var(--bar); display: flex; align-items: center; gap: 12px;
      padding: 0 14px; background: #11201b; color: #eaf3ef; border-bottom: 1px solid #1d3a30;
    }
    .deck-bar__title { font-weight: 700; font-size: 14px; letter-spacing: .2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .deck-bar__tag { font-size: 11px; opacity: .6; border: 1px solid #2a4a3e; border-radius: 999px; padding: 2px 8px; white-space: nowrap; }
    .deck-bar__spacer { flex: 1; }
    .deck-bar__btn { cursor: pointer; background: #1c3a30; color: #eaf3ef; border: 0; border-radius: 8px; padding: 7px 12px; font-size: 12px; font-weight: 600; }
    .deck-bar__btn:hover { background: #275346; }
    .stage { height: calc(100vh - var(--bar)); display: grid; place-items: center; padding: 18px; }
    /* The fixed 16:9 frame — the canonical PPT canvas. */
    .frame { width: 100%; max-width: calc((100vh - var(--bar) - 36px) * 16 / 9); aspect-ratio: 16 / 9; background: #fff; border-radius: 6px; overflow: hidden; box-shadow: 0 14px 50px rgba(0,0,0,.5); }
    .frame iframe { width: 100%; height: 100%; border: 0; display: block; }
    /* Placeholder slide (until real content is dropped in public/decks/<id>/). */
    .ph { width: 100%; height: 100%; display: grid; place-content: center; text-align: center; gap: 10px; color: var(--ink); background: repeating-linear-gradient(135deg,#f6f8f7,#f6f8f7 22px,#eef3f1 22px,#eef3f1 44px); }
    .ph__16x9 { font: 800 40px/1 Manrope, sans-serif; letter-spacing: 1px; }
    .ph__t { font: 700 16px/1.4 Manrope, sans-serif; }
    .ph__s { font-size: 12px; opacity: .6; }
    .ph__fmt { font: 700 11px/1 Inter; text-transform: uppercase; letter-spacing: 1px; color:#fff; background: var(--ink); border-radius: 999px; padding: 4px 10px; justify-self: center; }
  </style>
</head>
<body>
  <header class="deck-bar">
    <span class="deck-bar__title">{deck.title}</span>
    <span class="deck-bar__tag">{deck.stage} · {deck.theme}</span>
    <span class="deck-bar__spacer"></span>
    <button class="deck-bar__btn" id="fs">全屏放映</button>
  </header>

  <main class="stage">
    <div class="frame" id="frame">
      {deck.placeholder ? (
        <div class="ph">
          <div class="ph__16x9">16 : 9</div>
          <div class="ph__t">{deck.title}</div>
          <div class="ph__fmt">{deck.format}</div>
          <div class="ph__s">内容占位 — 把 deck 放到 public/deck-files/{deck.id}/ 后这里会嵌入实际幻灯</div>
        </div>
      ) : (
        <iframe src={src} title={deck.title} allow="fullscreen" allowfullscreen></iframe>
      )}
    </div>
  </main>

  <script is:inline>
    document.getElementById('fs')?.addEventListener('click', () => {
      const el = document.getElementById('frame');
      if (!el) return;
      if (document.fullscreenElement) document.exitFullscreen();
      else el.requestFullscreen?.();
    });
  </script>
</body>
</html>
