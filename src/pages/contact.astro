---
// src/pages/contact.astro — Contact page
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact | Chinese SDGs Institute" description="Get in touch with the Chinese SDG Institute for partnerships, research collaborations, and inquiries." lang="en">
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <div class="max-w-4xl mx-auto px-6 md:px-12">
      <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6 md:mb-8">
        <span>Institute</span>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-primary font-bold">Contact</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tight text-on-surface leading-[1.1] mb-4 md:mb-6">
        Get in Touch
      </h1>
      <p class="text-base md:text-lg text-on-surface-variant leading-relaxed mb-10 md:mb-16 max-w-2xl">
        Whether you are interested in research collaboration, institutional partnerships, or general inquiries, we would love to hear from you.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-8 mb-12 md:mb-20">
        <div class="bg-white p-5 md:p-8 rounded-xl border border-surface-container-high shadow-sm">
          <span class="material-symbols-outlined text-3xl text-primary mb-4 block">handshake</span>
          <h3 class="text-sm font-headline font-bold text-on-surface mb-2">Partnerships</h3>
          <p class="text-xs text-on-surface-variant leading-relaxed">Institutional collaborations, joint research programs, and SDG initiatives.</p>
        </div>
        <div class="bg-white p-5 md:p-8 rounded-xl border border-surface-container-high shadow-sm">
          <span class="material-symbols-outlined text-3xl text-primary mb-4 block">school</span>
          <h3 class="text-sm font-headline font-bold text-on-surface mb-2">Research</h3>
          <p class="text-xs text-on-surface-variant leading-relaxed">Submit proposals, request data, or discuss research collaboration opportunities.</p>
        </div>
        <div class="bg-white p-5 md:p-8 rounded-xl border border-surface-container-high shadow-sm">
          <span class="material-symbols-outlined text-3xl text-primary mb-4 block">groups</span>
          <h3 class="text-sm font-headline font-bold text-on-surface mb-2">Join Us</h3>
          <p class="text-xs text-on-surface-variant leading-relaxed">Volunteer, contribute articles, or join our editorial and events teams.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white p-6 md:p-10 lg:p-14 rounded-2xl border border-surface-container-high shadow-sm">
        <h2 class="text-2xl font-headline font-extrabold text-on-surface mb-2">Send us a message</h2>
        <p class="text-sm text-on-surface-variant mb-10">We typically respond within 2–3 business days.</p>

        <form id="contact-form" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="contact-name" class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold mb-2">Full Name *</label>
              <input
                type="text" id="contact-name" name="name" required
                class="w-full px-4 py-3 rounded-lg border border-outline-variant/20 bg-surface text-on-surface text-sm font-body focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold mb-2">Email *</label>
              <input
                type="email" id="contact-email" name="email" required
                class="w-full px-4 py-3 rounded-lg border border-outline-variant/20 bg-surface text-on-surface text-sm font-body focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                placeholder="you@example.com"
              />
            </div>
          </div>
          <div>
            <label for="contact-subject" class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold mb-2">Subject *</label>
            <select
              id="contact-subject" name="subject" required
              class="w-full px-4 py-3 rounded-lg border border-outline-variant/20 bg-surface text-on-surface text-sm font-body focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
            >
              <option value="">Select a topic</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="research">Research Collaboration</option>
              <option value="volunteer">Volunteer / Join Us</option>
              <option value="media">Media & Press</option>
              <option value="general">General Inquiry</option>
            </select>
          </div>
          <div>
            <label for="contact-message" class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold mb-2">Message *</label>
            <textarea
              id="contact-message" name="message" required rows="5"
              class="w-full px-4 py-3 rounded-lg border border-outline-variant/20 bg-surface text-on-surface text-sm font-body focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-y"
              placeholder="Tell us about your inquiry..."
            ></textarea>
          </div>
          <div class="flex items-center gap-4">
            <button
              type="submit"
              class="bg-primary text-on-primary px-10 py-3.5 rounded-md font-bold text-sm hover:bg-primary-dim transition-all shadow-sm inline-flex items-center gap-2"
            >
              <span class="material-symbols-outlined text-lg">send</span>
              Send Message
            </button>
            <span id="contact-status" class="text-sm font-medium hidden"></span>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    const GOOGLE_SHEET_URL = 'https://script.google.com/macros/s/AKfycbxtMVo_A42bOVHL51h8UJ2tTp7VP3q7uc0uKRDLcu5Cg0xVG3kNpfWNxvV19SkCFmxjUg/exec';

    const form = document.getElementById('contact-form');
    const status = document.getElementById('contact-status');

    // Auto-select subject from URL param (e.g. /contact?subject=partnership)
    const urlSubject = new URLSearchParams(window.location.search).get('subject');
    if (urlSubject) {
      const select = document.getElementById('contact-subject');
      if (select) select.value = urlSubject;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      if (!btn || !status) return;

      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined text-lg animate-spin">progress_activity</span> Sending...';

      const data = new FormData(form);
      const payload = {
        formType: 'contacts',
        name: data.get('name'),
        email: data.get('email'),
        subject: data.get('subject'),
        message: data.get('message'),
      };

      if (!GOOGLE_SHEET_URL) {
        status.textContent = 'Form endpoint not configured yet.';
        status.className = 'text-sm font-medium text-amber-600';
        status.classList.remove('hidden');
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined text-lg">send</span> Send Message';
        return;
      }

      try {
        await fetch(GOOGLE_SHEET_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        status.textContent = 'Message sent successfully!';
        status.className = 'text-sm font-medium text-green-700';
        status.classList.remove('hidden');
        form.reset();
      } catch (err) {
        status.textContent = 'Something went wrong. Please try again.';
        status.className = 'text-sm font-medium text-red-600';
        status.classList.remove('hidden');
      }

      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined text-lg">send</span> Send Message';
    });
  </script>
</MainLayout>
