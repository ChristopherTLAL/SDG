---
// src/pages/research/index.astro — News & Research Index (English)
import MainLayout from '../../layouts/MainLayout.astro';
import PostCard from '../../components/PostCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getResearchPosts, getTrendingPosts } from '../../lib/sanity/queries';
import { formatDate } from '../../utils/date';

const lang = 'en';

// Read filter params from URL
const url = Astro.url;
const activeType = url.searchParams.get('type') || '';
const activeYear = url.searchParams.get('year') || '';
const activeSdg = url.searchParams.get('sdg') || '';

// Fetch posts (contentType filter is done in GROQ, year/SDG filtered after)
const allPosts = await getResearchPosts(lang, activeType || undefined, 100);
const trending = await getTrendingPosts(lang);

// Server-side filtering for year and SDG
let posts = allPosts;
if (activeYear) {
  posts = posts.filter((p: any) => p.publishedAt && p.publishedAt.startsWith(activeYear));
}
if (activeSdg) {
  const sdgLabel = `SDG ${activeSdg}`;
  posts = posts.filter((p: any) => Array.isArray(p.sdgTags) && p.sdgTags.includes(sdgLabel));
}

// Resolve localized field
function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

// Helper: build filter URL preserving other params
function filterUrl(key: string, value: string): string {
  const params = new URLSearchParams();
  if (key === 'type') { if (value) params.set('type', value); }
  else if (activeType) params.set('type', activeType);
  if (key === 'year') { if (value) params.set('year', value); }
  else if (activeYear) params.set('year', activeYear);
  if (key === 'sdg') { if (value) params.set('sdg', value); }
  else if (activeSdg) params.set('sdg', activeSdg);
  const qs = params.toString();
  return qs ? `/research?${qs}` : '/research';
}

// Split posts: 1 featured + 2 secondary + rest as compact (paginated in groups of 3)
const featured = posts[0] || null;
const secondary = posts.slice(1, 3);
const compact = posts.slice(3);
const COMPACT_PER_PAGE = 3;
const hasActiveFilter = !!(activeType || activeYear || activeSdg);

// Pre-process trending
const processedTrending = (trending || []).map((p: any, i: number) => ({
  num: String(i + 1).padStart(2, '0'),
  title: t(p.title),
  href: `/research/${p.slug}`,
}));
---

<MainLayout title="News & Research | Chinese SDGs Institute" description="A curated archive of critical analysis, scientific breakthroughs, and policy frameworks." lang={lang}>
  <main class="pt-40 pb-32">
    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-20">
      <div class="max-w-4xl">
        <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6">
          <span>Institute</span>
          <span class="material-symbols-outlined text-[12px]">chevron_right</span>
          <span class="text-primary font-bold">Intelligence</span>
        </nav>
        <h1 class="text-5xl font-headline font-extrabold tracking-tight text-on-surface mb-6 leading-[1.1]">
          News &amp; Research Index
        </h1>
        <p class="text-lg text-on-surface-variant leading-relaxed font-body max-w-2xl">
          A curated archive of critical analysis, scientific breakthroughs, and policy frameworks driving sustainable development across the Asia-Pacific region.
        </p>
      </div>
    </section>

    <!-- Main Grid Layout -->
    <div class="max-w-6xl mx-auto px-6 md:px-12 grid grid-cols-12 gap-12">
      <!-- Sidebar: Left Filters -->
      <aside class="col-span-12 lg:col-span-2 space-y-10">
        <div class="sticky top-32 space-y-10">
          <div>
            <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-on-surface-variant mb-6 font-bold opacity-50">Content Types</h3>
            <ul class="flex flex-col gap-1">
              {[
                { value: '', label: 'All Content', icon: 'apps' },
                { value: 'news', label: 'News', icon: 'newspaper' },
                { value: 'policy-brief', label: 'Policy Briefs', icon: 'description' },
                { value: 'research', label: 'Research Papers', icon: 'school' },
              ].map(item => {
                const isActive = activeType === item.value;
                return (
                  <li>
                    <a href={filterUrl('type', item.value)}
                      class:list={[
                        'flex items-center gap-3 w-full px-3 py-2 rounded-lg text-xs transition-all',
                        isActive ? 'bg-primary text-white font-semibold shadow-sm' : 'text-on-surface-variant hover:bg-surface-container-low group'
                      ]}>
                      <span class:list={['material-symbols-outlined text-sm', !isActive && 'group-hover:text-primary']}>{item.icon}</span>
                      <span>{item.label}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
          <div>
            <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-on-surface-variant mb-6 font-bold opacity-50">Year</h3>
            <ul class="flex flex-col gap-1">
              {['2026', '2025', '2024', '2023'].map(year => {
                const isActive = activeYear === year;
                return (
                  <li>
                    <a href={filterUrl('year', isActive ? '' : year)}
                      class:list={[
                        'block px-3 py-1.5 rounded-lg text-xs transition-all',
                        isActive ? 'bg-primary text-white font-semibold' : 'text-on-surface-variant hover:bg-surface-container-low hover:text-primary'
                      ]}>
                      {year}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
          <div>
            <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-on-surface-variant mb-6 font-bold opacity-50">SDG Focus</h3>
            <ul class="flex flex-col gap-1">
              {[
                { num: '1', label: 'No Poverty' },
                { num: '4', label: 'Education' },
                { num: '7', label: 'Clean Energy' },
                { num: '11', label: 'Sust. Cities' },
                { num: '13', label: 'Climate Action' },
                { num: '17', label: 'Partnerships' },
              ].map(sdg => {
                const isActive = activeSdg === sdg.num;
                return (
                  <li>
                    <a href={filterUrl('sdg', isActive ? '' : sdg.num)}
                      class:list={[
                        'block px-3 py-1.5 rounded-lg text-xs transition-all',
                        isActive ? 'bg-primary text-white font-semibold' : 'text-on-surface-variant hover:bg-surface-container-low hover:text-primary'
                      ]}>
                      SDG {sdg.num} — {sdg.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      </aside>

      <!-- Main Feed -->
      <div class="col-span-12 lg:col-span-7">
        <div class="space-y-16">
          {featured && (
            <PostCard post={featured} variant="featured" lang={lang} />
          )}

          {secondary.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 border-b border-surface-container-high pb-16">
              {secondary.map((post: any) => (
                <PostCard post={post} variant="medium" lang={lang} />
              ))}
            </div>
          )}

          {compact.length > 0 && (
            <div id="compact-feed" class="space-y-12">
              {compact.map((post: any, i: number) => (
                <div class:list={["compact-item", { hidden: i >= COMPACT_PER_PAGE }]} data-index={i}>
                  <PostCard post={post} variant="compact" lang={lang} />
                </div>
              ))}
            </div>
          )}

          {compact.length > COMPACT_PER_PAGE && (
            <div class="text-center pt-8" id="load-more-wrap">
              <button
                id="load-more-btn"
                class="bg-surface-container-high text-on-surface px-10 py-4 rounded-md font-bold text-sm hover:bg-surface-container-highest transition-all inline-flex items-center gap-3"
              >
                <span class="material-symbols-outlined text-sm">expand_more</span>
                <span id="load-more-text">Load More ({compact.length - COMPACT_PER_PAGE} remaining)</span>
              </button>
            </div>
          )}

          {posts.length === 0 && (
            <div class="text-center py-20">
              <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 mb-6 block">{hasActiveFilter ? 'filter_list_off' : 'article'}</span>
              <h3 class="text-xl font-bold text-on-surface mb-2 font-headline">{hasActiveFilter ? 'No matching articles' : 'No articles yet'}</h3>
              <p class="text-on-surface-variant">{hasActiveFilter ? 'Try adjusting your filters to find more content.' : 'Research papers and news will appear here once published.'}</p>
              {hasActiveFilter && (
                <a href="/research" class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-primary hover:underline">
                  <span class="material-symbols-outlined text-sm">clear_all</span>
                  Clear all filters
                </a>
              )}
            </div>
          )}
        </div>
      </div>

      <!-- Sidebar: Right -->
      <aside class="col-span-12 lg:col-span-3 space-y-10">
        <!-- Trending -->
        <div class="bg-white p-6 rounded-xl border border-surface-container-high shadow-sm">
          <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-primary mb-8 font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">trending_up</span>
            Trending
          </h3>
          <ul class="space-y-6">
            {processedTrending.length > 0 ? processedTrending.map((item) => (
              <li class="group">
                <a class="block" href={item.href}>
                  <span class="text-[10px] font-bold text-primary/30 mb-1 block">{item.num}</span>
                  <h4 class="text-xs font-bold text-on-surface group-hover:text-primary transition-colors leading-snug">{item.title}</h4>
                </a>
              </li>
            )) : (
              <>
                <li>
                  <span class="text-[10px] font-bold text-primary/30 mb-1 block">01</span>
                  <span class="text-xs font-bold text-on-surface leading-snug block">The Evolution of Rural ESG Standards in Western Provinces</span>
                </li>
                <li>
                  <span class="text-[10px] font-bold text-primary/30 mb-1 block">02</span>
                  <span class="text-xs font-bold text-on-surface leading-snug block">Water Scarcity and Silicon Manufacturing Risks</span>
                </li>
                <li>
                  <span class="text-[10px] font-bold text-primary/30 mb-1 block">03</span>
                  <span class="text-xs font-bold text-on-surface leading-snug block">National Curriculum Reforms for Sustainability</span>
                </li>
              </>
            )}
          </ul>
        </div>

        <!-- Newsletter -->
        <div class="bg-surface-container-low p-6 rounded-xl border border-surface-container-high/50">
          <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-on-surface-variant mb-4 font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-lg text-primary">mark_email_unread</span>
            Intelligence
          </h3>
          <p class="text-[11px] text-on-surface-variant mb-6 leading-relaxed">Weekly policy briefs and research abstracts delivered to your inbox.</p>
          <NewsletterForm variant="sidebar" lang={lang} />
        </div>

        <!-- Resources -->
        <div class="px-2">
          <h3 class="text-[10px] font-label uppercase tracking-[0.3em] text-on-surface-variant mb-6 font-bold opacity-50">Resources</h3>
          <ul class="space-y-4">
            <li>
              <a class="flex items-center justify-between group" href="#">
                <span class="text-xs font-medium text-on-surface-variant group-hover:text-primary transition-colors">SDG Data Tracker</span>
                <span class="material-symbols-outlined text-sm opacity-20 group-hover:opacity-100 transition-all">open_in_new</span>
              </a>
            </li>
            <li>
              <a class="flex items-center justify-between group" href="#">
                <span class="text-xs font-medium text-on-surface-variant group-hover:text-primary transition-colors">Policy Simulation Lab</span>
                <span class="material-symbols-outlined text-sm opacity-20 group-hover:opacity-100 transition-all">open_in_new</span>
              </a>
            </li>
            <li>
              <a class="flex items-center justify-between group" href="#">
                <span class="text-xs font-medium text-on-surface-variant group-hover:text-primary transition-colors">Annual Impact Report</span>
                <span class="material-symbols-outlined text-sm opacity-20 group-hover:opacity-100 transition-all">download</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const btn = document.getElementById('load-more-btn');
    const wrap = document.getElementById('load-more-wrap');
    const text = document.getElementById('load-more-text');
    const items = document.querySelectorAll('.compact-item');
    const PER_PAGE = 3;
    let shown = PER_PAGE;

    if (btn && wrap && items.length > 0) {
      btn.addEventListener('click', () => {
        const next = Math.min(shown + PER_PAGE, items.length);
        for (let i = shown; i < next; i++) {
          items[i].classList.remove('hidden');
        }
        shown = next;
        const remaining = items.length - shown;
        if (remaining <= 0) {
          wrap.remove();
        } else if (text) {
          text.textContent = `Load More (${remaining} remaining)`;
        }
      });
    }
  </script>
</MainLayout>
