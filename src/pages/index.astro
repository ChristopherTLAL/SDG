---
// src/pages/index.astro — Home page (English)
import MainLayout from '../layouts/MainLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getHomepageData } from '../lib/sanity/queries';
import { urlForImage } from '../lib/sanity/image';
import { formatDate } from '../utils/date';

const lang = 'en';
const data = await getHomepageData(lang);
const { latestPosts, trendingPosts, projects, upcomingDialogues } = data || {};

// Status badge colors
const statusColors: Record<string, string> = {
  active: 'bg-primary text-white',
  recruiting: 'bg-primary text-white',
  ongoing: 'bg-secondary text-white',
  completed: 'bg-surface-container-high text-on-surface-variant',
};

// Content type labels
const contentTypeLabels: Record<string, string> = {
  news: 'News',
  research: 'Research Paper',
  'policy-brief': 'Policy Brief',
};

// Resolve localized field helper
function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

// Pre-process latest posts for the template
const processedPosts = (latestPosts || []).map((post: any) => ({
  title: t(post.title),
  excerpt: t(post.excerpt),
  href: `/research/${post.slug}`,
  sdgTag: post.sdgTags?.[0] || '',
  contentType: post.contentType ? (contentTypeLabels[post.contentType] || post.contentType) : '',
  date: post.publishedAt ? formatDate(post.publishedAt) : '',
}));

// Pre-process trending posts
const processedTrending = (trendingPosts || []).map((post: any, i: number) => ({
  title: t(post.title),
  href: `/research/${post.slug}`,
  label: `${String(i + 1).padStart(2, '0')}. ${contentTypeLabels[post.contentType] || post.contentType || 'Article'}`,
}));

const iconImageMap: Record<string, string> = {
  air: '/images/air.png', diversity_3: '/images/inclusion.png', eco: '/images/decarbon.png',
  water_drop: '/images/water.png', park: '/images/roof.png', account_balance: '/images/fintech.png',
  school: '/images/inclusion.png',
};

// Pre-process projects
const processedProjects = (projects || []).map((project: any) => ({
  title: t(project.title),
  description: t(project.description),
  slug: project.slug,
  icon: project.icon || 'eco',
  image: iconImageMap[project.icon] || '',
  status: project.status || 'active',
  statusClass: statusColors[project.status] || statusColors.active,
  team: project.team || '',
  teamInitials: project.team ? project.team.substring(0, 2).toUpperCase() : '',
}));

// Pre-process upcoming dialogues
const processedDialogues = (upcomingDialogues || []).map((d: any) => ({
  title: t(d.title),
  dateStr: d.date ? new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase() : '',
}));
---

<MainLayout title="Chinese SDGs Institute | The Digital Curator" description="Advancing sustainable development through rigorous research, data transparency, and institutional collaboration." lang={lang}>
  <main class="pt-28 md:pt-48 pb-16 md:pb-24">
    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-16 md:mb-40">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start">
        <div class="md:col-span-7 pt-6 md:pt-12">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tight text-on-surface mb-6 md:mb-8 leading-[1.05] font-headline">
            The Digital Curator of Progress
          </h1>
          <p class="text-base md:text-lg lg:text-xl text-on-surface-variant leading-relaxed mb-8 md:mb-12 max-w-xl font-body">
            Advancing sustainable development through rigorous research, data transparency, and institutional collaboration. We decode complexity into actionable intelligence.
          </p>
          <div class="flex flex-wrap gap-3 md:gap-5">
            <a href="/research" class="bg-primary text-on-primary px-6 md:px-10 py-3 md:py-4 rounded-md font-bold text-sm md:text-base hover:bg-primary-dim transition-all flex items-center gap-3 shadow-md">
              Explore Repository
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/about" class="bg-surface-container-high text-on-surface px-6 md:px-10 py-3 md:py-4 rounded-md font-bold text-sm md:text-base hover:bg-surface-container-highest transition-all">
              Annual Reports
            </a>
          </div>
        </div>
        <div class="md:col-span-5 md:pt-16 lg:pt-24">
          <div class="aspect-square rounded-3xl relative overflow-hidden max-w-[280px] mx-auto md:max-w-none">
            <img src="/images/hero-home.png" alt="Chinese SDGs Institute" class="w-full h-full object-contain" />
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Intelligence Section -->
    <section class="bg-surface-container-low py-16 md:py-28 border-y border-outline-variant/10">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-10 md:mb-16">
          <div>
            <span class="text-xs font-bold uppercase tracking-[0.25em] text-primary mb-4 block">Intelligence</span>
            <h2 class="text-2xl md:text-4xl font-bold tracking-tight text-on-surface font-headline">Latest Research &amp; Insights</h2>
          </div>
          <a class="text-sm font-bold text-primary hover:underline underline-offset-4 flex items-center gap-2" href="/research">
            Archive Repository
            <span class="material-symbols-outlined text-xs">open_in_new</span>
          </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
          <!-- Main Grid -->
          <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            {processedPosts.length > 0 ? processedPosts.map((p) => (
              <a href={p.href} class="bg-surface-container-lowest p-5 md:p-8 rounded-2xl border border-outline-variant/10 hover:shadow-xl hover:shadow-primary/5 transition-all flex flex-col group">
                <div class="flex gap-3 mb-6">
                  {p.sdgTag && (
                    <span class="px-2.5 py-1 bg-tertiary-container text-on-tertiary-container text-[10px] font-bold rounded uppercase tracking-wider">{p.sdgTag}</span>
                  )}
                  {p.contentType && (
                    <span class="text-[10px] font-semibold text-on-surface-variant pt-1 uppercase">{p.contentType}</span>
                  )}
                </div>
                <h3 class="text-xl font-bold mb-4 leading-snug text-on-surface group-hover:text-primary transition-colors font-headline">{p.title}</h3>
                {p.excerpt && <p class="text-sm text-on-surface-variant mb-8 line-clamp-3 leading-relaxed">{p.excerpt}</p>}
                <div class="flex items-center justify-between mt-auto pt-5 border-t border-outline-variant/10">
                  {p.date && <span class="text-[11px] font-medium text-on-surface-variant">{p.date}</span>}
                  <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary">bookmark</span>
                </div>
              </a>
            )) : (
              <>
                <div class="bg-surface-container-lowest p-8 rounded-2xl border border-outline-variant/10 flex flex-col">
                  <div class="flex gap-3 mb-6">
                    <span class="px-2.5 py-1 bg-tertiary-container text-on-tertiary-container text-[10px] font-bold rounded uppercase tracking-wider">SDG 7</span>
                    <span class="text-[10px] font-semibold text-on-surface-variant pt-1 uppercase">Research Paper</span>
                  </div>
                  <h3 class="text-xl font-bold mb-4 leading-snug text-on-surface font-headline">Decentralized Energy Grids in rural Zhejiang: A 5-year longitudinal study</h3>
                  <p class="text-sm text-on-surface-variant mb-8 line-clamp-3 leading-relaxed">Evaluating the socio-economic impact of local solar cooperatives on household income and energy security across three major districts.</p>
                  <div class="flex items-center justify-between mt-auto pt-5 border-t border-outline-variant/10">
                    <span class="text-[11px] font-medium text-on-surface-variant">Coming Soon</span>
                    <span class="material-symbols-outlined text-on-surface-variant">bookmark</span>
                  </div>
                </div>
                <div class="bg-surface-container-lowest p-8 rounded-2xl border border-outline-variant/10 flex flex-col">
                  <div class="flex gap-3 mb-6">
                    <span class="px-2.5 py-1 bg-tertiary-container text-on-tertiary-container text-[10px] font-bold rounded uppercase tracking-wider">SDG 13</span>
                    <span class="text-[10px] font-semibold text-on-surface-variant pt-1 uppercase">Policy Brief</span>
                  </div>
                  <h3 class="text-xl font-bold mb-4 leading-snug text-on-surface font-headline">Climate Mitigation Strategies for the Pearl River Delta Megacity Region</h3>
                  <p class="text-sm text-on-surface-variant mb-8 line-clamp-3 leading-relaxed">An analysis of adaptive infrastructure requirements for 2030-2050 sea level projection scenarios.</p>
                  <div class="flex items-center justify-between mt-auto pt-5 border-t border-outline-variant/10">
                    <span class="text-[11px] font-medium text-on-surface-variant">Coming Soon</span>
                    <span class="material-symbols-outlined text-on-surface-variant">bookmark</span>
                  </div>
                </div>
              </>
            )}
          </div>

          <!-- Trending Sidebar -->
          <aside class="lg:col-span-4">
            <div class="lg:sticky lg:top-28 bg-white border border-outline-variant/10 rounded-2xl p-5 md:p-8 shadow-sm">
              <h3 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant mb-10 flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-xl">trending_up</span>
                Trending Intelligence
              </h3>
              <ul class="space-y-10">
                {processedTrending.length > 0 ? processedTrending.map((item) => (
                  <li>
                    <span class="text-[10px] font-bold text-primary/60 block mb-2 uppercase tracking-wide">{item.label}</span>
                    <a class="text-sm font-bold leading-snug text-on-surface hover:text-primary transition-colors block" href={item.href}>
                      {item.title}
                    </a>
                  </li>
                )) : (
                  <>
                    <li>
                      <span class="text-[10px] font-bold text-primary/60 block mb-2 uppercase tracking-wide">01. Research Paper</span>
                      <span class="text-sm font-bold leading-snug text-on-surface block">Global Green Taxonomy Convergence: China's Role in 2024</span>
                    </li>
                    <li>
                      <span class="text-[10px] font-bold text-primary/60 block mb-2 uppercase tracking-wide">02. Field Report</span>
                      <span class="text-sm font-bold leading-snug text-on-surface block">Mangrove Restoration Success Metrics in Shenzhen Bay</span>
                    </li>
                    <li>
                      <span class="text-[10px] font-bold text-primary/60 block mb-2 uppercase tracking-wide">03. White Paper</span>
                      <span class="text-sm font-bold leading-snug text-on-surface block">AI for Social Good: Ethics Framework for Public Sector Apps</span>
                    </li>
                  </>
                )}
              </ul>
              <div class="mt-12 pt-10 border-t border-outline-variant/10">
                <NewsletterForm variant="sidebar" lang={lang} />
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Social Projects Section -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 py-16 md:py-32">
      <div class="text-center mb-12 md:mb-20 max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 bg-primary-container text-on-primary-container text-[11px] font-bold rounded-full uppercase tracking-widest mb-6">Student Initiatives</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6 md:mb-8 text-on-surface font-headline">Social Projects &amp; Community Action</h2>
        <p class="text-on-surface-variant text-base md:text-lg leading-relaxed mb-8 md:mb-10">
          Empowering the next generation of sustainability pioneers. Discover student-led research and field projects making a tangible difference across urban and rural landscapes.
        </p>
        <a href="/projects" class="inline-block bg-primary text-on-primary px-12 py-4 rounded-md font-bold text-base hover:bg-primary-dim transition-all shadow-md">
          Explore Open Projects
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-10 mb-12 md:mb-20">
        {processedProjects.length > 0 ? processedProjects.map((proj) => (
          <a href={`/projects#${proj.slug}`} class="group bg-white border border-outline-variant/20 rounded-2xl overflow-hidden hover:shadow-2xl hover:shadow-primary/5 transition-all duration-300 block">
            <div class="h-48 bg-surface-container-low relative flex items-center justify-center overflow-hidden">
              {proj.image ? <img src={proj.image} alt={proj.title} class="h-full object-contain group-hover:scale-110 transition-transform duration-500" /> : <span class="material-symbols-outlined text-primary/20 text-7xl group-hover:scale-110 transition-transform duration-500">{proj.icon}</span>}
              <div class={`absolute bottom-4 left-4 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest ${proj.statusClass}`}>
                {proj.status}
              </div>
            </div>
            <div class="p-5 md:p-8">
              <h3 class="text-xl font-bold mb-3 text-on-surface font-headline">{proj.title}</h3>
              {proj.description && <p class="text-sm text-on-surface-variant leading-relaxed mb-6">{proj.description}</p>}
              {proj.team && (
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-tertiary-container flex items-center justify-center text-[10px] font-bold text-on-tertiary-container">{proj.teamInitials}</div>
                  <span class="text-xs font-semibold text-on-surface-variant">{proj.team}</span>
                </div>
              )}
            </div>
          </a>
        )) : (
          <>
            <div class="group bg-white border border-outline-variant/20 rounded-2xl overflow-hidden">
              <div class="h-48 bg-surface-container-low relative flex items-center justify-center overflow-hidden">
                <img src="/images/decarbon.png" alt="Zero-Waste Campus Pilot" class="h-full object-contain" />
                <div class="absolute bottom-4 left-4 bg-primary text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Active</div>
              </div>
              <div class="p-5 md:p-8">
                <h3 class="text-xl font-bold mb-3 text-on-surface font-headline">Zero-Waste Campus Pilot</h3>
                <p class="text-sm text-on-surface-variant leading-relaxed mb-6">A student-led circular economy framework reducing single-use plastic by 40% across five major university dining halls.</p>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-tertiary-container flex items-center justify-center text-[10px] font-bold text-on-tertiary-container">ZU</div>
                  <span class="text-xs font-semibold text-on-surface-variant">Zhejiang University Team</span>
                </div>
              </div>
            </div>
            <div class="group bg-white border border-outline-variant/20 rounded-2xl overflow-hidden">
              <div class="h-48 bg-surface-container-low relative flex items-center justify-center overflow-hidden">
                <img src="/images/inclusion.png" alt="Heritage Digital Archive" class="h-full object-contain" />
                <div class="absolute bottom-4 left-4 bg-primary text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Recruiting</div>
              </div>
              <div class="p-5 md:p-8">
                <h3 class="text-xl font-bold mb-3 text-on-surface font-headline">Heritage Digital Archive</h3>
                <p class="text-sm text-on-surface-variant leading-relaxed mb-6">Documenting oral histories and intangible cultural heritage in the Liangshan mountains using interactive geospatial mapping.</p>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-[10px] font-bold text-on-secondary-container">TH</div>
                  <span class="text-xs font-semibold text-on-surface-variant">Tsinghua Design Collective</span>
                </div>
              </div>
            </div>
            <div class="group bg-white border border-outline-variant/20 rounded-2xl overflow-hidden">
              <div class="h-48 bg-surface-container-low relative flex items-center justify-center overflow-hidden">
                <img src="/images/water.png" alt="Urban Water Literacy" class="h-full object-contain" />
                <div class="absolute bottom-4 left-4 bg-secondary text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Ongoing</div>
              </div>
              <div class="p-5 md:p-8">
                <h3 class="text-xl font-bold mb-3 text-on-surface font-headline">Urban Water Literacy</h3>
                <p class="text-sm text-on-surface-variant leading-relaxed mb-6">Developing open-source sensors for community-led water quality monitoring in the Suzhou canal network.</p>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-[10px] font-bold text-on-primary-container">SU</div>
                  <span class="text-xs font-semibold text-on-surface-variant">Soochow University Lab</span>
                </div>
              </div>
            </div>
          </>
        )}
      </div>

      <!-- Upcoming Dialogues & Newsletter Banner -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 items-center bg-primary text-on-primary p-6 md:p-12 rounded-2xl md:rounded-3xl shadow-xl">
        <div class="lg:col-span-7 flex flex-col md:flex-row gap-8 items-center md:items-start">
          <div class="bg-white/10 p-4 rounded-xl shrink-0">
            <span class="material-symbols-outlined text-4xl">event_note</span>
          </div>
          <div>
            <h4 class="text-xl font-bold mb-3 font-headline">Upcoming Dialogues</h4>
            <div class="space-y-4">
              {processedDialogues.length > 0 ? processedDialogues.map((d) => (
                <div class="flex gap-4 items-center">
                  <span class="text-[10px] font-bold bg-white/20 px-2 py-1 rounded uppercase">{d.dateStr}</span>
                  <p class="text-sm font-medium opacity-90">{d.title}</p>
                </div>
              )) : (
                <>
                  <div class="flex gap-4 items-center">
                    <span class="text-[10px] font-bold bg-white/20 px-2 py-1 rounded uppercase">TBD</span>
                    <p class="text-sm font-medium opacity-90">Urban Resilience: Post-Pandemic Architecture in Asia</p>
                  </div>
                  <div class="flex gap-4 items-center">
                    <span class="text-[10px] font-bold bg-white/20 px-2 py-1 rounded uppercase">TBD</span>
                    <p class="text-sm font-medium opacity-90">Decoding Carbon Markets: A Practical Workshop</p>
                  </div>
                </>
              )}
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 h-full flex flex-col justify-center border-t lg:border-t-0 lg:border-l border-white/10 pt-8 lg:pt-0 lg:pl-12">
          <NewsletterForm variant="banner" lang={lang} />
        </div>
      </div>
    </section>
  </main>
</MainLayout>
