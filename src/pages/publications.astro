---
// src/pages/publications.astro — Publications overview
import MainLayout from '../layouts/MainLayout.astro';
import { studentCriticalEssaySeries } from '../data/publications-meta';
import { getResearchPosts } from '../lib/sanity/queries';
import { formatDate } from '../utils/date';

const lang = 'en';

const [researchPapers, policyBriefs] = await Promise.all([
  getResearchPosts('en', 'research', 50).catch(() => []),
  getResearchPosts('en', 'policy-brief', 30).catch(() => []),
]);

function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

const totalBooks = studentCriticalEssaySeries.books.length;
const totalPapers = researchPapers.length;
const totalBriefs = policyBriefs.length;

// Map accent keyword → Tailwind gradient classes for cover art
const coverGradient: Record<string, string> = {
  emerald: 'from-emerald-700 to-emerald-500',
  amber: 'from-amber-700 to-amber-500',
  sky: 'from-sky-700 to-sky-500',
  rose: 'from-rose-700 to-rose-500',
  indigo: 'from-indigo-700 to-indigo-500',
  violet: 'from-violet-700 to-violet-500',
  default: 'from-primary to-primary/70',
};
---

<MainLayout title="Publications" description="Books, research papers, and policy briefs from the Chinese SDGs Institute." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6 md:mb-8">
        <span>Institute</span>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-primary font-bold">Publications</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tight text-on-surface leading-[1.1] mb-6 md:mb-8">
        Publications
      </h1>

      <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl mb-16">
        Books, peer-edited research papers, and policy briefs produced by our volunteer research community. Every contributor is credited by name with a verifiable certificate of authorship.
      </p>

      <!-- Stats strip -->
      <div class="flex flex-wrap gap-x-10 gap-y-4 mb-20 max-w-xl">
        <div>
          <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">{totalBooks}</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Books</p>
        </div>
        {totalPapers > 0 && (
          <div>
            <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">{totalPapers}</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Research Papers</p>
          </div>
        )}
        {totalBriefs > 0 && (
          <div>
            <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">{totalBriefs}</p>
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Policy Briefs</p>
          </div>
        )}
      </div>

      <!-- ── BOOK SERIES ── -->
      <section class="mb-24">
        <div class="flex items-center gap-3 mb-8">
          <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
            {studentCriticalEssaySeries.name}
          </h2>
          <span class="text-xs font-bold text-on-surface-variant/40">01</span>
        </div>

        <!-- Series intro -->
        <div class="bg-white border border-outline-variant/15 rounded-2xl p-6 md:p-10 mb-8">
          <p class="text-base md:text-lg text-on-surface-variant leading-relaxed mb-6 max-w-3xl">
            {studentCriticalEssaySeries.description}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={studentCriticalEssaySeries.amazonUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-primary text-on-primary font-bold text-sm rounded-lg hover:bg-primary/90 transition-colors">
              <span class="material-symbols-outlined text-base">shopping_bag</span>
              View the full series on Amazon
            </a>
            <a href="/verify" class="inline-flex items-center gap-1.5 px-5 py-2.5 border border-outline-variant/20 text-on-surface font-bold text-sm rounded-lg hover:border-primary/30 hover:text-primary transition-colors">
              <span class="material-symbols-outlined text-base">verified</span>
              Verify a contributor's certificate
            </a>
          </div>
        </div>

        <!-- Books grid -->
        <div class="grid md:grid-cols-2 gap-5">
          {studentCriticalEssaySeries.books.map((book, i) => (
            <article class="bg-white border border-outline-variant/15 rounded-2xl overflow-hidden hover:shadow-lg hover:shadow-primary/5 hover:border-primary/20 transition-all flex flex-col">
              <!-- Cover -->
              <div class={`relative aspect-[5/2] bg-gradient-to-br ${coverGradient[book.accent || 'default']} p-5 flex flex-col justify-between`}>
                <p class="text-[9px] font-bold uppercase tracking-[0.25em] text-white/70">Vol. {String(i + 1).padStart(2, '0')}</p>
                <div>
                  <h3 class="font-headline font-extrabold text-white text-xl md:text-2xl leading-[1.1] tracking-tight mb-1">
                    {book.title}
                  </h3>
                  {book.subtitle && (
                    <p class="text-white/70 text-[11px] leading-tight font-medium line-clamp-2">{book.subtitle}</p>
                  )}
                </div>
              </div>

              <!-- Body -->
              <div class="flex-1 p-6 flex flex-col">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  <span>{book.publishedDate}</span>
                </div>
                <p class="text-xs text-on-surface-variant/70 mb-3 font-semibold">{book.authors}</p>
                <p class="text-sm text-on-surface-variant leading-relaxed mb-5 flex-1">
                  {book.description}
                </p>
                <a href={book.amazonUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 self-start px-4 py-2 bg-primary/5 text-primary font-bold text-xs rounded-lg hover:bg-primary/10 transition-colors">
                  <span class="material-symbols-outlined text-sm">shopping_bag</span>
                  Buy on Amazon
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- ── RESEARCH PAPERS ── -->
      {totalPapers > 0 && (
        <section class="mb-24">
          <div class="flex items-center gap-3 mb-8">
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
              Research Papers
            </h2>
            <span class="text-xs font-bold text-on-surface-variant/40">02</span>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {researchPapers.map((p: any) => (
              <a href={`/research/${p.slug}`} class="group block bg-white border border-outline-variant/15 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md hover:shadow-primary/5 transition-all">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  <span>Research Paper</span>
                  {p.publishedAt && <span>·</span>}
                  {p.publishedAt && <span>{formatDate(p.publishedAt)}</span>}
                </div>
                <h3 class="font-headline font-bold text-base text-on-surface group-hover:text-primary transition-colors mb-2 leading-snug">
                  {t(p.title)}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
                  {t(p.excerpt)}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ── POLICY BRIEFS ── -->
      {totalBriefs > 0 && (
        <section class="mb-16">
          <div class="flex items-center gap-3 mb-8">
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
              Policy Briefs
            </h2>
            <span class="text-xs font-bold text-on-surface-variant/40">03</span>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {policyBriefs.map((p: any) => (
              <a href={`/research/${p.slug}`} class="group block bg-white border border-outline-variant/15 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md hover:shadow-primary/5 transition-all">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  <span>Policy Brief</span>
                  {p.publishedAt && <span>·</span>}
                  {p.publishedAt && <span>{formatDate(p.publishedAt)}</span>}
                </div>
                <h3 class="font-headline font-bold text-base text-on-surface group-hover:text-primary transition-colors mb-2 leading-snug">
                  {t(p.title)}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
                  {t(p.excerpt)}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>
</MainLayout>
