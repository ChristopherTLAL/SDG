---
// src/pages/publications.astro — Publications overview
import MainLayout from '../layouts/MainLayout.astro';
import { digitalSymbiosis } from '../data/publications-meta';
import { getResearchPosts } from '../lib/sanity/queries';
import { formatDate } from '../utils/date';

const lang = 'en';

// Fetch research papers and policy briefs from Sanity (in parallel)
const [researchPapers, policyBriefs] = await Promise.all([
  getResearchPosts('en', 'research', 50).catch(() => []),
  getResearchPosts('en', 'policy-brief', 30).catch(() => []),
]);

function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

const totalChapters = digitalSymbiosis.chapters.length;
const totalPapers = researchPapers.length;
const totalBriefs = policyBriefs.length;
---

<MainLayout title="Publications" description="Books, research papers, and policy briefs from the Chinese SDGs Institute." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6 md:mb-8">
        <span>Institute</span>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-primary font-bold">Publications</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tight text-on-surface leading-[1.1] mb-6 md:mb-8">
        Publications
      </h1>

      <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl mb-16">
        Books, peer-edited research papers, and policy briefs produced by our volunteer research community. Every chapter and paper is authored by a named contributor and linked to a verifiable certificate of authorship.
      </p>

      <!-- Stats strip -->
      <div class="grid grid-cols-3 gap-4 mb-20 max-w-xl">
        <div>
          <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">1</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Book</p>
        </div>
        <div>
          <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">{totalPapers}</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Research Papers</p>
        </div>
        <div>
          <p class="font-headline font-extrabold text-3xl md:text-4xl text-primary tracking-tighter">{totalBriefs}</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-on-surface-variant mt-1">Policy Briefs</p>
        </div>
      </div>

      <!-- ── BOOK SECTION ── -->
      <section class="mb-24">
        <div class="flex items-center gap-3 mb-8">
          <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
            Books
          </h2>
          <span class="text-xs font-bold text-on-surface-variant/40">01</span>
        </div>

        <!-- Featured book -->
        <div class="bg-white border border-outline-variant/15 rounded-2xl p-6 md:p-10 shadow-sm">
          <div class="grid md:grid-cols-3 gap-8 md:gap-10 items-start">
            <!-- Cover placeholder -->
            <div class="md:col-span-1">
              <div class="relative aspect-[2/3] bg-gradient-to-br from-primary to-primary/60 rounded-xl overflow-hidden shadow-lg shadow-primary/10 flex flex-col justify-between p-6">
                <div class="text-white/90">
                  <p class="text-[9px] font-bold uppercase tracking-[0.25em] opacity-70 mb-4">Chinese SDGs Institute</p>
                  <h3 class="font-headline font-extrabold text-2xl md:text-3xl leading-[1.05] tracking-tight mb-3">
                    {digitalSymbiosis.title}
                  </h3>
                  <p class="text-xs font-medium opacity-80 leading-snug">
                    {digitalSymbiosis.subtitle}
                  </p>
                </div>
                <div class="text-white/60">
                  <p class="text-[9px] font-bold uppercase tracking-[0.25em]">Edited by</p>
                  <p class="text-xs font-semibold">{digitalSymbiosis.editor}</p>
                </div>
              </div>
            </div>

            <!-- Book info -->
            <div class="md:col-span-2">
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-widest rounded-full">
                  <span class="material-symbols-outlined text-[13px]">menu_book</span>
                  Edited Volume
                </span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  Published {digitalSymbiosis.publishedDate}
                </span>
              </div>

              <h3 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight leading-tight mb-2">
                {digitalSymbiosis.title}:
                <span class="text-on-surface-variant/80">{digitalSymbiosis.subtitle}</span>
              </h3>

              <p class="text-sm text-on-surface-variant/70 font-mono mb-5">
                ISBN {digitalSymbiosis.isbn} · {totalChapters} chapters · Editor: {digitalSymbiosis.editor}
              </p>

              <p class="text-base text-on-surface-variant leading-relaxed mb-6">
                {digitalSymbiosis.description}
              </p>

              <div class="flex flex-wrap gap-3">
                <a href="#chapters" class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary text-on-primary font-bold text-sm rounded-lg hover:bg-primary/90 transition-colors">
                  <span class="material-symbols-outlined text-base">list</span>
                  Browse {totalChapters} chapters
                </a>
                <a href="/verify" class="inline-flex items-center gap-1.5 px-4 py-2 border border-outline-variant/20 text-on-surface font-bold text-sm rounded-lg hover:border-primary/30 hover:text-primary transition-colors">
                  <span class="material-symbols-outlined text-base">verified</span>
                  Verify a chapter certificate
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Chapters list -->
        <div id="chapters" class="mt-10 bg-surface-container-low/50 border border-outline-variant/10 rounded-2xl p-5 md:p-8">
          <div class="flex items-center justify-between mb-6">
            <h4 class="font-headline font-bold text-base md:text-lg text-on-surface">
              Chapter contributors
            </h4>
            <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/50">
              {totalChapters} authors
            </span>
          </div>
          <div class="grid md:grid-cols-2 gap-x-8 gap-y-3">
            {digitalSymbiosis.chapters.map((ch, i) => (
              <div class="flex gap-3 items-start py-3 border-b border-outline-variant/10 last:border-0">
                <span class="text-[10px] font-mono text-on-surface-variant/40 shrink-0 pt-0.5 w-7">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-on-surface leading-snug mb-0.5 font-medium">
                    {ch.title}
                  </p>
                  <p class="text-xs text-on-surface-variant">
                    by <span class="font-semibold">{ch.author}</span>
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── RESEARCH PAPERS ── -->
      {totalPapers > 0 && (
        <section class="mb-24">
          <div class="flex items-center gap-3 mb-8">
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
              Research Papers
            </h2>
            <span class="text-xs font-bold text-on-surface-variant/40">02</span>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {researchPapers.map((p: any) => (
              <a href={`/research/${p.slug}`} class="group block bg-white border border-outline-variant/15 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md hover:shadow-primary/5 transition-all">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  <span>Research Paper</span>
                  {p.publishedAt && <span>·</span>}
                  {p.publishedAt && <span>{formatDate(p.publishedAt)}</span>}
                </div>
                <h3 class="font-headline font-bold text-base text-on-surface group-hover:text-primary transition-colors mb-2 leading-snug">
                  {t(p.title)}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
                  {t(p.excerpt)}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ── POLICY BRIEFS ── -->
      {totalBriefs > 0 && (
        <section class="mb-16">
          <div class="flex items-center gap-3 mb-8">
            <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
              Policy Briefs
            </h2>
            <span class="text-xs font-bold text-on-surface-variant/40">03</span>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {policyBriefs.map((p: any) => (
              <a href={`/research/${p.slug}`} class="group block bg-white border border-outline-variant/15 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md hover:shadow-primary/5 transition-all">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/60">
                  <span>Policy Brief</span>
                  {p.publishedAt && <span>·</span>}
                  {p.publishedAt && <span>{formatDate(p.publishedAt)}</span>}
                </div>
                <h3 class="font-headline font-bold text-base text-on-surface group-hover:text-primary transition-colors mb-2 leading-snug">
                  {t(p.title)}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
                  {t(p.excerpt)}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Empty state hint if no research posts -->
      {totalPapers === 0 && totalBriefs === 0 && (
        <div class="bg-surface-container-low/50 border border-outline-variant/10 rounded-2xl p-10 text-center">
          <p class="text-on-surface-variant">More publications coming soon. Check our <a href="/research" class="text-primary font-semibold hover:underline">research feed</a> for the latest work.</p>
        </div>
      )}
    </div>
  </main>
</MainLayout>
