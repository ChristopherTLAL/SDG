---
// src/pages/internal/students.astro — student roster (auth-gated).
// Multi-select fields rendered " / " joined. 私单 visible only to 王世杰 / admin.
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';
import { tierFor, tierStyle, tierLabel, daysSinceToday, INACTIVE_STAGES } from '../../utils/contact-radar';

const url = new URL(Astro.request.url);
// Multi-select filters — values are comma-separated in the URL (?stage=已结案,中期在途).
function parseMulti(v: string | null): string[] {
  if (!v) return [];
  return v.split(',').map(s => s.trim()).filter(Boolean);
}
const stageFilter   = parseMulti(url.searchParams.get('stage'));
const advisorFilter = parseMulti(url.searchParams.get('advisor'));
const cohortFilter  = parseMulti(url.searchParams.get('cohort'));
const includeInactive = url.searchParams.get('include_inactive') === '1';
const viewer = Astro.locals?.viewer ?? null;

const PRIVATE_CONTRACTS = ['私单', '私单（非公司合同）'];
const canSeePrivate = !!viewer && (viewer.isAdmin || viewer.name === '王世杰');

let q = supabase
  .from('students')
  .select('id, name, stage, contracts, contract_type, major_intention, major_current, current_school, client_email, early_advisors, mid_advisors, late_advisors, last_contact_at, enroll_years, target_regions, synced_at');

if (stageFilter.length)   q = q.in('stage', stageFilter);
// Array-column filters: overlaps = OR semantics (ANY match), good for multi-select.
if (advisorFilter.length) q = q.overlaps('mid_advisors', advisorFilter);
if (cohortFilter.length)  q = q.overlaps('enroll_years', cohortFilter);

// Hide inactive unless either:
//   - user toggled "+ 已结案" (includeInactive=1), or
//   - user explicitly picked an inactive stage in the stage filter (then they
//     obviously want to see those rows)
const stageHasInactive = stageFilter.some(s => INACTIVE_STAGES.has(s));
if (!includeInactive && !stageHasInactive) {
  q = q.not('stage', 'in', `(${Array.from(INACTIVE_STAGES).join(',')})`);
}

// Hide private-contract students from anyone who shouldn't see them. Silent — no UI mention.
if (!canSeePrivate) {
  q = q.not('contracts', 'ov', `{${PRIVATE_CONTRACTS.join(',')}}`);
}

const { data: studentsRaw, error } = await q.order('last_contact_at', { ascending: false, nullsFirst: false }).limit(500);
const students = studentsRaw ?? [];

// Counts for header badges
const { count: inactiveCount } = await supabase
  .from('students')
  .select('id', { count: 'exact', head: true })
  .in('stage', Array.from(INACTIVE_STAGES));

// ── Chip option lists ──
// Compute from the FULL student set (no filters applied) so chips don't
// shrink as you select. Same private-contract gate as the main query.
let chipQ = supabase.from('students').select('stage, mid_advisors, enroll_years');
if (!canSeePrivate) {
  chipQ = chipQ.not('contracts', 'ov', `{${PRIVATE_CONTRACTS.join(',')}}`);
}
const { data: chipRows } = await chipQ.limit(2000);
const chipPool = chipRows ?? [];
const stages   = Array.from(new Set(chipPool.map((s: any) => s.stage).filter(Boolean))).sort() as string[];
const cohorts  = Array.from(new Set(chipPool.flatMap((s: any) => (s.enroll_years ?? [])).filter(Boolean))).sort() as string[];
const advisors = Array.from(new Set(chipPool.flatMap((s: any) => (s.mid_advisors ?? [])).filter(Boolean))).sort() as string[];

const withRadar = students.map((s: any) => {
  const ds = daysSinceToday(s.last_contact_at);
  const tier = tierFor(ds, s.stage);
  return { ...s, daysSince: ds, tier };
});

const criticalCount = withRadar.filter((s: any) => s.tier === 'critical').length;
const redCount = withRadar.filter((s: any) => s.tier === 'red').length;
const pinkCount = withRadar.filter((s: any) => s.tier === 'pink').length;
const yellowCount = withRadar.filter((s: any) => s.tier === 'yellow').length;

// buildHref gives back a URL with the current filter state, with any keys
// from `overrides` taking precedence. Pass an empty string to clear a key.
type FilterKey = 'stage' | 'advisor' | 'cohort' | 'include_inactive';
function buildHref(overrides: Partial<Record<FilterKey, string>>): string {
  const params = new URLSearchParams();
  const next: Record<FilterKey, string> = {
    stage:   stageFilter.join(','),
    advisor: advisorFilter.join(','),
    cohort:  cohortFilter.join(','),
    include_inactive: includeInactive ? '1' : '',
    ...overrides,
  };
  for (const [k, v] of Object.entries(next)) if (v) params.set(k, v);
  const qs = params.toString();
  return qs ? `/internal/students?${qs}` : '/internal/students';
}

// toggleHref returns the URL that would result from adding `value` to the
// `key` filter if it isn't there yet, or removing it if it is. Used by
// every chip click for true multi-select toggle.
function toggleHref(key: 'stage' | 'advisor' | 'cohort', value: string): string {
  const current = key === 'stage' ? stageFilter : key === 'advisor' ? advisorFilter : cohortFilter;
  const next = current.includes(value)
    ? current.filter(v => v !== value)
    : [...current, value];
  return buildHref({ [key]: next.join(',') });
}

// Stage badge palette — semantic by progression. Anything unmapped falls back to neutral.
const STAGE_STYLE: Record<string, { bg: string; fg: string }> = {
  '需对接':   { bg: '#dbeafe', fg: '#1e40af' },
  '中期在途': { bg: '#dcfce7', fg: '#166534' },
  '后期在途': { bg: '#bbf7d0', fg: '#14532d' },
  '已结案':   { bg: '#e5e7eb', fg: '#475569' },
  '已完成':   { bg: '#e0e7ff', fg: '#3730a3' },
  '退费':     { bg: '#fee2e2', fg: '#991b1b' },
};
function stageBadge(stage: string | null | undefined) {
  if (!stage) return { bg: '#f1f5f9', fg: '#64748b' };
  return STAGE_STYLE[stage] ?? { bg: '#f1f5f9', fg: '#475569' };
}
---

<InternalLayout title="Students" active="students">
  <div class="roster-header">
    <div>
      <h1 class="font-headline page-title" style="font-size: 26px;">Students</h1>
      <p class="page-subtitle" style="margin-bottom: 8px;">在管学生总览。点击姓名查看详情。</p>
      <a href={buildHref({ include_inactive: includeInactive ? '' : '1' })}
        class={`pill ${includeInactive ? 'pill--active' : ''}`}>
        {includeInactive ? '✓ 含已结案' : `+ 已结案 (${inactiveCount ?? 0})`}
      </a>
    </div>
    <div class="roster-counters">
      <span class="rc" title="28d+ 没联系"><span class="rc__dot" style={`background: ${tierStyle('critical').border};`}></span><strong class="font-mono" style={`color: ${tierStyle('critical').border};`}>{criticalCount}</strong> 28d+</span>
      <span class="rc" title="21–27d 没联系"><span class="rc__dot" style={`background: ${tierStyle('red').border};`}></span><strong class="font-mono" style={`color: ${tierStyle('red').border};`}>{redCount}</strong> 21–27d</span>
      <span class="rc" title="14–20d 没联系"><span class="rc__dot" style={`background: ${tierStyle('pink').border};`}></span><strong class="font-mono" style={`color: ${tierStyle('pink').border};`}>{pinkCount}</strong> 14–20d</span>
      <span class="rc" title="7–13d 没联系"><span class="rc__dot" style={`background: ${tierStyle('yellow').border};`}></span><strong class="font-mono" style={`color: ${tierStyle('yellow').border};`}>{yellowCount}</strong> 7–13d</span>
      <span class="rc rc--total"><strong class="font-mono">{students.length}</strong> 总数</span>
    </div>
  </div>

  {/* Filters — multi-select. "All" clears the row; clicking an option
       toggles it in the current selection. */}
  <div class="filter-row">
    <span class="filter-row__label">Cohort</span>
    <a href={buildHref({ cohort: '' })} class={`pill ${cohortFilter.length === 0 ? 'pill--active' : ''}`}>All</a>
    {cohorts.map(c => (
      <a href={toggleHref('cohort', c)} class={`pill ${cohortFilter.includes(c) ? 'pill--active' : ''}`}>{c}</a>
    ))}
  </div>

  <div class="filter-row">
    <span class="filter-row__label">Stage</span>
    <a href={buildHref({ stage: '' })} class={`pill ${stageFilter.length === 0 ? 'pill--active' : ''}`}>All</a>
    {stages.map(s => (
      <a href={toggleHref('stage', s)} class={`pill ${stageFilter.includes(s) ? 'pill--active' : ''}`}>{s}</a>
    ))}
  </div>

  <div class="filter-row" style="margin-bottom: 24px;">
    <span class="filter-row__label">Advisor</span>
    <a href={buildHref({ advisor: '' })} class={`pill ${advisorFilter.length === 0 ? 'pill--active' : ''}`}>All</a>
    {advisors.map(a => (
      <a href={toggleHref('advisor', a)} class={`pill ${advisorFilter.includes(a) ? 'pill--active' : ''}`}>{a}</a>
    ))}
  </div>

  {error && (
    <div style="padding: 14px 16px; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 8px; font-size: 13px;">
      数据库错误：{error.message}
    </div>
  )}

  {!error && students.length === 0 && (
    <div style="text-align: center; padding: 80px 24px; color: var(--text-soft); font-size: 14px;">
      没有匹配的学生。
    </div>
  )}

  {students.length > 0 && (
    <div class="roster-wrap">
      <table class="roster-table">
        <colgroup>
          <col style="width: 11%;" />
          <col style="width: 11%;" />
          <col style="width: 13%;" />
          <col style="width: 17%;" />
          <col style="width: 13%;" />
          <col style="width: 9%;" />
          <col style="width: 11%;" />
          <col style="width: 9%;" />
          <col style="width: 6%;" />
        </colgroup>
        <thead>
          <tr>
            <th>姓名</th>
            <th>阶段</th>
            <th>合同</th>
            <th>方向</th>
            <th>学校</th>
            <th>入学</th>
            <th>目标地区</th>
            <th>中期</th>
            <th>雷达</th>
          </tr>
        </thead>
        <tbody>
          {withRadar.map((s: any) => {
            const ts = tierStyle(s.tier);
            const label = tierLabel(s.tier, s.daysSince);
            const contractLabels = (s.contracts && s.contracts.length) ? s.contracts.join(' / ') : (s.contract_type ?? '—');
            const sb = stageBadge(s.stage);
            return (
              <tr id={String(s.id)}>
                <td class="cell-name">
                  <a href={`/internal/students/${s.id}`}>{s.name}</a>
                </td>
                <td>
                  {s.stage
                    ? <span class="badge" style={`background: ${sb.bg}; color: ${sb.fg};`}>{s.stage}</span>
                    : <span class="badge badge-empty">—</span>}
                </td>
                <td class="cell-text">{contractLabels}</td>
                <td class="cell-text">
                  {s.major_intention ?? '—'}
                  {s.major_current && (
                    <div class="cell-sub">在读：{s.major_current}</div>
                  )}
                </td>
                <td class="cell-text">{s.current_school ?? '—'}</td>
                <td>
                  <div class="badges-stack">
                    {(s.enroll_years && s.enroll_years.length)
                      ? s.enroll_years.map((y: string) => <span class="badge badge-neutral">{y}</span>)
                      : <span class="badge badge-empty">—</span>}
                  </div>
                </td>
                <td>
                  <div class="badges-stack">
                    {(s.target_regions && s.target_regions.length)
                      ? s.target_regions.map((r: string) => <span class="badge badge-neutral">{r}</span>)
                      : <span class="badge badge-empty">—</span>}
                  </div>
                </td>
                <td>
                  <div class="badges-stack">
                    {(s.mid_advisors && s.mid_advisors.length)
                      ? s.mid_advisors.map((a: string) => <span class="badge badge-neutral">{a}</span>)
                      : <span class="badge badge-empty">—</span>}
                  </div>
                </td>
                <td>
                  <span class="badge badge-mono" style={`background: ${ts.bg}; color: ${ts.fg};`}>{label}</span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <style>
    /* Roster header — title block left, tier counters right. */
    .roster-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 20px;
    }
    .roster-counters {
      display: flex;
      gap: 16px;
      font-size: 12px;
      color: var(--text-muted);
      align-items: baseline;
      flex-wrap: wrap;
    }
    .rc {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
    }
    .rc strong { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; }
    .rc__dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      align-self: center;
      margin-right: 1px;
    }
    .rc--total strong { color: var(--text); }

    /* Table wrapper uses the editorial card pattern — soft shadow + hairline border. */
    .roster-wrap {
      background: var(--surface-raised);
      border: 1px solid #eef0f3;
      border-radius: 14px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      overflow: hidden;
    }
    .roster-table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
    .roster-table thead {
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .roster-table thead th {
      background: #fbfcfd;
      border-bottom: 1px solid #eef0f3;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-align: left;
      padding: 11px 14px;
      white-space: nowrap;
    }
    .roster-table tbody tr { border-bottom: 1px solid #f1f3f6; }
    .roster-table tbody tr:last-child { border-bottom: 0; }
    .roster-table tbody tr:hover { background: #fafbfc; }
    .roster-table td { padding: 11px 14px; vertical-align: middle; color: var(--text-muted); }
    .roster-table .cell-name a { color: var(--primary); text-decoration: none; font-weight: 600; font-size: 14px; }
    .roster-table .cell-name a:hover { text-decoration: underline; }
    .roster-table .cell-text { font-size: 12.5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .roster-table .cell-sub { font-size: 11px; color: var(--text-soft); margin-top: 2px; }
    .badge {
      display: inline-block;
      padding: 3px 9px;
      border-radius: 6px;
      font-size: 11.5px;
      font-weight: 600;
      white-space: nowrap;
      line-height: 1.4;
    }
    .badge-neutral { background: #f1f5f9; color: #475569; }
    .badge-empty { background: transparent; color: var(--text-soft); padding-left: 0; padding-right: 0; }
    .badge-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-weight: 700; font-size: 11px; }
    .badges-stack { display: flex; flex-wrap: wrap; gap: 3px; }
  </style>
</InternalLayout>
