---
// src/pages/internal/students.astro — student roster (auth-gated).
// Multi-select fields rendered " / " joined. 私单 visible only to 王世杰 / admin.
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';
import { tierFor, tierStyle, tierLabel, daysSinceToday, INACTIVE_STAGES } from '../../utils/contact-radar';

const url = new URL(Astro.request.url);
const stageFilter = url.searchParams.get('stage') || '';
const advisorFilter = url.searchParams.get('advisor') || '';
const cohortFilter = url.searchParams.get('cohort') || '';
const includeInactive = url.searchParams.get('include_inactive') === '1';
const viewer = Astro.locals?.viewer ?? null;

const PRIVATE_CONTRACTS = ['私单', '私单（非公司合同）'];
const canSeePrivate = !!viewer && (viewer.isAdmin || viewer.name === '王世杰');

let q = supabase
  .from('students')
  .select('id, name, stage, contracts, contract_type, major_intention, major_current, current_school, client_email, early_advisors, mid_advisors, late_advisors, last_contact_at, enroll_years, target_regions, synced_at');

if (stageFilter) q = q.eq('stage', stageFilter);
// Multi-select: contains check (mid_advisors contains the filtered name)
if (advisorFilter) q = q.contains('mid_advisors', [advisorFilter]);
if (cohortFilter)  q = q.contains('enroll_years', [cohortFilter]);

const stageIsInactive = stageFilter && INACTIVE_STAGES.has(stageFilter);
if (!includeInactive && !stageIsInactive) {
  q = q.not('stage', 'in', `(${Array.from(INACTIVE_STAGES).join(',')})`);
}

// Hide private-contract students from anyone who shouldn't see them. Silent — no UI mention.
if (!canSeePrivate) {
  q = q.not('contracts', 'ov', `{${PRIVATE_CONTRACTS.join(',')}}`);
}

const { data: studentsRaw, error } = await q.order('last_contact_at', { ascending: false, nullsFirst: false }).limit(500);
const students = studentsRaw ?? [];

// Counts for header badges
const { count: inactiveCount } = await supabase
  .from('students')
  .select('id', { count: 'exact', head: true })
  .in('stage', Array.from(INACTIVE_STAGES));

const withRadar = students.map((s: any) => {
  const ds = daysSinceToday(s.last_contact_at);
  const tier = tierFor(ds, s.stage);
  return { ...s, daysSince: ds, tier };
});

// Build filter chip values from the FULL active student set (so filters don't disappear
// when current page is empty). Reasonable approximation: enumerate over current results.
const stages = Array.from(new Set(students.map((s: any) => s.stage).filter(Boolean))).sort();
const cohorts = Array.from(new Set(students.flatMap((s: any) => (s.enroll_years ?? [])).filter(Boolean))).sort() as string[];
const advisors = Array.from(new Set(students.flatMap((s: any) => (s.mid_advisors ?? [])).filter(Boolean))).sort() as string[];

const criticalCount = withRadar.filter((s: any) => s.tier === 'critical').length;
const redCount = withRadar.filter((s: any) => s.tier === 'red').length;
const pinkCount = withRadar.filter((s: any) => s.tier === 'pink').length;
const yellowCount = withRadar.filter((s: any) => s.tier === 'yellow').length;

function buildHref(overrides: Record<string, string>): string {
  const params = new URLSearchParams();
  const next: Record<string, string> = {
    stage: stageFilter,
    advisor: advisorFilter,
    cohort: cohortFilter,
    include_inactive: includeInactive ? '1' : '',
    ...overrides,
  };
  for (const [k, v] of Object.entries(next)) if (v) params.set(k, v);
  const qs = params.toString();
  return qs ? `/internal/students?${qs}` : '/internal/students';
}

function joinList(arr: string[] | null | undefined, fallback = '—'): string {
  if (!arr || !arr.length) return fallback;
  return arr.join(' / ');
}
---

<InternalLayout title="Students" active="students">
  <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px;">
    <div>
      <h1 class="font-headline" style="font-size: 26px; font-weight: 800; margin: 0 0 4px; letter-spacing: -0.02em;">
        Students
      </h1>
      <p style="color: var(--text-muted); margin: 0 0 8px; font-size: 14px;">
        在管学生总览。点击姓名查看详情。
      </p>
      <a href={buildHref({ include_inactive: includeInactive ? '' : '1' })}
        style={`display: inline-block; padding: 5px 12px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${includeInactive ? 'var(--primary)' : 'var(--border)'}; color: ${includeInactive ? 'var(--primary)' : 'var(--text-muted)'}; background: ${includeInactive ? '#e8f0ee' : 'transparent'};`}>
        {includeInactive ? '✓ 含已结案' : `+ 已结案 (${inactiveCount ?? 0})`}
      </a>
    </div>
    <div style="display: flex; gap: 18px; font-size: 12px; color: var(--text-muted); align-items: baseline;">
      <div title="28d+ 没联系">
        <strong style={`color: ${tierStyle('critical').border}; font-size: 22px; font-family: 'JetBrains Mono', monospace;`}>{criticalCount}</strong> ⚠️
      </div>
      <div title="21-27d 没联系">
        <strong style={`color: ${tierStyle('red').border}; font-size: 22px; font-family: 'JetBrains Mono', monospace;`}>{redCount}</strong> 红
      </div>
      <div title="14-20d 没联系">
        <strong style={`color: ${tierStyle('pink').border}; font-size: 22px; font-family: 'JetBrains Mono', monospace;`}>{pinkCount}</strong> 淡红
      </div>
      <div title="7-13d 没联系">
        <strong style={`color: ${tierStyle('yellow').border}; font-size: 22px; font-family: 'JetBrains Mono', monospace;`}>{yellowCount}</strong> 黄
      </div>
      <div>
        <strong style="font-size: 22px; font-family: 'JetBrains Mono', monospace;">{students.length}</strong> 总数
      </div>
    </div>
  </div>

  {/* Filters */}
  <div style="display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap;">
    <span style="font-size: 11px; font-weight: 700; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.08em; align-self: center; margin-right: 6px;">Cohort</span>
    <a href={buildHref({ cohort: '' })}
      style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${!cohortFilter ? 'var(--primary)' : 'var(--border)'}; color: ${!cohortFilter ? 'var(--primary)' : 'var(--text-muted)'};`}>
      All
    </a>
    {cohorts.map(c => (
      <a href={buildHref({ cohort: c })}
        style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${cohortFilter === c ? 'var(--primary)' : 'var(--border)'}; color: ${cohortFilter === c ? 'var(--primary)' : 'var(--text-muted)'};`}>
        {c}
      </a>
    ))}
  </div>

  <div style="display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap;">
    <span style="font-size: 11px; font-weight: 700; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.08em; align-self: center; margin-right: 6px;">Stage</span>
    <a href={buildHref({ stage: '' })}
      style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${!stageFilter ? 'var(--primary)' : 'var(--border)'}; color: ${!stageFilter ? 'var(--primary)' : 'var(--text-muted)'};`}>
      All
    </a>
    {stages.map(s => (
      <a href={buildHref({ stage: s as string })}
        style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${stageFilter === s ? 'var(--primary)' : 'var(--border)'}; color: ${stageFilter === s ? 'var(--primary)' : 'var(--text-muted)'};`}>
        {s}
      </a>
    ))}
  </div>

  <div style="display: flex; gap: 6px; margin-bottom: 24px; flex-wrap: wrap;">
    <span style="font-size: 11px; font-weight: 700; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.08em; align-self: center; margin-right: 6px;">Advisor</span>
    <a href={buildHref({ advisor: '' })}
      style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${!advisorFilter ? 'var(--primary)' : 'var(--border)'}; color: ${!advisorFilter ? 'var(--primary)' : 'var(--text-muted)'};`}>
      All
    </a>
    {advisors.map(a => (
      <a href={buildHref({ advisor: a })}
        style={`padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; border: 1px solid ${advisorFilter === a ? 'var(--primary)' : 'var(--border)'}; color: ${advisorFilter === a ? 'var(--primary)' : 'var(--text-muted)'};`}>
        {a}
      </a>
    ))}
  </div>

  {error && (
    <div style="padding: 14px 16px; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 8px; font-size: 13px;">
      数据库错误：{error.message}
    </div>
  )}

  {!error && students.length === 0 && (
    <div style="text-align: center; padding: 80px 24px; color: var(--text-soft); font-size: 14px;">
      没有匹配的学生。
    </div>
  )}

  {students.length > 0 && (
    <div style="background: var(--surface-raised); border: 1px solid var(--border); border-radius: 10px; overflow: hidden;">
      <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
        <thead>
          <tr style="background: #f8fafc; border-bottom: 1px solid var(--border); font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
            <th style="text-align: left; padding: 10px 14px;">姓名</th>
            <th style="text-align: left; padding: 10px 14px;">阶段</th>
            <th style="text-align: left; padding: 10px 14px;">合同</th>
            <th style="text-align: left; padding: 10px 14px;">方向</th>
            <th style="text-align: left; padding: 10px 14px;">学校</th>
            <th style="text-align: left; padding: 10px 14px;">入学年份</th>
            <th style="text-align: left; padding: 10px 14px;">目标地区</th>
            <th style="text-align: left; padding: 10px 14px;">中期</th>
            <th style="text-align: left; padding: 10px 14px;">最后沟通</th>
            <th style="text-align: left; padding: 10px 14px;">雷达</th>
          </tr>
        </thead>
        <tbody>
          {withRadar.map((s: any) => {
            const ts = tierStyle(s.tier);
            const label = tierLabel(s.tier, s.daysSince);
            const contractLabels = (s.contracts && s.contracts.length) ? s.contracts.join(' / ') : (s.contract_type ?? '—');
            return (
              <tr id={String(s.id)} style="border-bottom: 1px solid var(--border);">
                <td style="padding: 10px 14px; font-weight: 600;">
                  <a href={`/internal/students/${s.id}`} style="color: var(--primary); text-decoration: none;">
                    {s.name}
                  </a>
                  {s.client_email && (
                    <div style="font-size: 11px; color: var(--text-soft); font-weight: 400; margin-top: 2px;">{s.client_email}</div>
                  )}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted);">{s.stage ?? '—'}</td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px;">{contractLabels}</td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.major_intention ?? '—'}
                  {s.major_current && (
                    <div style="font-size: 11px; color: var(--text-soft); margin-top: 2px;">在读：{s.major_current}</div>
                  )}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.current_school ?? '—'}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px;">
                  {joinList(s.enroll_years)}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px; max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {joinList(s.target_regions)}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-size: 12px;">
                  {joinList(s.mid_advisors)}
                </td>
                <td style="padding: 10px 14px; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size: 12px;">{s.last_contact_at ?? '—'}</td>
                <td style="padding: 10px 14px;">
                  <span style={`display: inline-block; padding: 3px 8px; border-radius: 999px; background: ${ts.bg}; color: ${ts.fg}; font-weight: 700; font-family: 'JetBrains Mono', monospace; font-size: 11px; white-space: nowrap;`}>
                    {label}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</InternalLayout>
