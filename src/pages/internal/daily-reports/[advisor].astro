---
// src/pages/internal/daily-reports/[advisor].astro — single advisor's daily report.
// Access: viewer must be the same advisor OR admin. Non-matching viewers are
// redirected to their own report (helpful) rather than 403'd.
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { buildWikilinkIndex, resolveWikilinks } from '../../../utils/wikilinks';
import { preprocessCallouts } from '../../../utils/callouts';
import { marked } from 'marked';

const viewer = Astro.locals?.viewer ?? null;
const { advisor } = Astro.params;
const advisorName = decodeURIComponent(advisor ?? '');

if (!advisorName) {
  return Astro.redirect('/internal/daily-reports');
}

// Access control — only the advisor herself, or an admin, can view.
if (!viewer) {
  return new Response('Unauthorized', { status: 401 });
}
// XDF guests (authenticated but not in the advisors table) → dashboard.
if (!viewer.isAdmin && !viewer.isAdvisor) {
  return Astro.redirect('/internal');
}
if (!viewer.isAdmin && viewer.name !== advisorName) {
  // Advisor trying to peek at someone else's report → bounce to their own.
  return Astro.redirect(`/internal/daily-reports/${encodeURIComponent(viewer.name)}`);
}

const { data: report, error } = await supabase
  .from('daily_reports')
  .select('advisor, body_md, synced_at, obsidian_path')
  .eq('advisor', advisorName)
  .single();

if (error || !report) {
  return new Response(`No daily report found for ${advisorName}`, { status: 404 });
}

// Wikilink resolver (scope: students + their notes — same as detail page)
const { data: allStudents } = await supabase.from('students').select('id, name, attachments');
const { data: allNotes } = await supabase.from('student_notes').select('student_id, note_name');
const wikiIndex = buildWikilinkIndex({
  students: allStudents ?? [],
  notes: allNotes ?? [],
});

marked.setOptions({ gfm: true, breaks: true });
const html = (() => {
  const body = report.body_md ?? '';
  if (!body.trim()) return '';
  const withWikilinks = resolveWikilinks(body, wikiIndex);
  const withCallouts = preprocessCallouts(withWikilinks);
  return marked.parse(withCallouts) as string;
})();

// Extract all date entries for the right-side TOC
type Entry = { date: string; lineCount: number };
const dateEntries: Entry[] = [];
if (report.body_md) {
  const lines = report.body_md.split('\n');
  let cur: { date: string; start: number } | null = null;
  for (let i = 0; i < lines.length; i++) {
    const m = lines[i].match(/^##\s+(\d{4}-\d{2}-\d{2})/);
    if (m) {
      if (cur) dateEntries.push({ date: cur.date, lineCount: i - cur.start });
      cur = { date: m[1], start: i };
    }
  }
  if (cur) dateEntries.push({ date: cur.date, lineCount: lines.length - cur.start });
}

// Advisor picker is admin-only — regular advisors don't need to switch (they only
// have access to their own).
const { data: allAdvisorsRaw } = viewer.isAdmin
  ? await supabase.from('daily_reports').select('advisor').order('advisor')
  : { data: [] as { advisor: string }[] };
const allAdvisors = allAdvisorsRaw ?? [];

function dateAnchor(d: string): string {
  return `d-${d}`;
}
---

<InternalLayout title={`Daily Report — ${advisorName}`} active="daily-reports">
  {viewer.isAdmin && (
    <a href="/internal/daily-reports" class="back-link">← Daily Reports</a>
  )}

  <div class="dr-detail-header">
    <h1 class="font-headline dr-detail-title">
      日报 <span class="dr-detail-title__sep">·</span> {advisorName}
    </h1>
    {viewer.isAdmin && allAdvisors.length > 1 && (
      <div class="dr-advisor-switcher">
        {allAdvisors.filter((a: any) => a.advisor !== advisorName).map((a: any) => (
          <a href={`/internal/daily-reports/${encodeURIComponent(a.advisor)}`} class="pill">
            {a.advisor}
          </a>
        ))}
      </div>
    )}
  </div>
  <p class="dr-detail-meta font-mono">
    {report.obsidian_path} · 同步于 {new Date(report.synced_at).toLocaleString('zh-CN')}
  </p>

  <div class="dr-detail-grid">
    <article class="dr-detail-body">
      {html ? (
        <div class="md-body daily-report-body" set:html={html} />
      ) : (
        <p class="section-card__empty">日报为空。</p>
      )}
    </article>

    <aside class="dr-toc">
      <div class="dr-toc__label">时间轴 ({dateEntries.length})</div>
      <ul class="dr-toc__list">
        {dateEntries.slice(0, 60).map(e => (
          <li>
            <a href={`#${dateAnchor(e.date)}`} class="dr-toc__item font-mono">
              <span>{e.date}</span>
              <span class="dr-toc__item-count">{e.lineCount}L</span>
            </a>
          </li>
        ))}
        {dateEntries.length > 60 && (
          <li class="dr-toc__overflow">… 还有 {dateEntries.length - 60} 个更早的条目</li>
        )}
      </ul>
    </aside>
  </div>
</InternalLayout>

<script is:inline>
  // Auto-attach id="d-YYYY-MM-DD" to ## date headings so the TOC anchors work.
  document.querySelectorAll('.daily-report-body h2').forEach(h => {
    const m = h.textContent && h.textContent.match(/^(\d{4}-\d{2}-\d{2})/);
    if (m) h.id = 'd-' + m[1];
  });
</script>

<style>
  /* .back-link lives in InternalLayout global. */
  .dr-detail-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .dr-detail-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .dr-detail-title__sep {
    color: var(--text-soft);
    font-weight: 400;
    margin: 0 4px;
  }
  .dr-advisor-switcher {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .dr-detail-meta {
    color: var(--text-soft);
    font-size: 12px;
    margin: 0 0 24px;
  }

  .dr-detail-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 32px;
    align-items: start;
  }
  .dr-detail-body {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 28px 36px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }

  .dr-toc { position: sticky; top: 16px; }
  .dr-toc__label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }
  .dr-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 70vh;
    overflow-y: auto;
    border: 1px solid #eef0f3;
    border-radius: 10px;
    background: var(--surface-raised);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .dr-toc__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 8px 12px;
    font-size: 12px;
    color: var(--text);
    border-bottom: 1px solid #f1f3f6;
    transition: background 120ms ease;
  }
  .dr-toc__item:hover { background: #fafbfc; }
  .dr-toc__list li:last-child .dr-toc__item { border-bottom: 0; }
  .dr-toc__item-count {
    color: var(--text-soft);
    font-size: 11px;
  }
  .dr-toc__overflow {
    padding: 8px 12px;
    font-size: 11px;
    color: var(--text-soft);
    text-align: center;
  }
</style>

<style is:global>
  .md-body { font-size: 14px; line-height: 1.65; color: var(--text); }
  .md-body p { margin: 0 0 12px; }
  .md-body h2 {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    margin: 24px 0 10px;
    font-size: 17px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 80px;
  }
  .md-body h2:first-child { margin-top: 0; }
  .md-body ul, .md-body ol { padding-left: 22px; margin: 0 0 12px; }
  .md-body li { margin: 4px 0; }
  .md-body code {
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }
  .md-body a { color: var(--primary); text-decoration: underline; text-decoration-color: rgba(4, 47, 36, 0.3); text-underline-offset: 2px; }
  .md-body a:hover { text-decoration-color: var(--primary); }
  .md-body strong { font-weight: 700; }

  .wikilink-student, .wikilink-note {
    color: var(--primary);
    background: rgba(4, 47, 36, 0.06);
    padding: 1px 6px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  }
  .wikilink-student:hover, .wikilink-note:hover {
    background: rgba(4, 47, 36, 0.12);
  }
  .wikilink-attachment {
    color: var(--text-muted);
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.92em;
  }
  .wikilink-unresolved {
    color: var(--text-soft);
    background: transparent;
    border-bottom: 1px dashed var(--text-soft);
    padding: 0 2px;
  }
</style>
