---
// src/pages/internal/daily-reports/index.astro — overview.
// Admin sees every advisor's report card; a regular advisor is sent straight
// to their own report (no need to pick from a list — they'd see only one card).
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';

const viewer = Astro.locals?.viewer ?? null;

// Non-admin advisors → straight to their own page. Skip the picker entirely.
if (viewer && !viewer.isAdmin) {
  return Astro.redirect(`/internal/daily-reports/${encodeURIComponent(viewer.name)}`);
}

const { data: reportsRaw } = await supabase
  .from('daily_reports')
  .select('advisor, body_md, synced_at, obsidian_path')
  .order('advisor');
const reports = reportsRaw ?? [];

// For each report, extract the most recent date heading + a tiny preview snippet
type ReportCard = {
  advisor: string;
  latestDate: string | null;
  preview: string;
  totalEntries: number;
  bytes: number;
  syncedAt: string;
};

function summarize(body: string | null): { latestDate: string | null; preview: string; totalEntries: number } {
  if (!body) return { latestDate: null, preview: '', totalEntries: 0 };
  const lines = body.split('\n');
  let latestDate: string | null = null;
  const dateMatches: string[] = [];
  for (const line of lines) {
    const m = line.match(/^##\s+(\d{4}-\d{2}-\d{2})/);
    if (m) {
      dateMatches.push(m[1]);
      if (!latestDate) latestDate = m[1];
    }
  }
  // Preview: the first 200 chars of content after the first ## heading
  const idx = body.search(/^##\s/m);
  let preview = '';
  if (idx >= 0) {
    preview = body.slice(idx).split('\n').slice(1, 6).join('\n').trim();
    if (preview.length > 240) preview = preview.slice(0, 240) + '…';
  }
  return { latestDate, preview, totalEntries: dateMatches.length };
}

const cards: ReportCard[] = reports.map((r: any) => {
  const s = summarize(r.body_md);
  return {
    advisor: r.advisor,
    latestDate: s.latestDate,
    preview: s.preview,
    totalEntries: s.totalEntries,
    bytes: r.body_md ? r.body_md.length : 0,
    syncedAt: r.synced_at,
  };
});

// Days since the latest date entry
const today = new Date();
function daysSince(d: string | null): number | null {
  if (!d) return null;
  return Math.floor((today.getTime() - new Date(d).getTime()) / 86400000);
}

function fmtKB(b: number): string {
  if (b < 1024) return `${b} B`;
  return `${(b / 1024).toFixed(1)} KB`;
}
---

<InternalLayout title="Daily Reports" active="daily-reports">
  <div class="page-header" style="margin-bottom: 20px;">
    <div>
      <h1 class="font-headline page-title" style="font-size: 26px;">Daily Reports</h1>
      <p class="page-subtitle" style="margin-bottom: 0;">
        每位顾问的日报 rolling 流，新的在顶部。
      </p>
    </div>
    <div class="dr-count">
      <strong class="font-mono">{cards.length}</strong>
      <span>位顾问</span>
    </div>
  </div>

  {cards.length === 0 ? (
    <div class="empty-state">暂无日报。</div>
  ) : (
    <div class="dr-grid">
      {cards.map(c => {
        const ds = daysSince(c.latestDate);
        const stale = ds !== null && ds > 3;
        return (
          <a href={`/internal/daily-reports/${encodeURIComponent(c.advisor)}`} class="dr-card">
            <div class="dr-card__header">
              <h3 class="font-headline dr-card__name">{c.advisor}</h3>
              <span class="font-mono dr-card__date" style={stale ? 'color: var(--warning);' : ''}>
                {c.latestDate ?? '—'} {ds !== null && `· ${ds}d 前`}
              </span>
            </div>
            <div class="dr-card__meta">
              {c.totalEntries} 个日期条目 · {fmtKB(c.bytes)}
            </div>
            <pre class="dr-card__preview">{c.preview || '(暂无最近条目)'}</pre>
          </a>
        );
      })}
    </div>
  )}

  <style>
    .dr-count {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
    }
    .dr-count strong {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .dr-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 16px;
    }
    .dr-card {
      display: block;
      background: var(--surface-raised);
      border: 1px solid #eef0f3;
      border-radius: 14px;
      padding: 20px 22px;
      text-decoration: none;
      color: inherit;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
    }
    .dr-card:hover {
      border-color: var(--text-muted);
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
      transform: translateY(-1px);
    }
    .dr-card__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 8px;
      gap: 8px;
    }
    .dr-card__name {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .dr-card__date {
      font-size: 11px;
      color: var(--text-soft);
      white-space: nowrap;
    }
    .dr-card__meta {
      font-size: 11px;
      color: var(--text-soft);
      margin-bottom: 12px;
      letter-spacing: 0.02em;
    }
    .dr-card__preview {
      margin: 0;
      font-family: inherit;
      font-size: 12px;
      line-height: 1.55;
      color: var(--text-muted);
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 100px;
      overflow: hidden;
    }
    .empty-state {
      text-align: center;
      padding: 80px 24px;
      color: var(--text-soft);
      font-size: 14px;
    }
  </style>
</InternalLayout>
