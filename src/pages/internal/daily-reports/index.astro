---
// src/pages/internal/daily-reports/index.astro — overview.
// Admin sees every advisor's report card; a regular advisor is sent straight
// to their own report (no need to pick from a list — they'd see only one card).
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';

const viewer = Astro.locals?.viewer ?? null;

// XDF guests (no advisor row) can't see daily reports at all — bounce to dashboard.
if (!viewer || (!viewer.isAdmin && !viewer.isAdvisor)) {
  return Astro.redirect('/internal');
}
// Non-admin advisors → straight to their own page. Skip the picker entirely.
if (!viewer.isAdmin) {
  return Astro.redirect(`/internal/daily-reports/${encodeURIComponent(viewer.name)}`);
}

const { data: reportsRaw } = await supabase
  .from('daily_reports')
  .select('advisor, body_md, synced_at, obsidian_path')
  .order('advisor');
const reports = reportsRaw ?? [];

// For each report, extract the most recent date heading + a tiny preview snippet
type ReportCard = {
  advisor: string;
  latestDate: string | null;
  totalEntries: number;
  syncedAt: string;
};

function summarize(body: string | null): { latestDate: string | null; totalEntries: number } {
  if (!body) return { latestDate: null, totalEntries: 0 };
  const lines = body.split('\n');
  let latestDate: string | null = null;
  let count = 0;
  for (const line of lines) {
    const m = line.match(/^##\s+(\d{4}-\d{2}-\d{2})/);
    if (m) {
      count++;
      if (!latestDate) latestDate = m[1];
    }
  }
  return { latestDate, totalEntries: count };
}

const cards: ReportCard[] = reports.map((r: any) => {
  const s = summarize(r.body_md);
  return {
    advisor: r.advisor,
    latestDate: s.latestDate,
    totalEntries: s.totalEntries,
    syncedAt: r.synced_at,
  };
});

// Days since the latest date entry
const today = new Date();
function daysSince(d: string | null): number | null {
  if (!d) return null;
  return Math.floor((today.getTime() - new Date(d).getTime()) / 86400000);
}
---

<InternalLayout title="Daily Reports" active="daily-reports">
  <div class="page-header" style="margin-bottom: 20px;">
    <div>
      <h1 class="font-headline page-title" style="font-size: 26px;">Daily Reports</h1>
      <p class="page-subtitle" style="margin-bottom: 0;">
        每位顾问的日报 rolling 流，新的在顶部。
      </p>
    </div>
    <div class="dr-count">
      <strong class="font-mono">{cards.length}</strong>
      <span>位顾问</span>
    </div>
  </div>

  {cards.length === 0 ? (
    <div class="empty-state">暂无日报。</div>
  ) : (
    <div class="dr-grid">
      {cards.map(c => {
        const ds = daysSince(c.latestDate);
        const stale = ds !== null && ds > 3;
        return (
          <a href={`/internal/daily-reports/${encodeURIComponent(c.advisor)}`} class="dr-card">
            <h3 class="font-headline dr-card__name">{c.advisor}</h3>
            <div class="dr-card__stats">
              <span class="dr-card__stat">
                <span class="dr-card__stat-num font-mono">{c.totalEntries}</span>
                <span class="dr-card__stat-label">条目</span>
              </span>
              <span class="dr-card__stat">
                <span class="dr-card__stat-num font-mono" style={stale ? 'color: var(--warning);' : ''}>
                  {ds !== null ? `${ds}d` : '—'}
                </span>
                <span class="dr-card__stat-label">距上次</span>
              </span>
            </div>
            <div class="dr-card__date font-mono">{c.latestDate ?? '—'}</div>
          </a>
        );
      })}
    </div>
  )}

  <style>
    .dr-count {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
    }
    .dr-count strong {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .dr-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 16px;
    }
    .dr-card {
      display: block;
      background: var(--surface-raised);
      border: 1px solid #eef0f3;
      border-radius: 14px;
      padding: 22px 24px;
      text-decoration: none;
      color: inherit;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
    }
    .dr-card:hover {
      border-color: var(--text-muted);
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
      transform: translateY(-1px);
    }
    .dr-card__name {
      margin: 0 0 18px;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .dr-card__stats {
      display: flex;
      gap: 28px;
      margin-bottom: 16px;
    }
    .dr-card__stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .dr-card__stat-num {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--text);
    }
    .dr-card__stat-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .dr-card__date {
      font-size: 11px;
      color: var(--text-soft);
      letter-spacing: 0.04em;
    }
    .empty-state {
      text-align: center;
      padding: 80px 24px;
      color: var(--text-soft);
      font-size: 14px;
    }
  </style>
</InternalLayout>
