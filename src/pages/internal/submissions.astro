---
// src/pages/internal/submissions.astro — inbox for Shijie to process
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';

const viewer = Astro.locals?.viewer ?? null;

// Inbox is admin-only. Anyone else (advisor or XDF guest) bounces to dashboard.
if (!viewer || !viewer.isAdmin) {
  return Astro.redirect('/internal');
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'unprocessed'; // unprocessed | all | processed
const typeFilter = url.searchParams.get('type') || '';

let q = supabase
  .from('submissions')
  .select('id, student_id, student_name_raw, type, submitted_at, submitted_by, summary, content, audio_url, attachment_url, ai_transcript, ai_summary, processed, processed_at, students(name, mid_advisor, stage)')
  .order('submitted_at', { ascending: false })
  .limit(200);

if (filter === 'unprocessed') q = q.eq('processed', false);
else if (filter === 'processed') q = q.eq('processed', true);

if (typeFilter) q = q.eq('type', typeFilter);

const { data: rows, error } = await q;
const submissions = rows ?? [];

// Count summaries for the filter bar
const { count: unprocessedCount } = await supabase
  .from('submissions')
  .select('id', { count: 'exact', head: true })
  .eq('processed', false);

// Generate signed download URLs for any attachments (1 hour expiry).
// Stored as bucket-relative paths; we mint URLs at render time.
const SIGN_TTL = 3600;
const filesToSign = submissions
  .flatMap((s: any) => [s.attachment_url, s.audio_url].filter(Boolean));
const signedByPath = new Map<string, string>();
if (filesToSign.length) {
  const { data: signed } = await supabase.storage
    .from('submissions')
    .createSignedUrls(filesToSign, SIGN_TTL);
  for (const item of signed ?? []) {
    if (item.path && item.signedUrl) signedByPath.set(item.path, item.signedUrl);
  }
}
function basename(path: string): string {
  return path.split('/').pop() ?? path;
}

function fmt(dt: string | null): string {
  if (!dt) return '—';
  const d = new Date(dt);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
}

const typeColors: Record<string, string> = {
  沟通记录: '#6366f1',
  录音: '#dc2626',
  重要comment: '#d97706',
  状态更新: '#059669',
  会议: '#7c3aed',
  其他: '#64748b',
};
---

<InternalLayout title="Inbox" active="submissions">
  <div class="page-header" style="margin-bottom: 20px;">
    <div>
      <h1 class="font-headline page-title" style="font-size: 26px;">Inbox</h1>
      <p class="page-subtitle" style="margin-bottom: 0;">员工提交，待审核与归档。</p>
    </div>
    <div class="inbox-pending">
      <strong class="font-mono" style="color: var(--danger);">{unprocessedCount ?? 0}</strong>
      <span>条待处理</span>
    </div>
  </div>

  <!-- Filters -->
  <div class="filter-row" style="margin-bottom: 20px;">
    {[
      { key: 'unprocessed', label: 'Unprocessed' },
      { key: 'all', label: 'All' },
      { key: 'processed', label: 'Processed' },
    ].map(({ key, label }) => (
      <a href={`/internal/submissions?filter=${key}${typeFilter ? `&type=${typeFilter}` : ''}`}
        class={`pill ${filter === key ? 'pill--active' : ''}`}>
        {label}
      </a>
    ))}
    <span class="filter-divider"></span>
    {['', '沟通记录', '重要comment', '状态更新', '会议', '其他'].map(t => (
      <a href={`/internal/submissions?filter=${filter}${t ? `&type=${t}` : ''}`}
        class={`pill ${typeFilter === t ? 'pill--active' : ''}`}>
        {t || 'All types'}
      </a>
    ))}
  </div>

  {error && (
    <div style="padding: 14px 16px; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 8px; font-size: 13px;">
      数据库错误：{error.message}
    </div>
  )}

  {!error && submissions.length === 0 && (
    <div style="text-align: center; padding: 80px 24px; color: var(--text-soft); font-size: 14px;">
      没有匹配的记录。
    </div>
  )}

  <div class="sub-list">
    {submissions.map((s: any) => {
      const student = s.students;
      const displayName = student?.name ?? s.student_name_raw ?? '(unknown)';
      const isNew = !s.student_id && s.student_name_raw;
      const tColor = typeColors[s.type] || 'var(--text-muted)';
      return (
        <article data-id={s.id} class={`sub-card ${s.processed ? 'is-processed' : ''}`}>
          <div class="sub-card__meta">
            <span class="sub-card__type" style={`color: ${tColor}; background: ${tColor}1a;`}>
              {s.type}
            </span>
            <span class="font-mono sub-card__time">{fmt(s.submitted_at)}</span>
            <span class="sub-card__by">by <strong>{s.submitted_by || '—'}</strong></span>
            {s.processed && <span class="sub-card__processed">✓ processed</span>}
          </div>
          <div class="sub-card__title-row">
            <h3 class="sub-card__title">
              <a href={s.student_id ? `/internal/students/${s.student_id}` : '/internal/students'}>
                {displayName}
              </a>
              {isNew && <span class="sub-card__new">新客</span>}
            </h3>
            {student?.mid_advisor && <span class="sub-card__sub">{student.mid_advisor}</span>}
            {student?.stage && <span class="sub-card__sub">· {student.stage}</span>}
          </div>
          {s.summary && <p class="sub-card__summary">{s.summary}</p>}
          {s.content && (
            <div class="sub-card__content">{s.content}</div>
          )}
          {s.ai_transcript && (
            <details class="sub-card__details">
              <summary>AI 转写（{s.ai_transcript.length} 字符）</summary>
              <div class="sub-card__transcript">{s.ai_transcript}</div>
            </details>
          )}
          {s.ai_summary && (
            <div class="sub-card__ai-summary">
              <strong>AI SUMMARY</strong>
              <div>{s.ai_summary}</div>
            </div>
          )}

          <div class="sub-card__actions">
            {s.audio_url && (
              signedByPath.get(s.audio_url)
                ? <a href={signedByPath.get(s.audio_url)} target="_blank" rel="noopener" class="sub-card__attachment">🎙 {basename(s.audio_url)}</a>
                : <span class="sub-card__attachment sub-card__attachment--broken">🎙 {basename(s.audio_url)} <em>(URL 失败)</em></span>
            )}
            {s.attachment_url && (
              signedByPath.get(s.attachment_url)
                ? <a href={signedByPath.get(s.attachment_url)} target="_blank" rel="noopener" class="sub-card__attachment">📎 {basename(s.attachment_url)}</a>
                : <span class="sub-card__attachment sub-card__attachment--broken">📎 {basename(s.attachment_url)} <em>(URL 失败)</em></span>
            )}
            <span class="sub-card__spacer"></span>
            <button
              class="copy-md btn-ghost"
              data-id={s.id}
              data-payload={JSON.stringify({
                id: s.id,
                type: s.type,
                submitted_at: s.submitted_at,
                submitted_by: s.submitted_by,
                summary: s.summary,
                content: s.content,
                student_name: displayName,
                student_id: s.student_id,
                mid_advisor: student?.mid_advisor ?? null,
                early_advisor: null,
                stage: student?.stage ?? null,
                ai_transcript: s.ai_transcript,
                ai_summary: s.ai_summary,
                attachment_url: s.attachment_url,
                attachment_signed: s.attachment_url ? (signedByPath.get(s.attachment_url) ?? null) : null,
                audio_url: s.audio_url,
                audio_signed: s.audio_url ? (signedByPath.get(s.audio_url) ?? null) : null,
              })}>
              复制为 markdown
            </button>
            <button
              class={`toggle-processed ${s.processed ? 'btn-ghost' : 'btn-primary'}`}
              data-id={s.id}
              data-processed={String(s.processed)}>
              {s.processed ? 'Unmark' : 'Mark processed'}
            </button>
          </div>
        </article>
      );
    })}
  </div>

  <style>
    .inbox-pending {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
    }
    .inbox-pending strong {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .sub-list { display: grid; gap: 14px; }
    .sub-card {
      background: var(--surface-raised);
      border: 1px solid #eef0f3;
      border-radius: 14px;
      padding: 18px 22px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      transition: opacity 120ms ease;
    }
    .sub-card.is-processed { opacity: 0.55; }

    .sub-card__meta {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 11px;
      color: var(--text-soft);
      flex-wrap: wrap;
    }
    .sub-card__type {
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 3px 9px;
      border-radius: 999px;
      font-size: 10.5px;
    }
    .sub-card__time { color: var(--text-muted); }
    .sub-card__by { color: var(--text-soft); }
    .sub-card__by strong { color: var(--text); font-weight: 600; }
    .sub-card__processed {
      color: var(--success);
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .sub-card__title-row {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }
    .sub-card__title {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .sub-card__title a {
      color: var(--primary);
    }
    .sub-card__title a:hover {
      text-decoration: underline;
    }
    .sub-card__new {
      font-size: 10px;
      background: #fef3c7;
      color: #92400e;
      padding: 2px 8px;
      border-radius: 999px;
      margin-left: 8px;
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .sub-card__sub {
      font-size: 12px;
      color: var(--text-soft);
    }

    .sub-card__summary {
      margin: 0 0 10px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text);
      line-height: 1.5;
    }
    .sub-card__content {
      margin: 8px 0;
      padding: 12px 14px;
      background: #fafbfc;
      border: 1px solid #f1f3f6;
      border-radius: 8px;
      font-size: 13px;
      line-height: 1.55;
      white-space: pre-wrap;
    }
    .sub-card__details summary {
      cursor: pointer;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-muted);
      padding: 4px 0;
    }
    .sub-card__transcript {
      margin-top: 8px;
      padding: 12px 14px;
      background: #f1f5f9;
      border-radius: 8px;
      font-size: 13px;
      line-height: 1.55;
      white-space: pre-wrap;
    }
    .sub-card__ai-summary {
      margin: 8px 0;
      padding: 12px 14px;
      background: #ecfdf5;
      border-left: 3px solid var(--success);
      border-radius: 4px;
      font-size: 13px;
      line-height: 1.55;
    }
    .sub-card__ai-summary strong {
      font-size: 11px;
      letter-spacing: 0.05em;
      color: var(--success);
      display: block;
      margin-bottom: 4px;
    }

    .sub-card__actions {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-top: 14px;
      font-size: 12px;
      flex-wrap: wrap;
    }
    .sub-card__attachment {
      color: var(--primary);
      font-weight: 600;
      font-size: 12px;
    }
    .sub-card__attachment:hover { text-decoration: underline; }
    .sub-card__attachment--broken {
      color: var(--text-soft);
      font-weight: 500;
    }
    .sub-card__spacer { flex: 1; }
  </style>

  <script is:inline>
    document.querySelectorAll('.toggle-processed').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const wasProcessed = btn.dataset.processed === 'true';
        btn.disabled = true;
        try {
          const r = await fetch(`/internal/api/submissions/${id}/processed`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ processed: !wasProcessed }),
          });
          if (!r.ok) throw new Error(await r.text());
          location.reload();
        } catch (err) {
          alert('Failed: ' + err.message);
          btn.disabled = false;
        }
      });
    });

    function buildMarkdown(p) {
      const lines = [];
      lines.push('---');
      lines.push(`submission_id: ${p.id}`);
      lines.push(`type: ${p.type}`);
      lines.push(`submitted_at: ${p.submitted_at}`);
      if (p.submitted_by) lines.push(`submitted_by: ${p.submitted_by}`);
      lines.push(`student: ${p.student_name}`);
      if (p.student_id) lines.push(`student_id: ${p.student_id}`);
      if (p.mid_advisor) lines.push(`mid_advisor: ${p.mid_advisor}`);
      if (p.stage) lines.push(`stage: ${p.stage}`);
      lines.push('---');
      lines.push('');
      lines.push(`# ${p.type} · ${p.student_name} · ${p.submitted_at?.slice(0, 10) ?? ''}`);
      lines.push('');
      if (p.summary) {
        lines.push('## 摘要');
        lines.push(p.summary);
        lines.push('');
      }
      if (p.content) {
        lines.push('## 详细内容');
        lines.push(p.content);
        lines.push('');
      }
      if (p.ai_transcript) {
        lines.push('## AI 转写');
        lines.push(p.ai_transcript);
        lines.push('');
      }
      if (p.ai_summary) {
        lines.push('## AI 摘要');
        lines.push(p.ai_summary);
        lines.push('');
      }
      if (p.attachment_url || p.audio_url) {
        lines.push('## 附件');
        if (p.attachment_url) {
          const name = p.attachment_url.split('/').pop();
          lines.push(p.attachment_signed
            ? `- [${name}](${p.attachment_signed}) (signed URL，1 小时内有效)`
            : `- ${name} (Supabase Storage path: ${p.attachment_url})`);
        }
        if (p.audio_url) {
          const name = p.audio_url.split('/').pop();
          lines.push(p.audio_signed
            ? `- 🎙 [${name}](${p.audio_signed}) (signed URL，1 小时内有效)`
            : `- 🎙 ${name} (Supabase Storage path: ${p.audio_url})`);
        }
        lines.push('');
      }
      return lines.join('\n');
    }

    document.querySelectorAll('.copy-md').forEach(btn => {
      btn.addEventListener('click', async () => {
        try {
          const payload = JSON.parse(btn.dataset.payload);
          const md = buildMarkdown(payload);
          await navigator.clipboard.writeText(md);
          const old = btn.textContent;
          btn.textContent = '✓ 已复制';
          setTimeout(() => { btn.textContent = old; }, 1500);
        } catch (err) {
          alert('复制失败：' + err.message);
        }
      });
    });
  </script>
</InternalLayout>
