---
// src/pages/internal/students/[id].astro — student detail page
// Renders: YAML metadata panel, main note body, communication notes (newest first),
// attachments list. Wikilinks `[[xxx]]` are resolved against the student-scope index.
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { buildWikilinkIndex, resolveWikilinks, noteAnchor } from '../../../utils/wikilinks';
import { preprocessCallouts } from '../../../utils/callouts';
import { findSOPsForStudent, substitute } from '../../../data/contract-sops';
import { marked } from 'marked';

const { id } = Astro.params;
const studentId = Number(id);
const viewer = Astro.locals?.viewer ?? null;

if (!Number.isFinite(studentId)) {
  return Astro.redirect('/internal/students');
}

const { data: student, error: studentErr } = await supabase
  .from('students')
  .select('*')
  .eq('id', studentId)
  .single();

if (studentErr || !student) {
  return new Response(`Student ${studentId} not found`, { status: 404 });
}

// Fetch this student's communication notes
const { data: notes } = await supabase
  .from('student_notes')
  .select('id, note_name, body_md, note_date, obsidian_path')
  .eq('student_id', studentId)
  .order('note_date', { ascending: false, nullsFirst: false });

// Fetch all students + all notes for the wikilink index
// Scoped to student notes only per current product decision.
const { data: allStudents } = await supabase.from('students').select('id, name, attachments');
const { data: allNotes } = await supabase.from('student_notes').select('student_id, note_name');

const wikiIndex = buildWikilinkIndex({
  students: allStudents ?? [],
  notes: allNotes ?? [],
});

marked.setOptions({ gfm: true, breaks: true });

function renderMarkdown(md: string | null | undefined): string {
  if (!md || !md.trim()) return '';
  const withWikilinks = resolveWikilinks(md, wikiIndex);
  const withCallouts = preprocessCallouts(withWikilinks);
  return marked.parse(withCallouts) as string;
}

const mainHtml = renderMarkdown(student.body_md);
const renderedNotes = (notes ?? []).map(n => ({
  ...n,
  html: renderMarkdown(n.body_md),
  anchor: noteAnchor(n.note_name),
}));

// Match contracts to SOP definitions and pre-substitute placeholders so the
// emails appear with the student's name + advisor already filled in.
const matchedSOPs = findSOPsForStudent(student.contracts).map(m => ({
  contractName: m.contractName,
  sop: m.sop,
  deliverables: m.sop.deliverables.map(d => ({
    key: d.key,
    title: d.title,
    repeats: d.repeats ?? 1,
    emailSubject: substitute(d.emailSubject, { studentName: student.name, midAdvisor: student.mid_advisor }),
    emailBody: substitute(d.emailBody, { studentName: student.name, midAdvisor: student.mid_advisor }),
  })),
}));

// Days since last contact (for the badge)
const today = new Date();
let daysSince: number | null = null;
if (student.last_contact_at) {
  daysSince = Math.floor((today.getTime() - new Date(student.last_contact_at).getTime()) / (24 * 60 * 60 * 1000));
}

// Build the metadata panel rows. Prefer the multi-select arrays; fall back to
// singular columns (for any legacy row that hasn't been re-synced yet).
function joinOrSingular(arr: string[] | null | undefined, single: string | null | undefined): string | null | undefined {
  if (Array.isArray(arr) && arr.length) return arr.join(' / ');
  return single;
}

type Row = { label: string; value: string | null | undefined; mono?: boolean };
const metaRows: Row[] = [
  { label: '当前进度', value: student.stage },
  { label: '入学年份', value: joinOrSingular(student.enroll_years, student.enroll_year) },
  { label: '合同', value: (student.contracts?.length ? student.contracts.join(' / ') : student.contract_type) },
  { label: '意向方向', value: student.major_intention },
  { label: '在读专业', value: student.major_current },
  { label: '目前就读学校', value: student.current_school },
  { label: '目标地区', value: joinOrSingular(student.target_regions, null) },
  { label: '前期顾问', value: joinOrSingular(student.early_advisors, student.early_advisor) },
  { label: '中期顾问', value: joinOrSingular(student.mid_advisors, student.mid_advisor) },
  { label: '后期顾问', value: joinOrSingular(student.late_advisors, null) },
  { label: '客户邮箱', value: student.client_email, mono: true },
  { label: '最后沟通', value: student.last_contact_at, mono: true },
];
---

<InternalLayout title={student.name} active="students">
  <a href="/internal/students" class="back-link">← Students</a>

  <div class="sd-header">
    <h1 class="font-headline sd-title">{student.name}</h1>
    {daysSince !== null && (
      <span class={`font-mono sd-days ${daysSince >= 14 ? 'sd-days--red' : daysSince >= 12 ? 'sd-days--yellow' : 'sd-days--green'}`}>
        {daysSince}d 未联系
      </span>
    )}
  </div>
  <p class="sd-path font-mono">{student.obsidian_path}</p>

  <div class="sd-grid">
    <aside class="sd-meta">
      <div class="meta-eyebrow">Frontmatter</div>
      <dl class="meta-list">
        {metaRows.map(r => (
          <div class="meta-row">
            <dt class="meta-row__label">{r.label}</dt>
            <dd class={`meta-row__value ${r.mono ? 'font-mono' : ''} ${r.value ? '' : 'meta-row__value--empty'}`}>
              {r.value || '—'}
            </dd>
          </div>
        ))}
      </dl>

      {student.attachments && student.attachments.length > 0 && (
        <>
          <div class="meta-divider"></div>
          <div class="meta-eyebrow">个性化材料 ({student.attachments.length})</div>
          <ul class="meta-attachments">
            {student.attachments.map((f: string) => (
              <li>📎 {f}</li>
            ))}
          </ul>
          <p class="meta-attachments__note">目前仅显示文件名。</p>
        </>
      )}
    </aside>

    <div>
      {/* Quick add submission */}
      <section class="sd-quickadd">
        <details id="quick-add-details">
          <summary class="sd-quickadd__summary">
            <span class="sd-quickadd__plus">+</span>
            新增沟通记录 / Comment / 状态更新
          </summary>
          <form id="quick-add-form" class="sd-quickadd__form">
            <input type="hidden" name="student_id" value={String(student.id)} />

            <label class="field field--compact">
              <span class="field__label">类型</span>
              <select name="type" required>
                <option value="沟通记录">沟通记录</option>
                <option value="重要comment">重要 comment</option>
                <option value="状态更新">状态更新</option>
                <option value="会议">会议</option>
                <option value="其他">其他</option>
              </select>
            </label>

            <label class="field field--compact">
              <span class="field__label">你是谁</span>
              <input type="text" name="submitted_by" required value={viewer?.name ?? ''} placeholder="自己的名字" />
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">一句话摘要</span>
              <input type="text" name="summary" placeholder="一句话讲清楚" />
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">详细内容</span>
              <textarea name="content" rows="4" placeholder="沟通要点、comment 正文、状态变化原因等"></textarea>
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">附件（可选）</span>
              <input type="file" name="attachment" class="field__file" />
            </label>

            <div class="field--full sd-quickadd__actions">
              <button type="submit" id="quick-add-btn" class="btn-primary">提交</button>
              <span id="quick-add-status" class="sd-quickadd__status"></span>
            </div>
          </form>
        </details>
      </section>

      <script is:inline>
        (function () {
          const form = document.getElementById('quick-add-form');
          const btn = document.getElementById('quick-add-btn');
          const statusEl = document.getElementById('quick-add-status');
          const details = document.getElementById('quick-add-details');
          if (!form) return;
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            statusEl.textContent = '提交中…';
            statusEl.style.color = '';
            try {
              const r = await fetch('/internal/api/submissions', { method: 'POST', body: new FormData(form) });
              const json = await r.json();
              if (!r.ok) throw new Error(json.error || 'submit failed');
              statusEl.textContent = '✓ 已提交 #' + json.id + '，刷新页面看 inbox';
              statusEl.style.color = '#059669';
              form.reset();
              setTimeout(() => { details.open = false; statusEl.textContent = ''; }, 2500);
            } catch (err) {
              statusEl.textContent = '✗ ' + err.message;
              statusEl.style.color = '#dc2626';
            } finally {
              btn.disabled = false;
            }
          });
        })();
      </script>

      {matchedSOPs.length > 0 && (
        <section class="sd-sops">
          <div class="meta-eyebrow" style="margin-bottom: 14px;">合同 SOP</div>
          {matchedSOPs.map(m => (
            <details class="sop-group">
              <summary class="sop-group__summary">
                <span class="sop-group__title">
                  <span class="sop-chevron">▸</span>
                  <h3 class="font-headline sop-group__name">{m.sop.displayName}</h3>
                </span>
                <span class="sop-group__meta">
                  {m.deliverables.reduce((s, d) => s + (d.repeats ?? 1), 0)} 项 · 「{m.contractName}」
                </span>
              </summary>
              <ol class="sop-list">
                {m.deliverables.map(d => {
                  const subjectId = `subj-${m.sop.id}-${d.key}`;
                  const bodyId = `body-${m.sop.id}-${d.key}`;
                  return (
                    <li class="sop-item">
                      <details class="sop-deliv">
                        <summary class="sop-deliv__summary">
                          <span class="font-mono sop-deliv__num">
                            {String([...m.deliverables].indexOf(d) + 1).padStart(2, '0')}
                          </span>
                          <span class="sop-deliv__label">
                            {d.title}
                            {d.repeats > 1 && (
                              <span class="font-mono sop-deliv__count">×{d.repeats}</span>
                            )}
                          </span>
                          <span class="sop-deliv__cta">查看邮件 →</span>
                        </summary>
                        <div class="sop-deliv__body">
                          <div>
                            <div class="sop-deliv__field-head">
                              <span class="sop-deliv__field-label">主题</span>
                              <button type="button" class="sop-copy sop-deliv__copy" data-target={subjectId}>复制</button>
                            </div>
                            <pre id={subjectId} class="sop-deliv__pre">{d.emailSubject}</pre>
                          </div>
                          <div>
                            <div class="sop-deliv__field-head">
                              <span class="sop-deliv__field-label">正文</span>
                              <button type="button" class="sop-copy sop-deliv__copy" data-target={bodyId}>复制</button>
                            </div>
                            <pre id={bodyId} class="sop-deliv__pre">{d.emailBody}</pre>
                          </div>
                        </div>
                      </details>
                    </li>
                  );
                })}
              </ol>
            </details>
          ))}
          <p class="sd-sops__footnote">
            邮件模板在 <code>src/data/contract-sops.ts</code>。改完 push 一下就生效。占位符 <code>{'{{学生姓名}}'}</code> 和 <code>{'{{中期顾问}}'}</code> 已自动替换。
          </p>
        </section>
      )}

      <style>
        /* SOP chevron: details/summary/span structure unchanged from before — chevron rotates when open. */
        details[open] > summary .sop-chevron { transform: rotate(90deg); }
      </style>

      <script is:inline>
        document.addEventListener('click', async (e) => {
          const btn = e.target.closest && e.target.closest('.sop-copy');
          if (!btn) return;
          const target = document.getElementById(btn.dataset.target);
          if (!target) return;
          try {
            await navigator.clipboard.writeText(target.textContent);
            const old = btn.textContent;
            btn.textContent = '✓ 已复制';
            setTimeout(() => { btn.textContent = old; }, 1500);
          } catch (err) {
            btn.textContent = '✗ 失败';
          }
        });
      </script>

      <section class="sd-main">
        <div class="meta-eyebrow" style="margin-bottom: 12px;">主档案</div>
        {mainHtml ? (
          <div class="md-body" set:html={mainHtml} />
        ) : (
          <p class="section-card__empty">主档案 body 为空。</p>
        )}
      </section>

      {renderedNotes.length > 0 && (
        <section>
          <div class="meta-eyebrow" style="margin-bottom: 12px;">沟通记录 ({renderedNotes.length})</div>
          {renderedNotes.map(n => (
            <article id={n.anchor} class="sd-note">
              <header class="sd-note__header">
                <h3 class="font-headline sd-note__title">{n.note_name}</h3>
                {n.note_date && <span class="font-mono sd-note__date">{n.note_date}</span>}
              </header>
              <div class="md-body" set:html={n.html} />
            </article>
          ))}
        </section>
      )}

      {renderedNotes.length === 0 && (
        <section class="sd-empty-notes">还没有沟通记录。</section>
      )}
    </div>
  </div>
</InternalLayout>

<style>
  /* Student detail page — header, meta panel, quick-add, SOPs, notes. */

  .sd-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .sd-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .sd-days {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 999px;
    font-weight: 700;
  }
  .sd-days--green { background: #d1fae5; color: #065f46; }
  .sd-days--yellow { background: #fef3c7; color: #92400e; }
  .sd-days--red { background: #fee2e2; color: #991b1b; }
  .sd-path {
    color: var(--text-soft);
    font-size: 12px;
    margin: 0 0 24px;
  }

  .sd-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Meta panel (left aside) */
  .sd-meta {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 20px 20px 12px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .meta-eyebrow {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .meta-list {
    margin: 12px 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .meta-row__label {
    font-size: 11px;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .meta-row__value {
    margin: 0;
    font-size: 13px;
    color: var(--text);
  }
  .meta-row__value.font-mono { font-size: 12px; }
  .meta-row__value--empty { color: var(--text-soft); }
  .meta-divider {
    border-top: 1px solid #eef0f3;
    margin: 16px -20px 12px;
  }
  .meta-attachments {
    margin: 8px 0 12px;
    padding: 0;
    list-style: none;
  }
  .meta-attachments li {
    font-size: 12px;
    color: var(--text-muted);
    padding: 4px 0;
    word-break: break-all;
  }
  .meta-attachments__note {
    font-size: 10px;
    color: var(--text-soft);
    margin: 0 0 12px;
    line-height: 1.5;
  }

  /* Quick-add submission card */
  .sd-quickadd {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 18px 22px;
    margin-bottom: 16px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .sd-quickadd__summary {
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    color: var(--primary);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sd-quickadd__summary::-webkit-details-marker { display: none; }
  .sd-quickadd__plus {
    display: inline-block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    color: white;
    font-size: 14px;
    line-height: 18px;
    text-align: center;
    font-weight: 700;
  }
  .sd-quickadd__form {
    margin-top: 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .sd-quickadd__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-top: 4px;
  }
  .sd-quickadd__status {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* SOPs section */
  .sd-sops {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 20px 24px;
    margin-bottom: 24px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .sd-sops__footnote {
    font-size: 11px;
    color: var(--text-soft);
    margin: 14px 0 0;
    line-height: 1.5;
  }
  .sd-sops__footnote code {
    font-size: 11px;
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
  }

  .sop-group {
    margin-bottom: 10px;
    border: 1px solid #eef0f3;
    border-radius: 10px;
  }
  .sop-group__summary {
    cursor: pointer;
    padding: 12px 14px;
    list-style: none;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .sop-group__summary::-webkit-details-marker { display: none; }
  .sop-group__title {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .sop-chevron {
    display: inline-block;
    transition: transform 120ms ease;
    color: var(--text-soft);
    font-size: 11px;
  }
  .sop-group__name {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .sop-group__meta {
    font-size: 11px;
    color: var(--text-soft);
    white-space: nowrap;
  }

  .sop-list {
    list-style: none;
    margin: 0;
    padding: 8px 14px 14px;
    border-top: 1px solid #eef0f3;
    background: #fafbfc;
  }
  .sop-item { padding: 4px 0; }
  .sop-deliv {
    border: 1px solid #eef0f3;
    border-radius: 8px;
    overflow: hidden;
    background: white;
  }
  .sop-deliv__summary {
    cursor: pointer;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    list-style: none;
  }
  .sop-deliv__summary::-webkit-details-marker { display: none; }
  .sop-deliv__num {
    display: inline-block;
    min-width: 22px;
    font-size: 11px;
    color: var(--text-soft);
    font-weight: 700;
  }
  .sop-deliv__label { flex: 1; }
  .sop-deliv__count {
    display: inline-block;
    margin-left: 8px;
    padding: 1px 8px;
    background: var(--primary);
    color: white;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
  }
  .sop-deliv__cta {
    font-size: 11px;
    color: var(--primary);
    font-weight: 600;
    white-space: nowrap;
  }
  .sop-deliv__body {
    padding: 14px;
    background: #fafbfc;
    border-top: 1px solid #eef0f3;
    display: grid;
    gap: 12px;
  }
  .sop-deliv__field-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .sop-deliv__field-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .sop-deliv__copy {
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid #eef0f3;
    background: white;
    border-radius: 5px;
    cursor: pointer;
    font-weight: 600;
    color: var(--primary);
    transition: border-color 120ms ease;
  }
  .sop-deliv__copy:hover { border-color: var(--primary); }
  .sop-deliv__pre {
    margin: 0;
    padding: 10px 12px;
    background: white;
    border: 1px solid #eef0f3;
    border-radius: 6px;
    font-family: inherit;
    font-size: 13px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Main archive + notes */
  .sd-main {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 26px 30px;
    margin-bottom: 24px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .sd-note {
    background: var(--surface-raised);
    border: 1px solid #eef0f3;
    border-radius: 14px;
    padding: 22px 26px;
    margin-bottom: 16px;
    scroll-margin-top: 80px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
  }
  .sd-note__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid #eef0f3;
  }
  .sd-note__title {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .sd-note__date {
    font-size: 11px;
    color: var(--text-soft);
    white-space: nowrap;
  }
  .sd-empty-notes {
    background: var(--surface-raised);
    border: 1px dashed #d4d8de;
    border-radius: 14px;
    padding: 28px;
    text-align: center;
    color: var(--text-soft);
    font-size: 13px;
  }
</style>

<style is:global>
  /* Markdown body styling — scoped via .md-body to keep it inside the article cards */
  .md-body { font-size: 14px; line-height: 1.65; color: var(--text); }
  .md-body p { margin: 0 0 12px; }
  .md-body h1, .md-body h2, .md-body h3, .md-body h4 {
