---
// src/pages/internal/students/[id].astro — student detail page
// Renders: YAML metadata panel, main note body, communication notes (newest first),
// attachments list. Wikilinks `[[xxx]]` are resolved against the student-scope index.
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { isVIP, canSeeVIP } from '../../../utils/vip';
import { resolveWikilinks, noteAnchor } from '../../../utils/wikilinks';
import { getWikilinkIndex } from '../../../lib/wikilink-index';
import { daysSinceToday, tierFor, tierStyle } from '../../../utils/contact-radar';
import { preprocessCallouts } from '../../../utils/callouts';
import { sanitizeHtml } from '../../../lib/sanitize';
import { findSOPsForStudent, substitute } from '../../../data/contract-sops';
import { STUDENT_TOOLS } from '../../../data/student-tools';
import { englishArticleMeta } from '../../../data/english/_meta.generated';
import { marked } from 'marked';

const { id } = Astro.params;
const studentId = Number(id);
const viewer = Astro.locals?.viewer ?? null;

if (!Number.isFinite(studentId)) {
  return Astro.redirect('/internal/students');
}

const { data: student, error: studentErr } = await supabase
  .from('students')
  .select('*')
  .eq('id', studentId)
  .single();

if (studentErr || !student) {
  return new Response(`Student ${studentId} not found`, { status: 404 });
}

// VIP students are visible only to admin / 王世杰. Return 404 (not 403) so a
// non-privileged viewer can't use the response to confirm the student exists.
if (isVIP(student.contracts) && !canSeeVIP(viewer)) {
  return new Response(`Student ${studentId} not found`, { status: 404 });
}

// Fetch this student's communication notes
const { data: notes } = await supabase
  .from('student_notes')
  .select('id, note_name, body_md, note_date, obsidian_path')
  .eq('student_id', studentId)
  .order('note_date', { ascending: false, nullsFirst: false });

// Wikilink [[link]] resolution index (all students + notes), cached per instance.
const wikiIndex = await getWikilinkIndex();

marked.setOptions({ gfm: true, breaks: true });

function renderMarkdown(md: string | null | undefined): string {
  if (!md || !md.trim()) return '';
  const withWikilinks = resolveWikilinks(md, wikiIndex, canSeeVIP(viewer));
  const withCallouts = preprocessCallouts(withWikilinks);
  return sanitizeHtml(marked.parse(withCallouts) as string);
}

const mainHtml = renderMarkdown(student.body_md);
const renderedNotes = (notes ?? []).map(n => ({
  ...n,
  html: renderMarkdown(n.body_md),
  anchor: noteAnchor(n.note_name),
}));

// Match contracts to SOP definitions and pre-substitute placeholders so the
// emails appear with the student's name + advisor + 合同编号 already filled in.
// m.contractName here is the short label from student.contracts (e.g. 格物-半年);
// contract_details[].大类 uses the same short label, so we match on that to pull
// the ERP 合同编号 (e.g. JSSZYZ202501028) for the 结案邮件 placeholder.
const contractDetailsArr = (student.contract_details ?? []) as Array<{ 大类?: string; 名称?: string; 合同编号?: string }>;
// Co-advised students: render BOTH mid-advisors (e.g. "张三 / 李四") into the
// deliverable emails / 话术, not just the first. joinOrSingular is hoisted below.
const midAdvisorName = joinOrSingular(student.mid_advisors, student.mid_advisor) ?? null;
const matchedSOPs = findSOPsForStudent(student.contracts, student.yueling_tier, contractDetailsArr).map(m => {
  const contractNumber = contractDetailsArr.find(cd => cd.大类 === m.contractName)?.合同编号 ?? null;
  return {
    contractName: m.contractName,
    contractNumber,
    sop: m.sop,
    deliverables: m.sop.deliverables.map(d => ({
      key: d.key,
      title: d.title,
      repeats: d.repeats ?? 1,
      emailSubject: substitute(d.emailSubject, { studentName: student.name, midAdvisor: midAdvisorName, contractNumber }),
      emailBody: substitute(d.emailBody, { studentName: student.name, midAdvisor: midAdvisorName, contractNumber }),
    })),
  };
});

// ── 英文阅读推荐工具：动态素材 ──
// 217 篇 article 的瘦身 meta (slug/title/cefr/words/minutes/titleZh) 序列化进
// 页面 JSON，给"换一篇"按钮 client-side 再抽用。SSR 先抽一篇当初始展示。
// Slim meta only (no article bodies) — see scripts/gen-english-meta.mjs.
const articleMeta = englishArticleMeta;
const initialArticle = articleMeta.length
  ? articleMeta[Math.floor(Math.random() * articleMeta.length)]
  : null;

type ArticleMeta = (typeof articleMeta)[number];
// substitute() 的扩展版：在 学生姓名 / 中期顾问 / 合同编号 基础上再吃 article 字段
function substituteWithArticle(
  template: string,
  vars: { studentName: string; midAdvisor: string | null; article?: ArticleMeta | null },
): string {
  let s = substitute(template, { studentName: vars.studentName, midAdvisor: vars.midAdvisor });
  if (vars.article) {
    const a = vars.article;
    s = s
      .replaceAll('{{articleTitle}}',   a.title)
      .replaceAll('{{articleTitleZh}}', a.titleZh)
      .replaceAll('{{articleCefr}}',    a.cefr)
      .replaceAll('{{articleWords}}',   String(a.words))
      .replaceAll('{{articleMinutes}}', String(a.minutes))
      .replaceAll('{{articleSlug}}',    a.slug);
  }
  return s;
}

// Days since last contact — same tiering as the roster / kanban (contact-radar).
const daysSince = daysSinceToday(student.last_contact_at);
const daysTierStyle = tierStyle(tierFor(daysSince, student.stage));

// Build the metadata panel rows. Prefer the multi-select arrays; fall back to
// singular columns (for any legacy row that hasn't been re-synced yet).
function joinOrSingular(arr: string[] | null | undefined, single: string | null | undefined): string | null | undefined {
  if (Array.isArray(arr) && arr.length) return arr.join(' / ');
  return single;
}

type Row = { label: string; value: string | null | undefined; mono?: boolean };
const metaRows: Row[] = [
  { label: '当前进度', value: student.stage },
  { label: '入学年份', value: joinOrSingular(student.enroll_years, student.enroll_year) },
  { label: '合同', value: (student.contracts?.length ? student.contracts.join(' / ') : student.contract_type) },
  { label: '意向方向', value: student.major_intention },
  { label: '在读专业', value: student.major_current },
  { label: '目前就读学校', value: student.current_school },
  { label: '目标地区', value: joinOrSingular(student.target_regions, null) },
  { label: '前期顾问', value: joinOrSingular(student.early_advisors, student.early_advisor) },
  { label: '中期顾问', value: joinOrSingular(student.mid_advisors, student.mid_advisor) },
  { label: '后期顾问', value: joinOrSingular(student.late_advisors, null) },
  { label: '客户邮箱', value: student.client_email, mono: true },
  { label: '最后沟通', value: student.last_contact_at, mono: true },
];
---

<InternalLayout title={student.name} active="students">
  <link rel="stylesheet" href="/styles/tufte-notes.css" />
  <a href="/internal/students" class="back-link">← Students</a>

  <div class="sd-header">
    <h1 class="font-headline sd-title">{student.name}</h1>
    {daysSince !== null && (
      <span class="font-mono sd-days" style={`background:${daysTierStyle.bg};color:${daysTierStyle.fg}`}>
        {daysSince}d 未联系
      </span>
    )}
  </div>
  <p class="sd-path font-mono">{student.obsidian_path}</p>

  <div class="sd-grid">
    <aside class="sd-meta">
      <div class="meta-eyebrow">Frontmatter</div>
      <dl class="meta-list">
        {metaRows.map(r => (
          <div class="meta-row">
            <dt class="meta-row__label">{r.label}</dt>
            <dd class={`meta-row__value ${r.mono ? 'font-mono' : ''} ${r.value ? '' : 'meta-row__value--empty'}`}>
              {r.value || '—'}
            </dd>
          </div>
        ))}
      </dl>

      {student.attachments && student.attachments.length > 0 && (
        <>
          <div class="meta-divider"></div>
          <div class="meta-eyebrow">个性化材料 ({student.attachments.length})</div>
          <ul class="meta-attachments">
            {student.attachments.map((f: string) => (
              <li>📎 {f}</li>
            ))}
          </ul>
          <p class="meta-attachments__note">目前仅显示文件名。</p>
        </>
      )}

      {Array.isArray(student.contract_details) && student.contract_details.length > 0 && (() => {
        type CD = {
          名称?: string; 大类?: string; 签约日期?: string;
          签约金额?: number; 合同状态?: string; 合同编号?: string;
        };
        const cds = student.contract_details as CD[];
        const totalSigning = cds.reduce((s, c) => s + (Number(c.签约金额) || 0), 0);
        const fmt = (n: number) => '¥' + Math.round(n).toLocaleString('en-US');
        const sortedCds = [...cds].sort((a, b) => (a.签约日期 ?? '').localeCompare(b.签约日期 ?? ''));
        return (
          <>
            <div class="meta-divider"></div>
            <div class="meta-eyebrow">
              合同明细 ({cds.length}{student.yueling_tier ? ` · 跃领分级 ${student.yueling_tier}` : ''})
            </div>
            <div class="contract-summary">
              <div><span class="contract-summary__label">总签约</span><span class="font-mono">{fmt(totalSigning)}</span></div>
            </div>
            <ul class="contract-detail-list">
              {sortedCds.map((c) => (
                <li>
                  <details class="contract-detail">
                    <summary class="contract-detail__summary">
                      <span class="contract-detail__chevron">▸</span>
                      <span class="contract-detail__name" title={c.名称}>{c.名称}</span>
                      <span class="contract-detail__amount font-mono">{fmt(Number(c.签约金额) || 0)}</span>
                    </summary>
                    <dl class="contract-detail__fields">
                      <dt>大类</dt><dd>{c.大类 ?? '—'}</dd>
                      <dt>签约日期</dt><dd class="font-mono">{c.签约日期 ?? '—'}</dd>
                      <dt>签约金额</dt><dd class="font-mono">{fmt(Number(c.签约金额) || 0)}</dd>
                      <dt>合同状态</dt><dd>{c.合同状态 ?? '—'}</dd>
                      <dt>合同编号</dt><dd class="font-mono contract-detail__cid">{c.合同编号 ?? '—'}</dd>
                    </dl>
                  </details>
                </li>
              ))}
            </ul>
            <p class="meta-attachments__note">来源：ERP 客户签约明细。</p>
          </>
        );
      })()}

      {STUDENT_TOOLS.length > 0 && (
        <>
          <div class="meta-divider"></div>
          <div class="meta-eyebrow">推荐工具 ({STUDENT_TOOLS.length})</div>
          <ul class="tool-list">
            {STUDENT_TOOLS.map(t => {
              const bodyId = `tool-body-${t.id}`;
              const article = t.dynamic === 'english-article' ? initialArticle : null;
              const renderedBody = substituteWithArticle(t.scriptBody, {
                studentName: student.name,
                midAdvisor: midAdvisorName,
                article,
              });
              return (
                <li>
                  <details
                    class="tool-item"
                    data-dynamic={t.dynamic ?? null}
                    data-student-name={t.dynamic ? student.name : null}
                    data-advisor-name={t.dynamic ? (midAdvisorName ?? '顾问') : null}
                  >
                    <summary class="tool-item__summary">
                      <span class="tool-item__chevron">▸</span>
                      <span class="tool-item__title">{t.title}</span>
                    </summary>
                    <div class="tool-item__body">
                      {t.description && (
                        <p class="tool-item__desc">{t.description}</p>
                      )}
                      <div class="tool-item__copy-row">
                        <span class="tool-item__copy-label">话术</span>
                        <span class="tool-item__copy-actions">
                          {t.dynamic === 'english-article' && (
                            <button type="button" class="tool-item__copy tool-item__reroll" data-target={bodyId} data-action="reroll-english">
                              <span class="material-symbols-outlined">refresh</span>
                              换一篇
                            </button>
                          )}
                          <button type="button" class="sop-copy tool-item__copy" data-target={bodyId}>复制</button>
                        </span>
                      </div>
                      {t.dynamic && (
                        <span hidden data-tool-template>{t.scriptBody}</span>
                      )}
                      <pre id={bodyId} class="tool-item__pre">{renderedBody}</pre>
                    </div>
                  </details>
                </li>
              );
            })}
          </ul>
          <script is:inline type="application/json" id="english-articles-data" set:html={JSON.stringify(articleMeta)} />
          <script is:inline>
            // 「换一篇」 — client-side 再抽一篇英文文章 + 重新 substitute 模板
            (function () {
              document.addEventListener('click', (e) => {
                const btn = e.target.closest && e.target.closest('[data-action="reroll-english"]');
                if (!btn) return;
                const details = btn.closest('[data-dynamic="english-article"]');
                if (!details) return;
                const pre = document.getElementById(btn.dataset.target);
                const tpl = details.querySelector('[data-tool-template]');
                const data = document.getElementById('english-articles-data');
                if (!pre || !tpl || !data) return;
                let list;
                try { list = JSON.parse(data.textContent || '[]'); }
                catch { return; }
                if (!Array.isArray(list) || list.length === 0) return;
                const a = list[Math.floor(Math.random() * list.length)];
                const studentName = details.dataset.studentName || '';
                const advisor     = details.dataset.advisorName || '顾问';
                pre.textContent = (tpl.textContent || '')
                  .replaceAll('{{学生姓名}}',      studentName)
                  .replaceAll('{{中期顾问}}',      advisor)
                  .replaceAll('{{articleTitle}}',   a.title)
                  .replaceAll('{{articleTitleZh}}', a.titleZh)
                  .replaceAll('{{articleCefr}}',    a.cefr)
                  .replaceAll('{{articleWords}}',   String(a.words))
                  .replaceAll('{{articleMinutes}}', String(a.minutes))
                  .replaceAll('{{articleSlug}}',    a.slug);
              });
            })();
          </script>
        </>
      )}
    </aside>

    <div>
      {/* Quick add submission */}
      <section class="sd-quickadd">
        <details id="quick-add-details">
          <summary class="sd-quickadd__summary">
            <span class="sd-quickadd__plus">+</span>
            新增沟通记录 / Comment / 状态更新
          </summary>
          <form id="quick-add-form" class="sd-quickadd__form">
            <input type="hidden" name="student_id" value={String(student.id)} />

            <label class="field field--compact">
              <span class="field__label">类型</span>
              <select name="type" required>
                <option value="沟通记录">沟通记录</option>
                <option value="重要comment">重要 comment</option>
                <option value="状态更新">状态更新</option>
                <option value="会议">会议</option>
                <option value="其他">其他</option>
              </select>
            </label>

            <label class="field field--compact">
              <span class="field__label">你是谁</span>
              <input type="text" name="submitted_by" required value={viewer?.name ?? ''} placeholder="自己的名字" />
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">一句话摘要</span>
              <input type="text" name="summary" placeholder="一句话讲清楚" />
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">详细内容</span>
              <textarea name="content" rows="4" placeholder="沟通要点、comment 正文、状态变化原因等"></textarea>
            </label>

            <label class="field field--compact field--full">
              <span class="field__label">附件（可选）</span>
              <input type="file" name="attachment" class="field__file" />
            </label>

            <div class="field--full sd-quickadd__actions">
              <button type="submit" id="quick-add-btn" class="btn-primary">提交</button>
              <span id="quick-add-status" class="sd-quickadd__status"></span>
            </div>
          </form>
        </details>
      </section>

      <script is:inline>
        (function () {
          const form = document.getElementById('quick-add-form');
          const btn = document.getElementById('quick-add-btn');
          const statusEl = document.getElementById('quick-add-status');
          const details = document.getElementById('quick-add-details');
          if (!form) return;
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            statusEl.textContent = '提交中…';
            statusEl.style.color = '';
            try {
              const r = await fetch('/internal/api/submissions', { method: 'POST', body: new FormData(form) });
              const json = await r.json();
              if (!r.ok) throw new Error(json.error || 'submit failed');
              statusEl.textContent = '✓ 已提交 #' + json.id + '，刷新页面看 inbox';
              statusEl.style.color = '#059669';
              form.reset();
              setTimeout(() => { details.open = false; statusEl.textContent = ''; }, 2500);
            } catch (err) {
              statusEl.textContent = '✗ ' + err.message;
              statusEl.style.color = '#dc2626';
            } finally {
              btn.disabled = false;
            }
          });
        })();
      </script>

      {matchedSOPs.length > 0 && (
        <section class="sd-sops">
          <div class="meta-eyebrow" style="margin-bottom: 14px;">合同 SOP</div>
          {matchedSOPs.map(m => (
            <details class="sop-group">
              <summary class="sop-group__summary">
                <span class="sop-group__title">
                  <span class="sop-chevron">▸</span>
                  <h3 class="font-headline sop-group__name">{m.sop.displayName}</h3>
                </span>
                <span class="sop-group__meta">
                  {m.deliverables.reduce((s, d) => s + (d.repeats ?? 1), 0)} 项 · 「{m.contractName}」
                </span>
              </summary>
              <ol class="sop-list">
                {m.deliverables.map(d => {
                  const subjectId = `subj-${m.sop.id}-${d.key}`;
                  const bodyId = `body-${m.sop.id}-${d.key}`;
                  const mailto = `mailto:${encodeURIComponent(student.client_email ?? '')}?subject=${encodeURIComponent(d.emailSubject)}&body=${encodeURIComponent(d.emailBody)}`;
                  const hasEmail = !!student.client_email;
                  return (
                    <li class="sop-item">
                      <details class="sop-deliv">
                        <summary class="sop-deliv__summary">
                          <span class="font-mono sop-deliv__num">
                            {String([...m.deliverables].indexOf(d) + 1).padStart(2, '0')}
                          </span>
                          <span class="sop-deliv__label">
                            {d.title}
                            {d.repeats > 1 && (
                              <span class="font-mono sop-deliv__count">×{d.repeats}</span>
                            )}
                          </span>
                          <span class="sop-deliv__cta">查看邮件 →</span>
                        </summary>
                        <div class="sop-deliv__body">
                          <div class="sop-deliv__actionbar">
                            <a href={mailto} class="sop-deliv__mail-btn" title={hasEmail ? `发送到 ${student.client_email}` : '学生邮箱未填，请手动填收件人'}>
                              <span class="material-symbols-outlined" style="font-size:18px">mail</span>
                              <span>用邮箱打开</span>
                              {!hasEmail && <span class="sop-deliv__mail-warn">收件人空白</span>}
                            </a>
                            <span class="sop-deliv__mail-hint">
                              {hasEmail ? `→ ${student.client_email}` : '⚠ 学生 客户邮箱 未填'}
                            </span>
                          </div>
                          <div>
                            <div class="sop-deliv__field-head">
                              <span class="sop-deliv__field-label">主题</span>
                              <button type="button" class="sop-copy sop-deliv__copy" data-target={subjectId}>复制</button>
                            </div>
                            <pre id={subjectId} class="sop-deliv__pre">{d.emailSubject}</pre>
                          </div>
                          <div>
                            <div class="sop-deliv__field-head">
                              <span class="sop-deliv__field-label">正文</span>
                              <button type="button" class="sop-copy sop-deliv__copy" data-target={bodyId}>复制</button>
                            </div>
                            <pre id={bodyId} class="sop-deliv__pre">{d.emailBody}</pre>
                          </div>
                        </div>
                      </details>
                    </li>
                  );
                })}
              </ol>
            </details>
          ))}
          <p class="sd-sops__footnote">
            邮件模板在 <code>src/data/contract-sops.ts</code>。改完 push 一下就生效。占位符 <code>{'{{学生姓名}}'}</code> 和 <code>{'{{中期顾问}}'}</code> 已自动替换。
          </p>
        </section>
      )}

      <style>
        /* SOP chevron: details/summary/span structure unchanged from before — chevron rotates when open. */
        details[open] > summary .sop-chevron { transform: rotate(90deg); }
      </style>

      <script is:inline>
        document.addEventListener('click', async (e) => {
          const btn = e.target.closest && e.target.closest('.sop-copy');
          if (!btn) return;
          const target = document.getElementById(btn.dataset.target);
          if (!target) return;
          try {
            await navigator.clipboard.writeText(target.textContent);
            const old = btn.textContent;
            btn.textContent = '✓ 已复制';
            setTimeout(() => { btn.textContent = old; }, 1500);
          } catch (err) {
            btn.textContent = '✗ 失败';
          }
        });
      </script>

      <script is:inline>
        // Tufte 视图 toggle：状态持久化到 localStorage，全局应用到所有 .sd-note .md-body
        (function () {
          const KEY = 'sdg.tufte-notes-mode';
          function apply(on) {
            document.querySelectorAll('.sd-note .md-body').forEach((el) => {
              el.classList.toggle('tufte-body', on);
            });
            const btn = document.getElementById('tufte-toggle');
            if (btn) {
              btn.setAttribute('aria-pressed', on ? 'true' : 'false');
              btn.classList.toggle('is-active', on);
            }
          }
          function init() {
            const saved = localStorage.getItem(KEY) === 'on';
            apply(saved);
            const btn = document.getElementById('tufte-toggle');
            if (!btn) return;
            btn.addEventListener('click', () => {
              const next = btn.getAttribute('aria-pressed') !== 'true';
              localStorage.setItem(KEY, next ? 'on' : 'off');
              apply(next);
            });
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
          } else {
            init();
          }
        })();
      </script>

      <section class="sd-main">
        <div class="meta-eyebrow" style="margin-bottom: 12px;">主档案</div>
        {mainHtml ? (
          <div class="md-body" set:html={mainHtml} />
        ) : (
          <p class="section-card__empty">主档案 body 为空。</p>
        )}
      </section>

      {renderedNotes.length > 0 && (
        <section id="notes-section">
          <div class="notes-section__head">
            <div class="meta-eyebrow">沟通记录 ({renderedNotes.length})</div>
            <button type="button" id="tufte-toggle" class="tufte-toggle" aria-pressed="false" title="切换 Tufte 风格视图（斜体标题 / 淡蓝高亮 / 旁注）">
              <span class="material-symbols-outlined">format_color_text</span>
              <span class="tufte-toggle__label">Tufte 视图</span>
            </button>
          </div>
          {renderedNotes.map(n => (
            <article id={n.anchor} class="sd-note">
              <header class="sd-note__header">
                <h3 class="font-headline sd-note__title">{n.note_name}</h3>
                <div class="sd-note__meta">
                  {n.note_date && <span class="font-mono sd-note__date">{n.note_date}</span>}
                  <a class="sd-note__export"
                     href={`/internal/students/${student.id}/notes/${n.anchor}`}
                     target="_blank" rel="noopener"
                     title="导出 Tufte 风格 PDF（新页打开后 Cmd+P 保存）">
                    <span class="material-symbols-outlined">picture_as_pdf</span>
                    导出
                  </a>
                </div>
              </header>
              <div class="md-body" set:html={n.html} />
            </article>
          ))}
        </section>
      )}

      {renderedNotes.length === 0 && (
        <section class="sd-empty-notes">还没有沟通记录。</section>
      )}
    </div>
  </div>
</InternalLayout>

