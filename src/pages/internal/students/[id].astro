<style is:global>
  /* Markdown body styling — scoped via .md-body to keep it inside the article cards */
  .md-body { font-size: 14px; line-height: 1.65; color: var(--text); }
  .md-body p { margin: 0 0 12px; }
  .md-body h1, .md-body h2, .md-body h3, .md-body h4 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    margin: 20px 0 10px;
    letter-spacing: -0.01em;
  }
  .md-body h1 { font-size: 22px; }
  .md-body h2 { font-size: 18px; }
  .md-body h3 { font-size: 15px; }
  .md-body ul, .md-body ol { padding-left: 22px; margin: 0 0 12px; }
  .md-body li { margin: 4px 0; }
  .md-body code {
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }
  .md-body pre {
    background: #f8fafc;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    overflow-x: auto;
    /* 关键：long 单行（如英文 email 一整段无换行）必须 wrap，
       否则 pre 默认 nowrap，撑出横向滚动条，整页排版乱。
       pre-wrap 保留 \n 和缩进，但允许 word boundary 自动换行。 */
    white-space: pre-wrap;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .md-body pre code { background: transparent; padding: 0; }
  .md-body blockquote {
    margin: 0 0 12px;
    padding: 4px 14px;
    border-left: 3px solid var(--border);
    color: var(--text-muted);
  }
  .md-body blockquote p { margin: 8px 0; }
  .md-body blockquote p:first-child { margin-top: 0; }
  .md-body blockquote p:last-child { margin-bottom: 0; }
  .md-body a { color: var(--primary); text-decoration: underline; text-decoration-color: rgba(0, 0, 0, 0.3); text-underline-offset: 2px; }
  .md-body a:hover { text-decoration-color: var(--primary); }
  .md-body hr { border: 0; border-top: 1px solid var(--border); margin: 16px 0; }
  .md-body table {
    border-collapse: collapse;
    margin: 0 0 12px;
    font-size: 13px;
    /* 宽表（如建议表，单格几百字）必须 width:100% + 单元格 break-word，
       否则 table 默认按内容撑宽，溢出 .sd-note card 横向。 */
    width: 100%;
    max-width: 100%;
    table-layout: auto;
  }
  .md-body th, .md-body td {
    border: 1px solid var(--border);
    padding: 6px 10px;
    text-align: left;
    /* 长单格内容 wrap，不撑表 */
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .md-body th { background: #f8fafc; font-weight: 600; }

