---
// src/pages/internal/index.astro — dashboard overview (publicly visible).
//
// Data model: a STUDENT can map to multiple CASES = (student × mid_advisor × enroll_year).
// Multi-counted in the cohort×advisor matrix, distinct-counted in the headline stat.
//
// 私单 visibility: 王世杰 (admin) sees his 私单 students when authenticated; everyone
// else (anonymous + other advisors) doesn't see them at all.
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';
import {
  tierFor, tierStyle, tierLabel, daysSinceToday,
  inTriage, tierRank, isInactive, type RadarTier,
} from '../../utils/contact-radar';

const url = new URL(Astro.request.url);
const includeInactive = url.searchParams.get('include_inactive') === '1';
const advisorFilter = url.searchParams.get('advisor') || '';
const viewer = Astro.locals?.viewer ?? null;

const PRIVATE_CONTRACTS = new Set(['私单', '私单（非公司合同）']);
function isPrivate(contracts: string[] | null | undefined): boolean {
  if (!contracts) return false;
  return contracts.some(c => PRIVATE_CONTRACTS.has(c));
}

// Only 王世杰 (admin / explicit name match) sees private-contract students,
// and only when they overlap his caseload.
const canSeePrivate = !!viewer && (viewer.isAdmin || viewer.name === '王世杰');

// Parallel fetches
const [
  { count: unprocessed },
  { data: recentSubmissions },
  { data: allActiveStudents },
  { data: recentNotes },
  { data: advisorList },
] = await Promise.all([
  supabase.from('submissions').select('id', { count: 'exact', head: true }).eq('processed', false),
  supabase
    .from('submissions')
    .select('id, type, submitted_at, submitted_by, summary, student_name_raw, students(id, name)')
    .order('submitted_at', { ascending: false })
    .limit(6),
  supabase
    .from('students')
    .select('id, name, mid_advisors, early_advisors, late_advisors, stage, last_contact_at, enroll_years, contracts')
    .order('last_contact_at', { ascending: true, nullsFirst: false }),
  supabase
    .from('student_notes')
    .select('id, student_id, note_name, note_date, students(name)')
    .order('note_date', { ascending: false, nullsFirst: false })
    .limit(6),
  supabase
    .from('advisors')
    .select('name, roles')
    .eq('active', true),
]);

const midAdvisorNames = (advisorList ?? [])
  .filter((a: any) => Array.isArray(a.roles) && a.roles.includes('中期'))
  .map((a: any) => a.name);

function buildHref(overrides: Record<string, string>): string {
  const params = new URLSearchParams();
  const next: Record<string, string> = {
    advisor: advisorFilter,
    include_inactive: includeInactive ? '1' : '',
    ...overrides,
  };
  for (const [k, v] of Object.entries(next)) if (v) params.set(k, v);
  const qs = params.toString();
  return qs ? `/internal?${qs}` : '/internal';
}

type StudentRow = {
  id: number; name: string;
  mid_advisors: string[] | null; early_advisors: string[] | null; late_advisors: string[] | null;
  stage: string | null; last_contact_at: string | null;
  enroll_years: string[] | null; contracts: string[] | null;
};

const allStudentsTagged: (StudentRow & { daysSince: number | null; tier: RadarTier })[] =
  (allActiveStudents ?? []).map((s: any) => {
    const ds = daysSinceToday(s.last_contact_at);
    return { ...s, daysSince: ds, tier: tierFor(ds, s.stage) };
  });

const inactiveCount = allStudentsTagged.filter(s => isInactive(s.stage)).length;

// Stage filter (closed / refunded / completed)
let students = includeInactive ? allStudentsTagged : allStudentsTagged.filter(s => !isInactive(s.stage));

// Private-contract students: only visible to authenticated viewers who can see them
// (王世杰 / admin). Everyone else has them filtered out — silently, no UI mention.
if (!canSeePrivate) {
  students = students.filter(s => !isPrivate(s.contracts));
}

// Per-focus filter (for stat strip + triage). When advisorFilter is set, narrow to
// students who have that advisor in their mid_advisors array (multi-counted).
const studentsForFocus = advisorFilter
  ? students.filter(s => Array.isArray(s.mid_advisors) && s.mid_advisors.includes(advisorFilter))
  : students;

// Triage (pink and worse)
const triage = studentsForFocus
  .filter(s => inTriage(s.tier))
  .sort((a, b) => (b.daysSince ?? 0) - (a.daysSince ?? 0));

const tierCounts = {
  critical: studentsForFocus.filter(s => s.tier === 'critical').length,
  red:      studentsForFocus.filter(s => s.tier === 'red').length,
  pink:     studentsForFocus.filter(s => s.tier === 'pink').length,
  yellow:   studentsForFocus.filter(s => s.tier === 'yellow').length,
};

// ── Per-advisor chip counts ──
// Each advisor's count = students with that advisor in their mid_advisors (multi-counted).
const advisorChipCounts = new Map<string, number>();
for (const s of students) {
  for (const a of s.mid_advisors ?? []) {
    advisorChipCounts.set(a, (advisorChipCounts.get(a) ?? 0) + 1);
  }
}
for (const name of midAdvisorNames) {
  if (!advisorChipCounts.has(name)) advisorChipCounts.set(name, 0);
}
const advisorChips = Array.from(advisorChipCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

// ── Cohort × Advisor matrix ──
// CASE EXPANSION: each student contributes to (mid_advisor × enroll_year) cells.
// 刘昱彤 with mid_advisors=[王, 陆] enroll_years=[2028 fall] → 2 cells (王/2028, 陆/2028).
// 马江涛 with mid_advisors=[陆] enroll_years=[2026 fall, 2028 fall] → 2 cells (陆/2026, 陆/2028).
type Cell = { count: number; worstRank: number; worstTier: RadarTier };
const COHORT_FALLBACK = '未填';
const ADVISOR_FALLBACK = '未分配';

function bumpCell(c: Cell, tier: RadarTier) {
  c.count += 1;
  const r = tierRank(tier);
  if (r > c.worstRank) { c.worstRank = r; c.worstTier = tier; }
}

const matrix = new Map<string, Cell>();
const rowTotals = new Map<string, Cell>();
const colTotals = new Map<string, Cell>();
const grandTotal: Cell = { count: 0, worstRank: -1, worstTier: 'inactive' };

const cohortSet = new Set<string>();
const advisorOrder = new Map<string, number>();

for (const s of students) {
  const cohorts = (s.enroll_years && s.enroll_years.length) ? s.enroll_years : [COHORT_FALLBACK];
  const advisors = (s.mid_advisors && s.mid_advisors.length) ? s.mid_advisors : [ADVISOR_FALLBACK];

  for (const cohort of cohorts) {
    cohortSet.add(cohort);
    if (!rowTotals.has(cohort)) rowTotals.set(cohort, { count: 0, worstRank: -1, worstTier: 'inactive' });

    for (const advisor of advisors) {
      advisorOrder.set(advisor, (advisorOrder.get(advisor) ?? 0) + 1);
      const key = `${cohort}::${advisor}`;
      if (!matrix.has(key)) matrix.set(key, { count: 0, worstRank: -1, worstTier: 'inactive' });
      if (!colTotals.has(advisor)) colTotals.set(advisor, { count: 0, worstRank: -1, worstTier: 'inactive' });

      bumpCell(matrix.get(key)!, s.tier);
      bumpCell(rowTotals.get(cohort)!, s.tier);
      bumpCell(colTotals.get(advisor)!, s.tier);
      bumpCell(grandTotal, s.tier);
    }
  }
}

const cohortKeys = Array.from(cohortSet).sort((a, b) => {
  if (a === COHORT_FALLBACK) return 1;
  if (b === COHORT_FALLBACK) return -1;
  return a.localeCompare(b);
});

// Seed advisorOrder with every active 中期 advisor so empty-caseload advisors
// still show up as a column (count 0). Anyone already in advisorOrder keeps
// their student-derived count; new entries land at 0 and sort last.
for (const name of midAdvisorNames) {
  if (!advisorOrder.has(name)) advisorOrder.set(name, 0);
}

const advisorKeys = Array.from(advisorOrder.entries())
  .sort((a, b) => {
    if (a[0] === ADVISOR_FALLBACK) return 1;
    if (b[0] === ADVISOR_FALLBACK) return -1;
    return b[1] - a[1] || a[0].localeCompare(b[0]);
  })
  .map(([k]) => k);

function cellLink(cohort: string, advisor: string): string {
  const params = new URLSearchParams();
  if (cohort !== COHORT_FALLBACK) params.set('cohort', cohort);
  if (advisor !== ADVISOR_FALLBACK) params.set('advisor', advisor);
  return params.toString() ? `/internal/students?${params}` : '/internal/students';
}

function fmtDateTime(dt: string | null): string {
  if (!dt) return '—';
  const d = new Date(dt);
  return `${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
}

---

<InternalLayout title={advisorFilter ? `Overview · ${advisorFilter}` : 'Overview'} active="overview">
  <div class="page-header">
    <h1 class="font-headline page-title">
      Overview {advisorFilter && <span style="font-weight: 600; font-size: 20px; color: var(--primary);">· {advisorFilter}</span>}
    </h1>
    <a href={buildHref({ include_inactive: includeInactive ? '' : '1' })}
      style={`padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; border: 1px solid ${includeInactive ? 'var(--primary)' : 'var(--border)'}; color: ${includeInactive ? 'var(--primary)' : 'var(--text-muted)'}; background: ${includeInactive ? '#e8f0ee' : 'transparent'}; white-space: nowrap;`}>
      {includeInactive ? '✓ 含已结案' : `+ 已结案 (${inactiveCount})`}
    </a>
  </div>
  <p class="page-subtitle">
    实时联系频率分诊。点击顾问名查看其视角。
  </p>

  <!-- Advisor filter chips -->
  <div class="filter-row" style="margin-bottom: 24px;">
    <span class="filter-row__label">中期</span>
    <a href={buildHref({ advisor: '' })} class={`pill ${!advisorFilter ? 'pill--active' : ''}`}>All</a>
    {advisorChips.map(([name, count]) => (
      <a href={buildHref({ advisor: name })} class={`pill ${advisorFilter === name ? 'pill--active' : ''}`}>
        {name} <span style="opacity: 0.6; margin-left: 2px;" class="font-mono">{count}</span>
      </a>
    ))}
  </div>

  <!-- ── Stat strip ── -->
  <div class="stat-strip">
    <div class="stat-card">
      <div class="stat-card__label">{advisorFilter ? `${advisorFilter} 在管` : (includeInactive ? '学生总数' : '在管学生')}</div>
      <div class="stat-card__value font-mono">{studentsForFocus.length}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">28d+ 失联</div>
      <div class="stat-card__value font-mono" style={`color: ${tierStyle('critical').border};`}>{tierCounts.critical}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">21–27d</div>
      <div class="stat-card__value font-mono" style={`color: ${tierStyle('red').border};`}>{tierCounts.red}</div>
    </div>
    <div class="stat-card">
      <div class="stat-card__label">14–20d</div>
      <div class="stat-card__value font-mono" style={`color: ${tierStyle('pink').border};`}>{tierCounts.pink}</div>
    </div>
    {viewer?.isAdmin && (
      <div class="stat-card">
        <div class="stat-card__label">Inbox 待处理</div>
        <div class="stat-card__value font-mono" style="color: var(--primary);">{unprocessed ?? 0}</div>
      </div>
    )}
  </div>

  <!-- ── Triage ── -->
  <section class="section-card">
    <div class="section-card__header">
      <h2 class="font-headline section-card__title">
        Triage <span class="section-card__subtitle">14d+ 没联系，按天数倒序</span>
      </h2>
      <a href="/internal/students" class="section-card__action">查看全部学生 →</a>
    </div>
    {triage.length === 0 ? (
      <p class="section-card__empty">所有人都在 14 天内有过接触，干得漂亮。</p>
    ) : (
      <ul class="triage-list">
        {triage.map(s => {
          const ts = tierStyle(s.tier);
          const advisorsLabel = (s.mid_advisors && s.mid_advisors.length) ? s.mid_advisors.join(' / ') : '—';
          return (
            <li class="triage-row">
              <span class="triage-row__dot" style={`background: ${ts.border};`}></span>
              <a href={`/internal/students/${s.id}`} class="triage-row__name">{s.name}</a>
              <span class="triage-row__advisor">{advisorsLabel}</span>
              <span class="triage-row__days font-mono" style={`color: ${ts.border};`}>
                {tierLabel(s.tier, s.daysSince)}
              </span>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  <!-- ── Cohort × Advisor matrix ── -->
  <section class="section-card">
    <div class="section-card__header">
      <h2 class="font-headline section-card__title">
        分布 <span class="section-card__subtitle">入学年份 × 中期顾问</span>
      </h2>
    </div>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
        <thead>
          <tr>
            <th style="text-align: left; padding: 8px 10px; border-bottom: 2px solid var(--border); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); position: sticky; left: 0; background: var(--surface-raised);">
              Cohort \ Advisor
            </th>
            {advisorKeys.map(a => {
              const isSel = advisorFilter === a;
              return (
                <th style={`text-align: center; padding: 8px 10px; border-bottom: 2px solid var(--border); font-size: 11px; font-weight: 700; color: ${isSel ? 'var(--primary)' : 'var(--text-muted)'}; white-space: nowrap; background: ${isSel ? '#e8f0ee' : 'transparent'};`}>
                  {a}
                </th>
              );
            })}
            <th style="text-align: center; padding: 8px 10px; border-bottom: 2px solid var(--border); font-size: 11px; font-weight: 700; color: var(--text); background: #f8fafc;">
              总计
            </th>
          </tr>
        </thead>
        <tbody>
          {cohortKeys.map(cohort => {
            const rowTotal = rowTotals.get(cohort) ?? { count: 0, worstRank: -1, worstTier: 'inactive' as RadarTier };
            return (
              <tr style="border-bottom: 1px solid var(--border);">
                <th style="text-align: left; padding: 10px; font-weight: 700; font-size: 13px; position: sticky; left: 0; background: var(--surface-raised); white-space: nowrap;">
                  {cohort}
                </th>
                {advisorKeys.map(advisor => {
                  const cell = matrix.get(`${cohort}::${advisor}`);
                  const isSel = advisorFilter === advisor;
                  const cellBg = isSel ? '#f4faf7' : 'transparent';
                  if (!cell || cell.count === 0) {
                    return <td style={`text-align: center; padding: 10px; color: var(--text-soft); background: ${cellBg};`}>·</td>;
                  }
                  return (
                    <td style={`text-align: center; padding: 6px; background: ${cellBg};`}>
                      <a href={cellLink(cohort, advisor)} style="text-decoration: none; display: inline-block;">
                        <span style="display: inline-block; padding: 4px 10px; border-radius: 6px; color: var(--text); font-weight: 700; font-family: 'JetBrains Mono', monospace; font-size: 13px;">
                          {cell.count}
                        </span>
                      </a>
                    </td>
                  );
                })}
                <td style="text-align: center; padding: 10px; font-weight: 700; font-family: 'JetBrains Mono', monospace; font-size: 13px; background: #f8fafc;">
                  {rowTotal.count}
                </td>
              </tr>
            );
          })}
          <tr style="background: #f8fafc; border-top: 2px solid var(--border);">
            <th style="text-align: left; padding: 10px; font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); position: sticky; left: 0; background: #f8fafc;">
              总计
            </th>
            {advisorKeys.map(advisor => {
              const t = colTotals.get(advisor) ?? { count: 0, worstRank: -1, worstTier: 'inactive' as RadarTier };
              return (
                <td style="text-align: center; padding: 10px; font-weight: 700; font-family: 'JetBrains Mono', monospace; font-size: 13px;">
                  {t.count}
                </td>
              );
            })}
            <td style="text-align: center; padding: 10px; font-weight: 800; font-family: 'JetBrains Mono', monospace; font-size: 14px; background: #eef2f7;">
              {grandTotal.count}
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Activity streams (admin-only — these surface inbox + recent
       student notes which can include 私单 references) ── -->
  {viewer?.isAdmin && (
  <div class="activity-grid">
    <section class="section-card">
      <div class="section-card__header">
        <h2 class="font-headline section-card__title">最近 Inbox 提交</h2>
        <a href="/internal/submissions" class="section-card__action">Inbox →</a>
      </div>
      {(recentSubmissions ?? []).length === 0 ? (
        <p class="section-card__empty">还没有提交记录。</p>
      ) : (
        <ul style="list-style: none; margin: 0; padding: 0;">
          {(recentSubmissions ?? []).map((s: any) => (
            <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px;">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                {s.students?.id ? (
                  <a href={`/internal/students/${s.students.id}`} style="font-weight: 700; color: var(--text); text-decoration: none;">
                    {s.students.name}
                  </a>
                ) : (
                  <span style="font-weight: 700;">{s.student_name_raw ?? '—'}</span>
                )}
                <span style="font-size: 11px; font-weight: 600; color: var(--text-muted);">{s.type}</span>
                <span style="flex: 1;"></span>
                <span class="font-mono" style="font-size: 11px; color: var(--text-soft);">{fmtDateTime(s.submitted_at)}</span>
              </div>
              {s.summary && <div style="color: var(--text-muted); font-size: 12px; margin-top: 2px;">{s.summary}</div>}
              {s.submitted_by && <div style="font-size: 11px; color: var(--text-soft); margin-top: 1px;">by {s.submitted_by}</div>}
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="section-card">
      <div class="section-card__header">
        <h2 class="font-headline section-card__title">最近沟通记录</h2>
      </div>
      {(recentNotes ?? []).length === 0 ? (
        <p class="section-card__empty">还没有同步到沟通记录。</p>
      ) : (
        <ul style="list-style: none; margin: 0; padding: 0;">
          {(recentNotes ?? []).map((n: any) => (
            <li style="padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px;">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <a href={`/internal/students/${n.student_id}`} style="font-weight: 700; color: var(--text); text-decoration: none;">
                  {n.students?.name ?? '—'}
                </a>
                <span style="flex: 1;"></span>
                <span class="font-mono" style="font-size: 11px; color: var(--text-soft);">{n.note_date ?? '—'}</span>
              </div>
              <div style="color: var(--text-muted); font-size: 12px; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                {n.note_name}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
  )}
</InternalLayout>

<style>
  /* Triage row — dot indicator replaces colored left border + pastel bg.
     section-card / stat-card / page-header live in InternalLayout's global CSS. */
  .triage-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(205px, 1fr));
    gap: 2px;
  }
  .triage-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 7px;
    transition: background 120ms ease;
  }
  .triage-row:hover {
    background: #f8fafc;
  }
  .triage-row__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .triage-row__name {
    font-weight: 600;
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }
  .triage-row__name:hover {
    color: var(--primary);
  }
  .triage-row__advisor {
    font-size: 11px;
    color: var(--text-soft);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }
  .triage-row__days {
    font-weight: 700;
    font-size: 12px;
    flex-shrink: 0;
  }

  /* Activity grid — same two-column rhythm as before, slightly tighter gap. */
  .activity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
</style>
