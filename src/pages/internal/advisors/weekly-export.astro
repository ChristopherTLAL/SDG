---
// /internal/advisors/weekly-export — admin-only one-page Excel export.
// Linked from the "导出本周顾问周报 (Excel)" button on /internal/advisors. SSR
// fetches advisors + their in-管 active students + this week's `student_weekly_advice`
// rows (per-student AI suggestions, written by the refactored advisor-weekly skill).
// Client-side xlsx-js-style (CDN) builds a multi-sheet styled xlsx and triggers download.
//
// Sheets: 总览 + one per 中期 advisor. Columns (9, no 私单标 — 私单 students are
// segregated into 王世杰's sheet only, so the column carries no info anywhere).
import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { studentHasInScopeCohort } from '../../../utils/cohort-filter';

const viewer = Astro.locals?.viewer ?? null;
if (!viewer?.isAdmin) return Astro.redirect('/internal');

// Monday-of-this-week (advisor-weekly skill convention; same as `/internal/advisors/[name]/weekly`).
function mondayOfThisWeek(d = new Date()): string {
  const day = d.getDay() || 7; // 1..7, Mon=1
  const m = new Date(d);
  m.setDate(d.getDate() - (day - 1));
  m.setHours(0, 0, 0, 0);
  return m.toISOString().slice(0, 10);
}
const weekStart = mondayOfThisWeek();
const ACTIVE_STAGES = ['中期在途', '后期在途', '需对接'];
const PRIVATE_CONTRACTS = ['私单', '私单（非公司合同）'];

// 1) Active 中期 advisors
const { data: advisorRows } = await supabase
  .from('advisors')
  .select('name, roles')
  .eq('active', true);
const advisors = ((advisorRows ?? []) as { name: string; roles: string[] | null }[])
  .filter((a) => Array.isArray(a.roles) && a.roles.includes('中期'))
  .sort((a, b) => a.name.localeCompare(b.name, 'zh-Hans-CN'));

// 2) Active in-scope students (cohort ≥26F)
type Stu = {
  id: number; name: string; stage: string | null;
  enroll_years: string[] | null; contracts: string[] | null;
  yueling_tier: string | null; mid_advisors: string[] | null;
  early_advisors: string[] | null; last_contact_at: string | null;
};
const { data: rawStudents } = await supabase
  .from('students')
  .select('id, name, stage, enroll_years, contracts, yueling_tier, mid_advisors, early_advisors, last_contact_at')
  .in('stage', ACTIVE_STAGES);
const allStudents = ((rawStudents ?? []) as Stu[]).filter((s) => studentHasInScopeCohort(s.enroll_years));

// 3) This week's per-student AI advice
const { data: adviceRows } = await supabase
  .from('student_weekly_advice')
  .select('student_id, advisor_name, bucket, suggestion_md')
  .eq('week_start', weekStart);
type Advice = { student_id: number; advisor_name: string; bucket: string; suggestion_md: string };
const adviceMap = new Map<string, Advice>();
for (const r of (adviceRows ?? []) as Advice[]) adviceMap.set(`${r.student_id}::${r.advisor_name}`, r);

// 4) Helpers
function daysSince(d: string | null): number | null {
  if (!d) return null;
  return Math.max(0, Math.floor((Date.now() - new Date(d + 'T00:00:00').getTime()) / 86400000));
}
type BKey = 'urgent' | 'normal' | 'kickoff' | 'ok';
function deriveBucket(stage: string | null, days: number | null): BKey {
  if (stage === '待对接') return 'kickoff';
  if (days == null) return 'ok';
  const urgentDays = stage === '后期在途' ? 31 : 28;
  if (days >= urgentDays) return 'urgent';
  if (days >= 14) return 'normal';
  return 'ok';
}
const LABEL: Record<BKey, string> = { urgent: '🔴 紧急', normal: '🟠 常规', kickoff: '🆕 待对接', ok: '正常' };
const RANK: Record<BKey, number> = { urgent: 0, normal: 1, kickoff: 2, ok: 3 };
const isPrivate = (c: string[] | null) => Array.isArray(c) && c.some((x) => PRIVATE_CONTRACTS.includes(x));

// 5) Build per-advisor sheets + overview
type SheetRow = {
  '姓名': string; '紧急度': string;
  '距上次沟通(d)': number | ''; '上次沟通日期': string;
  '阶段': string; '入学年份': string; '合同': string;
  '跃领分级': string; '前期': string; '本周建议(AI)': string;
};
const sheets: { advisor: string; rows: SheetRow[] }[] = [];
const overview: Array<Record<string, string | number>> = [];

for (const adv of advisors) {
  const name = adv.name;
  let mine = allStudents.filter((s) => s.mid_advisors?.includes(name));
  if (name !== '王世杰') mine = mine.filter((s) => !isPrivate(s.contracts));

  const meta = mine.map((s) => {
    const days = daysSince(s.last_contact_at);
    const a = adviceMap.get(`${s.id}::${name}`);
    const bucket = ((a?.bucket as BKey) ?? deriveBucket(s.stage, days));
    return { s, days, a, bucket };
  }).sort((x, y) => RANK[x.bucket] - RANK[y.bucket] || ((y.days ?? -1) - (x.days ?? -1)));

  const rows: SheetRow[] = meta.map(({ s, days, a, bucket }) => ({
    '姓名': s.name,
    '紧急度': LABEL[bucket],
    '距上次沟通(d)': days ?? '',
    '上次沟通日期': s.last_contact_at ?? '',
    '阶段': s.stage ?? '',
    '入学年份': (s.enroll_years ?? []).join(' / '),
    '合同': (s.contracts ?? []).join(' / '),
    '跃领分级': s.yueling_tier ?? '',
    '前期': (s.early_advisors ?? []).join(' / '),
    '本周建议(AI)': a?.suggestion_md ?? '',
  }));

  const counts = { urgent: 0, normal: 0, kickoff: 0, ok: 0 };
  for (const m of meta) counts[m.bucket]++;

  sheets.push({ advisor: name, rows });
  const hasAdvice = ((adviceRows ?? []) as Advice[]).some((r) => r.advisor_name === name);
  overview.push({
    '顾问': name,
    '在管': mine.length,
    '🔴 紧急': counts.urgent,
    '🟠 常规': counts.normal,
    '🆕 待对接': counts.kickoff,
    '本周 AI 建议': hasAdvice ? '✓' : '—',
  });
}

const payload = { weekStart, overview, sheets };
const totalStudents = sheets.reduce((s, x) => s + x.rows.length, 0);
const hasAnyAdvice = (adviceRows ?? []).length > 0;
---
<InternalLayout title="导出本周顾问周报">
  <div class="exp">
    <h1 class="font-headline">导出本周顾问周报 (Excel)</h1>
    <p class="exp__sub">
      周一 <code>{weekStart}</code> · {advisors.length} 位 中期 顾问 · {totalStudents} 名在管学生
      {!hasAnyAdvice && <span class="exp__warn">⚠ 本周还没跑过 /advisor-weekly,「本周建议(AI)」列将为空</span>}
    </p>
    <div id="status" class="exp__s">生成中…</div>
    <p class="exp__hint">下载完成后可直接关闭此页。如未触发下载,请检查浏览器拦截设置。</p>
  </div>

  <script id="exp-data" type="application/json" set:html={JSON.stringify(payload)}></script>
  <!-- xlsx-js-style: maintained fork of SheetJS CE that re-adds cell-level styling
       (fill / font / border / alignment). Same global `XLSX` API as upstream. -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
  <script is:inline>
    (function () {
      var st = document.getElementById('status');
      function say(t, ok) { if (!st) return; st.textContent = t; st.className = 'exp__s' + (ok ? ' exp__s--ok' : ''); }

      // ── style constants ──
      var HEADER_STYLE = {
        fill: { fgColor: { rgb: '1F2937' } },
        font: { bold: true, color: { rgb: 'FFFFFF' }, sz: 11, name: 'Microsoft YaHei' },
        alignment: { horizontal: 'center', vertical: 'center', wrapText: true },
        border: {
          top:    { style: 'thin', color: { rgb: 'FFFFFF' } },
          bottom: { style: 'thin', color: { rgb: 'FFFFFF' } },
          left:   { style: 'thin', color: { rgb: '374151' } },
          right:  { style: 'thin', color: { rgb: '374151' } },
        },
      };
      var BORDER_LIGHT = {
        top:    { style: 'thin', color: { rgb: 'E5E7EB' } },
        bottom: { style: 'thin', color: { rgb: 'E5E7EB' } },
        left:   { style: 'thin', color: { rgb: 'E5E7EB' } },
        right:  { style: 'thin', color: { rgb: 'E5E7EB' } },
      };
      var BUCKET_FILL = {
        '🔴 紧急':  'FEE2E2',
        '🟠 常规':  'FFEDD5',
        '🆕 待对接': 'DBEAFE',
      };
      function bodyStyle(fillRgb) {
        var s = {
          alignment: { vertical: 'top', wrapText: true },
          font: { sz: 10, name: 'Microsoft YaHei' },
          border: BORDER_LIGHT,
        };
        if (fillRgb) s.fill = { fgColor: { rgb: fillRgb } };
        return s;
      }
      // bucketCol: 0-indexed column of 紧急度 (null = no tinting, e.g. 总览)
      function stylize(ws, bucketCol, bodyRowPt) {
        if (!ws['!ref']) return;
        var range = XLSX.utils.decode_range(ws['!ref']);
        // header row
        for (var C = range.s.c; C <= range.e.c; C++) {
          var hAddr = XLSX.utils.encode_cell({ r: 0, c: C });
          if (ws[hAddr]) ws[hAddr].s = HEADER_STYLE;
        }
        // body rows
        for (var R = 1; R <= range.e.r; R++) {
          var fill = null;
          if (bucketCol != null) {
            var bAddr = XLSX.utils.encode_cell({ r: R, c: bucketCol });
            var b = ws[bAddr] ? ws[bAddr].v : '';
            fill = BUCKET_FILL[b] || null;
          }
          for (var Cb = range.s.c; Cb <= range.e.c; Cb++) {
            var addr = XLSX.utils.encode_cell({ r: R, c: Cb });
            if (!ws[addr]) ws[addr] = { v: '', t: 's' };
            ws[addr].s = bodyStyle(fill);
          }
        }
        // row heights
        ws['!rows'] = [{ hpt: 28 }];
        for (var i = 1; i <= range.e.r; i++) ws['!rows'][i] = { hpt: bodyRowPt || 22 };
        // frozen header + autofilter
        ws['!views'] = [{ state: 'frozen', xSplit: 0, ySplit: 1 }];
        ws['!autofilter'] = { ref: ws['!ref'] };
      }

      try {
        var dataEl = document.getElementById('exp-data');
        var data = JSON.parse((dataEl && dataEl.textContent) || '{}');
        if (typeof XLSX === 'undefined') { say('SheetJS 加载失败 (CDN 可能被拦截)'); return; }
        var wb = XLSX.utils.book_new();

        // 总览
        var ov = XLSX.utils.json_to_sheet(data.overview || []);
        ov['!cols'] = [{wch:12},{wch:8},{wch:8},{wch:8},{wch:10},{wch:14}];
        stylize(ov, null, 22);
        XLSX.utils.book_append_sheet(wb, ov, '总览');

        // 每顾问 — col 1 (B) = 紧急度 → tint, AI 建议列(col J) wrap → 60pt 行高
        (data.sheets || []).forEach(function (s) {
          var ws = XLSX.utils.json_to_sheet(s.rows);
          ws['!cols'] = [{wch:12},{wch:11},{wch:14},{wch:14},{wch:11},{wch:14},{wch:30},{wch:11},{wch:11},{wch:64}];
          stylize(ws, 1, 60);
          XLSX.utils.book_append_sheet(wb, ws, String(s.advisor).slice(0, 31));
        });

        var fn = '顾问周报_' + data.weekStart + '.xlsx';
        XLSX.writeFile(wb, fn);
        say('已下载 ✓ ' + fn, true);
      } catch (e) {
        say('生成失败: ' + (e && e.message ? e.message : e));
      }
    })();
  </script>

  <style>
    .exp { max-width: 720px; margin: 32px auto; padding: 24px; }
    .exp h1 { font-size: 22px; color: var(--text); margin: 0 0 6px; }
    .exp__sub { color: var(--text-muted); font-size: 13px; margin: 0 0 18px; }
    .exp__sub code { background: var(--surface-raised); padding: 1px 6px; border-radius: 4px; font-size: 12px; }
    .exp__warn { display: inline-block; margin-left: 8px; color: var(--warning); font-weight: 600; }
    .exp__s { padding: 12px 16px; background: var(--surface-raised); border: 1px solid var(--border); border-radius: 8px; color: var(--text); }
    .exp__s--ok { background: #e8f7ee; border-color: #b7e2c4; color: #14532d; }
    .exp__hint { color: var(--text-soft); font-size: 12px; margin: 12px 0 0; }
  </style>
</InternalLayout>
