---
// src/pages/internal/submit.astro — employee submission form
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';

// Fetch student list for the dropdown. Ordered by last_contact_at desc so
// the students you've touched recently float to the top.
const { data: studentsRaw, error } = await supabase
  .from('students')
  .select('id, name, stage, mid_advisor, last_contact_at')
  .order('last_contact_at', { ascending: false, nullsFirst: false })
  .limit(500);

const students = studentsRaw ?? [];
const dbError = error?.message ?? null;
const viewer = Astro.locals?.viewer ?? null;
---

<InternalLayout title="Submit" active="submit">
  <h1 class="font-headline page-title" style="font-size: 26px;">Submit</h1>
  <p class="page-subtitle" style="margin-bottom: 28px;">
    员工提交：沟通记录 / 重要 comment / 状态更新 / 会议 / 其他
  </p>

  {dbError && (
    <div class="form-error">
      <strong>数据库连接错误：</strong> {dbError}
    </div>
  )}

  <form id="submit-form" class="submit-form">
    <label class="field field--full">
      <span class="field__label">学生 <span class="field__req">*</span></span>
      <select name="student_id" id="student_id" required>
        <option value="">— 选择学生 —</option>
        {students.map((s: any) => (
          <option value={s.id} data-name={s.name}>
            {s.name}
            {s.mid_advisor ? ` · ${s.mid_advisor}` : ''}
            {s.stage ? ` · ${s.stage}` : ''}
            {s.last_contact_at ? ` · 上次 ${s.last_contact_at}` : ''}
          </option>
        ))}
        <option value="__new__">➕ 新客（还没建档）</option>
      </select>
      <small class="field__hint">{students.length} 个学生。</small>
    </label>

    <label id="new-student-wrap" class="field field--full" style="display: none;">
      <span class="field__label">新客姓名 <span class="field__req">*</span></span>
      <input type="text" name="student_name_raw" id="student_name_raw"
        placeholder="手打姓名，王老师后面会建档并关联" />
    </label>

    <label class="field">
      <span class="field__label">类型 <span class="field__req">*</span></span>
      <select name="type" id="type" required>
        <option value="沟通记录">沟通记录</option>
        <option value="重要comment">重要 comment</option>
        <option value="状态更新">状态更新</option>
        <option value="会议">会议</option>
        <option value="其他">其他</option>
      </select>
    </label>

    <label class="field">
      <span class="field__label">你是谁 <span class="field__req">*</span></span>
      <input type="text" name="submitted_by" id="submitted_by" required
        value={viewer?.name ?? ''}
        placeholder="自己的名字（会显示在 inbox 里）" />
    </label>

    <label class="field field--full">
      <span class="field__label">一句话摘要</span>
      <input type="text" name="summary" id="summary"
        placeholder="一句话讲清楚，比如：家长问雅思首考时间 / 今天聊了选校 / 家长可能想退" />
    </label>

    <label class="field field--full">
      <span class="field__label">详细内容</span>
      <textarea name="content" id="content" rows="6"
        placeholder="沟通要点、comment 正文、状态变化原因等。"></textarea>
    </label>

    <label class="field field--full">
      <span class="field__label">附件（可选）</span>
      <input type="file" name="attachment" id="attachment" class="field__file" />
      <small class="field__hint">PDF / Word / 图片 等。敏感材料（合同、银行卡）请勿上传。</small>
    </label>

    <div class="field--full submit-form__actions">
      <button type="submit" id="submit-btn" class="btn-primary submit-form__cta">提交</button>
      <span id="status" class="submit-form__status"></span>
    </div>
  </form>

  <style>
    .submit-form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      background: var(--surface-raised);
      padding: 28px;
      border: 1px solid #eef0f3;
      border-radius: 14px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
    }
    /* .field / .field__* / .field__file live in InternalLayout global. */
    .submit-form__actions {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-top: 8px;
    }
    .submit-form__cta {
      padding: 12px 28px;
      font-size: 14px;
      font-weight: 700;
      border-radius: 8px;
    }
    .submit-form__status {
      font-size: 13px;
      color: var(--text-muted);
    }
    .form-error {
      padding: 14px 16px;
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #991b1b;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 24px;
    }
  </style>

  <script is:inline>
    const form = document.getElementById('submit-form');
    const statusEl = document.getElementById('status');
    const submitBtn = document.getElementById('submit-btn');
    const studentSel = document.getElementById('student_id');
    const newStudentWrap = document.getElementById('new-student-wrap');

    function toggleNewStudent() {
      newStudentWrap.style.display = studentSel.value === '__new__' ? 'flex' : 'none';
    }
    studentSel.addEventListener('change', toggleNewStudent);
    toggleNewStudent();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      statusEl.textContent = '提交中…';
      statusEl.style.color = 'var(--text-muted)';

      const fd = new FormData(form);
      try {
        const r = await fetch('/internal/api/submissions', {
          method: 'POST',
          body: fd,
        });
        const json = await r.json();
        if (!r.ok) throw new Error(json.error || 'submit failed');
        statusEl.textContent = '✓ 已提交 #' + json.id;
        statusEl.style.color = 'var(--success)';
        form.reset();
        toggleNewStudent();
      } catch (err) {
        statusEl.textContent = '✗ ' + err.message;
        statusEl.style.color = 'var(--danger)';
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</InternalLayout>
