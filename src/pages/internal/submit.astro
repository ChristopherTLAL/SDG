---
// src/pages/internal/submit.astro — employee submission form
import InternalLayout from '../../layouts/InternalLayout.astro';
import { supabase } from '../../lib/supabase/client';

// Fetch student list for the dropdown. Ordered by last_contact_at desc so
// the students you've touched recently float to the top.
const { data: studentsRaw, error } = await supabase
  .from('students')
  .select('id, name, stage, mid_advisor, last_contact_at')
  .order('last_contact_at', { ascending: false, nullsFirst: false })
  .limit(500);

const students = studentsRaw ?? [];
const dbError = error?.message ?? null;
---

<InternalLayout title="Submit" active="submit">
  <h1 class="font-headline" style="font-size: 26px; font-weight: 800; margin: 0 0 4px; letter-spacing: -0.02em;">
    Submit
  </h1>
  <p style="color: var(--text-muted); margin: 0 0 32px; font-size: 14px;">
    员工提交：沟通记录 / 重要 comment / 状态更新 / 会议 / 其他
  </p>

  {dbError && (
    <div style="padding: 14px 16px; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 8px; font-size: 13px; margin-bottom: 24px;">
      <strong>数据库连接错误：</strong> {dbError}
    </div>
  )}

  <form id="submit-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; background: var(--surface-raised); padding: 28px; border: 1px solid var(--border); border-radius: 12px;">

    <!-- Student picker -->
    <label style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        学生 <span style="color: var(--danger);">*</span>
      </span>
      <select name="student_id" id="student_id" required
        style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; background: white;">
        <option value="">— 选择学生 —</option>
        {students.map((s: any) => (
          <option value={s.id} data-name={s.name}>
            {s.name}
            {s.mid_advisor ? ` · ${s.mid_advisor}` : ''}
            {s.stage ? ` · ${s.stage}` : ''}
            {s.last_contact_at ? ` · 上次 ${s.last_contact_at}` : ''}
          </option>
        ))}
        <option value="__new__">➕ 新客（还没建档）</option>
      </select>
      <small style="color: var(--text-soft); font-size: 11px;">
        {students.length} 个学生。
      </small>
    </label>

    <!-- New student name (conditional) -->
    <label id="new-student-wrap" style="grid-column: 1 / -1; display: none; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        新客姓名 <span style="color: var(--danger);">*</span>
      </span>
      <input type="text" name="student_name_raw" id="student_name_raw"
        placeholder="手打姓名，王老师后面会建档并关联"
        style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px;" />
    </label>

    <!-- Type -->
    <label style="display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        类型 <span style="color: var(--danger);">*</span>
      </span>
      <select name="type" id="type" required
        style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; background: white;">
        <option value="沟通记录">沟通记录</option>
        <option value="重要comment">重要 comment</option>
        <option value="状态更新">状态更新</option>
        <option value="会议">会议</option>
        <option value="其他">其他</option>
      </select>
    </label>

    <!-- Submitted by -->
    <label style="display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        你是谁 <span style="color: var(--danger);">*</span>
      </span>
      <input type="text" name="submitted_by" id="submitted_by" required
        placeholder="自己的名字（会显示在 inbox 里）"
        style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px;" />
    </label>

    <!-- Summary -->
    <label style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        一句话摘要
      </span>
      <input type="text" name="summary" id="summary"
        placeholder="一句话讲清楚，比如：家长问雅思首考时间 / 今天聊了选校 / 家长可能想退"
        style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px;" />
    </label>

    <!-- Content -->
    <label style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        详细内容
      </span>
      <textarea name="content" id="content" rows="6"
        placeholder="沟通要点、comment 正文、状态变化原因等。"
        style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; resize: vertical; font-family: inherit;"></textarea>
    </label>

    <!-- Generic attachment -->
    <label style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 6px;">
      <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted);">
        附件（可选）
      </span>
      <input type="file" name="attachment" id="attachment"
        style="padding: 10px 12px; border: 1px dashed var(--border); border-radius: 8px; background: #fafafa;" />
      <small style="color: var(--text-soft); font-size: 11px;">
        PDF / Word / 图片 等。敏感材料（合同、银行卡）请勿上传。
      </small>
    </label>

    <!-- Submit -->
    <div style="grid-column: 1 / -1; display: flex; gap: 12px; align-items: center; margin-top: 8px;">
      <button type="submit" id="submit-btn"
        style="padding: 12px 24px; background: var(--primary); color: white; border: 0; border-radius: 8px; font-weight: 700; font-size: 14px; cursor: pointer;">
        提交
      </button>
      <span id="status" style="font-size: 13px; color: var(--text-muted);"></span>
    </div>
  </form>

  <script is:inline>
    const form = document.getElementById('submit-form');
    const statusEl = document.getElementById('status');
    const submitBtn = document.getElementById('submit-btn');
    const studentSel = document.getElementById('student_id');
    const newStudentWrap = document.getElementById('new-student-wrap');

    function toggleNewStudent() {
      newStudentWrap.style.display = studentSel.value === '__new__' ? 'flex' : 'none';
    }
    studentSel.addEventListener('change', toggleNewStudent);
    toggleNewStudent();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      statusEl.textContent = '提交中…';
      statusEl.style.color = 'var(--text-muted)';

      const fd = new FormData(form);
      try {
        const r = await fetch('/internal/api/submissions', {
          method: 'POST',
          body: fd,
        });
        const json = await r.json();
        if (!r.ok) throw new Error(json.error || 'submit failed');
        statusEl.textContent = '✓ 已提交 #' + json.id;
        statusEl.style.color = 'var(--success)';
        form.reset();
        toggleNewStudent();
      } catch (err) {
        statusEl.textContent = '✗ ' + err.message;
        statusEl.style.color = 'var(--danger)';
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</InternalLayout>
