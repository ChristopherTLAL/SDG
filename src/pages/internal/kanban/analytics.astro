---
// /internal/kanban/analytics — contract-table-driven analytics.
//
// Two widgets:
//   1. 产品复购率 by 顾问 (留学申请合同排除)
//   2. 周度收入热力图 (顾问 × 周, 最近 12 / 26 周可切换)
//
// Data source: Supabase `contracts` table (synced via scripts/import-signings.py).

import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';

const viewer = Astro.locals?.viewer ?? null;
if (!viewer || (!viewer.isAdvisor && !viewer.isAdmin)) {
  return Astro.redirect('/internal');
}

const url = new URL(Astro.request.url);
const weeksParam = parseInt(url.searchParams.get('weeks') || '12', 10);
const weeks = [4, 12, 26, 52].includes(weeksParam) ? weeksParam : 12;

// ── Widget 1: 产品复购率 by 顾问 ──
type RepurchaseRow = {
  mid_advisor: string;
  total_customers: number;
  repurchase_customers: number;
  repurchase_pct: number;
  avg_contracts: number;
  total_revenue: number;
};

const { data: repurchaseRaw } = await supabase
  .from('contracts')
  .select('mid_advisor, customer_id, signed_amount, status, is_application')
  .eq('is_application', false)
  .neq('status', '已终止')
  .not('mid_advisor', 'is', null);

const advisorCustomerMap = new Map<string, Map<string, { count: number; total: number }>>();
for (const c of (repurchaseRaw ?? []) as any[]) {
  if (!c.mid_advisor || !c.customer_id) continue;
  if (!advisorCustomerMap.has(c.mid_advisor)) {
    advisorCustomerMap.set(c.mid_advisor, new Map());
  }
  const cMap = advisorCustomerMap.get(c.mid_advisor)!;
  if (!cMap.has(c.customer_id)) {
    cMap.set(c.customer_id, { count: 0, total: 0 });
  }
  const e = cMap.get(c.customer_id)!;
  e.count += 1;
  e.total += Number(c.signed_amount) || 0;
}

const repurchaseRows: RepurchaseRow[] = [];
for (const [advisor, cMap] of advisorCustomerMap) {
  const total = cMap.size;
  if (total < 5) continue; // skip advisors with too few customers
  let repurchase = 0;
  let sumContracts = 0;
  let sumRevenue = 0;
  for (const e of cMap.values()) {
    if (e.count >= 2) repurchase += 1;
    sumContracts += e.count;
    sumRevenue += e.total;
  }
  repurchaseRows.push({
    mid_advisor: advisor,
    total_customers: total,
    repurchase_customers: repurchase,
    repurchase_pct: total > 0 ? Math.round((repurchase / total) * 1000) / 10 : 0,
    avg_contracts: total > 0 ? Math.round((sumContracts / total) * 100) / 100 : 0,
    total_revenue: sumRevenue,
  });
}
repurchaseRows.sort((a, b) => b.repurchase_pct - a.repurchase_pct);

// Total summary
const totalCustomersAll = repurchaseRows.reduce((s, r) => s + r.total_customers, 0);
const totalRepurchaseAll = repurchaseRows.reduce((s, r) => s + r.repurchase_customers, 0);
const overallPct = totalCustomersAll > 0 ? Math.round((totalRepurchaseAll / totalCustomersAll) * 1000) / 10 : 0;

// ── Widget 2: 周度收入热力图 ──
const { data: weeklyRaw } = await supabase
  .from('contracts')
  .select('mid_advisor, signed_at, signed_amount, status')
  .neq('status', '已终止')
  .gte('signed_at', new Date(Date.now() - weeks * 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10))
  .not('mid_advisor', 'is', null)
  .not('signed_at', 'is', null);

// Bucket: advisor -> week_start (yyyy-mm-dd) -> {count, total}
type WeekBucket = { count: number; total: number };
const advisorWeekly = new Map<string, Map<string, WeekBucket>>();
const advisorTotal = new Map<string, number>();

function weekStart(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00Z');
  const day = d.getUTCDay(); // 0=Sun
  // Monday-based: shift Sun(0) → +6, others → -1+1
  const offset = day === 0 ? -6 : 1 - day;
  d.setUTCDate(d.getUTCDate() + offset);
  return d.toISOString().slice(0, 10);
}

for (const c of (weeklyRaw ?? []) as any[]) {
  if (!c.mid_advisor || !c.signed_at) continue;
  const wk = weekStart(String(c.signed_at).slice(0, 10));
  if (!advisorWeekly.has(c.mid_advisor)) advisorWeekly.set(c.mid_advisor, new Map());
  const m = advisorWeekly.get(c.mid_advisor)!;
  if (!m.has(wk)) m.set(wk, { count: 0, total: 0 });
  const b = m.get(wk)!;
  b.count += 1;
  b.total += Number(c.signed_amount) || 0;
  advisorTotal.set(c.mid_advisor, (advisorTotal.get(c.mid_advisor) || 0) + (Number(c.signed_amount) || 0));
}

// Build week labels (Monday-anchored, going backwards)
const weekLabels: string[] = [];
const today = new Date();
const todayMonday = new Date(today);
{
  const d = todayMonday.getUTCDay();
  const offset = d === 0 ? -6 : 1 - d;
  todayMonday.setUTCDate(todayMonday.getUTCDate() + offset);
}
for (let i = weeks - 1; i >= 0; i--) {
  const d = new Date(todayMonday);
  d.setUTCDate(d.getUTCDate() - i * 7);
  weekLabels.push(d.toISOString().slice(0, 10));
}

// Pick top 12 advisors by total
const sortedAdvisors = Array.from(advisorTotal.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([n]) => n);

// Compute color scale max
let maxCellValue = 0;
for (const adv of sortedAdvisors) {
  const m = advisorWeekly.get(adv);
  if (!m) continue;
  for (const wk of weekLabels) {
    const b = m.get(wk);
    if (b && b.total > maxCellValue) maxCellValue = b.total;
  }
}

function colorFor(value: number): string {
  if (value <= 0) return 'transparent';
  const ratio = Math.min(1, value / maxCellValue);
  // Teal scale (matches --primary). Light → dark.
  const alpha = 0.15 + ratio * 0.85;
  return `rgba(4, 47, 36, ${alpha.toFixed(3)})`;
}

function fmtMoney(n: number): string {
  if (n >= 10000) return (n / 10000).toFixed(1) + '万';
  return n.toFixed(0);
}

function fmtWeekLabel(w: string): string {
  const [, m, d] = w.split('-');
  return `${parseInt(m)}/${parseInt(d)}`;
}

// Total summary (last N weeks)
const grandTotal = sortedAdvisors.reduce((s, a) => s + (advisorTotal.get(a) || 0), 0);
const grandContracts = (weeklyRaw ?? []).filter((c: any) => sortedAdvisors.includes(c.mid_advisor)).length;
---

<InternalLayout title="Contracts Analytics — 复购率 + 周度收入" active="kanban">
  <div class="page-header">
    <div>
      <h1 class="font-headline page-title">合同分析</h1>
      <p class="page-subtitle">复购率 by 顾问 · 周度收入热力图。数据源 = ERP 客户签约明细。</p>
    </div>
    <div class="back-link">
      <a href="/internal/kanban">← 返回 Kanban</a>
    </div>
  </div>

  <!-- ──────────────────────────────────────────────────────── -->
  <!-- Widget 1: 复购率 by 顾问                                  -->
  <!-- ──────────────────────────────────────────────────────── -->
  <section class="widget">
    <div class="widget__head">
      <div>
        <h2 class="font-headline widget__title">产品复购率 by 中期顾问</h2>
        <p class="widget__sub">非留学申请合同（培训 / 竞赛 / 班课 / 等），同客户 ≥ 2 单 = 复购。已排除 已终止 合同。最少 5 客户起统计。</p>
      </div>
      <div class="kpi-row">
        <div class="kpi"><div class="kpi__num">{repurchaseRows.length}</div><div class="kpi__label">顾问</div></div>
        <div class="kpi"><div class="kpi__num">{totalCustomersAll}</div><div class="kpi__label">总客户</div></div>
        <div class="kpi"><div class="kpi__num">{totalRepurchaseAll}</div><div class="kpi__label">复购客户</div></div>
        <div class="kpi kpi--accent"><div class="kpi__num">{overallPct}%</div><div class="kpi__label">总复购率</div></div>
      </div>
    </div>

    <div class="widget__body">
      <table class="datatable">
        <thead>
          <tr>
            <th>中期顾问</th>
            <th class="num">总客户</th>
            <th class="num">复购客户</th>
            <th class="num">复购率</th>
            <th class="num">人均合同</th>
            <th class="num">非留学总收入</th>
          </tr>
        </thead>
        <tbody>
          {repurchaseRows.map(r => (
            <tr>
              <td><strong>{r.mid_advisor}</strong></td>
              <td class="num font-mono">{r.total_customers}</td>
              <td class="num font-mono">{r.repurchase_customers}</td>
              <td class="num font-mono">
                <span class="pct-cell" style={`background: linear-gradient(90deg, var(--primary) ${r.repurchase_pct}%, transparent ${r.repurchase_pct}%);`}>
                  {r.repurchase_pct}%
                </span>
              </td>
              <td class="num font-mono">{r.avg_contracts.toFixed(2)}</td>
              <td class="num font-mono">¥{fmtMoney(r.total_revenue)}</td>
            </tr>
          ))}
          {repurchaseRows.length === 0 && (
            <tr><td colspan="6" class="empty">暂无数据</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────── -->
  <!-- Widget 2: 周度收入热力图                                  -->
  <!-- ──────────────────────────────────────────────────────── -->
  <section class="widget">
    <div class="widget__head">
      <div>
        <h2 class="font-headline widget__title">周度收入热力图（最近 {weeks} 周）</h2>
        <p class="widget__sub">中期顾问 × 周（周一锚定）。色阶 = 当周该顾问 签约金额（实时）。已排除 已终止。Top 12 顾问。</p>
      </div>
      <div class="filter-row">
        {[4, 12, 26, 52].map(w => (
          <a href={`/internal/kanban/analytics?weeks=${w}`} class={`pill ${weeks === w ? 'pill--active' : ''}`}>
            {w} 周
          </a>
        ))}
      </div>
    </div>

    <div class="widget__head-stats">
      <div class="kpi"><div class="kpi__num">{sortedAdvisors.length}</div><div class="kpi__label">顾问</div></div>
      <div class="kpi"><div class="kpi__num">{grandContracts}</div><div class="kpi__label">合同</div></div>
      <div class="kpi kpi--accent"><div class="kpi__num">¥{fmtMoney(grandTotal)}</div><div class="kpi__label">总收入</div></div>
    </div>

    <div class="widget__body">
      {sortedAdvisors.length === 0 ? (
        <div class="empty">所选周内无数据</div>
      ) : (
        <div class="heatmap-wrap">
          <table class="heatmap">
            <thead>
              <tr>
                <th class="heatmap__advisor-h">顾问</th>
                {weekLabels.map(w => <th class="heatmap__week-h">{fmtWeekLabel(w)}</th>)}
                <th class="heatmap__total-h">合计</th>
              </tr>
            </thead>
            <tbody>
              {sortedAdvisors.map(adv => {
                const m = advisorWeekly.get(adv);
                const total = advisorTotal.get(adv) || 0;
                return (
                  <tr>
                    <td class="heatmap__advisor"><strong>{adv}</strong></td>
                    {weekLabels.map(w => {
                      const b = m?.get(w);
                      const val = b?.total || 0;
                      const cnt = b?.count || 0;
                      return (
                        <td
                          class={`heatmap__cell ${val > 0 ? 'has-value' : ''}`}
                          style={`background: ${colorFor(val)};`}
                          title={cnt > 0 ? `${cnt} 单 · ¥${fmtMoney(val)}` : ''}
                        >
                          {val > 0 && (
                            <div class="heatmap__cell-inner">
                              <div class="heatmap__amount">{fmtMoney(val)}</div>
                              <div class="heatmap__count">{cnt} 单</div>
                            </div>
                          )}
                        </td>
                      );
                    })}
                    <td class="heatmap__total font-mono">¥{fmtMoney(total)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          <div class="heatmap-legend">
            <span>色阶：</span>
            <div class="heatmap-legend__bar">
              {[0.15, 0.3, 0.5, 0.7, 0.85, 1].map(a => (
                <span class="heatmap-legend__step" style={`background: rgba(4, 47, 36, ${a});`}></span>
              ))}
            </div>
            <span>少 → 多 (max ¥{fmtMoney(maxCellValue)})</span>
          </div>
        </div>
      )}
    </div>
  </section>

  <p class="footnote">
    数据源：Supabase <code>contracts</code> 表，每周由 <code>scripts/import-signings.py</code> 同步自最新 ERP 客户签约明细。最近一次校准请看 <code>contracts.imported_at</code>。
  </p>
</InternalLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .page-title { font-size: 28px; }
  .page-subtitle { font-size: 13px; color: var(--text-muted); margin: 4px 0 0; }
  .back-link a {
    font-size: 13px; color: var(--text-muted); font-weight: 600;
  }
  .back-link a:hover { color: var(--primary); }

  .widget {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 28px;
    margin-bottom: 24px;
  }
  .widget__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 18px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .widget__title { font-size: 18px; margin: 0 0 4px; }
  .widget__sub { font-size: 12px; color: var(--text-muted); margin: 0; max-width: 60ch; line-height: 1.5; }
  .widget__head-stats {
    display: flex; gap: 24px; margin: 16px 0 22px; flex-wrap: wrap;
  }
  .widget__body { overflow-x: auto; }

  .kpi-row { display: flex; gap: 18px; flex-wrap: wrap; }
  .kpi {
    background: #fafbfc;
    border: 1px solid #eef0f3;
    border-radius: 8px;
    padding: 8px 14px;
    min-width: 80px;
    text-align: right;
  }
  .kpi__num {
    font-family: 'SF Mono', monospace;
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.5px;
  }
  .kpi__label {
    font-size: 10px;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
  }
  .kpi--accent { background: var(--primary); border-color: var(--primary); }
  .kpi--accent .kpi__num { color: white; }
  .kpi--accent .kpi__label { color: rgba(255,255,255,0.7); }

  .filter-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .pill {
    display: inline-flex; align-items: center;
    padding: 5px 12px;
    background: white;
    border: 1px solid #d4d4d8;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    transition: all 120ms ease;
    text-decoration: none;
  }
  .pill:hover { border-color: var(--primary); color: var(--primary); }
  .pill--active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .datatable {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .datatable th {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 2px solid #eef0f3;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 700;
  }
  .datatable th.num, .datatable td.num { text-align: right; }
  .datatable td {
    padding: 10px 12px;
    border-bottom: 1px solid #f5f5f7;
  }
  .datatable tbody tr:hover { background: #fafafa; }
  .datatable .empty { text-align: center; color: var(--text-soft); padding: 24px; }

  .pct-cell {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    color: white;
    font-weight: 700;
    background-color: #f1f5f9;
    color: var(--primary);
    /* gradient bg passed inline; this fallback gives small left-bar look */
    background-clip: padding-box;
    font-family: 'SF Mono', monospace;
    font-size: 12px;
    border: 1px solid #e0e7e3;
  }

  .heatmap-wrap { width: 100%; }
  .heatmap {
    border-collapse: separate;
    border-spacing: 1px;
    font-size: 11px;
  }
  .heatmap th { padding: 4px 6px; font-weight: 600; }
  .heatmap__advisor-h { text-align: left; min-width: 80px; }
  .heatmap__week-h {
    text-align: center;
    font-family: 'SF Mono', monospace;
    color: var(--text-muted);
    transform: rotate(-45deg);
    transform-origin: bottom left;
    height: 50px;
    font-size: 10px;
    white-space: nowrap;
  }
  .heatmap__total-h { text-align: right; font-weight: 700; padding-left: 12px; }
  .heatmap__advisor { font-size: 12px; padding: 2px 6px; }
  .heatmap__cell {
    width: 60px; height: 36px;
    text-align: center;
    color: white;
    font-weight: 700;
    font-size: 10px;
    line-height: 1.1;
    background: #f8fafc;
    border-radius: 3px;
    transition: transform 80ms ease;
    cursor: help;
  }
  .heatmap__cell:not(.has-value) { color: transparent; }
  .heatmap__cell.has-value:hover { transform: scale(1.15); z-index: 2; position: relative; }
  .heatmap__cell-inner {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 100%;
    padding: 1px;
  }
  .heatmap__amount { font-size: 10px; font-family: 'SF Mono', monospace; }
  .heatmap__count { font-size: 9px; opacity: 0.85; font-weight: 500; }
  .heatmap__total { padding: 2px 8px; font-weight: 700; }

  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    font-size: 11px;
    color: var(--text-muted);
  }
  .heatmap-legend__bar { display: inline-flex; gap: 1px; }
  .heatmap-legend__step {
    display: inline-block;
    width: 18px; height: 14px;
    border-radius: 2px;
  }

  .empty { padding: 30px; text-align: center; color: var(--text-soft); font-size: 13px; }
  .footnote { margin-top: 24px; font-size: 11px; color: var(--text-soft); text-align: center; }
  .footnote code { background: #f1f5f9; padding: 1px 5px; border-radius: 3px; font-size: 10px; }
</style>
