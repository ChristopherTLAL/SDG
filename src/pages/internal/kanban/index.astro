const tailFamiliesMonthly = new Set(monthlyFamiliesOrdered.slice(TOP_FAMS_FOR_MONTHLY));
// Build echarts series per family
const monthlySeries: { name: string; data: number[] }[] = [];
for (const fam of topFamiliesMonthly) {
