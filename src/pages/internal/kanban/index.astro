---
// /internal/kanban — analytics dashboard.
//
// Strategic / business view (vs the operational Overview). Long-scroll
// of widgets, each one a section-card. Data is pre-aggregated server-side
// and passed to client-side ECharts / Cytoscape via inline JSON for the
// charts that need it.
//
// Access: advisors and admin only. xdf guests bounce to dashboard.

import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { INACTIVE_STAGES } from '../../../utils/contact-radar';
import { SOPS } from '../../../data/contract-sops';

const viewer = Astro.locals?.viewer ?? null;
if (!viewer || (!viewer.isAdvisor && !viewer.isAdmin)) {
  return Astro.redirect('/internal');
}

const url = new URL(Astro.request.url);
const advisorFilter = url.searchParams.get('advisor') || '';

const PRIVATE_CONTRACTS = new Set(['私单', '私单（非公司合同）']);
function isPrivate(contracts: string[] | null | undefined): boolean {
  if (!contracts) return false;
  return contracts.some(c => PRIVATE_CONTRACTS.has(c));
}
const canSeePrivate = !!viewer && (viewer.isAdmin || viewer.name === '王世杰');

// Load every active student. Inactive (已结案/退费/已完成) excluded by default —
// these are historical and would skew the live business picture.
const { data: rawStudents } = await supabase
  .from('students')
  .select('id, name, stage, current_school, target_regions, mid_advisors, enroll_years, contracts');

const allStudents = (rawStudents ?? []) as Array<{
  id: number;
  name: string;
  stage: string | null;
  current_school: string | null;
  target_regions: string[] | null;
  mid_advisors: string[] | null;
  enroll_years: string[] | null;
  contracts: string[] | null;
}>;

const studentsBeforeAdvisor = allStudents.filter(s => {
  if (s.stage && INACTIVE_STAGES.has(s.stage)) return false;
  if (!canSeePrivate && isPrivate(s.contracts)) return false;
  return true;
});

// Apply the advisor filter to the four widgets that should respect it
// (school / region / stage-year / contract). The advisor activity heatmap
// always shows ALL advisors — it IS the team-comparison view, so filtering
// to one advisor would defeat its purpose.
const students = advisorFilter
  ? studentsBeforeAdvisor.filter(s =>
      Array.isArray(s.mid_advisors) && s.mid_advisors.includes(advisorFilter)
    )
  : studentsBeforeAdvisor;

function buildHref(advisor: string): string {
  return advisor ? `/internal/kanban?advisor=${encodeURIComponent(advisor)}` : '/internal/kanban';
}

// ── Widget 1: 在读学校分布 ──
const schoolCounts = new Map<string, number>();
for (const s of students) {
  const v = (s.current_school ?? '').trim();
  if (!v) continue;
  schoolCounts.set(v, (schoolCounts.get(v) ?? 0) + 1);
}
const schoolData = Array.from(schoolCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const TOP_SCHOOLS = 18;
const schoolTop = schoolData.slice(0, TOP_SCHOOLS);
const schoolRest = schoolData.slice(TOP_SCHOOLS);
const schoolRestSum = schoolRest.reduce((s, x) => s + x.count, 0);
const schoolChartData = schoolTop
  .slice()
  .reverse()
  .concat(schoolRestSum > 0 ? [{ name: `其他 (${schoolRest.length} 所)`, count: schoolRestSum }] : []);

// ── Widget 2: 申请地区分布 + 共申网络 ──
const regionCounts = new Map<string, number>();
const coOccur = new Map<string, number>(); // "A|B" sorted-key → student count with both
for (const s of students) {
  const regions = Array.from(new Set((s.target_regions ?? []).map(r => r.trim()).filter(Boolean)));
  for (const r of regions) {
    regionCounts.set(r, (regionCounts.get(r) ?? 0) + 1);
  }
  for (let i = 0; i < regions.length; i++) {
    for (let j = i + 1; j < regions.length; j++) {
      const k = [regions[i], regions[j]].sort().join('|');
      coOccur.set(k, (coOccur.get(k) ?? 0) + 1);
    }
  }
}
const regionData = Array.from(regionCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
// Cytoscape node + edge data
const networkNodes = regionData.map(r => ({ data: { id: r.name, label: r.name, weight: r.count } }));
const networkEdges = Array.from(coOccur.entries())
  .filter(([, w]) => w > 0)
  .map(([k, w]) => {
    const [a, b] = k.split('|');
    return { data: { id: `e_${a}_${b}`, source: a, target: b, weight: w } };
  });

// ── Widget 5: 阶段 × 入学年份 heatmap ──
const STAGE_ORDER = ['需对接', '中期在途', '后期在途'];
const yearSet = new Set<string>();
for (const s of students) {
  for (const y of s.enroll_years ?? []) {
    if (y) yearSet.add(y);
  }
}
const yearList = Array.from(yearSet).sort();
// matrix[year][stage] = count (multi-counted by year if student has multiple)
type StageYearCell = { year: string; stage: string; count: number };
const stageYearCells: StageYearCell[] = [];
for (const y of yearList) {
  for (const st of STAGE_ORDER) {
    const c = students.filter(s =>
      s.stage === st &&
      Array.isArray(s.enroll_years) &&
      s.enroll_years.includes(y)
    ).length;
    stageYearCells.push({ year: y, stage: st, count: c });
  }
}

// ── Widget 7+9: advisor activity heatmap ──
// Build last 12 weeks (Monday-anchored) as ISO date strings
const TODAY = new Date();
TODAY.setHours(0, 0, 0, 0);
function startOfWeek(d: Date): Date {
  const day = d.getDay() || 7;  // Sun=7 → treat as last day; Mon=1 (ISO week)
  const x = new Date(d);
  x.setDate(d.getDate() - (day - 1));
  return x;
}
function isoDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}
function fmtWeekLabel(d: Date): string {
  return `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
}
const weekStartToday = startOfWeek(TODAY);
const weeks: { start: string; label: string }[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(weekStartToday);
  d.setDate(weekStartToday.getDate() - i * 7);
  weeks.push({ start: isoDate(d), label: fmtWeekLabel(d) });
}
const weekIndexByStart = new Map(weeks.map((w, i) => [w.start, i]));

// All current advisors (from advisors table)
const { data: advisorRows } = await supabase
  .from('advisors')
  .select('name, roles')
  .eq('active', true);
const advisors = (advisorRows ?? [])
  .filter((a: any) => Array.isArray(a.roles) && a.roles.includes('中期'))
  .map((a: any) => a.name as string)
  .sort();

// Build student → mid_advisors map for attribution
const studentAdvisors = new Map<number, string[]>();
for (const s of allStudents) {  // use allStudents so historical activity attributes correctly
  studentAdvisors.set(s.id, s.mid_advisors ?? []);
}

const sinceCutoff = weeks[0].start;  // 12 weeks ago, Monday
const [{ data: notes }, { data: subs }] = await Promise.all([
  supabase
    .from('student_notes')
    .select('student_id, note_date')
    .gte('note_date', sinceCutoff)
    .not('note_date', 'is', null),
  supabase
    .from('submissions')
    .select('student_id, submitted_at')
    .gte('submitted_at', sinceCutoff)
    .not('student_id', 'is', null),
]);

function bumpActivity(matrix: Map<string, number[]>, advisor: string, weekIdx: number): void {
  const row = matrix.get(advisor);
  if (!row) return;
  row[weekIdx] = (row[weekIdx] ?? 0) + 1;
}

const activity = new Map<string, number[]>();  // advisor → [w0, w1, ..., w11]
for (const a of advisors) activity.set(a, new Array(weeks.length).fill(0));

for (const n of (notes ?? [])) {
  const day = (n.note_date as string).slice(0, 10);
  const ws = isoDate(startOfWeek(new Date(day)));
  const wi = weekIndexByStart.get(ws);
  if (wi === undefined) continue;
  const advisorList = studentAdvisors.get(n.student_id as number) ?? [];
  for (const a of advisorList) bumpActivity(activity, a, wi);
}
for (const sub of (subs ?? [])) {
  const day = (sub.submitted_at as string).slice(0, 10);
  const ws = isoDate(startOfWeek(new Date(day)));
  const wi = weekIndexByStart.get(ws);
  if (wi === undefined) continue;
  const advisorList = studentAdvisors.get(sub.student_id as number) ?? [];
  for (const a of advisorList) bumpActivity(activity, a, wi);
}

// Build ECharts heatmap data: array of [weekIdx, advisorIdx, count]
const heatmapData: [number, number, number][] = [];
let heatmapMax = 0;
advisors.forEach((a, ai) => {
  const row = activity.get(a) ?? [];
  row.forEach((cnt, wi) => {
    heatmapData.push([wi, ai, cnt]);
    if (cnt > heatmapMax) heatmapMax = cnt;
  });
});

// ── Widget 3: 合同分布 ──
const contractCounts = new Map<string, number>();
for (const s of students) {
  for (const c of s.contracts ?? []) {
    const v = c.trim();
    if (!v) continue;
    if (!canSeePrivate && PRIVATE_CONTRACTS.has(v)) continue;
    contractCounts.set(v, (contractCounts.get(v) ?? 0) + 1);
  }
}
const contractData = Array.from(contractCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

// Slugify contract name for the per-contract URL
function slug(s: string): string {
  return encodeURIComponent(s);
}

// Chip strip — same per-advisor counts the dashboard uses.
const advisorChipCounts = new Map<string, number>();
for (const s of studentsBeforeAdvisor) {
  for (const a of s.mid_advisors ?? []) {
    advisorChipCounts.set(a, (advisorChipCounts.get(a) ?? 0) + 1);
  }
}

// Donut payload — top-N + 其他 bucket so the slices stay legible.
const TOP_CONTRACTS = 10;
const contractDonut = (() => {
  const top = contractData.slice(0, TOP_CONTRACTS);
  const rest = contractData.slice(TOP_CONTRACTS);
  const restSum = rest.reduce((s, x) => s + x.count, 0);
  const out = top.map(c => ({ name: c.name, value: c.count }));
  if (restSum > 0) out.push({ name: `其他 (${rest.length} 种)`, value: restSum });
  return out;
})();

// Stage palette for the stacked bar — semantic progression (blue early,
// progressively deeper green as the student moves through the funnel).
const STAGE_COLORS: Record<string, string> = {
  '需对接':   '#3b82f6',
  '中期在途': '#10b981',
  '后期在途': '#047857',
};

// Pass everything client-side via JSON for the chart inits.
const chartPayload = {
  schoolChartData,
  regionData,
  network: { nodes: networkNodes, edges: networkEdges },
  stageYearCells,
  stages: STAGE_ORDER,
  stageColors: STAGE_COLORS,
  years: yearList,
  advisors,
  weeks: weeks.map(w => w.label),
  heatmapData,
  heatmapMax,
  contractDonut,
};
---

<InternalLayout title={advisorFilter ? `Kanban · ${advisorFilter}` : 'Kanban'} active="kanban">
  <h1 class="font-headline page-title">
    Kanban {advisorFilter && <span style="font-weight: 600; font-size: 22px; color: var(--primary);">· {advisorFilter}</span>}
  </h1>
  <p class="page-subtitle" style="margin-bottom: 16px;">
    {advisorFilter
      ? <>{advisorFilter} 名下在管学生 <strong style="color: var(--text);">{students.length}</strong>。下方四个图按这位顾问筛选；顾问活动热力图始终显示团队全貌。</>
      : <>业务分布与团队节奏。在管学生（不含已结案 / 已完成 / 退费）共 <strong style="color: var(--text);">{students.length}</strong>。</>}
  </p>

  <!-- Advisor filter chip strip — toggles 4 widgets (school / region /
       stage-year / contract). Heatmap always team-wide. -->
  <div class="filter-row" style="margin-bottom: 24px;">
    <span class="filter-row__label">中期</span>
    <a href={buildHref('')} class={`pill ${!advisorFilter ? 'pill--active' : ''}`}>All</a>
    {Array.from(advisorChipCounts.entries())
      .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
      .map(([name, count]) => (
        <a href={buildHref(name)} class={`pill ${advisorFilter === name ? 'pill--active' : ''}`}>
          {name} <span style="opacity: 0.6; margin-left: 2px;" class="font-mono">{count}</span>
        </a>
      ))}
  </div>

  <div class="kanban-grid">
    <aside class="kanban-toc">
      <div class="kanban-toc__label">章节</div>
      <ul>
        <li><a href="#kanban-advisors">顾问活动</a></li>
        <li><a href="#kanban-stage-year">阶段 × 入学届</a></li>
        <li><a href="#kanban-regions">申请地区</a></li>
        <li><a href="#kanban-schools">在读学校</a></li>
        <li><a href="#kanban-contracts">合同</a></li>
      </ul>
    </aside>

    <div class="kanban-main">
      <!-- ── 顾问活动热力图 ── -->
      <section id="kanban-advisors" class="section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            顾问活动热力 <span class="section-card__subtitle">最近 12 周沟通记录 + 提交（按学生 mid_advisor 多人归属）· 点行查看顾问详情</span>
          </h2>
        </div>
        {advisors.length === 0 ? (
          <p class="section-card__empty">暂无顾问数据。</p>
        ) : (
          <>
            <div id="chart-advisor-heatmap" style="width: 100%; height: 360px;"></div>
            <div class="advisor-jump-row">
              {advisors.map(a => (
                <a href={`/internal/kanban/advisors/${slug(a)}`} class="pill">{a}</a>
              ))}
            </div>
          </>
        )}
      </section>

      <!-- ── 阶段 × 入学年份（stacked horizontal bar） ── -->
      <section id="kanban-stage-year" class="section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            阶段 × 入学年份 <span class="section-card__subtitle">每届学生在阶段间的进度分布</span>
          </h2>
        </div>
        {stageYearCells.every(c => c.count === 0) ? (
          <p class="section-card__empty">暂无入学年份数据。</p>
        ) : (
          <div id="chart-stage-year" style={`width: 100%; height: ${Math.max(180, yearList.length * 56 + 60)}px;`}></div>
        )}
      </section>

      <!-- ── 申请地区共申网络 ── -->
      <section id="kanban-regions" class="section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            申请地区 <span class="section-card__subtitle">节点大小 = 学生数（标在节点上） · 连线粗细 = 共申学生数</span>
          </h2>
        </div>
        {regionData.length === 0 ? (
          <p class="section-card__empty">暂无目标地区数据。</p>
        ) : (
          <div id="chart-network" style="width: 100%; height: 560px; background: #fafbfc; border-radius: 10px; border: 1px solid #eef0f3;"></div>
        )}
      </section>

      <!-- ── 在读学校分布（treemap） ── -->
      <section id="kanban-schools" class="section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            在读学校分布 <span class="section-card__subtitle">方块面积 = 学生数 · {schoolData.length} 所学校 · 长尾合并</span>
          </h2>
        </div>
        {schoolChartData.length === 0 ? (
          <p class="section-card__empty">暂无在读学校数据。</p>
        ) : (
          <div id="chart-schools-treemap" style="width: 100%; height: 480px;"></div>
        )}
      </section>

      <!-- ── 合同分布（donut + drilldown list） ── -->
      <section id="kanban-contracts" class="section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            合同分布 <span class="section-card__subtitle">{contractData.length} 种合同 · 点击列表行查看详情</span>
          </h2>
        </div>
        {contractData.length === 0 ? (
          <p class="section-card__empty">暂无合同数据。</p>
        ) : (
          <div class="contract-split">
            <div id="chart-contracts-donut" style="width: 100%; height: 360px;"></div>
            <ul class="contract-list">
              {contractData.map(({ name, count }) => {
                const sopMatch = SOPS.find(s => s.matchPatterns.some(p => name.includes(p)));
                return (
                  <li>
                    <a href={`/internal/kanban/contracts/${slug(name)}`} class="contract-row">
                      <span class="contract-row__name">
                        {name}
                        {sopMatch && <em class="contract-row__hint"> → {sopMatch.displayName}</em>}
                      </span>
                      <span class="contract-row__bar-wrap">
                        <span class="contract-row__bar" style={`width: ${Math.max(2, (count / contractData[0].count) * 100)}%;`}></span>
                      </span>
                      <span class="contract-row__count font-mono">{count}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </section>
    </div>
  </div>

  <script type="application/json" id="chart-payload" set:html={JSON.stringify(chartPayload)}></script>

  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/cytoscape@3.30.4/dist/cytoscape.min.js" is:inline></script>

  <script is:inline>
    (function () {
      const payload = JSON.parse(document.getElementById('chart-payload').textContent);
      const PRIMARY = '#042f24';

      // Resize all chart instances on viewport change.
      const charts = [];
      window.addEventListener('resize', () => charts.forEach(c => c && c.resize()));

      // ── Schools: treemap ──
      // Area = student count. Color band based on count via gradient. Long-tail
      // schools (small tiles) still show a label since treemap auto-hides
      // labels that don't fit, but tooltip works on hover.
      const schoolEl = document.getElementById('chart-schools-treemap');
      if (schoolEl && payload.schoolChartData.length) {
        const c = echarts.init(schoolEl);
        charts.push(c);
        const data = payload.schoolChartData
          .slice()
          .sort((a, b) => b.count - a.count)
          .map(d => ({ name: d.name, value: d.count }));
        c.setOption({
          tooltip: {
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.value}</strong> 学生`,
          },
          series: [{
            type: 'treemap',
            data,
            roam: false,
            nodeClick: false,
            breadcrumb: { show: false },
            visibleMin: 0,
            label: {
              show: true,
              formatter: (p) => `{name|${p.data.name}}\n{val|${p.data.value}}`,
              rich: {
                name: { color: '#fff', fontSize: 13, fontWeight: 600, lineHeight: 18 },
                val:  { color: 'rgba(255,255,255,0.85)', fontSize: 11, fontWeight: 500 },
              },
            },
            upperLabel: { show: false },
            itemStyle: { borderColor: '#fff', borderWidth: 2, gapWidth: 2 },
            colorMappingBy: 'value',
            color: ['#bbf7d0', '#86efac', '#22c55e', '#16a34a', '#15803d', '#166534'],
          }],
        });
      }

      // ── Widget 2: co-application network (now full-width, name + count
      // shown inside each node, size scales with student count) ──
      const netEl = document.getElementById('chart-network');
      if (netEl && payload.network.nodes.length && typeof cytoscape !== 'undefined') {
        const cy = cytoscape({
          container: netEl,
          elements: [...payload.network.nodes, ...payload.network.edges],
          layout: {
            name: 'cose',
            animate: false,
            // fit + small padding pushes the laid-out graph to fill the
            // container. Bigger nodeRepulsion keeps the chunkier nodes from
            // overlapping; idealEdgeLength scales accordingly.
            fit: true,
            padding: 12,
            nodeRepulsion: 28000,
            idealEdgeLength: 200,
            edgeElasticity: 200,
          },
          style: [
            {
              selector: 'node',
              style: {
                'background-color': PRIMARY,
                // Two-line label: region name + student count
                'label': (n) => `${n.data('label')}\n${n.data('weight')}`,
                'text-wrap': 'wrap',
                'text-max-width': '160px',
                'color': '#ffffff',
                'font-size': 17,
                'font-weight': 800,
                'text-halign': 'center',
                'text-valign': 'center',
                'line-height': 1.2,
                'width':  (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'height': (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'border-width': 0,
              },
            },
            {
              selector: 'edge',
              style: {
                'line-color': '#94a3b8',
                'opacity': 0.7,
                'curve-style': 'bezier',
                'width': (e) => 1.5 + Math.min(e.data('weight'), 8) * 1.5,
                // Label edges with the co-app count when ≥ 2 (avoid clutter on
                // 1-student lines). White-bg pill keeps it readable on any
                // edge color.
                'label': (e) => e.data('weight') >= 2 ? String(e.data('weight')) : '',
                'font-size': 14,
                'font-weight': 700,
                'color': '#0f172a',
                'text-background-color': '#ffffff',
                'text-background-opacity': 0.92,
                'text-background-padding': '3px',
                'text-background-shape': 'roundrectangle',
                'text-rotation': 'autorotate',
              },
            },
            {
              selector: 'node:selected',
              style: { 'background-color': '#dc2626' },
            },
          ],
        });
        cy.userZoomingEnabled(false);
        cy.userPanningEnabled(false);
        // Cose layout sometimes finishes before the container has its
        // final paint size (Astro hydration / TOC sidebar pushing in).
        // resize + fit on next tick (and on every window resize) makes
        // the graph fill the container properly. Padding 40 leaves
        // breathing room around the outermost nodes.
        const refit = () => { cy.resize(); cy.fit(undefined, 12); };
        requestAnimationFrame(refit);
        window.addEventListener('resize', refit);
        // ResizeObserver catches the case where the kanban-grid shifts
        // (e.g. sidebar collapses on mobile) without a window resize event.
        if (typeof ResizeObserver !== 'undefined') {
          new ResizeObserver(refit).observe(netEl);
        }
      }

      // ── Stage × year: stacked horizontal bar (cohort funnel) ──
      // Each bar = one enroll year, segmented by stage. Reading from left to
      // right = progression through the pipeline.
      const syEl = document.getElementById('chart-stage-year');
      if (syEl && payload.years.length) {
        const c = echarts.init(syEl);
        charts.push(c);
        // Reverse years so the most recent / nearest cohort is on top.
        const yearsAxis = payload.years.slice().reverse();
        const series = payload.stages.map(stage => ({
          name: stage,
          type: 'bar',
          stack: 'cohort',
          itemStyle: { color: payload.stageColors[stage] || '#94a3b8' },
          barCategoryGap: '32%',
          data: yearsAxis.map(year => {
            const cell = payload.stageYearCells.find(x => x.year === year && x.stage === stage);
            return cell ? cell.count : 0;
          }),
          label: {
            show: true,
            position: 'inside',
            color: '#fff',
            fontWeight: 700,
            fontSize: 12,
            formatter: (p) => p.value > 0 ? p.value : '',
          },
        }));
        c.setOption({
          tooltip: {
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: (params) => {
              const year = params[0]?.axisValue ?? '';
              const total = params.reduce((s, p) => s + (p.value || 0), 0);
              const lines = params
                .filter(p => p.value > 0)
                .map(p => `${p.marker} ${p.seriesName}: <strong>${p.value}</strong>`)
                .join('<br/>');
              return `<div style="font-weight:700;margin-bottom:4px;">${year} · 共 ${total}</div>${lines}`;
            },
          },
          legend: {
            data: payload.stages,
            top: 0,
            right: 0,
            icon: 'roundRect',
            itemWidth: 12,
            itemHeight: 12,
            textStyle: { color: '#475569', fontSize: 12 },
          },
          grid: { left: 12, right: 60, top: 36, bottom: 12, containLabel: true },
          xAxis: {
            type: 'value',
            axisLine: { show: false },
            axisTick: { show: false },
            splitLine: { lineStyle: { color: '#eef0f3' } },
            axisLabel: { color: '#94a3b8', fontSize: 11 },
          },
          yAxis: {
            type: 'category',
            data: yearsAxis,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 13 },
          },
          series,
        });
      }

      // ── Widget 7+9: advisor heatmap ──
      const ahEl = document.getElementById('chart-advisor-heatmap');
      if (ahEl && payload.advisors.length) {
        const c = echarts.init(ahEl);
        charts.push(c);
        const maxV = Math.max(1, payload.heatmapMax);
        c.setOption({
          tooltip: {
            position: 'top',
            formatter: (p) => `${payload.advisors[p.value[1]]} · ${payload.weeks[p.value[0]]} 周<br/><strong>${p.value[2]}</strong> 条活动`,
          },
          grid: { left: 80, right: 16, top: 32, bottom: 50 },
          xAxis: {
            type: 'category',
            data: payload.weeks,
            position: 'top',
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#64748b', fontSize: 11 },
            splitArea: { show: true },
          },
          yAxis: {
            type: 'category',
            data: payload.advisors,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 12 },
            splitArea: { show: true },
          },
          visualMap: {
            min: 0,
            max: maxV,
            calculable: false,
            orient: 'horizontal',
            left: 'center',
            bottom: 0,
            itemWidth: 12,
            itemHeight: 120,
            inRange: { color: ['#f8fafc', '#dcfce7', '#86efac', '#16a34a'] },
            textStyle: { color: '#64748b', fontSize: 11 },
          },
          series: [{
            type: 'heatmap',
            data: payload.heatmapData,
            label: {
              show: true,
              fontSize: 11,
              color: '#0f172a',
              formatter: (p) => p.value[2] > 0 ? p.value[2] : '',
            },
            itemStyle: { borderColor: '#fff', borderWidth: 1 },
          }],
        });
        c.on('click', (params) => {
          if (params.value && typeof params.value[1] === 'number') {
            const advisor = payload.advisors[params.value[1]];
            if (advisor) location.href = '/internal/kanban/advisors/' + encodeURIComponent(advisor);
          }
        });
      }

      // ── Contracts: donut ──
      // Brand-aligned palette (greens + indigo + amber accents) so each
      // slice is distinguishable. Top-N + 其他 bucket built server-side.
      const dnEl = document.getElementById('chart-contracts-donut');
      if (dnEl && payload.contractDonut.length) {
        const c = echarts.init(dnEl);
        charts.push(c);
        const total = payload.contractDonut.reduce((s, x) => s + x.value, 0);
        c.setOption({
          tooltip: {
            trigger: 'item',
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.value}</strong> 学生 · ${(p.data.value / total * 100).toFixed(1)}%`,
          },
          legend: { show: false },
          color: ['#042f24', '#15803d', '#16a34a', '#22c55e', '#86efac', '#3b82f6', '#6366f1', '#8b5cf6', '#f59e0b', '#ef4444', '#94a3b8'],
          series: [{
            type: 'pie',
            radius: ['52%', '82%'],
            center: ['50%', '50%'],
            avoidLabelOverlap: true,
            itemStyle: { borderColor: '#fff', borderWidth: 2 },
            label: {
              show: true,
              position: 'outside',
              formatter: (p) => `{n|${p.data.name}}\n{v|${p.data.value} · ${(p.percent ?? 0).toFixed(0)}%}`,
              rich: {
                n: { color: '#0f172a', fontSize: 12, fontWeight: 600, lineHeight: 16 },
                v: { color: '#64748b', fontSize: 11, lineHeight: 14 },
              },
            },
            labelLine: { length: 10, length2: 14, lineStyle: { color: '#cbd5e1' } },
            emphasis: {
              scale: true,
              scaleSize: 6,
              label: { fontWeight: 700 },
            },
            data: payload.contractDonut,
          }],
          graphic: [{
            type: 'text',
            left: 'center',
            top: 'middle',
            style: {
              text: `${total}\n合同`,
              textAlign: 'center',
              fill: '#0f172a',
              fontSize: 18,
              fontWeight: 700,
              lineHeight: 22,
            },
          }],
        });
      }
    })();
  </script>

  <style>
    /* Sidebar TOC + main column */
    .kanban-grid {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 32px;
      align-items: start;
    }
    .kanban-toc {
      position: sticky;
      top: 80px;
      font-size: 13px;
    }
    .kanban-toc__label {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 8px;
      padding: 0 10px;
    }
    .kanban-toc ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 2px;
    }
    .kanban-toc li a {
      display: block;
      padding: 7px 10px;
      border-radius: 6px;
      color: var(--text-muted);
      font-weight: 500;
      transition: background 120ms, color 120ms;
    }
    .kanban-toc li a:hover {
      background: #f1f5f9;
      color: var(--text);
    }
    /* Smooth scroll + offset so anchored sections don't tuck under the
       site header. Each section also gets scroll-margin-top below. */
    .kanban-main { display: grid; gap: 0; }
    .kanban-main > section { scroll-margin-top: 24px; }
    @media (max-width: 800px) {
      .kanban-grid { grid-template-columns: 1fr; }
      .kanban-toc {
        position: static;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        padding: 8px 0;
        border-bottom: 1px solid #eef0f3;
      }
      .kanban-toc__label { display: none; }
      .kanban-toc ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2px;
      }
    }

    .advisor-jump-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid #eef0f3;
    }

    /* Contract widget split layout: donut on the left, drilldown list on
       the right. Donut takes a fixed column on desktop so the list keeps a
       useful width; on narrower screens both stack. */
    .contract-split {
      display: grid;
      grid-template-columns: minmax(280px, 380px) 1fr;
      gap: 24px;
      align-items: center;
    }
    @media (max-width: 800px) {
      .contract-split { grid-template-columns: 1fr; }
    }

    /* Contract list — 3-col grid (name+hint / bar / count). The hint sits
       inline inside the name cell so the grid stays balanced even when no
       SOP match exists for a contract. */
    .contract-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 4px;
    }
    .contract-row {
      display: grid;
      grid-template-columns: minmax(180px, 320px) minmax(0, 1fr) 50px;
      gap: 16px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 8px;
      transition: background 120ms ease;
    }
    .contract-row:hover { background: #f8fafc; }
    .contract-row__name {
      font-weight: 600;
      font-size: 13.5px;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .contract-row__hint {
      font-size: 11px;
      color: var(--text-soft);
      letter-spacing: 0.04em;
      font-style: normal;
      font-weight: 500;
      margin-left: 4px;
    }
    .contract-row__bar-wrap {
      height: 8px;
      background: #f1f5f9;
      border-radius: 4px;
      overflow: hidden;
    }
    .contract-row__bar {
      display: block;
      height: 100%;
      background: var(--primary);
      border-radius: 4px;
      transition: width 240ms ease;
    }
    .contract-row__count {
      font-weight: 700;
      font-size: 13px;
      color: var(--text-muted);
      text-align: right;
    }

    html { scroll-behavior: smooth; }
  </style>
</InternalLayout>
