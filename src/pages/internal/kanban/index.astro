  <script type="application/json" id="chart-payload" set:html={JSON.stringify(chartPayload)}></script>

  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/cytoscape@3.30.4/dist/cytoscape.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.13/dist/html-to-image.min.js" is:inline></script>

  <script is:inline>
    (function () {
      const payload = JSON.parse(document.getElementById('chart-payload').textContent);

      // Resize all chart instances on viewport change.
      const charts = [];
      window.addEventListener('resize', () => charts.forEach(c => c && c.resize()));

      // ── Tab switching: hide non-active panels; resize charts on activate ──
      const tabButtons = document.querySelectorAll('.kanban-tab');
      const panels = document.querySelectorAll('.kanban-panel');
      function activateTab(name) {
        tabButtons.forEach(b => b.classList.toggle('is-active', b.dataset.tab === name));
        panels.forEach(p => p.classList.toggle('is-active', p.dataset.panel === name));
        // Charts inside hidden panels render at 0×0; force resize on activate.
        requestAnimationFrame(() => charts.forEach(c => c && c.resize()));
      }
      tabButtons.forEach(b => {
        b.addEventListener('click', () => activateTab(b.dataset.tab));
      });

      // ── 合同分布: hover any row → highlight same advisor in all 3 columns ──
      function highlightAdvisor(name, on) {
        document.querySelectorAll(`.cp-row[data-advisor="${CSS.escape(name)}"]`)
          .forEach(el => el.classList.toggle('is-paired', on));
      }
      document.querySelectorAll('.cp-row').forEach(row => {
        row.addEventListener('mouseenter', () => highlightAdvisor(row.dataset.advisor, true));
        row.addEventListener('mouseleave', () => highlightAdvisor(row.dataset.advisor, false));
      });

      // Mark body for fixed-shell CSS (no page scroll)
      document.body.classList.add('kanban-page');

      // ── Schools: treemap (Morandi, per-tile explicit color) ──
      // ECharts treemap was applying its own color treatment on top of my
      // palette (presumably saturation/value adjustments based on tile
      // size) which kept making the colors read as bright primaries instead
      // of muted Morandi. Set itemStyle.color directly on each data point —
      // ECharts treats that as authoritative and won't post-process. Donut
      // palette is reused verbatim since this view's not the issue. The
      // sqrt sizing + 其他 bucket exclusion stay.
      const schoolEl = document.getElementById('chart-schools-treemap');
      if (schoolEl && payload.schoolChartData.length) {
        const c = echarts.init(schoolEl);
        charts.push(c);
        const data = payload.schoolChartData
          .filter(d => !d.name.startsWith('其他'))
          .slice()
          .sort((a, b) => b.count - a.count)
          .map(d => ({
            name: d.name,
            value: Math.sqrt(d.count),
            realCount: d.count,
            itemStyle: { color: payload.schoolColors[d.name] || '#ADA39A' },
          }));
        c.setOption({
          tooltip: {
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.realCount}</strong> 学生`,
          },
          series: [{
            type: 'treemap',
            data,
            roam: false,
            nodeClick: false,
            breadcrumb: { show: false },
            visibleMin: 0,
            label: {
              show: true,
              formatter: (p) => `{name|${p.data.name}}\n{val|${p.data.realCount}}`,
              rich: {
                name: { color: '#3a3835', fontSize: 13, fontWeight: 600, lineHeight: 18 },
                val:  { color: 'rgba(58, 56, 53, 0.65)', fontSize: 11, fontWeight: 500 },
              },
            },
            upperLabel: { show: false },
            // Don't let ECharts auto-derive colors — items already carry them.
            colorMappingBy: 'value',
            colorAlpha: 1,
            colorSaturation: 1,
            levels: [{
              itemStyle: { borderColor: '#fafaf8', borderWidth: 3, gapWidth: 3 },
              colorAlpha: 1,
              colorSaturation: 1,
            }],
          }],
        });
      }

      // ── Widget 2: co-application network (now full-width, name + count
      // shown inside each node, size scales with student count) ──
      const netEl = document.getElementById('chart-network');
      if (netEl && payload.network.nodes.length && typeof cytoscape !== 'undefined') {
        const cy = cytoscape({
          container: netEl,
          elements: [...payload.network.nodes, ...payload.network.edges],
          layout: {
            name: 'cose',
            animate: false,
            // fit + small padding pushes the laid-out graph to fill the
            // container. Bigger nodeRepulsion keeps the chunkier nodes from
            // overlapping; idealEdgeLength scales accordingly. Higher
            // gravity (default 1) pulls nodes — including disconnected
            // ones — toward the center so an island region doesn't drift
            // to the corner of the canvas.
            fit: true,
            padding: 12,
            nodeRepulsion: 28000,
            idealEdgeLength: 200,
            edgeElasticity: 200,
            gravity: 2.5,
          },
          style: [
            {
              selector: 'node',
              style: {
                // Each node draws from the Morandi palette via data(color).
                'background-color': 'data(color)',
                // Two-line label: region name + student count
                'label': (n) => `${n.data('label')}\n${n.data('weight')}`,
                'text-wrap': 'wrap',
                'text-max-width': '160px',
                'color': '#3a3835',  // dark text reads on every Morandi tone
                'font-size': 17,
                'font-weight': 800,
                'text-halign': 'center',
                'text-valign': 'center',
                'line-height': 1.2,
                'width':  (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'height': (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'border-width': 0,
              },
            },
            {
              selector: 'edge',
              style: {
                'line-color': '#A8A39A',  // warm neutral grey — Morandi-ish
                'opacity': 0.7,
                'curve-style': 'bezier',
                'width': (e) => 1.5 + Math.min(e.data('weight'), 8) * 1.5,
                // Label edges with the co-app count when ≥ 2 (avoid clutter on
                // 1-student lines). White-bg pill keeps it readable on any
                // edge color.
                'label': (e) => e.data('weight') >= 2 ? String(e.data('weight')) : '',
                'font-size': 14,
                'font-weight': 700,
                'color': '#3a3835',
                'text-background-color': '#ffffff',
                'text-background-opacity': 0.92,
                'text-background-padding': '3px',
                'text-background-shape': 'roundrectangle',
                'text-rotation': 'autorotate',
              },
            },
            {
              selector: 'node:selected',
              style: { 'border-width': 3, 'border-color': '#3a3835' },
            },
          ],
        });
        cy.userZoomingEnabled(false);
        cy.userPanningEnabled(false);
        // Cose layout sometimes finishes before the container has its
        // final paint size (Astro hydration / TOC sidebar pushing in).
        // resize + fit on next tick (and on every window resize) makes
        // the graph fill the container properly. Padding 40 leaves
        // breathing room around the outermost nodes.
        const refit = () => { cy.resize(); cy.fit(undefined, 12); };
        requestAnimationFrame(refit);
        window.addEventListener('resize', refit);
        // ResizeObserver catches the case where the kanban-grid shifts
        // (e.g. sidebar collapses on mobile) without a window resize event.
        if (typeof ResizeObserver !== 'undefined') {
          new ResizeObserver(refit).observe(netEl);
        }

        // ── Panel: layout sliders, selection details, centrality ranking ──
        const sliders = document.querySelectorAll('.network-panel input[type="range"]');
        const baseLayout = {
          name: 'cose', animate: false, fit: true, padding: 12,
          edgeElasticity: 200,
        };
        let layoutTimer = null;
        const reLayout = () => {
          const params = { ...baseLayout };
          sliders.forEach(s => { params[s.dataset.tweak] = Number(s.value); });
          clearTimeout(layoutTimer);
          // 80ms debounce so dragging the slider isn't laggy.
          layoutTimer = setTimeout(() => cy.layout(params).run(), 80);
        };
        sliders.forEach(s => s.addEventListener('input', reLayout));

        const resetBtn = document.getElementById('network-reset');
        if (resetBtn) {
          resetBtn.addEventListener('click', () => {
            const defaults = { nodeRepulsion: 28000, idealEdgeLength: 200, gravity: 2.5 };
            sliders.forEach(s => { s.value = String(defaults[s.dataset.tweak]); });
            reLayout();
          });
        }

        // Centrality ranking — degree (= # of co-application connections).
        // Ties broken by student count.
        const centralityEl = document.getElementById('network-centrality');
        const ranks = cy.nodes().map(n => ({
          id: n.id(),
          name: n.data('label'),
          weight: n.data('weight'),
          color: n.data('color'),
          degree: n.degree(),
        })).sort((a, b) => b.degree - a.degree || b.weight - a.weight);
        const maxDegree = Math.max(1, ...ranks.map(r => r.degree));
        if (centralityEl) {
          centralityEl.innerHTML = ranks.map((r, i) => `
            <li data-region="${encodeURIComponent(r.id)}">
              <span class="panel-ranking__rank">${i + 1}</span>
              <span>
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${r.color};margin-right:6px;"></span>${r.name}
                <span class="panel-ranking__bar"><span style="width:${(r.degree / maxDegree) * 100}%;"></span></span>
              </span>
              <span style="text-align:right;font-weight:600;">${r.degree}</span>
            </li>
          `).join('');
          centralityEl.querySelectorAll('li').forEach(li => {
            li.addEventListener('click', () => {
              const id = decodeURIComponent(li.dataset.region || '');
              const node = cy.getElementById(id);
              if (node && node.length) {
                cy.elements().unselect();
                node.select();
                showSelection(node);
              }
            });
          });
        }

        // Selection panel — fill with neighborhood + co-app counts when a
        // node is clicked. Click-on-empty-canvas clears it.
        const selEl = document.getElementById('network-selection');
        const showSelection = (node) => {
          if (!selEl) return;
          const region = node.data('label');
          const total = node.data('weight');
          const color = node.data('color');
          const neighbors = node.connectedEdges().map(edge => {
            const other = edge.source().id() === node.id() ? edge.target() : edge.source();
            return { name: other.data('label'), color: other.data('color'), weight: edge.data('weight') };
          }).sort((a, b) => b.weight - a.weight);
          const list = neighbors.length === 0
            ? '<p class="panel-empty" style="margin-top:8px;">没有共申地区（孤立节点）</p>'
            : `<ul class="panel-coapps">${neighbors.map(n => `
                <li>
                  <span><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${n.color};margin-right:6px;vertical-align:middle;"></span>${n.name}</span>
                  <strong>${n.weight}</strong>
                </li>`).join('')}</ul>`;
          selEl.innerHTML = `
            <div class="panel-label">节点详情</div>
            <div class="panel-region">
              <span class="panel-region__dot" style="background:${color};"></span>
              ${region}
              <span class="panel-region__count">${total} 学生</span>
            </div>
            <div style="font-size:11px;color:var(--text-soft);text-transform:uppercase;letter-spacing:0.08em;margin-top:8px;">共申地区 (${neighbors.length})</div>
            ${list}
          `;
          // Highlight the matching row in the centrality ranking
          if (centralityEl) {
            centralityEl.querySelectorAll('li').forEach(li => {
              li.classList.toggle('is-active', decodeURIComponent(li.dataset.region || '') === node.id());
            });
          }
        };
        cy.on('tap', 'node', (e) => showSelection(e.target));
        cy.on('tap', (e) => {
          // Clicked outside any node → clear selection panel
          if (e.target === cy) {
            if (selEl) {
              selEl.innerHTML = `
                <div class="panel-label">节点详情</div>
                <p class="panel-empty">点一个节点查看共申关系</p>
              `;
            }
            if (centralityEl) {
              centralityEl.querySelectorAll('li').forEach(li => li.classList.remove('is-active'));
            }
          }
        });
      }

      // ── Stage × year: stacked horizontal bar (cohort funnel) ──
      // Each bar = one enroll year, segmented by stage. Reading from left to
      // right = progression through the pipeline.
      const syEl = document.getElementById('chart-stage-year');
      if (syEl && payload.years.length) {
        const c = echarts.init(syEl);
        charts.push(c);
        // Reverse years so the most recent / nearest cohort is on top.
        const yearsAxis = payload.years.slice().reverse();
        const series = payload.stages.map(stage => ({
          name: stage,
          type: 'bar',
          stack: 'cohort',
          itemStyle: { color: payload.stageColors[stage] || '#94a3b8' },
          barCategoryGap: '32%',
          data: yearsAxis.map(year => {
            const cell = payload.stageYearCells.find(x => x.year === year && x.stage === stage);
            return cell ? cell.count : 0;
          }),
          label: {
            show: true,
            position: 'inside',
            color: '#fff',
            fontWeight: 700,
            fontSize: 12,
            formatter: (p) => p.value > 0 ? p.value : '',
          },
        }));
        c.setOption({
          tooltip: {
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: (params) => {
              const year = params[0]?.axisValue ?? '';
              const total = params.reduce((s, p) => s + (p.value || 0), 0);
              const lines = params
                .filter(p => p.value > 0)
                .map(p => `${p.marker} ${p.seriesName}: <strong>${p.value}</strong>`)
                .join('<br/>');
              return `<div style="font-weight:700;margin-bottom:4px;">${year} · 共 ${total}</div>${lines}`;
            },
          },
          legend: {
            data: payload.stages,
            top: 0,
            right: 0,
            icon: 'roundRect',
            itemWidth: 12,
            itemHeight: 12,
            textStyle: { color: '#475569', fontSize: 12 },
          },
          grid: { left: 12, right: 60, top: 36, bottom: 12, containLabel: true },
          xAxis: {
            type: 'value',
            axisLine: { show: false },
            axisTick: { show: false },
            splitLine: { lineStyle: { color: '#eef0f3' } },
            axisLabel: { color: '#94a3b8', fontSize: 11 },
          },
          yAxis: {
            type: 'category',
            data: yearsAxis,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 13 },
          },
          series,
        });
      }

      // ── Widget 7+9: advisor heatmap ──
      const ahEl = document.getElementById('chart-advisor-heatmap');
      if (ahEl && payload.advisors.length) {
        const c = echarts.init(ahEl);
        charts.push(c);
        const maxV = Math.max(1, payload.heatmapMax);
        c.setOption({
          tooltip: {
            position: 'top',
            formatter: (p) => `${payload.advisors[p.value[1]]} · ${payload.weeks[p.value[0]]} 周<br/><strong>${p.value[2]}</strong> 条活动`,
          },
          grid: { left: 80, right: 16, top: 32, bottom: 50 },
          xAxis: {
            type: 'category',
            data: payload.weeks,
            position: 'top',
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#64748b', fontSize: 11 },
            splitArea: { show: true },
          },
          yAxis: {
            type: 'category',
            data: payload.advisors,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 12 },
            splitArea: { show: true },
          },
          visualMap: {
            min: 0,
            max: maxV,
            calculable: false,
            orient: 'horizontal',
            left: 'center',
            bottom: 0,
            itemWidth: 12,
            itemHeight: 120,
            // pale → smoky-purple gradient (matches the deep tone reserved
            // for 后期在途 in the stage chart, so the page hangs together).
            inRange: { color: ['#f8fafc', '#EDE5ED', '#D1BFD1', '#B5A0B5'] },
            textStyle: { color: '#64748b', fontSize: 11 },
          },
          series: [{
            type: 'heatmap',
            data: payload.heatmapData,
            label: {
              show: true,
              fontSize: 11,
              color: '#0f172a',
              formatter: (p) => p.value[2] > 0 ? p.value[2] : '',
            },
            itemStyle: { borderColor: '#fff', borderWidth: 1 },
          }],
        });
        c.on('click', (params) => {
          if (params.value && typeof params.value[1] === 'number') {
            const advisor = payload.advisors[params.value[1]];
            if (advisor) location.href = '/internal/kanban/advisors/' + encodeURIComponent(advisor);
          }
        });
      }

      // ── Donut helper (Morandi palette, slices optionally clickable) ──
      // Top-N + 其他 bucket built server-side. donut data is { name, value }[].
      function renderDonut(elId, donutData, colorMap, options) {
        const el = document.getElementById(elId);
        if (!el || !donutData.length) return;
        const c = echarts.init(el);
        charts.push(c);
        const total = donutData.reduce((s, x) => s + x.value, 0);
        const unit = options.unit || '学生';
        const centerLabel = options.centerLabel || `${total}\n${unit}`;
        const slices = donutData.map(d => ({
          name: d.name,
          value: d.value,
          itemStyle: {
            color: d.name.startsWith('其他') ? '#ADA39A' : (colorMap[d.name] || '#ADA39A'),
          },
        }));
        c.setOption({
          tooltip: {
            trigger: 'item',
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.value}</strong> ${unit} · ${(p.data.value / total * 100).toFixed(1)}%`,
          },
          legend: { show: false },
          series: [{
            type: 'pie',
            radius: ['52%', '82%'],
            center: ['50%', '50%'],
            avoidLabelOverlap: true,
            itemStyle: { borderColor: '#fafaf8', borderWidth: 2 },
            label: {
              show: true,
              position: 'outside',
              formatter: (p) => `{n|${p.data.name}}\n{v|${p.data.value} · ${(p.percent ?? 0).toFixed(0)}%}`,
              rich: {
                n: { color: '#3a3835', fontSize: 12, fontWeight: 600, lineHeight: 16 },
                v: { color: '#7a7872', fontSize: 11, lineHeight: 14 },
              },
            },
            labelLine: { length: 12, length2: 16, lineStyle: { color: '#cbd5e1' } },
            emphasis: {
              scale: true,
              scaleSize: 8,
              label: { fontWeight: 700 },
              itemStyle: { shadowBlur: 12, shadowColor: 'rgba(0,0,0,0.08)' },
            },
            data: slices,
          }],
          graphic: [{
            type: 'text',
            left: 'center',
            top: 'middle',
            style: {
              text: centerLabel,
              textAlign: 'center',
              fill: '#3a3835',
              fontSize: 22,
              fontWeight: 700,
              lineHeight: 28,
            },
          }],
        });
        if (options.onSliceClick) {
          c.on('click', (params) => {
            if (!params || !params.data || !params.data.name) return;
            if (params.data.name.startsWith('其他')) return;
            options.onSliceClick(params.data.name);
          });
          el.style.cursor = 'pointer';
        }
      }

      // (留学/产品 donut charts replaced 2026-05-09 by per-advisor paired
      // widgets above — see #kanban-liuxue. Donut chart-id divs no longer
      // exist; renderDonut calls were removed to avoid orphan errors.)

      // ── 月度产品节奏: stacked bar (12+ families × 24 months) ──
      const mpEl = document.getElementById('chart-monthly-products');
      if (mpEl && payload.monthlyMonths && payload.monthlyMonths.length) {
        const c = echarts.init(mpEl);
        charts.push(c);
        const fmtY = (v) => {
          if (v >= 10000) return (v / 10000).toFixed(1) + '万';
          return v.toLocaleString();
        };
        c.setOption({
          tooltip: {
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: (params) => {
              const month = params[0].axisValue;
              const lines = params
                .filter(p => p.value > 0)
                .sort((a, b) => b.value - a.value)
                .map(p => `${p.marker} ${p.seriesName}: <strong>¥${fmtY(p.value)}</strong>`);
              const total = params.reduce((s, p) => s + p.value, 0);
              return `<div style="font-weight:600;margin-bottom:4px;">${month}</div>${lines.join('<br/>')}<div style="margin-top:4px;padding-top:4px;border-top:1px solid #eee;color:#666;">合计 ¥${fmtY(total)}</div>`;
            },
          },
          legend: {
            top: 0,
            type: 'scroll',
            textStyle: { fontSize: 11, color: '#555' },
          },
          grid: { left: 60, right: 24, top: 40, bottom: 40 },
          xAxis: {
            type: 'category',
            data: payload.monthlyMonths,
            axisLabel: { fontSize: 10, color: '#888', rotate: 45 },
            axisTick: { show: false },
            axisLine: { lineStyle: { color: '#ddd' } },
          },
          yAxis: {
            type: 'value',
            axisLabel: { fontSize: 10, color: '#888', formatter: fmtY },
            axisLine: { show: false },
            axisTick: { show: false },
            splitLine: { lineStyle: { color: '#f1f1f4' } },
          },
          series: payload.monthlySeries.map(s => ({
            name: s.name,
            type: 'bar',
            stack: 'total',
            data: s.data,
            itemStyle: { color: payload.monthlyFamilyColors[s.name] || '#c4c4c4' },
            emphasis: { focus: 'series' },
            barWidth: '70%',
          })),
        });
      }

      // ── 顾问 portfolio scatter (4 windows, pill-switchable, quadrants) ──
      const pfEl = document.getElementById('chart-portfolio');
      let pfChart = null;
      if (pfEl && payload.portfolioData) {
        pfChart = echarts.init(pfEl);
        charts.push(pfChart);
        const advisorColors = {};
        const palette = ['#a8b5c9', '#b8a98a', '#9eb89e', '#c5a3a3', '#a89bb5', '#bfb38a', '#9bb5b5', '#c8a78a', '#a8a8b8', '#b89e9e'];
        const allAdvisors = (payload.portfolioData['48'] || []).map(p => p.advisor);
        allAdvisors.forEach((a, i) => { advisorColors[a] = palette[i % palette.length]; });

        const fmtMoney = (v) => {
          if (v >= 10000) return (v / 10000).toFixed(1) + '万';
          return v.toLocaleString();
        };
        function median(arr) {
          if (!arr.length) return 0;
          const s = [...arr].sort((a, b) => a - b);
          const m = Math.floor(s.length / 2);
          return s.length % 2 === 0 ? (s[m - 1] + s[m]) / 2 : s[m];
        }

        function renderPortfolio(windowKey) {
          const pointsAll = payload.portfolioData[windowKey] || [];
          // Drop totally-inactive advisors (0 students, 0 revenue) for cleaner viz
          const points = pointsAll.filter(p => p.students > 0 || p.revenue > 0);
          const maxComms = Math.max(1, ...points.map(p => p.comms));
          const medX = median(points.map(p => p.students));
          const medY = median(points.map(p => p.revenue));
          const data = points.map(p => ({
            name: p.advisor,
            value: [p.students, p.revenue, p.comms],
            itemStyle: { color: advisorColors[p.advisor] || '#c4c4c4' },
            symbolSize: 14 + (p.comms / maxComms) * 36,
          }));
          pfChart.setOption({
            tooltip: {
              trigger: 'item',
              formatter: (p) => `<strong>${p.data.name}</strong><br/>学生: ${p.value[0]}<br/>签约: ¥${fmtMoney(p.value[1])}<br/>沟通频次: ${p.value[2]}`,
            },
            grid: { left: 70, right: 40, top: 30, bottom: 55 },
            xAxis: {
              type: 'value',
              name: '学生数 →',
              nameLocation: 'middle',
              nameGap: 32,
              nameTextStyle: { fontSize: 11, color: '#888' },
              axisLabel: { fontSize: 10, color: '#888' },
              splitLine: { lineStyle: { color: '#f1f1f4' } },
            },
            yAxis: {
              type: 'value',
              name: '签约 ¥ →',
              nameLocation: 'middle',
              nameGap: 56,
              nameTextStyle: { fontSize: 11, color: '#888' },
              axisLabel: { fontSize: 10, color: '#888', formatter: fmtMoney },
              splitLine: { lineStyle: { color: '#f1f1f4' } },
            },
            graphic: [
              // Quadrant labels — anchored to corners of grid area
              { type: 'text', right: 50, top: 38, style: { text: '明星\n量大 · 单大', fontSize: 10, fill: '#94a3b8', textAlign: 'right', lineHeight: 13 } },
              { type: 'text', left: 80, top: 38, style: { text: '高客单\n人少 · 单大', fontSize: 10, fill: '#94a3b8', textAlign: 'left', lineHeight: 13 } },
              { type: 'text', left: 80, bottom: 65, style: { text: '起步\n人少 · 单小', fontSize: 10, fill: '#94a3b8', textAlign: 'left', lineHeight: 13 } },
              { type: 'text', right: 50, bottom: 65, style: { text: '走量\n人多 · 单小', fontSize: 10, fill: '#94a3b8', textAlign: 'right', lineHeight: 13 } },
            ],
            series: [{
              type: 'scatter',
              data,
              label: {
                show: true,
                position: 'right',
                formatter: (p) => p.data.name,
                fontSize: 11,
                color: '#333',
                fontWeight: 600,
              },
              emphasis: {
                scale: 1.2,
                label: { fontWeight: 700 },
              },
              markLine: {
                silent: true,
                symbol: 'none',
                label: {
                  show: true,
                  formatter: (p) => p.data.xAxis !== undefined ? `中位 ${p.data.xAxis}` : `中位 ${fmtMoney(p.data.yAxis)}`,
                  fontSize: 9,
                  color: '#94a3b8',
                  position: 'end',
                },
                lineStyle: { color: '#cbd5e1', type: 'dashed', width: 1 },
                data: [
                  { xAxis: medX },
                  { yAxis: medY },
                ],
              },
            }],
          }, true);
        }
        renderPortfolio('48');  // default

        document.querySelectorAll('[data-panel="portfolio"] .pf-pill').forEach(btn => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('[data-panel="portfolio"] .pf-pill').forEach(b => b.classList.remove('is-active'));
            btn.classList.add('is-active');
            renderPortfolio(btn.dataset.window);
          });
        });
      }

      // ── 周度签约: 4-window pill switcher (HTML table panes) ──
      const wkPills = document.querySelectorAll('[data-panel="weekly"] .wk-pill');
      const wkPanes = document.querySelectorAll('[data-panel="weekly"] .wk-pane');
      wkPills.forEach(btn => {
        btn.addEventListener('click', () => {
          wkPills.forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          wkPanes.forEach(p => p.classList.toggle('is-active', p.dataset.window === btn.dataset.window));
        });
      });

      // ─────────────────────────────────────────────────────
      // 周报导出 drawer + 长图 渲染 (data-table edition)
      // ─────────────────────────────────────────────────────
      const REPORT_WIDTH = 1080;

      // 3 fixed data widgets — clean HTML tables, no chart cloning
      const DATA_WIDGETS = [
        { id: 'enroll',   label: '在管学生分布（入学届 × 中期）' },
        { id: 'signings', label: '上周新签约（按顾问）' },
        { id: 'comms',    label: '上周学生沟通（按顾问）' },
      ];

      // Default templates for top + bottom fixed text sections
      const DEFAULT_TOP_TEMPLATE =
`本周关键观察

1.
2.
3.

风险或机会

· `;
      const DEFAULT_BOTTOM_TEMPLATE =
`下周重点

1.
2.

需要支持

· `;

      // State
      let dataItems = DATA_WIDGETS.map(w => ({ ...w, checked: true, note: '' }));
      let middleTexts = [];  // [{ title, body }]

      // Init fixed textareas with template
      const topNoteEl = document.getElementById('report-top-note');
      const bottomNoteEl = document.getElementById('report-bottom-note');
      topNoteEl.value = DEFAULT_TOP_TEMPLATE;
      bottomNoteEl.value = DEFAULT_BOTTOM_TEMPLATE;

      // Build helpers (DOM API — bulletproof)
      function makeIcon(name) {
        const span = document.createElement('span');
        span.className = 'material-symbols-outlined';
        span.textContent = name;
        return span;
      }
      function makeBtn({ act, icon, title, disabled, danger }) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'report-item__btn' + (danger ? ' report-item__btn--danger' : '');
        b.dataset.act = act;
        b.title = title;
        b.setAttribute('aria-label', title);
        if (disabled) b.disabled = true;
        b.appendChild(makeIcon(icon));
        return b;
      }

      // ── List 1: data items (3 fixed widgets, checkbox + note, NO drag) ──
      const dataItemsEl = document.getElementById('report-items');
      function renderDataItems() {
        dataItemsEl.innerHTML = '';
        dataItems.forEach((item, idx) => {
          const li = document.createElement('li');
          li.className = 'report-item';
          li.dataset.idx = String(idx);

          const row = document.createElement('div');
          row.className = 'report-item__row';

          const main = document.createElement('label');
          main.className = 'report-item__main';
          const cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.checked = !!item.checked;
          cb.dataset.act = 'di-check';
          main.appendChild(cb);
          const lbl = document.createElement('span');
          lbl.className = 'report-item__label';
          lbl.textContent = item.label;
          main.appendChild(lbl);
          row.appendChild(main);

          const actions = document.createElement('div');
          actions.className = 'report-item__actions';
          actions.appendChild(makeBtn({
            act: 'di-note',
            icon: item.note ? 'edit_note' : 'add_comment',
            title: item.note ? '编辑批注' : '加批注',
          }));
          row.appendChild(actions);
          li.appendChild(row);

          const noteWrap = document.createElement('div');
          noteWrap.className = 'report-item__note';
          if (item.note) noteWrap.classList.add('is-open');
          const ta = document.createElement('textarea');
          ta.dataset.act = 'di-note-input';
          ta.placeholder = '可选 · 给这个数据板块加一句话注解';
          ta.value = item.note || '';
          noteWrap.appendChild(ta);
          li.appendChild(noteWrap);

          dataItemsEl.appendChild(li);
        });
      }
      renderDataItems();
      dataItemsEl.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-act], input[data-act]');
        if (!btn) return;
        const li = btn.closest('.report-item');
        if (!li) return;
        const idx = Number(li.dataset.idx);
        const act = btn.dataset.act;
        if (act === 'di-check') {
          dataItems[idx].checked = btn.checked;
        } else if (act === 'di-note') {
          li.querySelector('.report-item__note').classList.toggle('is-open');
        }
      });
      dataItemsEl.addEventListener('input', (e) => {
        const t = e.target;
        if (t.dataset.act !== 'di-note-input') return;
        const idx = Number(t.closest('.report-item').dataset.idx);
        dataItems[idx].note = t.value;
      });

      // ── List 2: middle text sections (reorderable via drag) ──
      const midEl = document.getElementById('report-middle-texts');
      function renderMiddleTexts() {
        midEl.innerHTML = '';
        const total = middleTexts.length;
        middleTexts.forEach((item, idx) => {
          const li = document.createElement('li');
          li.className = 'report-item report-item--text';
          li.dataset.idx = String(idx);

          const row = document.createElement('div');
          row.className = 'report-item__row';

          const handle = document.createElement('div');
          handle.className = 'report-item__handle';
          handle.title = '按住拖动调整顺序';
          handle.draggable = true;
          handle.appendChild(makeIcon('drag_indicator'));
          row.appendChild(handle);

          const pill = document.createElement('span');
          pill.className = 'report-item__pill';
          pill.textContent = '文字';
          row.appendChild(pill);

          const ti = document.createElement('input');
          ti.type = 'text';
          ti.className = 'report-item__title';
          ti.placeholder = '小标题（可留空）';
          ti.value = item.title || '';
          ti.dataset.act = 'mt-title';
          row.appendChild(ti);

          const actions = document.createElement('div');
          actions.className = 'report-item__actions';
          actions.appendChild(makeBtn({ act: 'mt-up', icon: 'keyboard_arrow_up', title: '上移', disabled: idx === 0 }));
          actions.appendChild(makeBtn({ act: 'mt-down', icon: 'keyboard_arrow_down', title: '下移', disabled: idx === total - 1 }));
          actions.appendChild(makeBtn({ act: 'mt-remove', icon: 'close', title: '删除', danger: true }));
          row.appendChild(actions);
          li.appendChild(row);

          const noteWrap = document.createElement('div');
          noteWrap.className = 'report-item__note is-open';
          const ta = document.createElement('textarea');
          ta.dataset.act = 'mt-body';
          ta.placeholder = '正文 — 这段文字会出现在长图里';
          ta.value = item.body || '';
          noteWrap.appendChild(ta);
          li.appendChild(noteWrap);

          midEl.appendChild(li);
        });
      }
      renderMiddleTexts();
      midEl.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-act], input[data-act]');
        if (!btn) return;
        const li = btn.closest('.report-item');
        if (!li) return;
        const idx = Number(li.dataset.idx);
        const act = btn.dataset.act;
        if (act === 'mt-up' && idx > 0) {
          [middleTexts[idx-1], middleTexts[idx]] = [middleTexts[idx], middleTexts[idx-1]];
          renderMiddleTexts();
        } else if (act === 'mt-down' && idx < middleTexts.length - 1) {
          [middleTexts[idx+1], middleTexts[idx]] = [middleTexts[idx], middleTexts[idx+1]];
          renderMiddleTexts();
        } else if (act === 'mt-remove') {
          middleTexts.splice(idx, 1);
          renderMiddleTexts();
        }
      });
      midEl.addEventListener('input', (e) => {
        const t = e.target;
        const li = t.closest('.report-item');
        if (!li) return;
        const idx = Number(li.dataset.idx);
        if (t.dataset.act === 'mt-title') middleTexts[idx].title = t.value;
        else if (t.dataset.act === 'mt-body') middleTexts[idx].body = t.value;
      });
      // Drag-and-drop only on middle list
      let mtDragSrc = null;
      midEl.addEventListener('dragstart', (e) => {
        const h = e.target.closest('.report-item__handle');
        if (!h) { e.preventDefault(); return; }
        const li = h.closest('.report-item');
        if (!li) { e.preventDefault(); return; }
        mtDragSrc = Number(li.dataset.idx);
        try {
          const r = li.getBoundingClientRect();
          e.dataTransfer.setDragImage(li, e.clientX - r.left, e.clientY - r.top);
        } catch (_) {}
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', String(mtDragSrc));
        requestAnimationFrame(() => li.classList.add('is-dragging'));
      });
      midEl.addEventListener('dragover', (e) => {
        if (mtDragSrc === null) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const li = e.target.closest('.report-item');
        if (!li) return;
        midEl.querySelectorAll('.is-drop-target').forEach(el => {
          el.classList.remove('is-drop-target', 'drop-above', 'drop-below');
        });
        const r = li.getBoundingClientRect();
        const above = e.clientY < r.top + r.height / 2;
        li.classList.add('is-drop-target', above ? 'drop-above' : 'drop-below');
      });
      midEl.addEventListener('drop', (e) => {
        if (mtDragSrc === null) return;
        e.preventDefault();
        const li = e.target.closest('.report-item');
        if (!li) { mtDragSrc = null; return; }
        let dst = Number(li.dataset.idx);
        const r = li.getBoundingClientRect();
        const above = e.clientY < r.top + r.height / 2;
        if (!above) dst += 1;
        if (mtDragSrc < dst) dst -= 1;
        if (mtDragSrc !== dst) {
          const [m] = middleTexts.splice(mtDragSrc, 1);
          middleTexts.splice(dst, 0, m);
          renderMiddleTexts();
        }
        mtDragSrc = null;
      });
      midEl.addEventListener('dragend', () => {
        midEl.querySelectorAll('.is-dragging, .is-drop-target').forEach(el => {
          el.classList.remove('is-dragging', 'is-drop-target', 'drop-above', 'drop-below');
        });
        mtDragSrc = null;
      });

      document.getElementById('add-middle-text').addEventListener('click', () => {
        middleTexts.push({ title: '', body: '' });
        renderMiddleTexts();
        requestAnimationFrame(() => {
          const last = midEl.querySelector('.report-item:last-child');
