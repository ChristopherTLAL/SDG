// NEW Widget data: 顾问 portfolio scatter
// Per advisor × time-window: students count, signing revenue, comm count.
// Pre-compute 4 windows (6/12/24/48 weeks) so client can switch.
// ──────────────────────────────────────────────────────
type PortfolioPoint = {
  advisor: string;
  students: number;
  revenue: number;
  comms: number;
};
type PortfolioData = Record<'6' | '12' | '24' | '48', PortfolioPoint[]>;
const PORTFOLIO_WINDOWS: (6 | 12 | 24 | 48)[] = [6, 12, 24, 48];
const portfolioData: PortfolioData = { '6': [], '12': [], '24': [], '48': [] };

for (const w of PORTFOLIO_WINDOWS) {
  const cutoff = isoDate(new Date(weekStartToday.getTime() - (w - 1) * 7 * 86400000));
  const perAdvisor = new Map<string, { students: Set<number>; revenue: number; comms: number }>();
  for (const adv of ACTIVE_ADVISORS) {
    perAdvisor.set(adv, { students: new Set(), revenue: 0, comms: 0 });
  }
  // contracts within window — 多顾问学生在每个顾问名下都计一次
  for (const c of activeContracts) {
    if (!c.signed_at || c.signed_at < cutoff) continue;
    const advs = studentAdvisorsInScope.get(c.student_id);
    if (!advs) continue;
    const amt = Number(c.signed_amount) || 0;
    for (const adv of advs) {
      const e = perAdvisor.get(adv);
      if (!e) continue;
      e.students.add(c.student_id);
      e.revenue += amt;
    }
  }
  // notes + subs within window
  for (const n of (notes ?? [])) {
    const day = (n.note_date as string).slice(0, 10);
    if (day < cutoff) continue;
    const advisorList = studentAdvisors.get(n.student_id as number) ?? [];
    for (const a of advisorList) {
      const e = perAdvisor.get(a);
      if (e) e.comms += 1;
    }
  }
  for (const sub of (subs ?? [])) {
    const day = (sub.submitted_at as string).slice(0, 10);
    if (day < cutoff) continue;
    const advisorList = studentAdvisors.get(sub.student_id as number) ?? [];
    for (const a of advisorList) {
      const e = perAdvisor.get(a);
      if (e) e.comms += 1;
    }
  }
  for (const [advisor, e] of perAdvisor) {
    portfolioData[String(w) as '6' | '12' | '24' | '48'].push({
      advisor, students: e.students.size, revenue: e.revenue, comms: e.comms,
    });
  }
}

// ──────────────────────────────────────────────────────
// NEW Widget data: 退费分析 (已终止 contracts, 近 2 年)
// 2-year window by signed_at — user directive 2026-05-09: 即使后续删除老合同
// (e.g. 24F 走完后清理), 此 widget 数值不变 (cleanup 只删 ≥2yr 老合同).
// By 中期顾问: count, ¥, 退费率 = terminated / (terminated + 在带) within 2yr.
// By product family: count, ¥.
// ──────────────────────────────────────────────────────
const TERMINATED_WINDOW_DAYS = 365 * 2;
const terminatedCutoff = isoDate(new Date(Date.now() - TERMINATED_WINDOW_DAYS * 86400000));
type TerminatedAdvisorRow = {
  advisor: string;
  termCount: number;
  termRevenue: number;
  totalCount: number;       // term + 在带 within 2yr for this advisor
  termRate: number;
};
const terminatedByAdvisor = new Map<string, { term: number; termRev: number }>();
const advisorTotalCount = new Map<string, number>();
for (const adv of ACTIVE_ADVISORS) {
  terminatedByAdvisor.set(adv, { term: 0, termRev: 0 });
  advisorTotalCount.set(adv, 0);
}
const terminatedByFamily = new Map<string, { count: number; revenue: number; isApp: boolean }>();

for (const c of allContracts) {
  if (!c.student_id) continue;
  if (!c.signed_at || c.signed_at < terminatedCutoff) continue;  // 2-year window
  // Only count 已归档 (在带) and 已终止 (退费) — exclude 已完成 from denominator.
  if (c.status !== '已归档' && c.status !== '已终止') continue;
  const advs = studentAdvisorsInScope.get(c.student_id);
  if (!advs) continue;
  const famKey = c.is_application ? '留学申请' : productFamily(c.category, c.template_name);
  const amt = Number(c.signed_amount) || 0;
  // 多顾问学生 → 每个顾问的分母都加 1（与该顾问的 advisorStats 合同数对齐）
  for (const adv of advs) {
    advisorTotalCount.set(adv, (advisorTotalCount.get(adv) || 0) + 1);
    if (c.status === '已终止') {
      const e = terminatedByAdvisor.get(adv);
      if (e) {
        e.term += 1;
        e.termRev += amt;
      }
    }
  }
  // by-family 桶只随合同算一次（这是产品维度，与顾问无关）
  if (c.status === '已终止') {
    if (!terminatedByFamily.has(famKey)) {
      terminatedByFamily.set(famKey, { count: 0, revenue: 0, isApp: c.is_application });
    }
    const fe = terminatedByFamily.get(famKey)!;
    fe.count += 1;
    fe.revenue += amt;
  }
}
const terminatedAdvisorRanked: TerminatedAdvisorRow[] = ACTIVE_ADVISORS.map(adv => {
  const e = terminatedByAdvisor.get(adv) || { term: 0, termRev: 0 };
  const total = advisorTotalCount.get(adv) || 0;
  return {
    advisor: adv,
    termCount: e.term,
    termRevenue: e.termRev,
    totalCount: total,
    termRate: total > 0 ? e.term / total : 0,
  };
}).sort((a, b) => b.termRate - a.termRate);

const terminatedFamilyRanked = Array.from(terminatedByFamily.entries())
  .map(([family, v]) => ({ family, ...v }))
  .sort((a, b) => b.revenue - a.revenue);
const totalTerminatedCount = terminatedFamilyRanked.reduce((s, r) => s + r.count, 0);
const totalTerminatedRevenue = terminatedFamilyRanked.reduce((s, r) => s + r.revenue, 0);

// ── Widget 3 & 3b: 合同分布（拆 留学 vs 产品 两个 donut） ──
// 留学合同：vault 合同字段值能匹配到 SOP 的（跃领/格物/菁英/亚洲英语系高端 等留学
// 产品大类）。产品合同：财务 ERP 同步进来的 add-on 类（就业力/学术指导/科研/英语/
// 背景提升/签证/境外服务/英领），无 SOP 匹配，直接用合同名。
const liuxueCounts = new Map<string, number>();
const productCounts = new Map<string, number>();
for (const s of students) {
  for (const c of s.contracts ?? []) {
    const v = c.trim();
    if (!v) continue;
    if (PRIVATE_CONTRACTS.has(v)) continue;  // 私单 不进 donut（虽然学生层级已经过滤了）
    const sop = findSOPByContract(v);
    if (sop && sop.groupName) {
      liuxueCounts.set(sop.groupName, (liuxueCounts.get(sop.groupName) ?? 0) + 1);
    } else {
      productCounts.set(v, (productCounts.get(v) ?? 0) + 1);
    }
  }
}
const liuxueData = Array.from(liuxueCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const productData = Array.from(productCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

// Slugify contract name for the per-contract URL
function slug(s: string): string {
  return encodeURIComponent(s);
}

// (chip strip removed — kanban no longer filters by advisor)

// Donut payload — top-N + 其他 bucket so the slices stay legible.
function buildDonut(rows: { name: string; count: number }[], topN: number) {
  const top = rows.slice(0, topN);
  const rest = rows.slice(topN);
  const restSum = rest.reduce((s, x) => s + x.count, 0);
  const out = top.map(c => ({ name: c.name, value: c.count }));
  if (restSum > 0) out.push({ name: `其他 (${rest.length} 种)`, value: restSum });
  return out;
}
const liuxueDonut  = buildDonut(liuxueData, 10);
const productDonut = buildDonut(productData, 12);

// ── Widget: KPI banner + 顾问业绩综合表 (财务 ERP 同步衍生) ──
//
// 财务字段链条（必懂，避免再犯"已收+预收当独立账户加"的错）：
//   主合同金额 (sticker) ─→ 签约金额（实时） ─→ 已收 ─→ 已交付 (= 转收入含税)
//                            (= 主-减钱+选校+补充)         └─ 预收余额 (= 已收 - 已交付)
// 关键：预收余额 是已收的子集，不是独立账户。已收 = 已交付 + 预收余额。
// 总营收口径用 签约金额（ERP 权威值，已含选校/补充/扣减优惠）— 不再用 主合同-减钱 推算。
//
// 归属规则与全局一致：多顾问学生在每位顾问名下都计一次（双倍口径，与
// advisorStats / advisorMix / 周度签约 / portfolio / 退费 / 周报 enroll 统一）。
// 客单价 = 学生 sum(签约金额)；优惠率 = sum(优惠减钱+优惠价值) / sum(主合同金额)
// 注：已收 / 已交付 / 预收 / 优惠 字段从新版 ERP 客户签约明细 schema 起已不存在，
//     下面相关 sum 都恒为 0；chartPayload 也已无消费方，留存仅作历史 schema 参考。
type AdvisorPerf = {
  advisor: string;
  studentCount: number;
  totalSigning: number;        // sum 学生签约金额
  mainTotal: number;           // sum 主合同金额（优惠率分母）
  discountCash: number;        // sum 优惠减钱（仅减钱）
  discountTotal: number;       // sum (优惠减钱 + 优惠价值)（优惠率分子）
  perStudentAmounts: number[]; // 每学生客单价 array — 算 mean / P50
};

let totalSigning = 0;     // sum(签约金额)
let totalReceived = 0;    // sum(已收)
let totalDelivered = 0;   // sum(已交付)
let totalPrepay = 0;      // sum(预收余额) — 注意 = totalReceived - totalDelivered
let signedStudentCount = 0;
const advisorPerfMap = new Map<string, AdvisorPerf>();

for (const s of students) {
  const details = s.contract_details ?? [];
  if (!details.length) continue;
  signedStudentCount++;
  const studentSigning = details.reduce((sum, d) => sum + (Number(d['签约金额']) || 0), 0);
  const mainTotal = details.reduce((sum, d) => sum + (Number(d['主合同金额']) || 0), 0);
  const discountCash = details.reduce((sum, d) => sum + (Number(d['优惠减钱']) || 0), 0);
  const discountTotal = details.reduce((sum, d) =>
    sum + (Number(d['优惠减钱']) || 0) + (Number(d['优惠价值']) || 0), 0);

  totalSigning += studentSigning;
  for (const d of details) {
    totalReceived += Number(d['已收']) || 0;
    totalDelivered += Number(d['已交付']) || 0;
    totalPrepay += Number(d['预收余额']) || 0;
  }

  const advs = studentAdvisorsInScope.get(s.id);
  if (!advs) continue;  // 学生不在 in-scope（无 active 顾问 / 私单 / 早于地板）
  for (const adv of advs) {
    if (!advisorPerfMap.has(adv)) {
      advisorPerfMap.set(adv, {
        advisor: adv, studentCount: 0, totalSigning: 0,
        mainTotal: 0, discountCash: 0, discountTotal: 0, perStudentAmounts: [],
      });
    }
    const e = advisorPerfMap.get(adv)!;
    e.studentCount++;
    e.totalSigning += studentSigning;
    e.mainTotal += mainTotal;
    e.discountCash += discountCash;
    e.discountTotal += discountTotal;
    e.perStudentAmounts.push(studentSigning);
  }
}

const avgPerStudent = signedStudentCount ? Math.round(totalSigning / signedStudentCount) : 0;

function median(nums: number[]): number {
  if (!nums.length) return 0;
  const sorted = [...nums].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
}

const advisorPerf = Array.from(advisorPerfMap.values())
  .map(e => ({
    advisor: e.advisor,
    studentCount: e.studentCount,
    totalSigning: Math.round(e.totalSigning),
    mainTotal: Math.round(e.mainTotal),
    discountCash: Math.round(e.discountCash),
    avgPrice: e.perStudentAmounts.length
      ? Math.round(e.perStudentAmounts.reduce((a, b) => a + b, 0) / e.perStudentAmounts.length)
      : 0,
    medianPrice: Math.round(median(e.perStudentAmounts)),
    discountRate: e.mainTotal > 0 ? (e.discountTotal / e.mainTotal) * 100 : 0,
    pct: totalSigning > 0 ? (e.totalSigning / totalSigning) * 100 : 0,
  }))
  .sort((a, b) => b.totalSigning - a.totalSigning);

// Hash-stable color maps for the treemap and donut. The 其他 bucket gets
// the neutral grey so it never visually competes with named entries.
const namedSchools = schoolChartData.filter(d => !d.name.startsWith('其他')).map(d => d.name);
const schoolColorMap = buildStableColorMap(namedSchools);
const namedLiuxue = liuxueDonut.filter(c => !c.name.startsWith('其他')).map(c => c.name);
const namedProducts = productDonut.filter(c => !c.name.startsWith('其他')).map(c => c.name);
const liuxueColorMap = buildStableColorMap(namedLiuxue);
const productColorMap = buildStableColorMap(namedProducts);
// Plain object for JSON-serialization into the client payload.
const schoolColors:  Record<string, string> = Object.fromEntries(schoolColorMap);
const liuxueColors:  Record<string, string> = Object.fromEntries(liuxueColorMap);
const productColors: Record<string, string> = Object.fromEntries(productColorMap);

// Stage palette — pure purple progression (light → smoky purple). Pipeline
// reads as a single hue deepening as students move through the funnel,
// rather than three competing colors. Anchor matches the heatmap.
const STAGE_COLORS: Record<string, string> = {
  '需对接':   '#DDC9DD',  // very light mauve
  '中期在途': '#C5AEC5',  // mid mauve
  '后期在途': SMOKY_PURPLE,
};

// ──────────────────────────────────────────────────────
// 周报 (weekly report) 数据集 — 替代图表 clone
// 三张表：在管学生 enroll × advisor cross-tab / 上周签约 / 上周沟通
// ──────────────────────────────────────────────────────
// 列与全局 cohort 地板对齐（见 EARLIEST_TRACKED_COHORT）。早于地板的学生在
// `students` 过滤时已剔除，不会进到这里，所以不需要 __SKIP__ 特殊分支了。
const ENROLL_COLS = ['26F', '27F', '28F', '29F', '待定'];

function normalizeEnroll(raw: string | null | undefined): string {
  if (!raw) return '待定';
  const s = String(raw).trim();
  if (!s || s === '待定' || s === '5000 fall' || s.startsWith('5000')) return '待定';
  const m = s.match(/^(\d{4})/);
  if (m) {
    const code = m[1].slice(2) + 'F';
    if (ENROLL_COLS.includes(code)) return code;
    return '待定';  // 兜底（理论不会触发，因为 students 已按 cohort 过滤过）
  }
  return '待定';
}

// Build enroll × advisor matrix.
// 多顾问学生 → 每个顾问名下都计一次（与全局口径一致）。
// 一个学生 multi-enroll（e.g. 美本 transfer 26F + 28F）→ 同时计入两列。
type EnrollRow = { advisor: string; counts: number[]; total: number };
const enrollMatrix = new Map<string, number[]>();
for (const adv of ACTIVE_ADVISORS) {
  enrollMatrix.set(adv, new Array(ENROLL_COLS.length).fill(0));
}
for (const s of students) {
  const advs = studentAdvisorsInScope.get(s.id);
  if (!advs) continue;
  const years = (s.enroll_years && s.enroll_years.length > 0) ? s.enroll_years : [null];
  // 该学生当前 enroll_years 落在哪些列（多届学生进多列；同列去重一次）
  const cols = new Set<number>();
  for (const y of years) {
    const colIdx = ENROLL_COLS.indexOf(normalizeEnroll(y));
    if (colIdx >= 0) cols.add(colIdx);
  }
  for (const adv of advs) {
    const row = enrollMatrix.get(adv);
    if (!row) continue;
    for (const colIdx of cols) row[colIdx] += 1;
  }
}
const enrollByAdvisor: EnrollRow[] = ACTIVE_ADVISORS.map(adv => {
  const counts = enrollMatrix.get(adv)!;
  return { advisor: adv, counts: [...counts], total: counts.reduce((a, b) => a + b, 0) };
}).sort((a, b) => b.total - a.total);
const enrollColTotals = ENROLL_COLS.map((_, i) =>
  enrollByAdvisor.reduce((s, r) => s + r.counts[i], 0)
);
const enrollGrandTotal = enrollColTotals.reduce((a, b) => a + b, 0);

// 上周 (last complete Mon→Sun) signings, by advisor.
// 用「上次完整周一→周日」而非「过去 7 天滚动窗口」：本周 Mon 早上数据
// 通常还没录入，rolling window 会把这周 0 行算进 ¥/天，误导;同时周报
// 描述的就是上完整周，用精确边界更自洽。
const lastSundayDate = new Date(TODAY);
{
  const day = TODAY.getDay();  // 0=Sun, 1=Mon, ..., 6=Sat
  const daysBackToLastSunday = day === 0 ? 7 : day;
  lastSundayDate.setDate(TODAY.getDate() - daysBackToLastSunday);
}
const lastMondayDate = new Date(lastSundayDate);
lastMondayDate.setDate(lastSundayDate.getDate() - 6);
const LAST_WEEK_START = isoDate(lastMondayDate);
const LAST_WEEK_END = isoDate(lastSundayDate);

type SigningRow = {
  advisor: string;
  studentName: string;
  contractName: string;
  amount: number;
  isApplication: boolean;
};
const weekSigningRows: SigningRow[] = [];
for (const c of activeContracts) {
  if (!c.signed_at) continue;
  const day = c.signed_at.slice(0, 10);
  if (day < LAST_WEEK_START || day > LAST_WEEK_END) continue;
  const advs = studentAdvisorsInScope.get(c.student_id);
  if (!advs) continue;  // 学生不在 in-scope（私单 / inactive / 早于地板）→ 跳过
  const meta = studentMeta.get(c.student_id);
  if (!meta) continue;
  // 多顾问学生 → 每个顾问名下都出一行（金额合计与 advisorStats 口径一致；
  // 表头 "合计" 会比公司实际签约多算）
  for (const adv of advs) {
    weekSigningRows.push({
      advisor: adv,
      studentName: meta.name,
      contractName: c.template_name || c.category || '—',
      amount: Number(c.signed_amount) || 0,
      isApplication: !!c.is_application,
    });
  }
}
weekSigningRows.sort((a, b) => b.amount - a.amount);
const weekSigningTotalAmount = weekSigningRows.reduce((s, r) => s + r.amount, 0);

// 上周 (last complete Mon→Sun) student communication, by advisor.
type CommRow = { advisor: string; count: number; students: number; perDay: string };
const weekCommMap = new Map<string, { count: number; students: Set<number> }>();
for (const adv of ACTIVE_ADVISORS) {
  weekCommMap.set(adv, { count: 0, students: new Set() });
}
// 用 studentAdvisorsInScope（in-scope 学生）而不是 studentAdvisors（全员含已结案），
// 保持与所有其他 widget 同一份口径。已结案 / 私单 / 早于地板的学生即使有上周
// 沟通记录也不算（与 advisorStats 一致）。
for (const n of (notes ?? [])) {
  const day = (n.note_date as string).slice(0, 10);
  if (day < LAST_WEEK_START || day > LAST_WEEK_END) continue;
  const sid = n.student_id as number;
  const advisorList = studentAdvisorsInScope.get(sid);
  if (!advisorList) continue;
  for (const a of advisorList) {
    const e = weekCommMap.get(a);
    if (e) { e.count += 1; e.students.add(sid); }
  }
}
for (const sub of (subs ?? [])) {
  const day = (sub.submitted_at as string).slice(0, 10);
  if (day < LAST_WEEK_START || day > LAST_WEEK_END) continue;
  const sid = sub.student_id as number;
  const advisorList = studentAdvisorsInScope.get(sid);
  if (!advisorList) continue;
  for (const a of advisorList) {
    const e = weekCommMap.get(a);
    if (e) { e.count += 1; e.students.add(sid); }
  }
}
const weekComms: CommRow[] = ACTIVE_ADVISORS.map(adv => {
  const e = weekCommMap.get(adv)!;
  return {
    advisor: adv,
    count: e.count,
    students: e.students.size,
    perDay: (e.count / 7).toFixed(1),
  };
}).sort((a, b) => b.count - a.count);
const weekCommTotal = weekComms.reduce((s, r) => s + r.count, 0);

// Pass everything client-side via JSON for the chart inits.
const chartPayload = {
  schoolChartData,
  schoolColors,
  regionData,
  network: { nodes: networkNodes, edges: networkEdges },
  stageYearCells,
  stages: STAGE_ORDER,
  stageColors: STAGE_COLORS,
  years: yearList,
  advisors,
  weeks: weeks.map(w => w.label),
  heatmapData,
  heatmapMax,
  liuxueDonut,
  liuxueColors,
  productDonut,
  productColors,
  // NEW widgets
  monthlyMonths: monthLabels,
  monthlySeries,
  monthlyFamilyColors: Object.fromEntries(
    [...topFamiliesMonthly, '其他'].map(f => [f, FAMILY_COLORS[f] || '#c4c4c4'])
  ),
  portfolioData,
  // KPI banner (used by 周报 export)
  kpi: {
    totalSigning: Math.round(totalSigning),
    totalReceived: Math.round(totalReceived),
    totalDelivered: Math.round(totalDelivered),
    totalPrepay: Math.round(totalPrepay),
    activeStudents: students.length,
    signedStudentCount,
    avgPerStudent: signedStudentCount ? Math.round(totalSigning / signedStudentCount) : 0,
    activeContractCount: activeContracts.length,
  },
  // 周报: 3 数据表 (替代图表 clone)
  weekly: {
    enrollCols: ENROLL_COLS,
    enrollRows: enrollByAdvisor,
    enrollColTotals,
    enrollGrandTotal,
    signings: weekSigningRows,
    signingTotal: weekSigningTotalAmount,
    comms: weekComms,
    commTotal: weekCommTotal,
  },
};

// 千分位格式化：¥1,234,567
function fmtMoney(n: number): string {
  return '¥' + Math.round(n).toLocaleString('en-US');
}
---

<InternalLayout title="Kanban" active="kanban">
  <!-- Fixed-shell layout: header strip + sidebar tabs + panel area.
       No page scroll; each panel scrolls internally if needed. -->
  <div class="kanban-shell">
    <!-- ── Top strip: title + 导出周报 button ── -->
    <div class="kanban-top">
      <div class="kanban-top__title">
        <h1 class="font-headline kanban-top__h1">Kanban</h1>
        <span class="kanban-top__count">在管学生 {students.length}</span>
      </div>
      <button id="open-report-drawer" class="kanban-top__action" type="button">
        <span class="material-symbols-outlined">image</span>
        导出周报
      </button>
    </div>

    <div class="kanban-grid">
    <aside class="kanban-tabs" role="tablist">
      <button class="kanban-tab is-active" data-tab="contracts" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">monitoring</span>
        <span class="kanban-tab__label">合同分布</span>
        <span class="kanban-tab__sub">留学 + 产品 by 顾问</span>
      </button>
      <button class="kanban-tab" data-tab="weekly" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">calendar_view_week</span>
        <span class="kanban-tab__label">周度签约</span>
        <span class="kanban-tab__sub">12 周 ¥ × 顾问</span>
      </button>
      <button class="kanban-tab" data-tab="monthly-products" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">trending_up</span>
        <span class="kanban-tab__label">产品节奏</span>
        <span class="kanban-tab__sub">24 月非留学产品分布</span>
      </button>
      <button class="kanban-tab" data-tab="top-students" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">star</span>
        <span class="kanban-tab__label">Top 学生</span>
        <span class="kanban-tab__sub">总签约 ¥ 排行 Top 30</span>
      </button>
      <button class="kanban-tab" data-tab="portfolio" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">scatter_plot</span>
        <span class="kanban-tab__label">顾问 portfolio</span>
        <span class="kanban-tab__sub">学生 × ¥ × 沟通</span>
      </button>
      <button class="kanban-tab" data-tab="activity" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">forum</span>
        <span class="kanban-tab__label">学生沟通</span>
        <span class="kanban-tab__sub">12 周沟通 + 提交</span>
      </button>
      <button class="kanban-tab" data-tab="terminated" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">cancel</span>
        <span class="kanban-tab__label">退费分析</span>
        <span class="kanban-tab__sub">已终止合同分布</span>
      </button>
      <button class="kanban-tab" data-tab="stage-year" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">timeline</span>
        <span class="kanban-tab__label">阶段 × 入学届</span>
        <span class="kanban-tab__sub">每届 funnel 分布</span>
      </button>
      <button class="kanban-tab" data-tab="regions" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">hub</span>
        <span class="kanban-tab__label">申请地区</span>
        <span class="kanban-tab__sub">共申网络</span>
      </button>
      <button class="kanban-tab" data-tab="schools" role="tab">
        <span class="material-symbols-outlined kanban-tab__icon">school</span>
        <span class="kanban-tab__label">在读学校</span>
        <span class="kanban-tab__sub">treemap</span>
      </button>
    </aside>

    <div class="kanban-main">
      <!-- ── PANEL: 顾问活动热力图 (沟通 + 提交) ── -->
      <section data-panel="activity" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            学生沟通热力 <span class="section-card__subtitle">最近 12 周沟通记录 + 提交（按学生 mid_advisor 多人归属）· 点行查看顾问详情</span>
          </h2>
        </div>
        {advisors.length === 0 ? (
          <p class="section-card__empty">暂无顾问数据。</p>
        ) : (
          <div id="chart-advisor-heatmap" style="width: 100%; height: 360px;"></div>
        )}
      </section>

      <!-- ── PANEL: 阶段 × 入学年份 ── -->
      <section data-panel="stage-year" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            阶段 × 入学年份 <span class="section-card__subtitle">每届学生在阶段间的进度分布</span>
          </h2>
        </div>
        {stageYearCells.every(c => c.count === 0) ? (
          <p class="section-card__empty">暂无入学年份数据。</p>
        ) : (
          <div id="chart-stage-year" style={`width: 100%; height: ${Math.max(180, yearList.length * 56 + 60)}px;`}></div>
        )}
      </section>

      <!-- ── PANEL: 申请地区共申网络 ── -->
      <section data-panel="regions" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            申请地区 <span class="section-card__subtitle">节点 = 地区 · 连线 = 共申学生 · 拖动滑块调整布局</span>
          </h2>
        </div>
        {regionData.length === 0 ? (
          <p class="section-card__empty">暂无目标地区数据。</p>
        ) : (
          <div class="network-row">
            <div id="chart-network" style="width: 100%; height: 560px; background: #fafbfc; border-radius: 10px; border: 1px solid #eef0f3;"></div>
            <aside class="network-panel">
              <div class="panel-section">
                <div class="panel-label">布局参数</div>
                <label class="panel-slider">
                  <span>节点排斥</span>
                  <input type="range" min="4000" max="60000" step="2000" value="28000" data-tweak="nodeRepulsion" />
                </label>
                <label class="panel-slider">
                  <span>连线长度</span>
                  <input type="range" min="60" max="400" step="10" value="200" data-tweak="idealEdgeLength" />
                </label>
                <label class="panel-slider">
                  <span>中心引力</span>
                  <input type="range" min="0.5" max="5" step="0.1" value="2.5" data-tweak="gravity" />
                </label>
                <button type="button" class="panel-reset" id="network-reset">重置</button>
              </div>
              <div class="panel-section" id="network-selection">
                <div class="panel-label">节点详情</div>
                <p class="panel-empty">点一个节点查看共申关系</p>
              </div>
              <div class="panel-section">
                <div class="panel-label">连接度排名</div>
                <ul id="network-centrality" class="panel-ranking"></ul>
              </div>
            </aside>
          </div>
        )}
      </section>

      <!-- ── PANEL: 在读学校分布 (treemap) ── -->
      <section data-panel="schools" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            在读学校分布 <span class="section-card__subtitle">方块面积 = 学生数 · {schoolData.length} 所学校 · 长尾合并</span>
          </h2>
        </div>
        {schoolChartData.length === 0 ? (
          <p class="section-card__empty">暂无在读学校数据。</p>
        ) : (
          <div id="chart-schools-treemap" style="width: 100%; height: 480px;"></div>
        )}
      </section>

      <!-- ─────────────────────────────────────────────────── -->
      <!-- PANEL: 合同分布 — 留学 / 客单价 / 产品 by advisor   -->
      <!--                                                     -->
      <!-- Three columns each sorted by its own metric.        -->
      <!-- Hover any row → all columns highlight that advisor. -->
      <!--                                                     -->
      <!-- 客单价 = 总收入 / 学生数 (across all contracts;     -->
      <!-- not filtered by 留学/产品). 学生数 = unique students -->
      <!-- this advisor has across both buckets.               -->
      <!-- ─────────────────────────────────────────────────── -->
      <section data-panel="contracts" class="kanban-panel section-card is-active">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            合同分布 <span class="section-card__subtitle">在册 {ACTIVE_ADVISORS.length} 位中期 · 多顾问学生在每位顾问名下都计一次（¥ 同步双倍）· 仅在带（status=已归档，排除已完成/已终止）· hover 任一行联动其他两列</span>
          </h2>
        </div>

        <div class="cp-grid">
          <!-- COL 1: 留学合同 (sorted by 留学 ¥ DESC) -->
          <div class="cp-col">
            <div class="cp-col-head">
              <h3 class="cp-col-title">留学合同</h3>
              <span class="cp-col-meta">按 ¥ 降序</span>
            </div>
            <ul class="cp-rows">
              {liuxueRanked.map((s, idx) => {
                const barWidth = maxLiuxue > 0 ? (s.liuxueRevenue / maxLiuxue) * 100 : 0;
                const isTop3 = idx < 3 && s.liuxueRevenue > 0;
                return (
                  <li class={`cp-row ${s.liuxueRevenue === 0 ? 'is-empty' : ''}`} data-advisor={s.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(s.advisor)} class="cp-name">{s.advisor}</a>
                      <span class="cp-money font-mono">{fmtMoney(s.liuxueRevenue)}</span>
                    </div>
                    <div class="cp-bar">
                      <span class="cp-bar__fill" style={`width: ${barWidth}%; background: var(--primary);`}></span>
                    </div>
                    <div class="cp-meta">
                      <span class="cp-meta__tag"><strong class="font-mono">{s.liuxueStudents.size}</strong>学生</span>
                      <span class="cp-meta__tag"><strong class="font-mono">{s.liuxueContracts}</strong>合同</span>
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- COL 2: 产品合同 (sorted by 产品 ¥ DESC) -->
          <div class="cp-col">
            <div class="cp-col-head">
              <h3 class="cp-col-title">产品合同</h3>
              <span class="cp-col-meta">按 ¥ 降序</span>
            </div>
            <ul class="cp-rows">
              {productRanked.map((s, idx) => {
                const barWidth = maxProduct > 0 ? (s.productRevenue / maxProduct) * 100 : 0;
                const isTop3 = idx < 3 && s.productRevenue > 0;
                // Build family stack — pull "其他" out FIRST so it doesn't
                // duplicate when slice(4)+ tail also accumulates into "其他".
                const allFams = Array.from(s.productByFamily.entries());
                const explicitOther = allFams.find(([k]) => k === '其他');
                const namedFams = allFams
                  .filter(([k]) => k !== '其他')
                  .sort((a, b) => b[1].revenue - a[1].revenue);
                const topFams = namedFams.slice(0, 4);
                const tailRev = namedFams.slice(4).reduce((sum, [, v]) => sum + v.revenue, 0)
                              + (explicitOther ? explicitOther[1].revenue : 0);
                const tailCount = namedFams.slice(4).reduce((sum, [, v]) => sum + v.count, 0)
                              + (explicitOther ? explicitOther[1].count : 0);
                const segments = topFams.map(([k, v]) => ({ name: k, revenue: v.revenue, count: v.count }));
                if (tailRev > 0) segments.push({ name: '其他', revenue: tailRev, count: tailCount });
                return (
                  <li class={`cp-row ${s.productRevenue === 0 ? 'is-empty' : ''}`} data-advisor={s.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(s.advisor)} class="cp-name">{s.advisor}</a>
                      <span class="cp-money font-mono">{fmtMoney(s.productRevenue)}</span>
                    </div>
                    <div class="cp-bar cp-bar--stacked" title={segments.map(seg => `${seg.name}: ${fmtMoneyShort(seg.revenue)} (${seg.count})`).join(' · ')}>
                      {segments.map(seg => {
                        const segWidthPct = s.productRevenue > 0 ? (seg.revenue / s.productRevenue) * barWidth : 0;
                        const color = FAMILY_COLORS[seg.name] || '#c4c4c4';
                        return (
                          <span class="cp-bar__seg" style={`width: ${segWidthPct}%; background: ${color};`} title={`${seg.name}: ${fmtMoneyShort(seg.revenue)} · ${seg.count} 单`}></span>
                        );
                      })}
                    </div>
                    <div class="cp-meta">
                      <span class="cp-meta__tag"><strong class="font-mono">{s.productStudents.size}</strong>学生</span>
                      <span class="cp-meta__tag"><strong class="font-mono">{s.productContracts}</strong>合同</span>
                      {topFams.length > 0 && (
                        <span class="cp-meta__tag cp-meta__tag--family">主打<strong>{topFams[0][0]}</strong>{Math.round((topFams[0][1].revenue / s.productRevenue) * 100)}%</span>
                      )}
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- COL 3: 客单价 (sorted by 客单价 DESC; all-students denominator) -->
