---
// /internal/kanban — analytics dashboard.
//
// Strategic / business view (vs the operational Overview). Long-scroll
// of widgets, each one a section-card. Data is pre-aggregated server-side
// and passed to client-side ECharts / Cytoscape via inline JSON for the
// charts that need it.
//
// Access: advisors and admin only. xdf guests bounce to dashboard.

import InternalLayout from '../../../layouts/InternalLayout.astro';
import { supabase } from '../../../lib/supabase/client';
import { INACTIVE_STAGES } from '../../../utils/contact-radar';
import { findSOPByContract } from '../../../data/contract-sops';

const viewer = Astro.locals?.viewer ?? null;
if (!viewer || (!viewer.isAdvisor && !viewer.isAdmin)) {
  return Astro.redirect('/internal');
}

const url = new URL(Astro.request.url);
// Note: advisor filter removed — kanban is team-wide, drill-down lives at
// /internal/kanban/advisors/[name]. URL param `?advisor=` is now ignored.
const _ignored = url.searchParams.get('advisor');

// 私单 是王世杰的个人 tag，不属于任何看板聚合 — 任何 viewer 在 kanban 都看不到。
// 学生详情页 / roster 不受此影响（管理员仍然可访问）。
const PRIVATE_CONTRACTS = new Set(['私单', '私单（非公司合同）']);
function isPrivate(contracts: string[] | null | undefined): boolean {
  if (!contracts) return false;
  return contracts.some(c => PRIVATE_CONTRACTS.has(c));
}

// Load every active student. Inactive (已结案/退费/已完成) excluded by default —
// these are historical and would skew the live business picture.
const { data: rawStudents } = await supabase
  .from('students')
  .select('id, name, stage, current_school, target_regions, mid_advisors, enroll_years, contracts, contract_details, yueling_tier');

type ContractDetail = {
  名称?: string;
  大类?: string;
  签约日期?: string;
  // 合同价
  主合同金额?: number;       // sticker
  签约金额?: number;         // 实际签约（ERP 实时）= 主合同 - 优惠减钱 + 选校 + 补充
  优惠减钱?: number;
  优惠价值?: number;
  选校金额?: number;
  补充金额?: number;
  退费?: number;
  // 现金 / 履约
  已收?: number;             // 实际到账
  已交付?: number;           // 已确认收入（含税）= 转收入含税
  预收余额?: number;         // 已收 - 已交付（是已收的子集，不是独立账户）
};

const allStudents = (rawStudents ?? []) as Array<{
  id: number;
  name: string;
  stage: string | null;
  current_school: string | null;
  target_regions: string[] | null;
  mid_advisors: string[] | null;
  enroll_years: string[] | null;
  contracts: string[] | null;
  contract_details: ContractDetail[] | null;  // 财务 ERP 合同明细 (derived data)
  yueling_tier: string | null;                // Max / Pro / 标准 / 博士 / 本科
}>;

// ── Active 中期顾问 list — only those in advisors table drive the contracts
//    widgets. New 顾问 onboarding = adding to advisors table. ──
const { data: rawAdvisorsRows } = await supabase.from('advisors').select('name');
const ACTIVE_ADVISORS = (rawAdvisorsRows ?? []).map((r: any) => r.name as string);
const ACTIVE_ADVISORS_SET = new Set(ACTIVE_ADVISORS);

// ── Contracts (留学 + 产品) by student → mid_advisor breakdown ──
// Pulls every contract whose vault student is managed by an active 中期顾问.
// Splits 留学申请 vs 非留学申请, with product-family bucketing for the 产品 widget.
const { data: rawContracts } = await supabase
  .from('contracts')
  .select('contract_id, customer_id, student_id, signed_at, signed_amount, template_name, category, status, is_application, mid_advisor, intake_year')
  .not('student_id', 'is', null)
  .neq('status', '已终止');

type ContractRow = {
  contract_id: string;
  customer_id: string;
  student_id: number;
  signed_at: string;
  signed_amount: number;
  template_name: string | null;
  category: string | null;
  status: string | null;
  is_application: boolean;
  mid_advisor: string | null;
  intake_year: number | null;
};

const allContracts = (rawContracts ?? []) as ContractRow[];

// Map student_id → primary 中期顾问 (first of mid_advisors[]). Multi-advisor
// students get attributed to first advisor for revenue counting; we don't
// double-count.
const studentPrimaryAdvisor = new Map<number, string>();
for (const s of allStudents) {
  const advisors = s.mid_advisors || [];
  if (advisors.length === 0) continue;
  const primary = advisors[0];
  if (ACTIVE_ADVISORS_SET.has(primary)) {
    studentPrimaryAdvisor.set(s.id, primary);
  }
}

// Product family bucketing — coalesce noisy template-with-OA-code categories
// into ~12 stable family labels so the stacked bar reads clean.
function productFamily(category: string | null, templateName: string | null): string {
  const cn = (templateName || category || '');
  if (!cn) return '其他';
  if (cn.includes('跃领')) return '跃领规划';
  if (cn.includes('格物')) return '格物';
  if (cn.includes('精英预备')) return '菁英课程';
  if (cn.includes('菁英') && !cn.includes('博士')) return '菁英课程';
  if (cn.includes('就业力') || cn.includes('顶锋') || cn.includes('优选') || cn.includes('人事实习') || cn.includes('美研职场起航') || cn.includes('美研高端实训')) return '就业力';
  if (cn.includes('美国本科志领') || cn.includes('志领学堂')) return '美本规划';
  if (cn.includes('美国本科')) return '美本规划';
  if (cn.includes('海外学术导师') || cn.includes('AST') || cn.includes('艾思特') || cn.includes('英领')) return '学术力';
  if (cn.includes('海外名校导师') || cn.includes('科研')) return '科研项目';
  if (cn.includes('1对1定制参赛') || cn.includes('AMC') || cn.includes('BPHO') || cn.includes('物理碗') || cn.includes('竞赛')) return '竞赛';
  if (cn.includes('云中学') || cn.includes('OSSD') || cn.includes('NCUK')) return '中学项目';
  if (cn.includes('日本前途塾')) return '日本规划';
  if (cn.includes('起点') || cn.includes('启程') || cn.includes('英文能力提升') || cn.includes('面授一对一')) return '语培班课';
  if (cn.includes('签证')) return '签证服务';
  return '其他';
}

// Aggregate per advisor
type AdvisorContractStats = {
  advisor: string;
  // 留学
  liuxueStudents: Set<number>;
  liuxueContracts: number;
  liuxueRevenue: number;
  liuxueRecent12wk: number;
  // 产品
  productStudents: Set<number>;
  productContracts: number;
  productRevenue: number;
  productRecent12wk: number;
  productByFamily: Map<string, { count: number; revenue: number }>;
};

const advisorStats = new Map<string, AdvisorContractStats>();
for (const adv of ACTIVE_ADVISORS) {
  advisorStats.set(adv, {
    advisor: adv,
    liuxueStudents: new Set(),
    liuxueContracts: 0,
    liuxueRevenue: 0,
    liuxueRecent12wk: 0,
    productStudents: new Set(),
    productContracts: 0,
    productRevenue: 0,
    productRecent12wk: 0,
    productByFamily: new Map(),
  });
}

const twelveWeeksAgo = new Date(Date.now() - 12 * 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

for (const c of allContracts) {
  const adv = studentPrimaryAdvisor.get(c.student_id);
  if (!adv) continue;
  const stats = advisorStats.get(adv);
  if (!stats) continue;
  const amt = Number(c.signed_amount) || 0;
  const recent = c.signed_at && c.signed_at >= twelveWeeksAgo;

  if (c.is_application) {
    stats.liuxueStudents.add(c.student_id);
    stats.liuxueContracts += 1;
    stats.liuxueRevenue += amt;
    if (recent) stats.liuxueRecent12wk += 1;
  } else {
    stats.productStudents.add(c.student_id);
    stats.productContracts += 1;
    stats.productRevenue += amt;
    if (recent) stats.productRecent12wk += 1;
    const family = productFamily(c.category, c.template_name);
    if (!stats.productByFamily.has(family)) {
      stats.productByFamily.set(family, { count: 0, revenue: 0 });
    }
    const fam = stats.productByFamily.get(family)!;
    fam.count += 1;
    fam.revenue += amt;
  }
}

// Rank arrays (sorted by respective revenue DESC), keeping ALL active advisors
// even if 0 — visual presence reveals the gap.
const liuxueRanked = Array.from(advisorStats.values())
  .sort((a, b) => b.liuxueRevenue - a.liuxueRevenue);
const productRanked = Array.from(advisorStats.values())
  .sort((a, b) => b.productRevenue - a.productRevenue);

const maxLiuxue = Math.max(1, ...liuxueRanked.map(s => s.liuxueRevenue));
const maxProduct = Math.max(1, ...productRanked.map(s => s.productRevenue));

// 客单价 = 总收入 / 总学生数 (across ALL contracts of advisor's students;
// no filter for 留学/产品). Denominator = unique students with any contract.
type CustomerValueRow = {
  advisor: string;
  totalRevenue: number;
  totalStudents: number;
  totalContracts: number;
  avgPrice: number;
};
const customerValueRanked: CustomerValueRow[] = Array.from(advisorStats.values()).map(s => {
  const allStuds = new Set([...s.liuxueStudents, ...s.productStudents]);
  const totalRevenue = s.liuxueRevenue + s.productRevenue;
  const total = allStuds.size;
  return {
    advisor: s.advisor,
    totalRevenue,
    totalStudents: total,
    totalContracts: s.liuxueContracts + s.productContracts,
    avgPrice: total > 0 ? totalRevenue / total : 0,
  };
}).sort((a, b) => b.avgPrice - a.avgPrice);
const maxAvgPrice = Math.max(1, ...customerValueRanked.map(r => r.avgPrice));

// Product family color palette (morandi)
const FAMILY_COLORS: Record<string, string> = {
  '跃领规划': '#7c8da6',
  '格物':    '#b39686',
  '菁英课程': '#a89989',
  '就业力':   '#8eaa9b',
  '美本规划': '#b69dc1',
  '英本规划': '#94a8b3',
  '学术力':   '#c8a87a',
  '科研项目': '#8e8f99',
  '竞赛':     '#bd8c7e',
  '中学项目': '#9bb097',
  '日本规划': '#a89888',
  '语培班课': '#a0acb8',
  '签证服务': '#7c8a8a',
  '其他':     '#c4c4c4',
};

function fmtMoneyShort(n: number): string {
  if (n >= 10000) return (n / 10000).toFixed(n >= 100000 ? 0 : 1) + '万';
  return Math.round(n).toString();
}

// ── Student-mix per advisor: 单留 / 双 / 单产 ──
// Each vault student belongs to one advisor (mid_advisors[0]). We split that
// advisor's students into 3 buckets based on what kinds of contracts they
// have. Sum of buckets = total students. Shows whether advisor's clients are
// shallow (single-product) vs deep (multi-purchase).
type StudentMix = { onlyLiuxue: number; both: number; onlyProduct: number; total: number };
const advisorMix = new Map<string, StudentMix>();
for (const adv of ACTIVE_ADVISORS) {
  advisorMix.set(adv, { onlyLiuxue: 0, both: 0, onlyProduct: 0, total: 0 });
}
for (const [studentId, adv] of studentPrimaryAdvisor.entries()) {
  if (!ACTIVE_ADVISORS_SET.has(adv)) continue;
  const stats = advisorStats.get(adv);
  if (!stats) continue;
  const hasLiuxue = stats.liuxueStudents.has(studentId);
  const hasProduct = stats.productStudents.has(studentId);
  const m = advisorMix.get(adv)!;
  if (hasLiuxue && hasProduct) m.both += 1;
  else if (hasLiuxue) m.onlyLiuxue += 1;
  else if (hasProduct) m.onlyProduct += 1;
  // students with NO contracts at all — count in total but not in mix buckets
  m.total += 1;
}
const advisorMixObj = (adv: string): StudentMix => advisorMix.get(adv) || { onlyLiuxue: 0, both: 0, onlyProduct: 0, total: 0 };

// ── Weekly signing heatmap data ──
// Per (advisor × ISO-week-start) → total signed amount.
function weekStart(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00Z');
  const day = d.getUTCDay();
  const offset = day === 0 ? -6 : 1 - day;
  d.setUTCDate(d.getUTCDate() + offset);
  return d.toISOString().slice(0, 10);
}

const WEEKS_BACK = 12;
const today = new Date();
const todayMonday = new Date(today);
{
  const d = todayMonday.getUTCDay();
  const offset = d === 0 ? -6 : 1 - d;
  todayMonday.setUTCDate(todayMonday.getUTCDate() + offset);
}
const weekLabels: string[] = [];
for (let i = WEEKS_BACK - 1; i >= 0; i--) {
  const d = new Date(todayMonday);
  d.setUTCDate(d.getUTCDate() - i * 7);
  weekLabels.push(d.toISOString().slice(0, 10));
}
const earliestWeek = weekLabels[0];

type WeekBucket = { revenue: number; count: number };
const weeklyByAdvisor = new Map<string, Map<string, WeekBucket>>();
const weeklyTotals = new Map<string, number>();
for (const adv of ACTIVE_ADVISORS) {
  weeklyByAdvisor.set(adv, new Map(weekLabels.map(w => [w, { revenue: 0, count: 0 }])));
  weeklyTotals.set(adv, 0);
}
for (const c of allContracts) {
  if (!c.signed_at) continue;
  const adv = studentPrimaryAdvisor.get(c.student_id);
  if (!adv) continue;
  const wk = weekStart(c.signed_at.slice(0, 10));
  if (wk < earliestWeek) continue;
  const advMap = weeklyByAdvisor.get(adv);
  if (!advMap || !advMap.has(wk)) continue;
  const b = advMap.get(wk)!;
  const amt = Number(c.signed_amount) || 0;
  b.revenue += amt;
  b.count += 1;
  weeklyTotals.set(adv, (weeklyTotals.get(adv) || 0) + amt);
}
const weeklyRanked = Array.from(weeklyTotals.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([adv]) => ({
    advisor: adv,
    cells: weekLabels.map(w => weeklyByAdvisor.get(adv)!.get(w)!),
    total: weeklyTotals.get(adv) || 0,
  }));
const weeklyMaxCell = Math.max(1, ...weeklyRanked.flatMap(r => r.cells.map(c => c.revenue)));

function fmtWk(w: string): string {
  const [, m, d] = w.split('-');
  return `${parseInt(m)}/${parseInt(d)}`;
}
function weeklyHeatColor(value: number): string {
  if (value <= 0) return '#fafafa';
  const ratio = Math.min(1, value / weeklyMaxCell);
  const alpha = 0.18 + ratio * 0.78;
  return `rgba(4, 47, 36, ${alpha.toFixed(3)})`;
}

const studentsBeforeAdvisor = allStudents.filter(s => {
  if (s.stage && INACTIVE_STAGES.has(s.stage)) return false;
  if (isPrivate(s.contracts)) return false;  // 私单 全局藏
  return true;
});

// Kanban is the team-comparison dashboard; no per-advisor filtering here.
// (Per-advisor drill-down lives at /internal/kanban/advisors/[name].)
const students = studentsBeforeAdvisor;

function buildHref(advisor: string): string {
  return `/internal/kanban/advisors/${encodeURIComponent(advisor)}`;
}

// ── Widget 1: 在读学校分布 ──
const schoolCounts = new Map<string, number>();
for (const s of students) {
  const v = (s.current_school ?? '').trim();
  if (!v) continue;
  schoolCounts.set(v, (schoolCounts.get(v) ?? 0) + 1);
}
const schoolData = Array.from(schoolCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const TOP_SCHOOLS = 18;
const schoolTop = schoolData.slice(0, TOP_SCHOOLS);
const schoolRest = schoolData.slice(TOP_SCHOOLS);
const schoolRestSum = schoolRest.reduce((s, x) => s + x.count, 0);
const schoolChartData = schoolTop
  .slice()
  .reverse()
  .concat(schoolRestSum > 0 ? [{ name: `其他 (${schoolRest.length} 所)`, count: schoolRestSum }] : []);

// ── Widget 2: 申请地区分布 + 共申网络 ──
const regionCounts = new Map<string, number>();
const coOccur = new Map<string, number>(); // "A|B" sorted-key → student count with both
for (const s of students) {
  const regions = Array.from(new Set((s.target_regions ?? []).map(r => r.trim()).filter(Boolean)));
  for (const r of regions) {
    regionCounts.set(r, (regionCounts.get(r) ?? 0) + 1);
  }
  for (let i = 0; i < regions.length; i++) {
    for (let j = i + 1; j < regions.length; j++) {
      const k = [regions[i], regions[j]].sort().join('|');
      coOccur.set(k, (coOccur.get(k) ?? 0) + 1);
    }
  }
}
const regionData = Array.from(regionCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
// Shared Morandi palette used by treemap / donut / network.
// Each hue is the original Morandi tone mixed ~12% with white — keeps
// the dusty character but lightens enough that black 13px labels stay
// crisp on top. Color assigned by NAME hash (not rank) so 西交利物浦
// always maps to the same swatch even as caseload shifts.
const MORANDI_PALETTE = [
  '#B1C0AB',  // sage
  '#D0ADA7',  // dusty pink
  '#A2B2C0',  // dusty blue
  '#CCBC92',  // dusty mustard
  '#BEABBE',  // mauve
  '#99B4AF',  // dusty teal
  '#E1BFB8',  // peachy pink
  '#C0BAC7',  // pale lavender
  '#CFBFB1',  // warm beige
  '#9EAE99',  // forest sage
  '#B7AEA6',  // warm grey
];

// Reserved deepest tone — used as the dark band of the advisor heatmap
// and as 后期在途 in the stage stacked bar. Kept at the original (un-
// brightened) Morandi mauve so it stays visually anchoring while the
// rest of the palette has been lightened.
const SMOKY_PURPLE = '#B5A0B5';
function djb2(s: string): number {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}
function buildStableColorMap(names: string[]): Map<string, string> {
  const used = new Set<number>();
  const sorted = [...names].sort((a, b) => a.localeCompare(b));
  const out = new Map<string, string>();
  for (const name of sorted) {
    let idx = djb2(name) % MORANDI_PALETTE.length;
    let tries = 0;
    // Walk forward until we find an unused slot. Past palette size we just
    // accept a duplicate (only matters if entity count > palette count).
    while (used.has(idx) && tries < MORANDI_PALETTE.length) {
      idx = (idx + 1) % MORANDI_PALETTE.length;
      tries++;
    }
    used.add(idx);
    out.set(name, MORANDI_PALETTE[idx]);
  }
  return out;
}
const FALLBACK_GREY = '#ADA39A';

const regionColorMap = buildStableColorMap(regionData.map(r => r.name));
const networkNodes = regionData.map(r => ({
  data: {
    id: r.name,
    label: r.name,
    weight: r.count,
    color: regionColorMap.get(r.name) ?? FALLBACK_GREY,
  },
}));
const networkEdges = Array.from(coOccur.entries())
  .filter(([, w]) => w > 0)
  .map(([k, w]) => {
    const [a, b] = k.split('|');
    return { data: { id: `e_${a}_${b}`, source: a, target: b, weight: w } };
  });

// ── Widget 5: 阶段 × 入学年份 heatmap ──
const STAGE_ORDER = ['需对接', '中期在途', '后期在途'];
const yearSet = new Set<string>();
for (const s of students) {
  for (const y of s.enroll_years ?? []) {
    if (y) yearSet.add(y);
  }
}
const yearList = Array.from(yearSet).sort();
// matrix[year][stage] = count (multi-counted by year if student has multiple)
type StageYearCell = { year: string; stage: string; count: number };
const stageYearCells: StageYearCell[] = [];
for (const y of yearList) {
  for (const st of STAGE_ORDER) {
    const c = students.filter(s =>
      s.stage === st &&
      Array.isArray(s.enroll_years) &&
      s.enroll_years.includes(y)
    ).length;
    stageYearCells.push({ year: y, stage: st, count: c });
  }
}

// ── Widget 7+9: advisor activity heatmap ──
// Build last 12 weeks (Monday-anchored) as ISO date strings
const TODAY = new Date();
TODAY.setHours(0, 0, 0, 0);
function startOfWeek(d: Date): Date {
  const day = d.getDay() || 7;  // Sun=7 → treat as last day; Mon=1 (ISO week)
  const x = new Date(d);
  x.setDate(d.getDate() - (day - 1));
  return x;
}
function isoDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}
function fmtWeekLabel(d: Date): string {
  return `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
}
const weekStartToday = startOfWeek(TODAY);
const weeks: { start: string; label: string }[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(weekStartToday);
  d.setDate(weekStartToday.getDate() - i * 7);
  weeks.push({ start: isoDate(d), label: fmtWeekLabel(d) });
}
const weekIndexByStart = new Map(weeks.map((w, i) => [w.start, i]));

// All current advisors (from advisors table)
const { data: advisorRows } = await supabase
  .from('advisors')
  .select('name, roles')
  .eq('active', true);
const advisors = (advisorRows ?? [])
  .filter((a: any) => Array.isArray(a.roles) && a.roles.includes('中期'))
  .map((a: any) => a.name as string)
  .sort();

// Build student → mid_advisors map for attribution
const studentAdvisors = new Map<number, string[]>();
for (const s of allStudents) {  // use allStudents so historical activity attributes correctly
  studentAdvisors.set(s.id, s.mid_advisors ?? []);
}

const sinceCutoff = weeks[0].start;  // 12 weeks ago, Monday
const [{ data: notes }, { data: subs }] = await Promise.all([
  supabase
    .from('student_notes')
    .select('student_id, note_date')
    .gte('note_date', sinceCutoff)
    .not('note_date', 'is', null),
  supabase
    .from('submissions')
    .select('student_id, submitted_at')
    .gte('submitted_at', sinceCutoff)
    .not('student_id', 'is', null),
]);

function bumpActivity(matrix: Map<string, number[]>, advisor: string, weekIdx: number): void {
  const row = matrix.get(advisor);
  if (!row) return;
  row[weekIdx] = (row[weekIdx] ?? 0) + 1;
}

const activity = new Map<string, number[]>();  // advisor → [w0, w1, ..., w11]
for (const a of advisors) activity.set(a, new Array(weeks.length).fill(0));

for (const n of (notes ?? [])) {
  const day = (n.note_date as string).slice(0, 10);
  const ws = isoDate(startOfWeek(new Date(day)));
  const wi = weekIndexByStart.get(ws);
  if (wi === undefined) continue;
  const advisorList = studentAdvisors.get(n.student_id as number) ?? [];
  for (const a of advisorList) bumpActivity(activity, a, wi);
}
for (const sub of (subs ?? [])) {
  const day = (sub.submitted_at as string).slice(0, 10);
  const ws = isoDate(startOfWeek(new Date(day)));
  const wi = weekIndexByStart.get(ws);
  if (wi === undefined) continue;
  const advisorList = studentAdvisors.get(sub.student_id as number) ?? [];
  for (const a of advisorList) bumpActivity(activity, a, wi);
}

// Build ECharts heatmap data: array of [weekIdx, advisorIdx, count]
const heatmapData: [number, number, number][] = [];
let heatmapMax = 0;
advisors.forEach((a, ai) => {
  const row = activity.get(a) ?? [];
  row.forEach((cnt, wi) => {
    heatmapData.push([wi, ai, cnt]);
    if (cnt > heatmapMax) heatmapMax = cnt;
  });
});

// ── Widget 3 & 3b: 合同分布（拆 留学 vs 产品 两个 donut） ──
// 留学合同：vault 合同字段值能匹配到 SOP 的（跃领/格物/菁英/亚洲英语系高端 等留学
// 产品大类）。产品合同：财务 ERP 同步进来的 add-on 类（就业力/学术指导/科研/英语/
// 背景提升/签证/境外服务/英领），无 SOP 匹配，直接用合同名。
const liuxueCounts = new Map<string, number>();
const productCounts = new Map<string, number>();
for (const s of students) {
  for (const c of s.contracts ?? []) {
    const v = c.trim();
    if (!v) continue;
    if (PRIVATE_CONTRACTS.has(v)) continue;  // 私单 不进 donut（虽然学生层级已经过滤了）
    const sop = findSOPByContract(v);
    if (sop && sop.groupName) {
      liuxueCounts.set(sop.groupName, (liuxueCounts.get(sop.groupName) ?? 0) + 1);
    } else {
      productCounts.set(v, (productCounts.get(v) ?? 0) + 1);
    }
  }
}
const liuxueData = Array.from(liuxueCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const productData = Array.from(productCounts.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

// Slugify contract name for the per-contract URL
function slug(s: string): string {
  return encodeURIComponent(s);
}

// (chip strip removed — kanban no longer filters by advisor)

// Donut payload — top-N + 其他 bucket so the slices stay legible.
function buildDonut(rows: { name: string; count: number }[], topN: number) {
  const top = rows.slice(0, topN);
  const rest = rows.slice(topN);
  const restSum = rest.reduce((s, x) => s + x.count, 0);
  const out = top.map(c => ({ name: c.name, value: c.count }));
  if (restSum > 0) out.push({ name: `其他 (${rest.length} 种)`, value: restSum });
  return out;
}
const liuxueDonut  = buildDonut(liuxueData, 10);
const productDonut = buildDonut(productData, 12);

// ── Widget: KPI banner + 顾问业绩综合表 (财务 ERP 同步衍生) ──
//
// 财务字段链条（必懂，避免再犯"已收+预收当独立账户加"的错）：
//   主合同金额 (sticker) ─→ 签约金额（实时） ─→ 已收 ─→ 已交付 (= 转收入含税)
//                            (= 主-减钱+选校+补充)         └─ 预收余额 (= 已收 - 已交付)
// 关键：预收余额 是已收的子集，不是独立账户。已收 = 已交付 + 预收余额。
// 总营收口径用 签约金额（ERP 权威值，已含选校/补充/扣减优惠）— 不再用 主合同-减钱 推算。
//
// 归属规则统一 mid_advisors[0] 主签约者，1 学生 1 行 metric 自洽。
// 客单价 = 学生 sum(签约金额)
// 优惠率 = sum(优惠减钱 + 优惠价值) / sum(主合同金额)
type AdvisorPerf = {
  advisor: string;
  studentCount: number;
  totalSigning: number;        // sum 学生签约金额
  mainTotal: number;           // sum 主合同金额（优惠率分母）
  discountCash: number;        // sum 优惠减钱（仅减钱）
  discountTotal: number;       // sum (优惠减钱 + 优惠价值)（优惠率分子）
  perStudentAmounts: number[]; // 每学生客单价 array — 算 mean / P50
};

let totalSigning = 0;     // sum(签约金额)
let totalReceived = 0;    // sum(已收)
let totalDelivered = 0;   // sum(已交付)
let totalPrepay = 0;      // sum(预收余额) — 注意 = totalReceived - totalDelivered
let signedStudentCount = 0;
const advisorPerfMap = new Map<string, AdvisorPerf>();

for (const s of students) {
  const details = s.contract_details ?? [];
  if (!details.length) continue;
  signedStudentCount++;
  const studentSigning = details.reduce((sum, d) => sum + (Number(d['签约金额']) || 0), 0);
  const mainTotal = details.reduce((sum, d) => sum + (Number(d['主合同金额']) || 0), 0);
  const discountCash = details.reduce((sum, d) => sum + (Number(d['优惠减钱']) || 0), 0);
  const discountTotal = details.reduce((sum, d) =>
    sum + (Number(d['优惠减钱']) || 0) + (Number(d['优惠价值']) || 0), 0);

  totalSigning += studentSigning;
  for (const d of details) {
    totalReceived += Number(d['已收']) || 0;
    totalDelivered += Number(d['已交付']) || 0;
    totalPrepay += Number(d['预收余额']) || 0;
  }

  const primary = (s.mid_advisors ?? [])[0] ?? '未填';
  if (!advisorPerfMap.has(primary)) {
    advisorPerfMap.set(primary, {
      advisor: primary, studentCount: 0, totalSigning: 0,
      mainTotal: 0, discountCash: 0, discountTotal: 0, perStudentAmounts: [],
    });
  }
  const e = advisorPerfMap.get(primary)!;
  e.studentCount++;
  e.totalSigning += studentSigning;
  e.mainTotal += mainTotal;
  e.discountCash += discountCash;
  e.discountTotal += discountTotal;
  e.perStudentAmounts.push(studentSigning);
}

const avgPerStudent = signedStudentCount ? Math.round(totalSigning / signedStudentCount) : 0;

function median(nums: number[]): number {
  if (!nums.length) return 0;
  const sorted = [...nums].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
}

const advisorPerf = Array.from(advisorPerfMap.values())
  .map(e => ({
    advisor: e.advisor,
    studentCount: e.studentCount,
    totalSigning: Math.round(e.totalSigning),
    mainTotal: Math.round(e.mainTotal),
    discountCash: Math.round(e.discountCash),
    avgPrice: e.perStudentAmounts.length
      ? Math.round(e.perStudentAmounts.reduce((a, b) => a + b, 0) / e.perStudentAmounts.length)
      : 0,
    medianPrice: Math.round(median(e.perStudentAmounts)),
    discountRate: e.mainTotal > 0 ? (e.discountTotal / e.mainTotal) * 100 : 0,
    pct: totalSigning > 0 ? (e.totalSigning / totalSigning) * 100 : 0,
  }))
  .sort((a, b) => b.totalSigning - a.totalSigning);

// Hash-stable color maps for the treemap and donut. The 其他 bucket gets
// the neutral grey so it never visually competes with named entries.
const namedSchools = schoolChartData.filter(d => !d.name.startsWith('其他')).map(d => d.name);
const schoolColorMap = buildStableColorMap(namedSchools);
const namedLiuxue = liuxueDonut.filter(c => !c.name.startsWith('其他')).map(c => c.name);
const namedProducts = productDonut.filter(c => !c.name.startsWith('其他')).map(c => c.name);
const liuxueColorMap = buildStableColorMap(namedLiuxue);
const productColorMap = buildStableColorMap(namedProducts);
// Plain object for JSON-serialization into the client payload.
const schoolColors:  Record<string, string> = Object.fromEntries(schoolColorMap);
const liuxueColors:  Record<string, string> = Object.fromEntries(liuxueColorMap);
const productColors: Record<string, string> = Object.fromEntries(productColorMap);

// Stage palette — pure purple progression (light → smoky purple). Pipeline
// reads as a single hue deepening as students move through the funnel,
// rather than three competing colors. Anchor matches the heatmap.
const STAGE_COLORS: Record<string, string> = {
  '需对接':   '#DDC9DD',  // very light mauve
  '中期在途': '#C5AEC5',  // mid mauve
  '后期在途': SMOKY_PURPLE,
};

// Pass everything client-side via JSON for the chart inits.
const chartPayload = {
  schoolChartData,
  schoolColors,
  regionData,
  network: { nodes: networkNodes, edges: networkEdges },
  stageYearCells,
  stages: STAGE_ORDER,
  stageColors: STAGE_COLORS,
  years: yearList,
  advisors,
  weeks: weeks.map(w => w.label),
  heatmapData,
  heatmapMax,
  liuxueDonut,
  liuxueColors,
  productDonut,
  productColors,
};

// 千分位格式化：¥1,234,567
function fmtMoney(n: number): string {
  return '¥' + Math.round(n).toLocaleString('en-US');
}
