                const barWidth = maxAvgPrice > 0 ? (r.avgPrice / maxAvgPrice) * 100 : 0;
                const isTop3 = idx < 3 && r.avgPrice > 0;
                const mix = advisorMixObj(r.advisor);
                return (
                  <li class={`cp-row ${r.avgPrice === 0 ? 'is-empty' : ''}`} data-advisor={r.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(r.advisor)} class="cp-name">{r.advisor}</a>
                      <span class="cp-money font-mono">¥{fmtMoneyShort(r.avgPrice)}</span>
