  monthLabels.push(`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`);
}
const earliestMonth = monthLabels[0];
const monthlyFamilyMatrix = new Map<string, Map<string, number>>();
const monthlyFamilies = new Set<string>();
// Use the dedicated company-wide query (rawMonthlyContracts) — already
