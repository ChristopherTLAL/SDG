}
// Order families by total revenue DESC (top 8 + 其他 bucket)
const familyTotals = new Map<string, number>();
for (const m of monthlyFamilyMatrix.values()) {
  for (const [k, v] of m) familyTotals.set(k, (familyTotals.get(k) || 0) + v);
}
const monthlyFamiliesOrdered = Array.from(familyTotals.entries())
  .sort((a, b) => b[1] - a[1])
