      display: flex;
    }
    .advisor-row__bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 240ms ease-out;
    }
    .advisor-row__bar--stacked {
      gap: 1px;
    }
    .advisor-row__bar-seg {
      height: 100%;
      transition: width 240ms ease-out;
    }
    .advisor-row__bar-seg:first-child {
      border-top-left-radius: 4px;
      border-bottom-left-radius: 4px;
    }
    .advisor-row__bar-seg:last-child {
      border-top-right-radius: 4px;
      border-bottom-right-radius: 4px;
    }

    .advisor-row__meta {
      display: flex;
      gap: 14px;
      font-size: 11px;
      color: var(--text-soft);
      flex-wrap: wrap;
      align-items: center;
      padding-left: 32px;  /* align with name (after rank) */
    }
    .advisor-row__meta-item {
      display: inline-flex;
      align-items: baseline;
      gap: 3px;
    }
    .advisor-row__meta-item--family {
      color: var(--text-muted);
    }
    .advisor-row__meta-item--family strong {
      color: var(--text);
      font-weight: 700;
    }
    .advisor-row__meta-num {
      font-weight: 700;
      color: var(--text);
      font-size: 12px;
    }
    .advisor-row__pulse {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 999px;
      background: #f5f5f7;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }
    .advisor-row__pulse.is-hot {
      background: var(--primary);
      color: white;
    }

    .family-legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid #f1f1f4;
      font-size: 10px;
    }
    .family-legend__item {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: var(--text-muted);
    }
    .family-legend__swatch {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 2px;
    }
    .family-legend__name {
      font-weight: 600;
    }

    /* ── Top 学生 Pareto rows ── */
    .ts-rows { list-style: none; margin: 0; padding: 0; }
    .ts-row {
      padding: 10px 0;
      border-bottom: 1px solid #f1f1f4;
    }
    .ts-row:last-child { border-bottom: none; }
    .ts-row__head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 4px;
    }
    .ts-rank {
      width: 24px;
      flex-shrink: 0;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 600;
    }
    .ts-name {
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
      font-size: 13px;
    }
    .ts-name:hover { text-decoration: underline; }
    .ts-advisor {
      color: var(--text-muted);
      font-size: 11px;
      padding: 1px 8px;
      background: #f5f5f7;
      border-radius: 999px;
    }
    .ts-money {
      margin-left: auto;
      font-weight: 700;
      color: var(--text);
      font-size: 13px;
    }
    .ts-bar {
      display: flex;
      width: 100%;
      height: 8px;
      background: #f5f5f7;
      border-radius: 2px;
      overflow: hidden;
      margin: 4px 0 6px;
    }
    .ts-bar__seg { display: block; height: 100%; }
    .ts-bar__seg--liuxue { background: #7c8da6; }
    .ts-bar__seg--product { background: #b8a98a; }
    .ts-meta {
      display: flex;
      gap: 8px;
      font-size: 11px;
      color: var(--text-muted);
    }
    .ts-meta__tag {
      padding: 1px 8px;
      background: #fafafa;
      border-radius: 999px;
      border: 1px solid #f1f1f4;
    }
    .ts-meta__tag strong { color: var(--text); }

    /* ── Portfolio scatter pill controls ── */
    .pf-controls {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 10px;
    }
    .pf-controls__label {
      font-size: 11px;
      color: var(--text-muted);
      margin-right: 4px;
    }
    .pf-pill {
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      background: var(--surface, #fafafa);
      border: 1px solid var(--border);
      border-radius: 999px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .pf-pill:hover {
      color: var(--text);
      background: white;
    }
    .pf-pill.is-active {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }

    /* ── 退费分析 ── */
    .tm-kpi {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 18px;
    }
    .tm-kpi__card {
      padding: 14px 16px;
      background: var(--surface, #fafafa);
      border: 1px solid var(--border);
      border-radius: 8px;
      text-align: center;
    }
    .tm-kpi__num {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.2;
    }
    .tm-kpi__label {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    .tm-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 18px;
    }
    @media (max-width: 1100px) {
      .tm-grid { grid-template-columns: 1fr; }
    }
    .tm-block__title {
      font-family: var(--font-headline, 'Manrope'), sans-serif;
      font-weight: 800;
      font-size: 14px;
      margin: 0 0 10px;
      color: var(--text);
    }
    .tm-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    .tm-table th {
      text-align: left;
      padding: 6px 8px;
      font-weight: 600;
      font-size: 11px;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
    }
    .tm-table th.num,
    .tm-table td.num { text-align: right; }
    .tm-table td {
      padding: 6px 8px;
      border-bottom: 1px solid #f1f1f4;
      color: var(--text);
    }
    .tm-table tbody tr:last-child td { border-bottom: none; }
    .tm-rate {
      display: inline-block;
      padding: 1px 8px;
      border-radius: 4px;
      font-weight: 600;
    }
    .tm-fam-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 6px;
      vertical-align: middle;
    }
    .tm-fam-tag {
      margin-left: 6px;
      font-size: 10px;
      color: var(--text-muted);
      padding: 1px 6px;
      background: #f1f1f4;
      border-radius: 999px;
    }

    /* ── 导出周报 button (top strip) ── */
    .kanban-top__action {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      color: white;
      background: var(--primary);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.15s, transform 0.15s;
    }
    .kanban-top__action:hover { background: var(--primary-dim); transform: translateY(-1px); }
    .kanban-top__action:active { transform: translateY(0); }
    .kanban-top__action .material-symbols-outlined { font-size: 18px; }

    /* ─────────────────────────────────────────────────────── */
    /* Drawer — defensive CSS, single-row items                 */
    /* ─────────────────────────────────────────────────────── */
    .report-drawer[hidden] { display: none !important; }
    .report-drawer {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      justify-content: flex-end;
    }
    .report-drawer__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.4);
      backdrop-filter: blur(2px);
      opacity: 0;
      transition: opacity 0.25s ease;
    }
    .report-drawer.is-open .report-drawer__backdrop { opacity: 1; }
    .report-drawer__panel {
      position: relative;
      z-index: 1;
      width: min(600px, 100%);
      height: 100%;
      background: #ffffff;
      box-shadow: -16px 0 48px rgba(15, 23, 42, 0.12);
      display: flex;
      flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .report-drawer.is-open .report-drawer__panel { transform: translateX(0); }
    .report-drawer__head {
      padding: 24px 28px 20px;
      border-bottom: 1px solid #f0f0f3;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }
    .report-drawer__eyebrow {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 4px;
    }
    .report-drawer__title {
      font-size: 22px;
      font-weight: 800;
      margin: 0;
      letter-spacing: -0.02em;
      color: var(--text, #1a1a1a);
    }
    .report-drawer__close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      color: var(--text-muted);
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
    }
    .report-drawer__close:hover { background: #f1f5f9; color: var(--text); }
    .report-drawer__body {
      flex: 1;
      overflow-y: auto;
      padding: 20px 28px;
    }
    .report-drawer__hint {
      font-size: 12px;
      color: var(--text-muted);
      margin: 0 0 18px;
      line-height: 1.7;
    }
    .report-drawer__foot {
      padding: 16px 28px;
      border-top: 1px solid #f0f0f3;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      background: #fafafa;
    }
    .report-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 18px;
      font-size: 13px;
      font-weight: 600;
      border-radius: 8px;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: -0.005em;
    }
    .report-btn--ghost { background: white; color: var(--text); }
    .report-btn--ghost:hover { background: #f5f5f7; }
    .report-btn--primary {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }
    .report-btn--primary:hover { background: var(--primary-dim); }
    .report-btn--primary:disabled { opacity: 0.6; cursor: wait; }
    .report-btn .material-symbols-outlined { font-size: 16px; }

    /* ── Drawer items: defensive layout ── */
    .report-items {
      list-style: none !important;
      margin: 12px 0 !important;
      padding: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 8px !important;
    }
    .report-item {
      box-sizing: border-box;
      background: #ffffff;
      border: 1px solid #ebebef;
      border-radius: 10px;
      padding: 8px 10px;
      transition: border-color 0.15s, box-shadow 0.15s;
      position: relative;
      list-style: none;
    }
    .report-item:hover { border-color: #cfd1d5; }
    .report-item.is-dragging { opacity: 0.35; }
    .report-item.is-drop-target.drop-above::before,
    .report-item.is-drop-target.drop-below::after {
      content: '';
      position: absolute;
      left: 8px;
      right: 8px;
      height: 2px;
      background: var(--primary);
      border-radius: 1px;
    }
    .report-item.is-drop-target.drop-above::before { top: -5px; }
    .report-item.is-drop-target.drop-below::after { bottom: -5px; }
    .report-item--text {
      background: #fffbeb;
      border-color: #fde68a;
    }
    .report-item--text:hover { border-color: #fcd34d; }

    /* The horizontal row — locked layout to prevent wrapping/stacking */
    .report-item__row {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      align-items: center !important;
      gap: 8px;
      width: 100%;
    }

    .report-item__handle {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 28px;
      color: #cbd5e1;
      cursor: grab;
      border-radius: 4px;
      user-select: none;
    }
    .report-item__handle:hover { color: #64748b; background: #f8fafc; }
    .report-item__handle:active { cursor: grabbing; }
    .report-item__handle .material-symbols-outlined { font-size: 18px; }

    .report-item__main {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }
    .report-item__main input[type="checkbox"] {
      flex: 0 0 auto;
      width: 16px;
      height: 16px;
      accent-color: var(--primary);
      cursor: pointer;
      margin: 0;
    }
    .report-item__label {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.005em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .report-item__pill {
      flex: 0 0 auto;
      padding: 3px 9px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      background: #fde68a;
      color: #78350f;
      border-radius: 999px;
    }
    .report-item__title {
      flex: 1 1 auto;
      min-width: 0;
      padding: 6px 10px;
      font-size: 13px;
      font-family: inherit;
      border: 1px solid transparent;
      background: rgba(255, 255, 255, 0.5);
      border-radius: 6px;
      color: var(--text);
    }
    .report-item__title:focus { border-color: #fcd34d; background: white; outline: none; }
    .report-item__title::placeholder { color: #b48a3f; }

    .report-item__actions {
      flex: 0 0 auto;
      display: flex;
      gap: 2px;
      align-items: center;
    }
    .report-item__btn {
      flex: 0 0 auto;
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
      padding: 0;
    }
    .report-item__btn .material-symbols-outlined { font-size: 18px; }
    .report-item__btn:hover:not(:disabled) { background: #f1f5f9; color: var(--text); }
    .report-item__btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .report-item__btn--danger { color: var(--danger, #dc2626); }
    .report-item__btn--danger:hover:not(:disabled) { background: #fef2f2; }

    /* Note section — must be hidden by default unless .is-open */
    .report-item__note { display: none !important; margin-top: 8px; padding-left: 30px; }
    .report-item__note.is-open { display: block !important; }
    .report-item__note textarea {
      width: 100%;
      box-sizing: border-box;
      min-height: 60px;
      padding: 8px 10px;
      font-size: 13px;
      font-family: inherit;
      line-height: 1.6;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      resize: vertical;
      background: white;
      color: var(--text);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .report-item--text .report-item__note textarea {
      border-color: #fde68a;
      background: rgba(255, 255, 255, 0.7);
    }
    .report-item__note textarea:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(4, 47, 36, 0.08);
    }
    .report-item--text .report-item__note textarea:focus {
      border-color: #f59e0b;
      box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.12);
    }

    .report-add-btn {
      box-sizing: border-box;
      width: 100%;
      padding: 11px 14px;
      font-size: 12.5px;
      font-weight: 600;
      color: var(--text-muted);
      background: transparent;
      border: 1px dashed #d8d8df;
      border-radius: 10px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      transition: all 0.15s;
      letter-spacing: -0.005em;
      font-family: inherit;
      margin-top: 8px;
    }
    .report-add-btn:hover { color: var(--primary); border-color: var(--primary); background: #f0fdf9; }
    .report-add-btn .material-symbols-outlined { font-size: 16px; }

    /* ── Fixed sections in drawer (top note / data list / middle / bottom note) ── */
    .report-fixed-section {
      margin-bottom: 24px;
    }
    .report-fixed-section:last-child { margin-bottom: 0; }
    .report-fixed-section__head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid #f0f0f3;
    }
    .report-fixed-section__num {
      font-size: 11px;
      font-weight: 800;
      color: var(--primary);
      font-family: 'Manrope', 'SF Mono', monospace;
      letter-spacing: 1px;
    }
    .report-fixed-section__label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.005em;
    }
    .report-fixed-section__hint {
      font-size: 11px;
      color: var(--text-muted);
      margin-left: auto;
    }
    .report-fixed-section__ta {
      width: 100%;
      box-sizing: border-box;
      padding: 12px 14px;
      font-size: 13px;
      font-family: inherit;
      line-height: 1.65;
      border: 1px solid #ebebef;
      border-radius: 10px;
      resize: vertical;
      background: #fafafa;
      color: var(--text);
      transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
      tab-size: 2;
    }
    .report-fixed-section__ta:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 3px rgba(4, 47, 36, 0.08);
    }

    /* ─────────────────────────────────────────────────────── */
    /* Hidden report canvas — publication / article aesthetic   */
    /* ─────────────────────────────────────────────────────── */
    #report-canvas-wrap {
      position: fixed;
      left: -20000px;
      top: 0;
      pointer-events: none;
      z-index: -1;
    }
    #report-canvas {
      width: 1080px;
      /* Single subtle linear at top, white below — clean magazine cover */
      background: linear-gradient(180deg, #f5f9f7 0%, #ffffff 480px, #ffffff 100%);
      padding: 64px 60px 80px;
      font-family:
        'Manrope',
        -apple-system, BlinkMacSystemFont,
        'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei',
        Arial, sans-serif;
      color: #0f172a;
      box-sizing: border-box;
      font-feature-settings: 'kern', 'liga';
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ─────────────────────────────────────────────────────── */
    /* Masthead — magazine cover style                           */
    /* ─────────────────────────────────────────────────────── */
    .rep-header {
      margin-bottom: 84px;
      padding-bottom: 36px;
      border-bottom: 2px solid #042f24;
    }
    .rep-header__strip {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 60px;
    }
    .rep-header__brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 16px;
      font-weight: 700;
      color: #042f24;
      letter-spacing: -0.2px;
      white-space: nowrap;
    }
    .rep-header__brand::before {
      content: '';
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #042f24;
      flex-shrink: 0;
    }
    .rep-header__pill {
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: white;
      background: #042f24;
      /* padding-right > padding-left — letter-spacing 给最后一个字符也加 trailing gap,
         html-to-image foreignObject 渲染时容易把右边切掉一截。多留 8px 右内边距 + 微缩
         letter-spacing 给字两侧留呼吸感。 */
      padding: 11px 24px 11px 18px;
      border-radius: 4px;
      font-family: 'Manrope', 'SF Mono', monospace;
      white-space: nowrap;
    }
    .rep-header__title {
      font-size: 64px;
      font-weight: 800;
      margin: 0 0 16px;
      letter-spacing: -2.4px;
      color: #042f24;
      line-height: 0.98;
    }
    .rep-header__byline {
      font-size: 18px;
      color: #475569;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    /* ─────────────────────────────────────────────────────── */
    /* Section heads — bold badge + full-width hairline rule     */
    /* IG-post / editorial-magazine vibe: each section is a      */
    /* clear "page break" with strong typographic moment.        */
    /* ─────────────────────────────────────────────────────── */
    .rep-section-head {
      display: flex;
      align-items: center;
      gap: 24px;
      margin-bottom: 28px;
      padding-bottom: 24px;
      border-bottom: 1px solid #e6e9ed;
    }
    .rep-section-badge {
      flex: 0 0 76px;
      width: 76px;
      height: 76px;
      border-radius: 18px;
      background: #042f24;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      font-weight: 800;
      font-family: 'Manrope', 'SF Mono', monospace;
      letter-spacing: -1.2px;
    }
    .rep-section-head[data-accent="amber"] .rep-section-badge { background: #b45309; }
    .rep-section-head[data-accent="rose"] .rep-section-badge { background: #9d174d; }
    .rep-section-text { flex: 1; min-width: 0; }
    .rep-section-en {
      font-size: 11px;
