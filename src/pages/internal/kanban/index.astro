        )}
      </section>

      <!-- ── PANEL: 在读学校分布 (treemap) ── -->
      <section data-panel="schools" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            在读学校分布 <span class="section-card__subtitle">方块面积 = 学生数 · {schoolData.length} 所学校 · 长尾合并</span>
          </h2>
        </div>
        {schoolChartData.length === 0 ? (
          <p class="section-card__empty">暂无在读学校数据。</p>
        ) : (
          <div id="chart-schools-treemap" style="width: 100%; height: 480px;"></div>
        )}
      </section>

      <!-- ─────────────────────────────────────────────────── -->
      <!-- PANEL: 合同分布 — 留学 / 客单价 / 产品 by advisor   -->
      <!--                                                     -->
      <!-- Three columns each sorted by its own metric.        -->
      <!-- Hover any row → all columns highlight that advisor. -->
      <!--                                                     -->
      <!-- 客单价 = 总收入 / 学生数 (across all contracts;     -->
      <!-- not filtered by 留学/产品). 学生数 = unique students -->
      <!-- this advisor has across both buckets.               -->
      <!-- ─────────────────────────────────────────────────── -->
      <section data-panel="contracts" class="kanban-panel section-card is-active">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            合同分布 <span class="section-card__subtitle">在册 {ACTIVE_ADVISORS.length} 位中期 · 学生归属 mid_advisors[0] · 排除已终止 · hover 任一行联动其他两列</span>
          </h2>
        </div>

        <div class="cp-grid">
          <!-- COL 1: 留学合同 (sorted by 留学 ¥ DESC) -->
          <div class="cp-col">
            <div class="cp-col-head">
              <h3 class="cp-col-title">留学合同</h3>
              <span class="cp-col-meta">按 ¥ 降序</span>
            </div>
            <ul class="cp-rows">
              {liuxueRanked.map((s, idx) => {
                const barWidth = maxLiuxue > 0 ? (s.liuxueRevenue / maxLiuxue) * 100 : 0;
                const isTop3 = idx < 3 && s.liuxueRevenue > 0;
                return (
                  <li class={`cp-row ${s.liuxueRevenue === 0 ? 'is-empty' : ''}`} data-advisor={s.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(s.advisor)} class="cp-name">{s.advisor}</a>
                      <span class="cp-money font-mono">{fmtMoney(s.liuxueRevenue)}</span>
                    </div>
                    <div class="cp-bar">
                      <span class="cp-bar__fill" style={`width: ${barWidth}%; background: var(--primary);`}></span>
                    </div>
                    <div class="cp-meta">
                      <span class="cp-meta__tag"><strong class="font-mono">{s.liuxueStudents.size}</strong>学生</span>
                      <span class="cp-meta__tag"><strong class="font-mono">{s.liuxueContracts}</strong>合同</span>
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- COL 2: 客单价 (sorted by 客单价 DESC; all-students denominator) -->
          <div class="cp-col cp-col--customer">
            <div class="cp-col-head">
              <h3 class="cp-col-title">客单价</h3>
              <span class="cp-col-meta">总 ¥ ÷ 总学生</span>
            </div>
            <ul class="cp-rows">
              {customerValueRanked.map((r, idx) => {
                const barWidth = maxAvgPrice > 0 ? (r.avgPrice / maxAvgPrice) * 100 : 0;
                const isTop3 = idx < 3 && r.avgPrice > 0;
                const mix = advisorMixObj(r.advisor);
                return (
                  <li class={`cp-row ${r.avgPrice === 0 ? 'is-empty' : ''}`} data-advisor={r.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(r.advisor)} class="cp-name">{r.advisor}</a>
                      <span class="cp-money font-mono">¥{fmtMoneyShort(r.avgPrice)}</span>
                    </div>
                    <div class="cp-bar">
                      <span class="cp-bar__fill" style={`width: ${barWidth}%; background: #b69d7e;`}></span>
                    </div>
                    <div class="cp-meta">
                      <span class="cp-meta__tag"><strong class="font-mono">{r.totalStudents}</strong>学生</span>
                      <span class="cp-meta__tag font-mono" style="color:var(--text-muted)">合计 {fmtMoneyShort(r.totalRevenue)}</span>
                      <span class="cp-mix" title={`总 ${mix.total} 学生 = 单留学 ${mix.onlyLiuxue} + 都有 ${mix.both} + 单产品 ${mix.onlyProduct}`}>
                        <span class="cp-mix__seg cp-mix__seg--liuxue" style={`flex: ${mix.onlyLiuxue};`}></span>
                        <span class="cp-mix__seg cp-mix__seg--both" style={`flex: ${mix.both};`}></span>
                        <span class="cp-mix__seg cp-mix__seg--product" style={`flex: ${mix.onlyProduct};`}></span>
                      </span>
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- COL 3: 产品合同 (sorted by 产品 ¥ DESC) -->
          <div class="cp-col">
            <div class="cp-col-head">
              <h3 class="cp-col-title">产品合同</h3>
              <span class="cp-col-meta">按 ¥ 降序</span>
            </div>
            <ul class="cp-rows">
              {productRanked.map((s, idx) => {
                const barWidth = maxProduct > 0 ? (s.productRevenue / maxProduct) * 100 : 0;
                const isTop3 = idx < 3 && s.productRevenue > 0;
                // Build family stack — pull "其他" out FIRST so it doesn't
                // duplicate when slice(4)+ tail also accumulates into "其他".
                const allFams = Array.from(s.productByFamily.entries());
                const explicitOther = allFams.find(([k]) => k === '其他');
                const namedFams = allFams
                  .filter(([k]) => k !== '其他')
                  .sort((a, b) => b[1].revenue - a[1].revenue);
                const topFams = namedFams.slice(0, 4);
                const tailRev = namedFams.slice(4).reduce((sum, [, v]) => sum + v.revenue, 0)
                              + (explicitOther ? explicitOther[1].revenue : 0);
                const tailCount = namedFams.slice(4).reduce((sum, [, v]) => sum + v.count, 0)
                              + (explicitOther ? explicitOther[1].count : 0);
                const segments = topFams.map(([k, v]) => ({ name: k, revenue: v.revenue, count: v.count }));
                if (tailRev > 0) segments.push({ name: '其他', revenue: tailRev, count: tailCount });
                return (
                  <li class={`cp-row ${s.productRevenue === 0 ? 'is-empty' : ''}`} data-advisor={s.advisor}>
                    <div class="cp-row__head">
                      <span class={`cp-rank ${isTop3 ? 'is-top' : ''}`}>{idx + 1}</span>
                      <a href={buildHref(s.advisor)} class="cp-name">{s.advisor}</a>
                      <span class="cp-money font-mono">{fmtMoney(s.productRevenue)}</span>
                    </div>
                    <div class="cp-bar cp-bar--stacked" title={segments.map(seg => `${seg.name}: ${fmtMoneyShort(seg.revenue)} (${seg.count})`).join(' · ')}>
                      {segments.map(seg => {
                        const segWidthPct = s.productRevenue > 0 ? (seg.revenue / s.productRevenue) * barWidth : 0;
                        const color = FAMILY_COLORS[seg.name] || '#c4c4c4';
                        return (
                          <span class="cp-bar__seg" style={`width: ${segWidthPct}%; background: ${color};`} title={`${seg.name}: ${fmtMoneyShort(seg.revenue)} · ${seg.count} 单`}></span>
                        );
                      })}
                    </div>
                    <div class="cp-meta">
                      <span class="cp-meta__tag"><strong class="font-mono">{s.productStudents.size}</strong>学生</span>
                      <span class="cp-meta__tag"><strong class="font-mono">{s.productContracts}</strong>合同</span>
                      {topFams.length > 0 && (
                        <span class="cp-meta__tag cp-meta__tag--family">主打<strong>{topFams[0][0]}</strong>{Math.round((topFams[0][1].revenue / s.productRevenue) * 100)}%</span>
                      )}
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>

        <!-- Legends row -->
        <div class="cp-legends">
          <div class="cp-legend">
            <span class="cp-legend__title">客单价 学生构成</span>
            <span class="cp-legend__item"><span class="cp-mix__seg cp-mix__seg--liuxue" style="width:14px;height:8px;"></span>单留学</span>
            <span class="cp-legend__item"><span class="cp-mix__seg cp-mix__seg--both" style="width:14px;height:8px;"></span>都有</span>
            <span class="cp-legend__item"><span class="cp-mix__seg cp-mix__seg--product" style="width:14px;height:8px;"></span>单产品</span>
          </div>
          <div class="cp-legend">
            <span class="cp-legend__title">产品族色</span>
            {Object.entries(FAMILY_COLORS).map(([name, color]) => {
              const used = productRanked.some(r => r.productByFamily.has(name));
              if (!used) return null;
              return (
                <span class="cp-legend__item">
                  <span class="cp-legend__swatch" style={`background: ${color};`}></span>{name}
                </span>
              );
            })}
          </div>
        </div>
      </section>

      <!-- ─────────────────────────────────────────────────── -->
      <!-- PANEL: 周度签约 ¥ — 12 周 heatmap                   -->
      <!--                                                     -->
      <!-- Per-advisor row × 12 weeks. Cell = signed amount,   -->
      <!-- color shaded by amount (0 → white, max → primary).  -->
      <!-- Rows sorted by 12-week total DESC.                  -->
      <!-- ─────────────────────────────────────────────────── -->
      <section data-panel="weekly" class="kanban-panel section-card">
        <div class="section-card__header">
          <h2 class="font-headline section-card__title">
            周度签约 ¥ <span class="section-card__subtitle">最近 12 周（周一锚定）· 色阶 = 当周顾问签约金额 · 排除已终止</span>
          </h2>
        </div>
        {weeklyRanked.length === 0 ? (
          <p class="section-card__empty">暂无数据。</p>
        ) : (
          <div class="wk-wrap">
            <table class="wk-table">
              <thead>
                <tr>
                  <th class="wk-th-advisor">中期</th>
                  {weekLabels.map(w => <th class="wk-th-week font-mono">{fmtWk(w)}</th>)}
                  <th class="wk-th-total">12 周合计</th>
                </tr>
              </thead>
              <tbody>
                {weeklyRanked.map(r => (
                  <tr data-advisor={r.advisor}>
                    <td class="wk-td-advisor">
                      <a href={buildHref(r.advisor)}>{r.advisor}</a>
                    </td>
                    {r.cells.map((c, i) => (
                      <td
                        class={`wk-cell ${c.revenue > 0 ? 'has-value' : ''}`}
                        style={`background:${weeklyHeatColor(c.revenue)}; color:${c.revenue / weeklyMaxCell > 0.45 ? 'white' : '#475569'};`}
                        title={c.revenue > 0 ? `${weekLabels[i]} 起 · ${c.count} 单 · ¥${fmtMoneyShort(c.revenue)}` : `${weekLabels[i]} 起 · 0`}
                      >
                        {c.revenue > 0 ? <span class="font-mono">{fmtMoneyShort(c.revenue)}</span> : ''}
                      </td>
                    ))}
                    <td class="wk-td-total font-mono">{fmtMoney(r.total)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="wk-legend">
              <span>0</span>
              <span class="wk-legend__bar">
                {[0.1, 0.25, 0.5, 0.75, 0.96].map(a => (
                  <span style={`background: rgba(4,47,36,${a});`}></span>
                ))}
              </span>
              <span>¥{fmtMoneyShort(weeklyMaxCell)} max</span>
            </div>
          </div>
        )}
      </section>
    </div>
  </div>

  <script type="application/json" id="chart-payload" set:html={JSON.stringify(chartPayload)}></script>

  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/cytoscape@3.30.4/dist/cytoscape.min.js" is:inline></script>

  <script is:inline>
    (function () {
      const payload = JSON.parse(document.getElementById('chart-payload').textContent);

      // Resize all chart instances on viewport change.
      const charts = [];
      window.addEventListener('resize', () => charts.forEach(c => c && c.resize()));

      // ── Tab switching: hide non-active panels; resize charts on activate ──
      const tabButtons = document.querySelectorAll('.kanban-tab');
      const panels = document.querySelectorAll('.kanban-panel');
      function activateTab(name) {
        tabButtons.forEach(b => b.classList.toggle('is-active', b.dataset.tab === name));
        panels.forEach(p => p.classList.toggle('is-active', p.dataset.panel === name));
        // Charts inside hidden panels render at 0×0; force resize on activate.
        requestAnimationFrame(() => charts.forEach(c => c && c.resize()));
      }
      tabButtons.forEach(b => {
        b.addEventListener('click', () => activateTab(b.dataset.tab));
      });

      // ── 合同分布: hover any row → highlight same advisor in all 3 columns ──
      function highlightAdvisor(name, on) {
        document.querySelectorAll(`.cp-row[data-advisor="${CSS.escape(name)}"]`)
          .forEach(el => el.classList.toggle('is-paired', on));
      }
      document.querySelectorAll('.cp-row').forEach(row => {
        row.addEventListener('mouseenter', () => highlightAdvisor(row.dataset.advisor, true));
        row.addEventListener('mouseleave', () => highlightAdvisor(row.dataset.advisor, false));
      });

      // Mark body for fixed-shell CSS (no page scroll)
      document.body.classList.add('kanban-page');

      // ── Schools: treemap (Morandi, per-tile explicit color) ──
      // ECharts treemap was applying its own color treatment on top of my
      // palette (presumably saturation/value adjustments based on tile
      // size) which kept making the colors read as bright primaries instead
      // of muted Morandi. Set itemStyle.color directly on each data point —
      // ECharts treats that as authoritative and won't post-process. Donut
      // palette is reused verbatim since this view's not the issue. The
      // sqrt sizing + 其他 bucket exclusion stay.
      const schoolEl = document.getElementById('chart-schools-treemap');
      if (schoolEl && payload.schoolChartData.length) {
        const c = echarts.init(schoolEl);
        charts.push(c);
        const data = payload.schoolChartData
          .filter(d => !d.name.startsWith('其他'))
          .slice()
          .sort((a, b) => b.count - a.count)
          .map(d => ({
            name: d.name,
            value: Math.sqrt(d.count),
            realCount: d.count,
            itemStyle: { color: payload.schoolColors[d.name] || '#ADA39A' },
          }));
        c.setOption({
          tooltip: {
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.realCount}</strong> 学生`,
          },
          series: [{
            type: 'treemap',
            data,
            roam: false,
            nodeClick: false,
            breadcrumb: { show: false },
            visibleMin: 0,
            label: {
              show: true,
              formatter: (p) => `{name|${p.data.name}}\n{val|${p.data.realCount}}`,
              rich: {
                name: { color: '#3a3835', fontSize: 13, fontWeight: 600, lineHeight: 18 },
                val:  { color: 'rgba(58, 56, 53, 0.65)', fontSize: 11, fontWeight: 500 },
              },
            },
            upperLabel: { show: false },
            // Don't let ECharts auto-derive colors — items already carry them.
            colorMappingBy: 'value',
            colorAlpha: 1,
            colorSaturation: 1,
            levels: [{
              itemStyle: { borderColor: '#fafaf8', borderWidth: 3, gapWidth: 3 },
              colorAlpha: 1,
              colorSaturation: 1,
            }],
          }],
        });
      }

      // ── Widget 2: co-application network (now full-width, name + count
      // shown inside each node, size scales with student count) ──
      const netEl = document.getElementById('chart-network');
      if (netEl && payload.network.nodes.length && typeof cytoscape !== 'undefined') {
        const cy = cytoscape({
          container: netEl,
          elements: [...payload.network.nodes, ...payload.network.edges],
          layout: {
            name: 'cose',
            animate: false,
            // fit + small padding pushes the laid-out graph to fill the
            // container. Bigger nodeRepulsion keeps the chunkier nodes from
            // overlapping; idealEdgeLength scales accordingly. Higher
            // gravity (default 1) pulls nodes — including disconnected
            // ones — toward the center so an island region doesn't drift
            // to the corner of the canvas.
            fit: true,
            padding: 12,
            nodeRepulsion: 28000,
            idealEdgeLength: 200,
            edgeElasticity: 200,
            gravity: 2.5,
          },
          style: [
            {
              selector: 'node',
              style: {
                // Each node draws from the Morandi palette via data(color).
                'background-color': 'data(color)',
                // Two-line label: region name + student count
                'label': (n) => `${n.data('label')}\n${n.data('weight')}`,
                'text-wrap': 'wrap',
                'text-max-width': '160px',
                'color': '#3a3835',  // dark text reads on every Morandi tone
                'font-size': 17,
                'font-weight': 800,
                'text-halign': 'center',
                'text-valign': 'center',
                'line-height': 1.2,
                'width':  (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'height': (n) => 56 + Math.sqrt(n.data('weight')) * 14,
                'border-width': 0,
              },
            },
            {
              selector: 'edge',
              style: {
                'line-color': '#A8A39A',  // warm neutral grey — Morandi-ish
                'opacity': 0.7,
                'curve-style': 'bezier',
                'width': (e) => 1.5 + Math.min(e.data('weight'), 8) * 1.5,
                // Label edges with the co-app count when ≥ 2 (avoid clutter on
                // 1-student lines). White-bg pill keeps it readable on any
                // edge color.
                'label': (e) => e.data('weight') >= 2 ? String(e.data('weight')) : '',
                'font-size': 14,
                'font-weight': 700,
                'color': '#3a3835',
                'text-background-color': '#ffffff',
                'text-background-opacity': 0.92,
                'text-background-padding': '3px',
                'text-background-shape': 'roundrectangle',
                'text-rotation': 'autorotate',
              },
            },
            {
              selector: 'node:selected',
              style: { 'border-width': 3, 'border-color': '#3a3835' },
            },
          ],
        });
        cy.userZoomingEnabled(false);
        cy.userPanningEnabled(false);
        // Cose layout sometimes finishes before the container has its
        // final paint size (Astro hydration / TOC sidebar pushing in).
        // resize + fit on next tick (and on every window resize) makes
        // the graph fill the container properly. Padding 40 leaves
        // breathing room around the outermost nodes.
        const refit = () => { cy.resize(); cy.fit(undefined, 12); };
        requestAnimationFrame(refit);
        window.addEventListener('resize', refit);
        // ResizeObserver catches the case where the kanban-grid shifts
        // (e.g. sidebar collapses on mobile) without a window resize event.
        if (typeof ResizeObserver !== 'undefined') {
          new ResizeObserver(refit).observe(netEl);
        }

        // ── Panel: layout sliders, selection details, centrality ranking ──
        const sliders = document.querySelectorAll('.network-panel input[type="range"]');
        const baseLayout = {
          name: 'cose', animate: false, fit: true, padding: 12,
          edgeElasticity: 200,
        };
        let layoutTimer = null;
        const reLayout = () => {
          const params = { ...baseLayout };
          sliders.forEach(s => { params[s.dataset.tweak] = Number(s.value); });
          clearTimeout(layoutTimer);
          // 80ms debounce so dragging the slider isn't laggy.
          layoutTimer = setTimeout(() => cy.layout(params).run(), 80);
        };
        sliders.forEach(s => s.addEventListener('input', reLayout));

        const resetBtn = document.getElementById('network-reset');
        if (resetBtn) {
          resetBtn.addEventListener('click', () => {
            const defaults = { nodeRepulsion: 28000, idealEdgeLength: 200, gravity: 2.5 };
            sliders.forEach(s => { s.value = String(defaults[s.dataset.tweak]); });
            reLayout();
          });
        }

        // Centrality ranking — degree (= # of co-application connections).
        // Ties broken by student count.
        const centralityEl = document.getElementById('network-centrality');
        const ranks = cy.nodes().map(n => ({
          id: n.id(),
          name: n.data('label'),
          weight: n.data('weight'),
          color: n.data('color'),
          degree: n.degree(),
        })).sort((a, b) => b.degree - a.degree || b.weight - a.weight);
        const maxDegree = Math.max(1, ...ranks.map(r => r.degree));
        if (centralityEl) {
          centralityEl.innerHTML = ranks.map((r, i) => `
            <li data-region="${encodeURIComponent(r.id)}">
              <span class="panel-ranking__rank">${i + 1}</span>
              <span>
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${r.color};margin-right:6px;"></span>${r.name}
                <span class="panel-ranking__bar"><span style="width:${(r.degree / maxDegree) * 100}%;"></span></span>
              </span>
              <span style="text-align:right;font-weight:600;">${r.degree}</span>
            </li>
          `).join('');
          centralityEl.querySelectorAll('li').forEach(li => {
            li.addEventListener('click', () => {
              const id = decodeURIComponent(li.dataset.region || '');
              const node = cy.getElementById(id);
              if (node && node.length) {
                cy.elements().unselect();
                node.select();
                showSelection(node);
              }
            });
          });
        }

        // Selection panel — fill with neighborhood + co-app counts when a
        // node is clicked. Click-on-empty-canvas clears it.
        const selEl = document.getElementById('network-selection');
        const showSelection = (node) => {
          if (!selEl) return;
          const region = node.data('label');
          const total = node.data('weight');
          const color = node.data('color');
          const neighbors = node.connectedEdges().map(edge => {
            const other = edge.source().id() === node.id() ? edge.target() : edge.source();
            return { name: other.data('label'), color: other.data('color'), weight: edge.data('weight') };
          }).sort((a, b) => b.weight - a.weight);
          const list = neighbors.length === 0
            ? '<p class="panel-empty" style="margin-top:8px;">没有共申地区（孤立节点）</p>'
            : `<ul class="panel-coapps">${neighbors.map(n => `
                <li>
                  <span><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${n.color};margin-right:6px;vertical-align:middle;"></span>${n.name}</span>
                  <strong>${n.weight}</strong>
                </li>`).join('')}</ul>`;
          selEl.innerHTML = `
            <div class="panel-label">节点详情</div>
            <div class="panel-region">
              <span class="panel-region__dot" style="background:${color};"></span>
              ${region}
              <span class="panel-region__count">${total} 学生</span>
            </div>
            <div style="font-size:11px;color:var(--text-soft);text-transform:uppercase;letter-spacing:0.08em;margin-top:8px;">共申地区 (${neighbors.length})</div>
            ${list}
          `;
          // Highlight the matching row in the centrality ranking
          if (centralityEl) {
            centralityEl.querySelectorAll('li').forEach(li => {
              li.classList.toggle('is-active', decodeURIComponent(li.dataset.region || '') === node.id());
            });
          }
        };
        cy.on('tap', 'node', (e) => showSelection(e.target));
        cy.on('tap', (e) => {
          // Clicked outside any node → clear selection panel
          if (e.target === cy) {
            if (selEl) {
              selEl.innerHTML = `
                <div class="panel-label">节点详情</div>
                <p class="panel-empty">点一个节点查看共申关系</p>
              `;
            }
            if (centralityEl) {
              centralityEl.querySelectorAll('li').forEach(li => li.classList.remove('is-active'));
            }
          }
        });
      }

      // ── Stage × year: stacked horizontal bar (cohort funnel) ──
      // Each bar = one enroll year, segmented by stage. Reading from left to
      // right = progression through the pipeline.
      const syEl = document.getElementById('chart-stage-year');
      if (syEl && payload.years.length) {
        const c = echarts.init(syEl);
        charts.push(c);
        // Reverse years so the most recent / nearest cohort is on top.
        const yearsAxis = payload.years.slice().reverse();
        const series = payload.stages.map(stage => ({
          name: stage,
          type: 'bar',
          stack: 'cohort',
          itemStyle: { color: payload.stageColors[stage] || '#94a3b8' },
          barCategoryGap: '32%',
          data: yearsAxis.map(year => {
            const cell = payload.stageYearCells.find(x => x.year === year && x.stage === stage);
            return cell ? cell.count : 0;
          }),
          label: {
            show: true,
            position: 'inside',
            color: '#fff',
            fontWeight: 700,
            fontSize: 12,
            formatter: (p) => p.value > 0 ? p.value : '',
          },
        }));
        c.setOption({
          tooltip: {
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: (params) => {
              const year = params[0]?.axisValue ?? '';
              const total = params.reduce((s, p) => s + (p.value || 0), 0);
              const lines = params
                .filter(p => p.value > 0)
                .map(p => `${p.marker} ${p.seriesName}: <strong>${p.value}</strong>`)
                .join('<br/>');
              return `<div style="font-weight:700;margin-bottom:4px;">${year} · 共 ${total}</div>${lines}`;
            },
          },
          legend: {
            data: payload.stages,
            top: 0,
            right: 0,
            icon: 'roundRect',
            itemWidth: 12,
            itemHeight: 12,
            textStyle: { color: '#475569', fontSize: 12 },
          },
          grid: { left: 12, right: 60, top: 36, bottom: 12, containLabel: true },
          xAxis: {
            type: 'value',
            axisLine: { show: false },
            axisTick: { show: false },
            splitLine: { lineStyle: { color: '#eef0f3' } },
            axisLabel: { color: '#94a3b8', fontSize: 11 },
          },
          yAxis: {
            type: 'category',
            data: yearsAxis,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 13 },
          },
          series,
        });
      }

      // ── Widget 7+9: advisor heatmap ──
      const ahEl = document.getElementById('chart-advisor-heatmap');
      if (ahEl && payload.advisors.length) {
        const c = echarts.init(ahEl);
        charts.push(c);
        const maxV = Math.max(1, payload.heatmapMax);
        c.setOption({
          tooltip: {
            position: 'top',
            formatter: (p) => `${payload.advisors[p.value[1]]} · ${payload.weeks[p.value[0]]} 周<br/><strong>${p.value[2]}</strong> 条活动`,
          },
          grid: { left: 80, right: 16, top: 32, bottom: 50 },
          xAxis: {
            type: 'category',
            data: payload.weeks,
            position: 'top',
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#64748b', fontSize: 11 },
            splitArea: { show: true },
          },
          yAxis: {
            type: 'category',
            data: payload.advisors,
            axisLine: { show: false },
            axisTick: { show: false },
            axisLabel: { color: '#475569', fontWeight: 600, fontSize: 12 },
            splitArea: { show: true },
          },
          visualMap: {
            min: 0,
            max: maxV,
            calculable: false,
            orient: 'horizontal',
            left: 'center',
            bottom: 0,
            itemWidth: 12,
            itemHeight: 120,
            // pale → smoky-purple gradient (matches the deep tone reserved
            // for 后期在途 in the stage chart, so the page hangs together).
            inRange: { color: ['#f8fafc', '#EDE5ED', '#D1BFD1', '#B5A0B5'] },
            textStyle: { color: '#64748b', fontSize: 11 },
          },
          series: [{
            type: 'heatmap',
            data: payload.heatmapData,
            label: {
              show: true,
              fontSize: 11,
              color: '#0f172a',
              formatter: (p) => p.value[2] > 0 ? p.value[2] : '',
            },
            itemStyle: { borderColor: '#fff', borderWidth: 1 },
          }],
        });
        c.on('click', (params) => {
          if (params.value && typeof params.value[1] === 'number') {
            const advisor = payload.advisors[params.value[1]];
            if (advisor) location.href = '/internal/kanban/advisors/' + encodeURIComponent(advisor);
          }
        });
      }

      // ── Donut helper (Morandi palette, slices optionally clickable) ──
      // Top-N + 其他 bucket built server-side. donut data is { name, value }[].
      function renderDonut(elId, donutData, colorMap, options) {
        const el = document.getElementById(elId);
        if (!el || !donutData.length) return;
        const c = echarts.init(el);
        charts.push(c);
        const total = donutData.reduce((s, x) => s + x.value, 0);
        const unit = options.unit || '学生';
        const centerLabel = options.centerLabel || `${total}\n${unit}`;
        const slices = donutData.map(d => ({
          name: d.name,
          value: d.value,
          itemStyle: {
            color: d.name.startsWith('其他') ? '#ADA39A' : (colorMap[d.name] || '#ADA39A'),
          },
        }));
        c.setOption({
          tooltip: {
            trigger: 'item',
            formatter: (p) => `${p.data.name}<br/><strong>${p.data.value}</strong> ${unit} · ${(p.data.value / total * 100).toFixed(1)}%`,
          },
          legend: { show: false },
          series: [{
            type: 'pie',
            radius: ['52%', '82%'],
            center: ['50%', '50%'],
            avoidLabelOverlap: true,
            itemStyle: { borderColor: '#fafaf8', borderWidth: 2 },
            label: {
              show: true,
              position: 'outside',
              formatter: (p) => `{n|${p.data.name}}\n{v|${p.data.value} · ${(p.percent ?? 0).toFixed(0)}%}`,
              rich: {
                n: { color: '#3a3835', fontSize: 12, fontWeight: 600, lineHeight: 16 },
                v: { color: '#7a7872', fontSize: 11, lineHeight: 14 },
              },
            },
            labelLine: { length: 12, length2: 16, lineStyle: { color: '#cbd5e1' } },
            emphasis: {
              scale: true,
              scaleSize: 8,
              label: { fontWeight: 700 },
              itemStyle: { shadowBlur: 12, shadowColor: 'rgba(0,0,0,0.08)' },
            },
            data: slices,
          }],
          graphic: [{
            type: 'text',
            left: 'center',
            top: 'middle',
            style: {
              text: centerLabel,
              textAlign: 'center',
              fill: '#3a3835',
              fontSize: 22,
              fontWeight: 700,
              lineHeight: 28,
            },
          }],
        });
        if (options.onSliceClick) {
          c.on('click', (params) => {
            if (!params || !params.data || !params.data.name) return;
            if (params.data.name.startsWith('其他')) return;
            options.onSliceClick(params.data.name);
          });
          el.style.cursor = 'pointer';
        }
      }

      // (留学/产品 donut charts replaced 2026-05-09 by per-advisor paired
      // widgets above — see #kanban-liuxue. Donut chart-id divs no longer
      // exist; renderDonut calls were removed to avoid orphan errors.)

    })();
  </script>

  <style>
    /* ── KPI banner ── */
    .kpi-banner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin-bottom: 24px;
    }
    .kpi-card {
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 18px;
    }
    .kpi-card__value {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.2;
    }
    .kpi-card__value-unit {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-muted);
    }
    .kpi-card__label {
      margin-top: 6px;
      font-size: 11px;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }

    /* ── Advisor revenue / 业绩 table ── */
    /* cell-stack: 让一格里堆 2 行 — primary 大数 + secondary 小数 */
    .cell-stack {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }
    .cell-stack__primary {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
    }
    .cell-stack__secondary {
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.2;
    }
    .perf-table th.num,
    .perf-table td.num {
      min-width: 110px;  /* 让客单价 / 签约 / 优惠 列稳定宽度，避免数字跳动 */
    }

    .advisor-revenue-table {
      width: 100%;
    }
    .advisor-revenue-table table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .advisor-revenue-table thead th {
      text-align: left;
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      font-weight: 700;
      color: var(--text-soft);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .advisor-revenue-table thead th.num,
    .advisor-revenue-table tbody td.num {
      text-align: right;
    }
    .advisor-revenue-table tbody td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
    }
    .advisor-revenue-table tbody tr:last-child td {
      border-bottom: none;
    }
    .bar-cell {
      position: relative;
      display: block;
      width: 100%;
      min-width: 120px;
      height: 18px;
      background: rgba(0,0,0,0.04);
      border-radius: 4px;
      overflow: hidden;
    }
    .bar-cell__fill {
      position: absolute;
      inset: 0 auto 0 0;
      background: linear-gradient(90deg, #B5A0B5 0%, #7B5E7B 100%);
      border-radius: 4px;
    }
    .bar-cell__num {
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 11px;
      color: var(--text);
      font-weight: 600;
    }

    /* ── Fixed-shell layout: viewport-bound; no page scroll ── */
    :global(body.kanban-page) { overflow: hidden; height: 100vh; }
    :global(body.kanban-page footer) { display: none; }

    .kanban-shell {
      position: fixed;
      top: 64px;       /* InternalLayout header height */
      left: 0; right: 0; bottom: 0;
      display: flex;
      flex-direction: column;
      background: var(--surface, #fafafa);
      padding: 14px 24px 18px;
      gap: 12px;
      box-sizing: border-box;
    }

    .kanban-top {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .kanban-top__title {
      display: flex;
      align-items: baseline;
      gap: 12px;
    }
    .kanban-top__h1 {
      font-size: 22px;
      margin: 0;
      letter-spacing: -0.02em;
      font-weight: 800;
    }
    .kanban-top__filter {
      font-weight: 600;
      color: var(--primary);
      margin-left: 6px;
    }
    .kanban-top__count {
      font-size: 12px;
      color: var(--text-muted);
    }
    .kanban-top__chips {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      max-width: 100%;
    }

    .kanban-grid {
      flex: 1;
      min-height: 0;
      display: grid;
      grid-template-columns: 200px minmax(0, 1fr);
      gap: 16px;
      align-items: stretch;
    }

    /* ── Tab sidebar ── */
    .kanban-tabs {
      background: white;
      border: 1px solid var(--border, #eef0f3);
      border-radius: 12px;
      padding: 8px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      overflow-y: auto;
    }
    .kanban-tab {
      background: transparent;
      border: none;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      text-align: left;
      display: grid;
      grid-template-columns: 20px 1fr;
      grid-template-rows: auto auto;
      column-gap: 10px;
      align-items: center;
      transition: background 120ms, color 120ms;
      color: var(--text-muted);
      font-family: inherit;
    }
    .kanban-tab__icon {
      grid-row: 1 / 3;
      font-size: 20px !important;
      color: inherit;
    }
    .kanban-tab__label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }
    .kanban-tab__sub {
      font-size: 10.5px;
      color: var(--text-soft);
      grid-column: 2;
    }
    .kanban-tab:hover {
      background: #f5f5f7;
    }
    .kanban-tab.is-active {
      background: var(--primary);
      color: white;
    }
    .kanban-tab.is-active .kanban-tab__label { color: white; }
    .kanban-tab.is-active .kanban-tab__sub { color: rgba(255, 255, 255, 0.7); }

    /* ── Panel area ── */
    .kanban-main {
      min-width: 0;
      min-height: 0;
      overflow: auto;
      background: white;
      border: 1px solid var(--border, #eef0f3);
      border-radius: 12px;
      padding: 18px 22px;
    }
    .kanban-panel {
      display: none;
      animation: panelFade 180ms ease-out;
    }
    .kanban-panel.is-active {
      display: block;
    }
    @keyframes panelFade {
      from { opacity: 0; transform: translateY(2px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .kanban-panel.section-card {
      background: transparent;
      border: none;
      padding: 0;
      margin: 0;
      box-shadow: none;
    }

    /* ── Mobile collapse ── */
    @media (max-width: 800px) {
      .kanban-shell { padding: 10px 14px; }
      .kanban-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
      }
      .kanban-tabs {
        flex-direction: row;
        overflow-x: auto;
        padding: 4px;
      }
      .kanban-tab {
        flex-shrink: 0;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto;
      }
      .kanban-tab__sub { display: none; }
    }

    /* ── 合同分布 cp-* (3-column widget) ── */
    .cp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
      align-items: start;
      margin-bottom: 16px;
    }
    @media (max-width: 1100px) {
      .cp-grid { grid-template-columns: 1fr; gap: 16px; }
    }
    .cp-col--customer .cp-col-head {
      border-bottom-color: #b69d7e;
    }
    .cp-col-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 0 0 8px;
      border-bottom: 2px solid #f1f1f4;
      margin-bottom: 12px;
    }
    .cp-col-title {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 14px;
      color: var(--text);
      margin: 0;
    }
    .cp-col-meta { font-size: 11px; color: var(--text-soft); }

    .cp-rows { list-style: none; margin: 0; padding: 0; }
    .cp-row {
      padding: 8px 6px;
      border-radius: 6px;
      transition: background 120ms;
      border-bottom: 1px solid #f5f5f7;
    }
    .cp-row:last-child { border-bottom: none; }
    .cp-row.is-empty { opacity: 0.4; }
    .cp-row.is-paired {
      background: rgba(4, 47, 36, 0.06);
    }

    .cp-row__head {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 5px;
    }
    .cp-rank {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: white;
      border: 1px solid #d4d4d8;
      font-size: 9px;
      font-weight: 700;
      color: var(--text-muted);
      font-family: 'SF Mono', monospace;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .cp-rank.is-top {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }
    .cp-name {
      flex: 1;
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
    }
    .cp-name:hover { color: var(--primary); }
    .cp-money {
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
    }

    .cp-bar {
      width: 100%;
      height: 7px;
      background: #f3f4f6;
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 5px;
      display: flex;
    }
    .cp-bar__fill {
      height: 100%;
      border-radius: 3px;
      transition: width 220ms ease-out;
    }
    .cp-bar--stacked { gap: 1px; }
    .cp-bar__seg {
      height: 100%;
      transition: width 220ms ease-out;
    }
    .cp-bar__seg:first-child { border-top-left-radius: 3px; border-bottom-left-radius: 3px; }
    .cp-bar__seg:last-child { border-top-right-radius: 3px; border-bottom-right-radius: 3px; }

    .cp-meta {
      display: flex;
      gap: 8px;
      font-size: 10.5px;
      color: var(--text-soft);
      flex-wrap: wrap;
      align-items: center;
      padding-left: 26px;
    }
    .cp-meta__tag {
      display: inline-flex;
      align-items: baseline;
      gap: 2px;
    }
    .cp-meta__tag strong {
      color: var(--text);
      font-weight: 700;
      font-size: 11px;
      margin: 0 2px;
    }
    .cp-meta__tag--family strong {
      color: var(--primary);
    }
    .cp-mix {
      display: inline-flex;
      width: 60px;
      height: 8px;
      border-radius: 2px;
      overflow: hidden;
      margin-left: auto;
      background: #f3f4f6;
    }
    .cp-mix__seg { height: 100%; }
    .cp-mix__seg--liuxue  { background: #7c8da6; }
    .cp-mix__seg--both    { background: #042f24; }
    .cp-mix__seg--product { background: #b6948c; }

    .cp-legends {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      padding-top: 12px;
      border-top: 1px solid #f1f1f4;
      font-size: 10.5px;
      color: var(--text-muted);
    }
    .cp-legend {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }
    .cp-legend__title {
      font-weight: 700;
      color: var(--text);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .cp-legend__item {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .cp-legend__swatch {
      display: inline-block;
      width: 10px;
      height: 8px;
      border-radius: 2px;
    }

    /* ── 周度签约 wk-* ── */
    .wk-wrap { width: 100%; }
    .wk-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 2px;
      font-size: 12px;
    }
    .wk-table th {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-soft);
      padding: 4px 8px;
      text-align: center;
    }
    .wk-th-advisor { text-align: left !important; min-width: 80px; }
    .wk-th-week { font-family: 'SF Mono', monospace; }
    .wk-th-total { text-align: right !important; min-width: 90px; }
    .wk-table td { padding: 8px; border-radius: 5px; }
    .wk-td-advisor {
      font-weight: 700;
      font-size: 13px;
    }
    .wk-td-advisor a { color: var(--text); text-decoration: none; }
    .wk-td-advisor a:hover { color: var(--primary); }
    .wk-cell {
      text-align: center;
      font-size: 11px;
      transition: transform 80ms;
    }
    .wk-cell.has-value { font-weight: 700; cursor: help; }
    .wk-cell.has-value:hover { transform: scale(1.05); }
    .wk-td-total {
      text-align: right;
      font-weight: 700;
      font-size: 13px;
      color: var(--text);
      padding: 8px 10px !important;
    }
    .wk-legend {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 14px;
      font-size: 11px;
      color: var(--text-muted);
    }
    .wk-legend__bar {
      display: inline-flex;
      gap: 2px;
    }
    .wk-legend__bar > span {
      display: inline-block;
      width: 22px;
      height: 12px;
      border-radius: 2px;
    }

    /* ── Network row: graph on the left, live panel on the right ── */
    .network-row {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 20px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .network-row { grid-template-columns: 1fr; }
    }
    .network-panel {
      display: grid;
      gap: 18px;
      font-size: 13px;
    }
    .panel-section {
      background: var(--surface-raised);
      border: 1px solid #eef0f3;
      border-radius: 10px;
      padding: 14px 16px;
    }
    .panel-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 12px;
    }
    .panel-slider {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 10px;
      align-items: center;
      margin-bottom: 10px;
      font-size: 12px;
      color: var(--text-muted);
    }
    .panel-slider input[type="range"] {
      width: 100%;
      accent-color: var(--primary);
    }
    .panel-reset {
      margin-top: 4px;
      padding: 5px 10px;
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      background: white;
      border: 1px solid #eef0f3;
      border-radius: 5px;
      cursor: pointer;
      transition: border-color 120ms ease;
    }
    .panel-reset:hover { border-color: var(--text-muted); }
    .panel-empty {
      color: var(--text-soft);
      font-size: 12px;
      margin: 0;
      line-height: 1.5;
    }
    .panel-region {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 8px;
      font-weight: 700;
      font-size: 14px;
      color: var(--text);
    }
    .panel-region__dot {
      display: inline-block;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .panel-region__count {
      margin-left: auto;
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
    }
    .panel-coapps {
      list-style: none;
      margin: 8px 0 0;
      padding: 0;
      display: grid;
      gap: 4px;
      font-size: 12px;
    }
    .panel-coapps li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 3px 0;
      color: var(--text-muted);
    }
    .panel-coapps li strong {
      color: var(--text);
      font-weight: 600;
      letter-spacing: -0.005em;
    }
    .panel-ranking {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 3px;
      font-size: 12px;
    }
    .panel-ranking li {
      display: grid;
      grid-template-columns: 18px 1fr 32px;
      gap: 8px;
      align-items: center;
      padding: 4px 0;
      color: var(--text-muted);
      cursor: pointer;
      transition: color 120ms ease;
    }
    .panel-ranking li:hover { color: var(--text); }
    .panel-ranking li.is-active { color: var(--text); font-weight: 600; }
    .panel-ranking__rank {
      color: var(--text-soft);
      font-size: 10px;
      font-weight: 700;
      text-align: center;
    }
    .panel-ranking__bar {
      height: 4px;
      background: #f1f5f9;
      border-radius: 2px;
      overflow: hidden;
      margin-top: 2px;
    }
    .panel-ranking__bar > span {
      display: block;
      height: 100%;
      background: var(--primary);
      border-radius: 2px;
      transition: width 200ms ease;
    }

    .advisor-jump-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid #eef0f3;
    }

    /* ─────────────────────────────────────────────────────────
       合同分布 widget — 留学 + 产品 by 中期顾问 (paired layout)
       Designed for visual side-by-side scanning per advisor row.
       ───────────────────────────────────────────────────────── */
    .contracts-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    @media (max-width: 1100px) {
      .contracts-pair { grid-template-columns: 1fr; gap: 24px; }
    }
    .contracts-pair__col-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding-bottom: 10px;
      border-bottom: 2px solid #f1f1f4;
      margin-bottom: 16px;
    }
    .contracts-pair__col-title {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 15px;
      color: var(--text);
      margin: 0;
      letter-spacing: -0.01em;
    }
    .contracts-pair__col-meta {
      font-size: 11px;
      color: var(--text-soft);
    }

    .advisor-rows {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .advisor-row {
      padding: 10px 0;
      border-bottom: 1px solid #f5f5f7;
    }
    .advisor-row:last-child { border-bottom: none; }
    .advisor-row.is-empty { opacity: 0.45; }

    .advisor-row__head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .advisor-row__rank {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: white;
      border: 1px solid #d4d4d8;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-muted);
      text-decoration: none;
      font-family: 'SF Mono', monospace;
    }
    .advisor-row__rank.is-top {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }
    .advisor-row__rank:hover {
      transform: scale(1.08);
    }
    .advisor-row__name {
      flex: 1;
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
    }
    .advisor-row__name:hover { color: var(--primary); }
    .advisor-row__money {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    .advisor-row__bar {
      width: 100%;
      height: 8px;
      background: #f3f4f6;
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 6px;
      display: flex;
    }
    .advisor-row__bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 240ms ease-out;
    }
    .advisor-row__bar--stacked {
      gap: 1px;
    }
    .advisor-row__bar-seg {
      height: 100%;
      transition: width 240ms ease-out;
    }
    .advisor-row__bar-seg:first-child {
      border-top-left-radius: 4px;
      border-bottom-left-radius: 4px;
    }
    .advisor-row__bar-seg:last-child {
      border-top-right-radius: 4px;
      border-bottom-right-radius: 4px;
    }

    .advisor-row__meta {
      display: flex;
      gap: 14px;
      font-size: 11px;
      color: var(--text-soft);
      flex-wrap: wrap;
      align-items: center;
      padding-left: 32px;  /* align with name (after rank) */
    }
    .advisor-row__meta-item {
      display: inline-flex;
      align-items: baseline;
      gap: 3px;
    }
    .advisor-row__meta-item--family {
      color: var(--text-muted);
    }
    .advisor-row__meta-item--family strong {
      color: var(--text);
      font-weight: 700;
    }
    .advisor-row__meta-num {
      font-weight: 700;
      color: var(--text);
      font-size: 12px;
    }
    .advisor-row__pulse {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 999px;
      background: #f5f5f7;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }
    .advisor-row__pulse.is-hot {
      background: var(--primary);
      color: white;
    }

    .family-legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid #f1f1f4;
      font-size: 10px;
    }
    .family-legend__item {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: var(--text-muted);
    }
    .family-legend__swatch {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 2px;
    }
    .family-legend__name {
      font-weight: 600;
    }

    html { scroll-behavior: smooth; }
  </style>
</InternalLayout>
