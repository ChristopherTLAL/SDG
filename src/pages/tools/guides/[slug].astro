---
// src/pages/tools/guides/[slug].astro — Individual guide article page
import MainLayout from '../../../layouts/MainLayout.astro';
import { getGuideBySlug, getCategoryById, guides } from '../../../data/guides-meta';

const { slug } = Astro.params;
const guide = getGuideBySlug(slug!);

if (!guide) return Astro.redirect('/tools');

const category = getCategoryById(guide.category);

// Dynamically import content
let content = '';
try {
  const mod = await import(`../../../data/guides/${slug}.ts`);
  content = mod.default || mod.content || '';
} catch {
  content = '<p class="text-on-surface-variant">This article is coming soon. Check back later for the full guide.</p>';
}

// Find prev/next in same category
const categoryGuides = guides.filter(g => g.category === guide.category).sort((a, b) => a.order - b.order);
const currentIdx = categoryGuides.findIndex(g => g.slug === guide.slug);
const prev = currentIdx > 0 ? categoryGuides[currentIdx - 1] : null;
const next = currentIdx < categoryGuides.length - 1 ? categoryGuides[currentIdx + 1] : null;
---

<MainLayout title={`${guide.title} | Chinese SDGs Institute`} description={guide.description} lang="en">
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <article class="max-w-3xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6 md:mb-8 flex-wrap">
        <a href="/tools" class="hover:text-primary transition-colors">Tools</a>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <a href="/tools#guides" class="hover:text-primary transition-colors">Guides</a>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-primary font-bold">{category?.label}</span>
      </nav>

      <!-- Header -->
      <header class="mb-10 md:mb-16">
        {category && (
          <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest mb-5 ${category.color}`}>
            <span class="material-symbols-outlined text-xs">{category.icon}</span>
            {category.label}
          </span>
        )}

        <h1 class="text-2xl sm:text-3xl md:text-4xl font-headline font-extrabold tracking-tight text-on-surface leading-[1.1] mb-5">
          {guide.title}
        </h1>

        <p class="text-on-surface-variant text-base md:text-lg leading-relaxed mb-6">
          {guide.description}
        </p>

        <div class="flex flex-wrap items-center gap-4 text-sm text-on-surface-variant">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base">schedule</span>
            <span>{guide.readingTime} read</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base">local_offer</span>
            <span>{guide.tags.join(' · ')}</span>
          </div>
        </div>
      </header>

      <!-- Article Content -->
      <div class="article-body prose prose-lg max-w-none
        prose-headings:font-headline prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-on-surface
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-outline-variant/10 prose-h2:pb-3
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-on-surface-variant prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-on-surface-variant prose-li:leading-relaxed
        prose-strong:text-on-surface prose-strong:font-semibold
        prose-blockquote:border-l-4 prose-blockquote:border-primary/30 prose-blockquote:bg-surface-container-low prose-blockquote:rounded-r-xl prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:not-italic
        prose-a:text-primary prose-a:underline prose-a:underline-offset-4
        prose-ul:my-4 prose-ol:my-4
        prose-hr:border-outline-variant/10 prose-hr:my-8"
        set:html={content}
      />

      <!-- Prev/Next Navigation -->
      <nav class="mt-16 pt-8 border-t border-outline-variant/10">
        <div class="flex items-center justify-between gap-4">
          {prev ? (
            <a href={`/tools/guides/${prev.slug}`} class="group flex items-center gap-3 text-sm hover:text-primary transition-colors">
              <span class="material-symbols-outlined text-lg group-hover:-translate-x-1 transition-transform">arrow_back</span>
              <div class="text-right">
                <div class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/50 mb-1">Previous</div>
                <div class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-1">{prev.title}</div>
              </div>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/tools/guides/${next.slug}`} class="group flex items-center gap-3 text-sm hover:text-primary transition-colors text-right">
              <div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant/50 mb-1">Next</div>
                <div class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-1">{next.title}</div>
              </div>
              <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          ) : <div />}
        </div>
      </nav>

      <!-- Back to guides -->
      <div class="mt-8 text-center">
        <a href="/tools#guides" class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:underline underline-offset-4">
          <span class="material-symbols-outlined text-sm">grid_view</span>
          Browse All Guides
        </a>
      </div>
    </article>
  </main>
</MainLayout>
