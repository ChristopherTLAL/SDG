---
// src/pages/tools/index.astro — Life Planning Tools (English)
import MainLayout from '../../layouts/MainLayout.astro';
import { guides as allGuides, categories as guideCategories, getGuidesByCategory } from '../../data/guides-meta';

const lang = 'en';
const guidesByCategory = getGuidesByCategory();

// Tool cards — each will eventually link to its own sub-app or external tool
const tools = [
  {
    title: 'Personality Assessment',
    description: 'Discover your MBTI type and understand how your personality traits align with academic disciplines and career paths.',
    icon: 'psychology',
    status: 'Available',
    statusColor: 'bg-primary text-white',
    href: '/tools/personality',
    tag: 'Self-Discovery',
  },
  {
    title: 'Career Aptitude Test',
    description: 'A structured evaluation mapping your interests, skills, and values to potential career trajectories and university majors.',
    icon: 'work',
    status: 'Coming Soon',
    statusColor: 'bg-surface-container-high text-on-surface-variant',
    href: '#',
    tag: 'Career Planning',
  },
  {
    title: 'HKU Multifaceted Excellence',
    description: 'Prepare for the University of Hong Kong\'s multi-dimensional interview format with timed practice sessions and feedback.',
    icon: 'diversity_3',
    status: 'Available',
    statusColor: 'bg-primary text-white',
    href: '/tools/hku-interview',
    tag: 'Interview Prep',
  },
  {
    title: 'Certificate Verification',
    description: 'Verify the authenticity of certificates issued by the Chinese SDGs Institute using a unique certificate ID, and download official copies.',
    icon: 'verified',
    status: 'Available',
    statusColor: 'bg-primary text-white',
    href: '/verify',
    tag: 'Credentials',
  },
  {
    title: 'Document Template Generator',
    description: 'Generate professional internship certificates, transcripts, and enrollment certificates with customizable bilingual templates.',
    icon: 'description',
    status: 'Available',
    statusColor: 'bg-primary text-white',
    href: '/tools/doc-generator',
    tag: 'Documents',
  },
  {
    title: 'GPA Calculator',
    description: 'Convert grades between 14 international grading systems with multiple algorithms. Generate printable reference transcripts with conversion details.',
    icon: 'calculate',
    status: 'Available',
    statusColor: 'bg-primary text-white',
    href: '/tools/gpa-calculator',
    tag: 'Academics',
  },
];

// Guides now come from guides-meta.ts
---

<MainLayout title="Life Planning Tools | Chinese SDGs Institute" description="Interactive tools and curated resources to navigate university admissions, career planning, and personal development." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-16 md:mb-32">
      <div class="grid lg:grid-cols-12 gap-8 md:gap-16 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-6 md:mb-8">
            <span class="material-symbols-outlined text-[14px]">construction</span>
            Planning Toolkit
          </div>
          <h1 class="font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-on-surface tracking-tighter leading-[1.02] mb-6 md:mb-8">
            Tools for Your<br /><span class="text-primary">Future</span>
          </h1>
          <p class="font-body text-base md:text-xl text-on-surface-variant leading-relaxed max-w-xl mb-8 md:mb-10">
            Interactive assessments, interview simulators, and curated guides — everything you need to navigate admissions, career planning, and personal growth.
          </p>
          <div class="flex items-center gap-6 text-sm text-on-surface-variant">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-lg">widgets</span>
              <span class="font-semibold">{tools.length} Tools</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-lg">menu_book</span>
              <span class="font-semibold">{allGuides.length} Guides</span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 hidden lg:block">
          <div class="aspect-square rounded-2xl overflow-hidden flex items-center justify-center">
            <img src="/images/illustrations/document-writing.png" alt="Planning Tools" class="w-full h-full object-contain" />
          </div>
        </div>
      </div>
    </section>

    <!-- Interactive Tools -->
    <section class="bg-surface-container-low py-16 md:py-32 border-y border-outline-variant/10">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="mb-10 md:mb-16">
          <h2 class="font-headline font-bold text-2xl md:text-4xl tracking-tight text-on-surface mb-4">Interactive Tools</h2>
          <p class="text-on-surface-variant text-lg max-w-2xl">Assessment platforms and simulators designed to give you clarity on who you are and where you're headed.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-8">
          {tools.map((tool) => (
            <a href={tool.href} class="group bg-white rounded-2xl border border-outline-variant/15 p-5 md:p-8 flex flex-col hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
              <div class="flex items-start justify-between mb-6">
                <div class="w-14 h-14 bg-primary/5 rounded-xl flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                  <span class="material-symbols-outlined text-primary text-2xl">{tool.icon}</span>
                </div>
                <span class={`text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full ${tool.statusColor}`}>{tool.status}</span>
              </div>
              <div class="text-[10px] font-bold text-primary/50 uppercase tracking-[0.2em] mb-3">{tool.tag}</div>
              <h3 class="text-lg font-headline font-bold text-on-surface mb-3 group-hover:text-primary transition-colors">{tool.title}</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed mb-6">{tool.description}</p>
              <div class="mt-auto flex items-center gap-2 text-xs font-bold text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                <span>Launch Tool</span>
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Knowledge Base -->
    <section id="guides" class="py-16 md:py-32">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="mb-10 md:mb-16 max-w-3xl">
          <h2 class="font-headline font-bold text-2xl md:text-4xl tracking-tight text-on-surface mb-4">Application Knowledge Base</h2>
          <p class="text-on-surface-variant text-base md:text-lg leading-relaxed">
            {allGuides.length} in-depth guides covering every aspect of university admissions, graduate applications, and career planning. Each article is a deep-dive distilled from official university advice and professional experience.
          </p>
        </div>

        {guideCategories.map((cat) => {
          const items = guidesByCategory.get(cat.id);
          if (!items || items.length === 0) return null;
          return (
            <div class="mb-12 md:mb-16">
              <div class="flex items-center gap-3 mb-6">
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${cat.color}`}>
                  <span class="material-symbols-outlined text-lg">{cat.icon}</span>
                </div>
                <div>
                  <h3 class="font-headline font-bold text-lg text-on-surface">{cat.label}</h3>
                  <span class="text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-widest">{items.length} {items.length === 1 ? 'guide' : 'guides'}</span>
                </div>
              </div>
              <div class="grid gap-3">
                {items.map((guide) => (
                  <a href={`/tools/guides/${guide.slug}`} class="group flex gap-5 p-5 rounded-2xl border border-outline-variant/10 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 bg-white transition-all duration-300">
                    <div class="shrink-0 w-11 h-11 bg-primary/5 rounded-xl flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                      <span class="material-symbols-outlined text-primary text-xl">{guide.icon}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-base font-headline font-bold text-on-surface group-hover:text-primary transition-colors mb-1.5 line-clamp-1">{guide.title}</h4>
                      <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-2 mb-2">{guide.description}</p>
                      <div class="flex items-center gap-4 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.15em]">
                        <span class="flex items-center gap-1">
                          <span class="material-symbols-outlined text-[12px]">schedule</span>
                          {guide.readingTime}
                        </span>
                        <span class="flex items-center gap-1">
                          <span class="material-symbols-outlined text-[12px]">local_offer</span>
                          {guide.tags.slice(0, 2).join(' · ')}
                        </span>
                      </div>
                    </div>
                    <div class="shrink-0 self-center">
                      <span class="material-symbols-outlined text-on-surface-variant/20 group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_forward</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-12 md:mb-20">
      <div class="bg-primary rounded-2xl md:rounded-[2rem] p-6 md:p-12 lg:p-20 relative overflow-hidden shadow-2xl shadow-primary/20">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-white/5 skew-x-12 translate-x-24"></div>
        <div class="relative z-10 max-w-2xl">
          <h2 class="font-headline font-bold text-2xl md:text-3xl lg:text-4xl tracking-tight text-white mb-4 md:mb-6">Have a tool idea?</h2>
          <p class="text-white/70 text-base md:text-lg leading-relaxed mb-6 md:mb-10">
            We're always looking for new tools that help students navigate the complex world of university admissions and career planning. If you have an idea, we'd love to hear from you.
          </p>
          <a href="/contact" class="inline-block bg-white text-primary px-10 py-4 rounded-xl font-bold hover:bg-primary-container transition-all shadow-xl">
            Get in Touch
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
