// ======== BUILD & ORDER ========
function buildAll(){
  var a=[];
  SIT.forEach(function(i){a.push(Object.assign({},i,{mod:'SIT'}));});
  ATT.forEach(function(i){a.push(Object.assign({},i,{mod:'SIT'}));});
  PAIR.forEach(function(i){a.push(Object.assign({},i,{mod:'PAIR'}));});
  POL.forEach(function(i){a.push(Object.assign({},i,{mod:'POL'}));});
  NSIT.forEach(function(i){a.push(Object.assign({},i,{mod:'N_SIT'}));});
  POLN.forEach(function(i){a.push(Object.assign({},i,{mod:'POL_N'}));});
  AV.forEach(function(i){a.push(Object.assign({},i,{mod:'AV'}));});
  return a;
}
function shuf(a){var b=a.slice();for(var i=b.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var tmp=b[i];b[i]=b[j];b[j]=tmp;}return b;}

function genOrder(items){
  var sit=shuf(items.filter(function(i){return i.mod==='SIT'&&!i.id.startsWith('ATT');}));
  var att=items.filter(function(i){return i.id.startsWith('ATT');});
  var pair=shuf(items.filter(function(i){return i.mod==='PAIR';}));
  var pol=shuf(items.filter(function(i){return i.mod==='POL';}));
  var nsit=shuf(items.filter(function(i){return i.mod==='N_SIT';}));
  var poln=shuf(items.filter(function(i){return i.mod==='POL_N';}));
  var av=shuf(items.filter(function(i){return i.mod==='AV';}));
  var s1=sit.findIndex(function(i){return i.id==='SIT_001';});
  if(s1>0){var tmp=sit[0];sit[0]=sit[s1];sit[s1]=tmp;}
  var ord=[];
  var si=0,pi=0,pli=0,ni=0,pni=0,ai=0;
  var placed=new Set();
  function put(item){if(item&&!placed.has(item.id)){ord.push(item);placed.add(item.id);}}
  for(var pos=0;pos<114;pos++){
    if(pos===24){put(att[0]);continue;}
    if(pos===63){put(att[1]);continue;}
    if(pos===78){put(att[2]);continue;}
    if(pos>=55&&ai<av.length&&(pos%6===1||pos%6===4)){put(av[ai++]);continue;}
    if(pos>=30&&ni<nsit.length&&pos%8===3){put(nsit[ni++]);continue;}
    if(pos>=38&&pni<poln.length&&pos%10===7){put(poln[pni++]);continue;}
    var last=ord.length>0?ord[ord.length-1].mod:'';
    var last2=ord.length>1?ord[ord.length-2].mod:'';
    if(last==='SIT'&&last2==='SIT'){
      if(pi<pair.length)put(pair[pi++]);
      else if(pli<pol.length)put(pol[pli++]);
      else if(si<sit.length)put(sit[si++]);
    }else{
      if(si<sit.length)put(sit[si++]);
      else if(pi<pair.length)put(pair[pi++]);
      else if(pli<pol.length)put(pol[pli++]);
    }
  }
  var rem=sit.slice(si).concat(pair.slice(pi),pol.slice(pli),nsit.slice(ni),poln.slice(pni),av.slice(ai));
  att.forEach(function(a){if(!placed.has(a.id))rem.push(a);});
  shuf(rem).forEach(function(r){put(r);});
  // ensure last is SIT (non-ATT)
  for(var i=ord.length-1;i>=0;i--){
    if(ord[i].mod==='SIT'&&!ord[i].id.startsWith('ATT')&&i<ord.length-1){
      var tmp2=ord[i];ord[i]=ord[ord.length-1];ord[ord.length-1]=tmp2;break;
    }
  }
  return ord;
}

// ======== STATE ========
var S={idx:0,order:[],resp:{},startT:0,navOpen:false,testStarted:false};
var app;

// ======== NAV PANEL ========
function renderNav(){
  var t=document.getElementById('nav-title');
  var g=document.getElementById('nav-grid');
  var p=document.getElementById('nav-progress');
  var answered=Object.keys(S.resp).filter(function(k){return !k.startsWith('_');}).length;
  var total=S.order.length;
  t.textContent='\u7B2C '+(S.idx+1)+' / '+total+' \u9898 \u00B7 \u5DF2\u7B54 '+answered;
  if(p)p.style.width=Math.round(answered/total*100)+'%';
  var h='';
  for(var i=0;i<S.order.length;i++){
    var cls=i===S.idx?'current':S.resp[S.order[i].id]?'done':'empty';
    h+='<button class="mdpa-nav-sq '+cls+'" onclick="jumpTo('+i+')">'+(i+1)+'</button>';
  }
  g.innerHTML=h;
  // Auto-scroll to current question
  var cur=g.querySelector('.current');
  if(cur)cur.scrollIntoView({block:'nearest',behavior:'smooth'});
}
function jumpTo(i){S.idx=i;render();}

// ======== RENDER ========
function render(){
  if(!S.testStarted)return;
  if(S.idx>=S.order.length){showCompletionPage();return;}
  var item=S.order[S.idx];
  var prev=S.resp[item.id];
  var h='';
  if(item.mod==='SIT')h=renderSIT(item,prev);
  else if(item.mod==='AV')h=renderAV(item,prev);
  else h=renderBin(item,prev);
  app.innerHTML=h;
  S.startT=Date.now();
  renderNav();
  // init drag if SIT
  if(item.mod==='SIT')initDrag();
  // init AV slider listener
  if(item.mod==='AV')initAVSlider(item,prev);
}

// ======== SIT RENDER + DRAG ========
var sortOrder=[0,1,2,3]; // current order of option indices

function renderSIT(item,prev){
  sortOrder=prev?prev.ranking.slice():[0,1,2,3];
  var h='<div class="mdpa-card"><div class="mdpa-scenario">'+item.s+'</div>';
  h+='<div class="mdpa-hint">\u2B0D 拖动排序：从最像你的排到最不像你的</div>';
  h+='<div class="mdpa-sort-list" id="sort-list">';
  for(var rank=0;rank<4;rank++){
    var oi=sortOrder[rank];
    h+='<div class="mdpa-sort-item r'+(rank+1)+'" data-oi="'+oi+'"><span class="rank-num">'+(rank+1)+'</span><span class="handle">\u2630</span><span>'+item.o[oi].t+'</span></div>';
  }
  h+='</div>';
  h+='<div class="mdpa-btn-row"><button class="mdpa-btn" style="flex:1" id="sit-confirm" onclick="submitSIT()">确认排序</button></div>';
  h+='</div>';
  return h;
}

function initDrag(){
  var list=document.getElementById('sort-list');
  if(!list)return;
  var drag=null;

  list.addEventListener('pointerdown',function(e){
    var el=e.target.closest('.mdpa-sort-item');
    if(!el)return;
    e.preventDefault();
    el.setPointerCapture(e.pointerId);
    drag={el:el,startY:e.clientY,dy:0,lockDir:null};
    el.style.zIndex='10';
    el.style.position='relative';
  });

  list.addEventListener('pointermove',function(e){
    if(!drag)return;
    drag.dy=e.clientY-drag.startY;
    drag.el.style.transform='translateY('+drag.dy+'px) scale(1.02)';
    drag.el.style.boxShadow='0 4px 16px rgba(4,47,36,0.18)';
    drag.el.style.borderColor='#042f24';

    // Direction lock: unlock when returning to neutral zone
    if(Math.abs(drag.dy)<10)drag.lockDir=null;

    var items=Array.from(list.children);
    var idx=items.indexOf(drag.el);
    var h=drag.el.offsetHeight+8;
    var threshold=h*0.35;

    // Swap up
    if(idx>0&&drag.dy<-threshold&&drag.lockDir!=='down'){
      var neighbor=items[idx-1];
      list.insertBefore(drag.el,neighbor);
      var tmp=sortOrder[idx-1];sortOrder[idx-1]=sortOrder[idx];sortOrder[idx]=tmp;
      drag.startY-=h;
      drag.dy=e.clientY-drag.startY;
      drag.el.style.transform='translateY('+drag.dy+'px) scale(1.02)';
      drag.lockDir='up';
      neighbor.style.transition='none';
      neighbor.style.transform='translateY('+(-h)+'px)';
      neighbor.offsetHeight;
      neighbor.style.transition='transform 0.15s ease';
      neighbor.style.transform='';
      setTimeout(function(){neighbor.style.transition='';},180);
      updateRanks();
    }

    // Swap down
    if(idx<list.children.length-1&&drag.dy>threshold&&drag.lockDir!=='up'){
      var neighbor2=items[idx+1];
      list.insertBefore(neighbor2,drag.el);
      var tmp2=sortOrder[idx];sortOrder[idx]=sortOrder[idx+1];sortOrder[idx+1]=tmp2;
      drag.startY+=h;
      drag.dy=e.clientY-drag.startY;
      drag.el.style.transform='translateY('+drag.dy+'px) scale(1.02)';
      drag.lockDir='down';
      neighbor2.style.transition='none';
      neighbor2.style.transform='translateY('+h+'px)';
      neighbor2.offsetHeight;
      neighbor2.style.transition='transform 0.15s ease';
      neighbor2.style.transform='';
      setTimeout(function(){neighbor2.style.transition='';},180);
      updateRanks();
    }
  });

  list.addEventListener('pointerup',function(e){
    if(!drag)return;
    drag.el.style.transition='transform 0.15s ease, box-shadow 0.15s, border-color 0.15s';
    drag.el.style.transform='';
    drag.el.style.zIndex='';
    drag.el.style.boxShadow='';
    drag.el.style.borderColor='';
    var capturedEl=drag.el;
    setTimeout(function(){capturedEl.style.transition='';capturedEl.style.position='';drag=null;},160);
  });

  list.addEventListener('pointercancel',function(){
    if(!drag)return;
    drag.el.style.transform='';drag.el.style.zIndex='';drag.el.style.boxShadow='';
    drag.el.style.borderColor='';drag.el.style.position='';drag=null;
  });
}

function updateRanks(){
  var list=document.getElementById('sort-list');
  if(!list)return;
  Array.from(list.children).forEach(function(el,i){
    el.querySelector('.rank-num').textContent=i+1;
    el.className='mdpa-sort-item r'+(i+1);
    el.style.position='relative';
  });
}

function submitSIT(){
  var btn=document.getElementById('sit-confirm');
  if(btn)btn.disabled=true; // prevent double click
  var item=S.order[S.idx];
  S.resp[item.id]={id:item.id,mod:'SIT',ranking:sortOrder.slice(),rt:Date.now()-S.startT,opts:item.o};
  S.idx++;render();
}

// ======== BINARY RENDER ========
function renderBin(item,prev){
  var h='<div class="mdpa-card">';
  if(item.s)h+='<div class="mdpa-scenario">'+item.s+'</div>';
  h+='<div class="mdpa-hint">选一个更像你的</div><div class="mdpa-bin-row">';
  for(var i=0;i<2;i++){
    var cls=prev&&prev.chosen===i?'chosen':'';
    h+='<div class="mdpa-bin-opt '+cls+'" onclick="submitBin('+i+')">'+item.o[i].t+'</div>';
  }
  h+='</div></div>';
  return h;
}
var binSubmitting=false;
function submitBin(idx){
  if(binSubmitting)return;
  binSubmitting=true;
  var item=S.order[S.idx];
  S.resp[item.id]={id:item.id,mod:item.mod,chosen:idx,rt:Date.now()-S.startT,opts:item.o};
  var opts=document.querySelectorAll('.mdpa-bin-opt');
  opts.forEach(function(o,i){o.classList.toggle('chosen',i===idx);});
  setTimeout(function(){binSubmitting=false;S.idx++;render();},250);
}

// ======== AV RENDER ========
function renderAV(item,prev){
  var h='<div class="mdpa-card">';
  h+='<div class="mdpa-av-anchors"><div class="mdpa-anchor"><b>'+item.lo.n+'</b>：'+item.lo.d+'</div><div class="mdpa-anchor"><b>'+item.hi.n+'</b>：'+item.hi.d+'</div></div>';
  h+='<div class="mdpa-scenario">'+item.q+'</div>';
  h+='<div class="mdpa-slider-wrap"><div class="mdpa-slider-labels"><span>'+item.lb[0]+'</span><span>'+item.lb[6]+'</span></div>';
  var val=prev?prev.position:4;
  var touched=!!prev;
  h+='<input type="range" min="1" max="7" value="'+val+'" id="av-sl">';
  h+='<div class="mdpa-av-val '+(touched?'':'mdpa-av-unset')+'" id="av-val">'+(touched?item.lb[val-1]:'\u2190 请滑动选择 \u2192')+'</div></div>';
  h+='<button class="mdpa-btn" id="av-btn" style="width:100%;margin-top:12px" '+(touched?'':'disabled')+' onclick="submitAV()">确认</button>';
  h+='</div>';
  return h;
}
function initAVSlider(item,prev){
  var sl=document.getElementById('av-sl');
  var vl=document.getElementById('av-val');
  var bt=document.getElementById('av-btn');
  if(!sl)return;
  sl.addEventListener('input',function(){
    vl.textContent=item.lb[sl.value-1];
    vl.classList.remove('mdpa-av-unset');
    bt.disabled=false;
  });
}
function submitAV(){
  var item=S.order[S.idx];
  var val=parseInt(document.getElementById('av-sl').value);
  S.resp[item.id]={id:item.id,mod:'AV',position:val,dim:item.dim,rt:Date.now()-S.startT};
  S.idx++;render();
}

// ======== COMPLETION CHECK ========
function showCompletionPage(){
  var answered=Object.keys(S.resp).filter(function(k){return !k.startsWith('_');}).length;
  var unanswered=S.order.length-answered;
  var h='<div class="mdpa-break-page">';
  if(unanswered===0){
    h+='<h2>全部完成！</h2><p>你已回答了所有 '+S.order.length+' 道题</p>';
    h+='<button class="mdpa-btn" onclick="runAnalysis()">查看我的人格报告</button>';
  }else{
    h+='<h2>即将完成</h2><p>还有 <b>'+unanswered+'</b> 道题未作答</p>';
    h+='<p style="font-size:13px;color:#64748b">未作答的题目不会影响已有结果的准确性，但回答越完整画像越精确</p>';
    // find first unanswered
    var firstEmpty=S.order.findIndex(function(i){return !S.resp[i.id];});
    h+='<div class="mdpa-btn-row" style="justify-content:center;flex-wrap:wrap">';
    if(firstEmpty>=0)h+='<button class="mdpa-btn mdpa-btn-outline" onclick="jumpTo('+firstEmpty+')">去补答未完成的题</button>';
    h+='<button class="mdpa-btn" onclick="runAnalysis()">直接查看报告</button>';
    h+='</div>';
  }
  h+='</div>';
  app.innerHTML=h;
  renderNav();
}

// ======== ANALYSIS ========
function runAnalysis(){
  document.getElementById('nav').style.display='none';
  app.classList.add('centered');
  app.style.maxWidth='720px';
  // 1. Pairwise expansion with null reference
  var comps=[];
  Object.values(S.resp).forEach(function(r){
    if(r.mod==='SIT'&&r.ranking){
      for(var i=0;i<r.ranking.length;i++){
        for(var j=i+1;j<r.ranking.length;j++){
          var w=r.opts[r.ranking[i]],l=r.opts[r.ranking[j]];
          if(!w||!l)continue;
          var wD=(w.d===null||w.d===undefined)?null:(w.d===-1?'null':w.D);
          var lD=(l.d===null||l.d===undefined)?null:(l.d===-1?'null':l.D);
          if(wD!==null&&lD!==null)comps.push({w:wD,l:lD});
        }
      }
    }
    if(r.mod==='PAIR'){
      var w2=r.opts[r.chosen].D,l2=r.opts[1-r.chosen].D;
      if(w2&&l2)comps.push({w:w2,l:l2});
    }
  });

  // 2. Bradley-Terry with null ref + regularization
  var players=['E','O','C','A'];
  var pi={E:1,O:1,C:1,A:1,'null':1};
  // Add regularization: 0.5 pseudo-wins for each player against null
  var regComps=comps.slice();
  players.forEach(function(p){regComps.push({w:p,l:'null'});regComps.push({w:'null',l:p});});

  for(var iter=0;iter<200;iter++){
    var newPi={};
    for(var pidx=0;pidx<players.length;pidx++){
      var p=players[pidx];
      var wins=regComps.filter(function(c){return c.w===p;}).length;
      var denom=0;
      for(var ci=0;ci<regComps.length;ci++){
        var c=regComps[ci];
        if(c.w===p||c.l===p){
          var opp=c.w===p?c.l:c.w;
          denom+=1/(pi[p]+(pi[opp]||1));
        }
      }
      newPi[p]=denom>0?wins/denom:pi[p];
    }
    var mx2=0;
    for(var pidx2=0;pidx2<players.length;pidx2++){
      var p2=players[pidx2];
      mx2=Math.max(mx2,Math.abs((newPi[p2]||0)-(pi[p2]||0)));
    }
    for(var pidx3=0;pidx3<players.length;pidx3++){
      pi[players[pidx3]]=newPi[players[pidx3]]||0.01;
    }
    pi['null']=1;
    if(mx2<0.0001)break;
  }
  var lam={};
  for(var pidx4=0;pidx4<players.length;pidx4++){
    lam[players[pidx4]]=Math.log(Math.max(pi[players[pidx4]],0.001));
  }

  // 3. AV calibration (additive)
  var avAdj={};
  var avDims=['E','O','C','A','N'];
  for(var di=0;di<avDims.length;di++){
    var d=avDims[di];
    var items=Object.values(S.resp).filter(function(r){return r.mod==='AV'&&r.dim===d;});
    var avMean=items.length>0?items.reduce(function(s,r){return s+r.position;},0)/items.length:4;
    avAdj[d]=(avMean-4)*0.15;
  }
  var lamCal={};
  for(var pidx5=0;pidx5<players.length;pidx5++){
    lamCal[players[pidx5]]=lam[players[pidx5]]+(avAdj[players[pidx5]]||0);
  }

  // 4. MBTI
  var mb={EI:{E:0,I:0},NS:{N:0,S:0},FT:{F:0,T:0},JP:{J:0,P:0}};
  POL.forEach(function(polItem){
    var r=S.resp[polItem.id];
    if(!r)return;
    var pole=polItem.o[r.chosen].p;
    if(mb[polItem.ax])mb[polItem.ax][pole]++;
  });
  var mbType=(mb.EI.E>=mb.EI.I?'E':'I')+(mb.NS.N>=mb.NS.S?'N':'S')+(mb.FT.F>=mb.FT.T?'F':'T')+(mb.JP.J>=mb.JP.P?'J':'P');
  var mbStr={EI:mb.EI.E/(mb.EI.E+mb.EI.I||1),NS:mb.NS.N/(mb.NS.N+mb.NS.S||1),FT:mb.FT.F/(mb.FT.F+mb.FT.T||1),JP:mb.JP.J/(mb.JP.J+mb.JP.P||1)};

  // 5. N clusters
  var cls={ar:{n:0,t:0,items:['N_SIT_01','N_SIT_02','N_SIT_04','N_SIT_05','POL_N_01','POL_N_02']},sv:{n:0,t:0,items:['N_SIT_03','N_SIT_06','POL_N_03','POL_N_04']},er:{n:0,t:0,items:['N_SIT_07','N_SIT_08','POL_N_05','POL_N_06']}};
  NSIT.concat(POLN).forEach(function(item){
    var r=S.resp[item.id];if(!r)return;
    var pole=item.o[r.chosen].p;
    var entries=Object.entries(cls);
    for(var ei=0;ei<entries.length;ei++){
      var k=entries[ei][0],c=entries[ei][1];
      if(c.items.indexOf(item.id)!==-1){c.t++;if(pole==='neurotic')c.n++;}
    }
  });

  // 6. Quality
  var qc=[];
  var a1=S.resp['ATT_001'];
  if(a1&&a1.ranking&&a1.ranking[0]===3)qc.push('注意力检查：陷阱题选项被排在第1位');
  ['ATT_002/SIT_005','ATT_003/SIT_020'].forEach(function(pair){
    var parts=pair.split('/');
    var aid=parts[0],sid=parts[1];
    var ar=S.resp[aid],sr=S.resp[sid];
    if(ar&&sr&&ar.ranking&&sr.ranking){
      if(ar.ranking[0]!==sr.ranking[0]&&ar.ranking[3]!==sr.ranking[3])
        qc.push('一致性检查：'+aid+'与'+sid+'排序差异较大');
    }
  });

  showReport(lamCal,lam,mbType,mbStr,cls,avAdj,qc);
}

// ======== REPORT ========
function drawRadar(canvasId,lamCal,nScore){
  var c=document.getElementById(canvasId);
  if(!c)return;
  var ctx=c.getContext('2d');
  var W=c.width,H=c.height,cx=W/2,cy=H/2;
  var R=Math.min(cx,cy)-40;
  // OCEAN order: O C E A N
  var dims=['O','C','E','A','N'];
  var labels=['\u5F00\u653E\u6027 O','\u5C3D\u8D23\u6027 C','\u5916\u5411\u6027 E','\u5B9C\u4EBA\u6027 A','\u795E\u7ECF\u8D28 N'];
  var colors=['#8b5cf6','#10b981','#3b82f6','#f59e0b','#ef4444'];
  // Normalize values to 0-1 range
  var vals=[];
  var allV=[];
  for(var i=0;i<dims.length;i++){
    var v=dims[i]==='N'?nScore:(lamCal[dims[i]]||0);
    allV.push(v);
  }
  var mn=Math.min.apply(null,allV),mx=Math.max.apply(null,allV),rng=mx-mn||1;
  for(var i2=0;i2<allV.length;i2++){vals.push(Math.max(0.08,(allV[i2]-mn)/rng));}

  var n=5;
  function angle(i){return (Math.PI*2*i/n)-Math.PI/2;}

  // Grid rings
  ctx.strokeStyle='#e2e8f0';ctx.lineWidth=1;
  for(var ring=1;ring<=4;ring++){
    var rr=R*ring/4;
    ctx.beginPath();
    for(var gi=0;gi<n;gi++){
      var a=angle(gi);
      var x=cx+Math.cos(a)*rr,y=cy+Math.sin(a)*rr;
      if(gi===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);
    }
    ctx.closePath();ctx.stroke();
  }
  // Grid spokes
  for(var si=0;si<n;si++){
    var a=angle(si);
    ctx.beginPath();ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R);ctx.stroke();
  }

  // Filled polygon
  ctx.beginPath();
  for(var fi=0;fi<n;fi++){
    var a2=angle(fi);
    var x2=cx+Math.cos(a2)*R*vals[fi],y2=cy+Math.sin(a2)*R*vals[fi];
    if(fi===0)ctx.moveTo(x2,y2);else ctx.lineTo(x2,y2);
  }
  ctx.closePath();
  ctx.fillStyle='rgba(4,47,36,0.12)';ctx.fill();
  ctx.strokeStyle='#042f24';ctx.lineWidth=2;ctx.stroke();

  // Dots + labels
  for(var di=0;di<n;di++){
    var a3=angle(di);
    var dx=cx+Math.cos(a3)*R*vals[di],dy=cy+Math.sin(a3)*R*vals[di];
    ctx.beginPath();ctx.arc(dx,dy,5,0,Math.PI*2);
    ctx.fillStyle=colors[di];ctx.fill();
    ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.stroke();
    // Labels
    var lx=cx+Math.cos(a3)*(R+24),ly=cy+Math.sin(a3)*(R+24);
    ctx.font='bold 13px Inter,sans-serif';ctx.fillStyle=colors[di];ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(labels[di],lx,ly);
    // Value percentage
    ctx.font='11px Inter,sans-serif';ctx.fillStyle='#94a3b8';
    ctx.fillText(Math.round(vals[di]*100)+'%',lx,ly+15);
  }
}

function showReport(lamCal,lamRaw,mbType,mbStr,cls,avAdj,qc){
  // Compute N score from clusters
  var nTotal=0,nN=0;
  var clsEntries=Object.entries(cls);
  for(var ci=0;ci<clsEntries.length;ci++){
    nTotal+=clsEntries[ci][1].t;nN+=clsEntries[ci][1].n;
  }
  // Convert N ratio to a lambda-like scale to match E/O/C/A range
  var nRatio=nTotal>0?nN/nTotal:0.5;
  var vals=[lamCal.E||0,lamCal.O||0,lamCal.C||0,lamCal.A||0];
  var vmn=Math.min.apply(null,vals),vmx=Math.max.apply(null,vals);
  var nScore=vmn+(vmx-vmn)*nRatio;

  var h='<div class="mdpa-report"><h2>MDPA \u591A\u7EF4\u4EBA\u683C\u8BC4\u4F30\u62A5\u544A</h2>';
  if(qc.length)h+='<div class="mdpa-card" style="border-left:3px solid #dc2626;font-size:14px">'+qc.join('<br>')+'</div>';

  // MBTI
  h+='<div class="mdpa-card"><h3>\u4F60\u7684 MBTI \u7C7B\u578B</h3><div class="mdpa-mbti-type">'+mbType+'</div>';
  var AXL={EI:['I \u5185\u5411','E \u5916\u5411'],NS:['S \u5B9E\u611F','N \u76F4\u89C9'],FT:['T \u601D\u8003','F \u60C5\u611F'],JP:['P \u611F\u77E5','J \u5224\u65AD']};
  var axes=['EI','NS','FT','JP'];
  for(var axi=0;axi<axes.length;axi++){
    var ax=axes[axi];
    var v=mbStr[ax];var pct=Math.round(Math.abs(v-0.5)*200);
    var st=pct>60?'\u660E\u786E':pct>20?'\u8F83\u660E\u786E':'\u8FB9\u754C\u578B';
    var stTag=pct>60?'mdpa-tag-s':pct>20?'mdpa-tag-m':'mdpa-tag-n';
    h+='<div class="mdpa-bar-wrap"><div class="mdpa-bar-label"><span style="font-size:13px">'+AXL[ax][0]+'</span><span class="mdpa-tag '+stTag+'">'+st+'</span><span style="font-size:13px">'+AXL[ax][1]+'</span></div>';
    h+='<div class="mdpa-bar"><div class="mdpa-bar-fill" style="width:'+Math.round(v*100)+'%;background:'+(v>=0.5?'#042f24':'#9ca3af')+'"></div></div></div>';
  }
  h+='</div>';

  // OCEAN Radar Chart
  h+='<div class="mdpa-card"><h3>OCEAN \u4EBA\u683C\u96F7\u8FBE\u56FE</h3>';
  h+='<div class="mdpa-radar-wrap"><canvas id="radar-canvas" width="360" height="360"></canvas></div>';
  h+='</div>';

  // Export
  h+='<div class="mdpa-card"><h3>\u6570\u636E\u5BFC\u51FA</h3><p style="font-size:13px;color:#9ca3af;margin-bottom:8px">\u70B9\u51FB\u4E0B\u65B9\u533A\u57DF\u590D\u5236\u5B8C\u6574JSON</p>';
  var exp={time:new Date().toISOString(),responses:Object.values(S.resp).filter(function(r){return r.mod;}),analysis:{lambda_raw:lamRaw,lambda_cal:lamCal,av_adjustments:avAdj,mbti:{type:mbType,strength:mbStr},n_clusters:Object.fromEntries(Object.entries(cls).map(function(entry){var k=entry[0],v=entry[1];return [k,{n:v.n,t:v.t,r:v.t?+(v.n/v.t).toFixed(3):0}];}))},qc:qc};
  h+='<div class="mdpa-json-box" onclick="navigator.clipboard.writeText(this.textContent).then(function(){alert(\'\u5DF2\u590D\u5236\')})">'+JSON.stringify(exp)+'</div></div></div>';
  app.innerHTML=h;
  // Draw radar after DOM update
  setTimeout(function(){drawRadar('radar-canvas',lamCal,nScore);},50);
}

