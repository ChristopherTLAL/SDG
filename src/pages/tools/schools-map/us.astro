---
export const prerender = true;
// Schools map — US country overview. Universities tiered by U.S. News National rank.
import MainLayout from '../../../layouts/MainLayout.astro';
import { UNIVERSITIES, USNEWS_TIERS } from '../../../data/universities/universities';
import { SCENE_IDS, SCENE_INDEX } from '../../../data/schools-map/registry';
import budgetData from '../../../data/budget-data.json';
import '../../../styles/schools-map.css';

const lang = 'en';
const hasDetail = new Set(SCENE_IDS);
const budgetIds = new Set(budgetData.regions.flatMap((r) => r.schools.map((s) => s.id)));

const us = UNIVERSITIES
  .filter((u) => u.country === 'US' && u.lat != null && u.lng != null)
  .map((u) => ({
    id: u.id, name: u.name, nameCn: u.nameCn, city: u.city,
    rank: u.usnewsRank ? Number(u.usnewsRank) : null,
    lat: u.lat, lng: u.lng, hasDetail: hasDetail.has(u.id),
    inBudget: budgetIds.has(u.id), tags: u.tags || [],
  }));

const tiers = USNEWS_TIERS.map((t) => ({ key: t.key, label: t.label, color: t.color, max: t.max === Infinity ? 999999 : t.max }));
const detailBase = '/tools/schools-map';
const usOpts = {
  center: [39.5, -98.35], zoom: 4, rankLabel: 'USNews',
  filters: [{ label: '前 10', max: 10 }, { label: '前 25', max: 25 }, { label: '前 50', max: 50 }, { label: '前 100', max: 100 }, { label: '全部', max: 99999 }],
  tags: ['藤校', 'Top20', '公立', '私立'],
};
---

<MainLayout title="美国院校地图 · U.S. News 分布 | Chinese SDGs Institute" description="美国大学按真实位置与 U.S. News 全国排名分档展示，可筛选、搜索、点击进入单校精览。" lang={lang}>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <main class="pt-24 md:pt-28 pb-10">
    <div class="max-w-[1440px] mx-auto px-4 md:px-8">
      <a href="/tools" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-5">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Back to Tools
      </a>

      <div class="smap-wrap" id="smap-wrap">
        <div class="smap-map" id="smap-map"></div>

        <div class="smap-card smap-nav">
          <span class="smap-nav-home"><span class="material-symbols-outlined" style="font-size:16px">map</span>美国院校总览</span>
          <select class="smap-switch" id="smap-switch" aria-label="跳转到学校或地区"></select>
        </div>

        <div class="smap-left">
          <div class="smap-card smap-title">
            <h2>美国院校地图 · U.S. News 分布</h2>
            <p>{us.length} 所美国大学按真实位置分布，颜色＝U.S. News 全国大学档位。点有「精览」的学校进入单校地图。</p>
            <button class="smap-pill" id="smap-fit">⤢ 缩放到全部</button>
            <button class="smap-pill ghost" id="smap-fullscreen" style="margin-left:6px">⛶ 全屏</button>
            <a class="smap-pill ghost" href="/tools/schools-map" style="margin-left:6px">🇬🇧 英国</a>
          </div>
          <div class="smap-card smap-panel">
            <div class="smap-sec">U.S. News 筛选</div>
            <div class="smap-filter-row" id="smap-filter-row"></div>
            <div class="smap-divider"></div>
            <div class="smap-sec">档位配色</div>
            <div class="smap-legend" id="smap-tier-row"></div>
            <div class="smap-divider"></div>
            <div class="smap-sec">标签</div>
            <div class="smap-filter-row" id="smap-tag-row"></div>
          </div>
        </div>

        <div class="smap-right">
          <div class="smap-card smap-toolscard">
            <div class="smap-tt">底图</div>
            <div class="smap-base-row" id="smap-base-row"></div>
            <div class="smap-toggles">
              <button class="smap-toggle" id="smap-label-btn"><span class="material-symbols-outlined">label</span>名称</button>
              <button class="smap-toggle active" id="smap-list-btn"><span class="material-symbols-outlined">list</span>列表</button>
            </div>
          </div>
          <div class="smap-card smap-list-wrap" id="smap-list-wrap">
            <h3>院校列表</h3>
            <input type="text" id="smap-search" placeholder="搜索学校 / 城市…" class="smap-search-input" />
            <p class="sub" id="smap-count"></p>
            <div class="smap-list-scroll" id="smap-list"></div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    .smap-search-input { width: 100%; border: 1px solid var(--line); border-radius: 8px; padding: 7px 10px; font-size: 12.5px; margin: 0 0 7px; font-family: 'Inter', sans-serif; }
    .smap-search-input:focus { outline: none; border-color: #042f24; }
  </style>

  <script is:inline define:vars={{ unisData: us, tiersData: tiers, baseData: detailBase, scenesData: SCENE_INDEX, optsData: usOpts }}>
    window.__SMAP_UNIS__ = unisData;
    window.__SMAP_TIERS__ = tiersData;
    window.__SMAP_BASE__ = baseData;
    window.__SMAP_SCENES__ = scenesData;
    window.__SMAP_OPTS__ = optsData;
  </script>
  <script>
    import { mountOverview } from '../../../scripts/schools-map/overview';
    mountOverview((window).__SMAP_UNIS__, (window).__SMAP_TIERS__, (window).__SMAP_BASE__, (window).__SMAP_SCENES__, (window).__SMAP_OPTS__);
  </script>
</MainLayout>
