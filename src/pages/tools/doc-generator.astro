---
// src/pages/tools/doc-generator.astro — Document Generator Tool
import MainLayout from '../../layouts/MainLayout.astro';

const lang = 'en';
---

<MainLayout title="Document Generator | Chinese SDGs Institute" description="Generate professional internship certificates, transcripts, and enrollment certificates with customizable bilingual templates." lang={lang}>
  <main class="pt-24 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-[1400px] mx-auto px-4 md:px-8">

      <!-- Back link -->
      <a href="/tools" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Back to Tools
      </a>

      <!-- Tool container -->
      <div id="doc-gen-app">
        <header class="text-center mb-8 no-print">
            <h1 class="text-2xl md:text-3xl font-headline font-bold text-on-surface tracking-tight">Document Template Generator</h1>
            <p class="text-on-surface-variant mt-2 text-sm md:text-base" id="header-subtitle"></p>
            <nav class="mt-6 bg-surface-container-low rounded-lg p-1.5 inline-flex space-x-1">
                <button class="dg-nav-btn active" data-page="internship">实习证明</button>
                <button class="dg-nav-btn" data-page="transcript">成绩单/在读证明</button>
            </nav>
        </header>

        <main>
            <!-- Internship Page -->
            <div id="page-internship">
                <div class="flex flex-col lg:flex-row gap-6">
                    <div class="w-full lg:w-[380px] shrink-0 bg-white p-5 rounded-xl border border-outline-variant/15 no-print space-y-5 max-h-[85vh] overflow-y-auto">
                        <div class="dg-form-section">
                            <h2 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">模板设置</h2>
                            <div class="dg-form-group">
                                <label for="experienceLevel" class="dg-form-label">1. 经历级别</label>
                                <select id="experienceLevel" class="dg-form-select"><option value="fullTime">全职实习</option><option value="partTime">兼职实习</option><option value="activity">活动/实训</option></select>
                            </div>
                            <div class="dg-form-group">
                                <label for="languageStyle" class="dg-form-label">2. 语言风格</label>
                                <select id="languageStyle" class="dg-form-select"><option value="formal">默认正式</option><option value="evaluation">带模板评价</option><option value="concise">超简洁</option></select>
                            </div>
                            <div class="dg-form-group">
                                <label for="languageOutput" class="dg-form-label">3. 输出语言</label>
                                <select id="languageOutput" class="dg-form-select"><option value="bilingual">双语</option><option value="cn">仅中文</option><option value="en">仅英文</option></select>
                            </div>
                        </div>
                        <div class="dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">实习生信息</h3>
                            <div class="dg-form-group"><label for="name-cn" class="dg-form-label">姓名 (中文)</label><input type="text" id="name-cn" class="dg-form-input" value="李华"></div>
                            <div class="dg-form-group"><label for="name-en" class="dg-form-label">Name (English)</label><input type="text" id="name-en" class="dg-form-input" value="Li Hua"></div>
                            <div class="dg-form-group">
                                <div class="flex justify-between items-center mb-1"><label for="gender-cn" class="dg-form-label">性别</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="show-gender" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                <select id="gender-cn" class="dg-form-select"><option>男</option><option>女</option></select>
                            </div>
                            <div class="dg-form-group">
                                <div class="flex justify-between items-center mb-1"><label for="gender-en" class="dg-form-label">Gender</label><span class="text-xs text-on-surface-variant/50">(自动同步)</span></div>
                                <select id="gender-en" class="dg-form-select" disabled><option>Male</option><option>Female</option></select>
                            </div>
                            <div class="dg-form-group">
                                <div class="flex justify-between items-center mb-1"><label for="school-name-cn" class="dg-form-label">学校名称</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="show-school" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                <input type="text" id="school-name-cn" class="dg-form-input" value="示例未来大学">
                            </div>
                            <div class="dg-form-group"><label for="school-name-en" class="dg-form-label">School Name</label><input type="text" id="school-name-en" class="dg-form-input" value="Future Example University"></div>
                            <div class="dg-form-group">
                                <div class="flex justify-between items-center mb-1"><label for="major-cn" class="dg-form-label">专业</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="show-major" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                <input type="text" id="major-cn" class="dg-form-input" value="计算机科学与技术">
                            </div>
                            <div class="dg-form-group"><label for="major-en" class="dg-form-label">Major</label><input type="text" id="major-en" class="dg-form-input" value="Computer Science and Technology"></div>
                        </div>
                        <div class="dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">实习单位信息</h3>
                             <div class="dg-form-group"><label for="company-name-cn" class="dg-form-label">公司名称 (中文)</label><input type="text" id="company-name-cn" class="dg-form-input" value="无限创新科技有限公司"></div>
                             <div class="dg-form-group"><label for="company-name-en" class="dg-form-label">Company Name (English)</label><input type="text" id="company-name-en" class="dg-form-input" value="Infinity Innovation Tech Co., Ltd."></div>
                             <div class="dg-form-group"><label for="department-cn" class="dg-form-label">实习部门 (中文)</label><input type="text" id="department-cn" class="dg-form-input" value="研发部"></div>
                             <div class="dg-form-group"><label for="department-en" class="dg-form-label">Department (English)</label><input type="text" id="department-en" class="dg-form-input" value="R&D Department"></div>
                             <div class="dg-form-group"><label for="position-cn" class="dg-form-label">实习岗位 (中文)</label><input type="text" id="position-cn" class="dg-form-input" value="软件开发实习生"></div>
                             <div class="dg-form-group"><label for="position-en" class="dg-form-label">Position (English)</label><input type="text" id="position-en" class="dg-form-input" value="Software Development Intern"></div>
                             <div class="dg-form-group"><label for="start-date" class="dg-form-label">开始日期</label><input type="date" id="start-date" class="dg-form-input" value="2025-07-01"></div>
                             <div class="dg-form-group"><label for="end-date" class="dg-form-label">结束日期</label><input type="date" id="end-date" class="dg-form-input" value="2025-09-30"></div>
                             <div class="dg-form-group"><label for="issue-date" class="dg-form-label">证明开具日期</label><input type="date" id="issue-date" class="dg-form-input"></div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="supervisor-cn" class="dg-form-label">导师/负责人</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="show-supervisor" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary">显示</label></div>
                                 <input type="text" id="supervisor-cn" class="dg-form-input" value="张伟 (技术总监)">
                             </div>
                             <div class="dg-form-group"><label for="supervisor-en" class="dg-form-label">Supervisor</label><input type="text" id="supervisor-en" class="dg-form-input" value="Wei Zhang (CTO)"></div>
                        </div>
                        <div class="dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">证明正文</h3>
                            <p class="text-xs text-on-surface-variant mb-2">以下内容已根据模板自动生成，你可以直接编辑修改。</p>
                            <div class="dg-form-group"><label for="cert-body-cn" class="dg-form-label">正文 (中文)</label><textarea id="cert-body-cn" class="dg-form-textarea" rows="5"></textarea></div>
                            <div class="dg-form-group"><label for="cert-body-en" class="dg-form-label">Body (English)</label><textarea id="cert-body-en" class="dg-form-textarea" rows="5"></textarea></div>
                            <button id="regenerate-btn" class="dg-btn dg-btn-secondary mt-2 text-sm !py-1.5">根据上方信息重新生成</button>
                        </div>
                        <div class="mt-2"><button id="internship-print-btn" class="dg-btn dg-btn-primary">打印或生成PDF</button></div>
                    </div>
                    <div class="flex-1 flex justify-center items-start">
                        <div id="internship-preview-container" class="dg-a4-preview print-area"></div>
                    </div>
                </div>
            </div>

            <div id="page-transcript" class="hidden">
                <!-- Demo disclaimer banner -->
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 no-print">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-amber-600 text-xl mt-0.5">info</span>
                        <div>
                            <p class="text-sm font-semibold text-amber-800">Template Preview Only</p>
                            <p class="text-xs text-amber-700 mt-1">This section generates sample documents to help students understand standard formatting requirements. All data shown is fictional and for demonstration purposes only. Do not use generated documents for any official purpose.</p>
                        </div>
                    </div>
                </div>
                 <div class="flex flex-col lg:flex-row gap-6">
                    <div class="w-full lg:w-[380px] shrink-0 bg-white p-5 rounded-xl border border-outline-variant/15 no-print space-y-5 max-h-[85vh] overflow-y-auto">
                        <div class="dg-form-section">
                            <h2 class="text-base font-bold mb-3 border-b border-outline-variant/10 pb-2">基础设置</h2>
                            <div class="dg-form-group"><label class="dg-form-label">1. 选择文档类型</label><select id="t-docType" class="dg-form-select"><option value="transcript">成绩单</option><option value="enrollment">在读证明</option></select></div>
                            <div class="dg-form-group"><label class="dg-form-label">2. 选择学段</label><select id="t-educationLevel" class="dg-form-select"><option value="highSchool">高中</option><option value="juniorHigh">初中</option><option value="university">大学</option></select></div>
                        </div>
                        <div class="dg-form-section">
                             <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">学生信息</h3>
                             <div class="dg-form-group"><label for="t-name-cn" class="dg-form-label">姓名 (中文)</label><input type="text" id="t-name-cn" class="dg-form-input" value="李华"></div>
                             <div class="dg-form-group"><label for="t-name-en" class="dg-form-label">Name (English)</label><input type="text" id="t-name-en" class="dg-form-input" value="Li Hua"></div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-gender-cn" class="dg-form-label">性别</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-gender" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                 <select id="t-gender-cn" class="dg-form-select"><option>男</option><option>女</option></select>
                             </div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-gender-en" class="dg-form-label">Gender</label><span class="text-xs text-on-surface-variant/50">(自动同步)</span></div>
                                 <select id="t-gender-en" class="dg-form-select" disabled><option>Male</option><option>Female</option></select>
                             </div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-birth-date" class="dg-form-label">出生日期</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-birth-date" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                 <input type="date" id="t-birth-date" class="dg-form-input" value="2006-08-15">
                             </div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-student-id" class="dg-form-label">学号</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-student-id" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                 <input type="text" id="t-student-id" class="dg-form-input" value="G20220318">
                             </div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-id-card" class="dg-form-label">身份证号</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-id-card" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary">显示</label></div>
                                 <input type="text" id="t-id-card" class="dg-form-input" value="32050120060815XXXX">
                             </div>
                             <div class="dg-form-group">
                                 <div class="flex justify-between items-center mb-1"><label for="t-current-grade" class="dg-form-label">目前年级</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-current-grade" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                 <select id="t-current-grade" class="dg-form-select"></select>
                             </div>
                        </div>
                        <div class="dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">学校信息</h3>
                            <div class="dg-form-group"><label for="t-school-name-cn" class="dg-form-label">学校名称 (中文)</label><input type="text" id="t-school-name-cn" class="dg-form-input" value="示例未来中学"></div>
                            <div class="dg-form-group"><label for="t-school-name-en" class="dg-form-label">School Name (English)</label><input type="text" id="t-school-name-en" class="dg-form-input" value="Future Example High School"></div>
                            <div class="dg-form-group">
                                <div class="flex justify-between items-center mb-1"><label for="t-enroll-date" class="dg-form-label">入学日期</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-enroll-date" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                <input type="date" id="t-enroll-date" class="dg-form-input" value="2022-09-01">
                            </div>
                            <div class="dg-form-group" id="t-grad-date-group">
                                <div class="flex justify-between items-center mb-1"><label for="t-grad-date" class="dg-form-label">毕业日期</label><label class="flex items-center text-xs text-on-surface-variant"><input type="checkbox" id="t-show-grad-date" class="mr-1 h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary" checked>显示</label></div>
                                <input type="date" id="t-grad-date" class="dg-form-input" value="2025-07-01">
                            </div>
                            <div class="dg-form-group hidden" id="t-major-cn-group"><label for="t-major-cn" class="dg-form-label">专业 (中文)</label><input type="text" id="t-major-cn" class="dg-form-input" value="计算机科学与技术"></div>
                            <div class="dg-form-group hidden" id="t-major-en-group"><label for="t-major-en" class="dg-form-label">Major (English)</label><input type="text" id="t-major-en" class="dg-form-input" value="Computer Science and Technology"></div>
                        </div>
                        <div id="t-transcript-section" class="dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">成绩信息</h3>
                            <div class="flex items-end gap-2 mb-3">
                                <div class="flex-grow dg-form-group"><label for="t-avg-score" class="dg-form-label">期望平均分</label><input type="number" id="t-avg-score" class="dg-form-input" value="85"></div>
                                <button id="t-random-grades-btn" class="dg-btn dg-btn-secondary whitespace-nowrap !w-auto text-sm">一键随机生成</button>
                            </div>
                            <div id="t-courses-container"></div>
                            <button id="t-add-course-btn" class="dg-btn dg-btn-secondary mt-2 text-sm">+ 添加科目</button>
                            <div class="dg-form-group mt-3"><label for="t-transcript-notes" class="dg-form-label">成绩备注</label><textarea id="t-transcript-notes" class="dg-form-textarea" rows="3">注：满分100分。优秀 (90-100), 良好 (80-89), 及格 (60-79), 不及格 (0-59)。
Note: The full mark is 100. Excellent (90-100), Good (80-89), Pass (60-79), Fail (0-59).</textarea>
                            </div>
                        </div>
                        <div id="t-enrollment-section" class="hidden dg-form-section">
                            <h3 class="text-base font-semibold mb-3 border-b border-outline-variant/10 pb-2">在读证明信息</h3>
                            <p class="text-xs text-on-surface-variant mb-2">内容已自动生成，可直接编辑修改。</p>
                            <div class="dg-form-group"><label for="t-enrollment-body-cn" class="dg-form-label">证明正文 (中文)</label><textarea id="t-enrollment-body-cn" class="dg-form-textarea" rows="5"></textarea></div>
                            <div class="dg-form-group"><label for="t-enrollment-body-en" class="dg-form-label">Certificate Body (English)</label><textarea id="t-enrollment-body-en" class="dg-form-textarea" rows="5"></textarea></div>
                            <button id="t-regenerate-enrollment-btn" class="dg-btn dg-btn-secondary mt-2 text-sm !py-1.5">根据上方信息重新生成</button>
                        </div>
                        <div class="mt-2"><button id="t-print-btn" class="dg-btn dg-btn-primary">打印或生成PDF</button></div>
                    </div>
                    <div class="flex-1 flex justify-center items-start">
                        <div id="transcript-preview-container" class="dg-a4-preview print-area"></div>
                    </div>
                </div>
            </div>
        </main>
      </div>
    </div>
  </main>

  <!-- Scoped styles for the doc generator -->
  <style is:inline>
    .dg-a4-preview {
        width: 100%;
        max-width: 800px;
        aspect-ratio: 210 / 297;
        background: #fff;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        padding: 2.5cm 1.9cm;
        box-sizing: border-box;
        color: #000;
        overflow: auto;
        display: flex;
        flex-direction: column;
        border-radius: 4px;
    }

    #transcript-table th, #transcript-table td {
        border: 1px solid #000;
        padding: 4px 8px;
        text-align: center;
        font-size: 10pt;
    }

    .dg-nav-btn {
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--md-sys-color-on-surface-variant, #49454f);
        transition: color 0.2s, background-color 0.2s;
        border: none;
        background-color: transparent;
        cursor: pointer;
    }

    .dg-nav-btn.active {
        background-color: var(--md-sys-color-primary, #042f24);
        color: #fff;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
    }

    .dg-form-section {
        background-color: #f8faf9;
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 0.75rem;
        padding: 0.875rem;
    }

    .dg-form-input, .dg-form-select, .dg-form-textarea {
        width: 100%;
        padding: 0.4rem 0.6rem;
        background-color: #fff;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        transition: all 150ms ease-in-out;
    }

    .dg-form-input:focus, .dg-form-select:focus, .dg-form-textarea:focus {
        outline: none;
        border-color: var(--md-sys-color-primary, #042f24);
        box-shadow: 0 0 0 3px rgba(4, 47, 36, 0.15);
    }

    .dg-form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.2rem;
    }

    .dg-form-group { margin-bottom: 0.75rem; }
    .dg-form-group:last-child { margin-bottom: 0; }

    .dg-btn {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 0.5rem 0.875rem;
        border-radius: 0.375rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: #fff;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        transition: transform 150ms ease-in-out;
        border: none;
        cursor: pointer;
        width: 100%;
    }

    .dg-btn:hover { transform: scale(1.02); }
    .dg-btn-primary { background-color: var(--md-sys-color-primary, #042f24); }
    .dg-btn-secondary { background-color: #6b7280; }
    .dg-btn-danger { background-color: #dc2626; }

    @media print {
        body * { visibility: hidden; }
        .print-area, .print-area * { visibility: visible; }
        .print-area {
            position: absolute; left: 0; top: 0; width: 100%; height: 100%;
            padding: 1.5cm; box-sizing: border-box; box-shadow: none; border: none;
        }
        .no-print { display: none !important; }
    }

    /* Watermark for transcript preview */
    #transcript-preview-container::before {
        content: 'SAMPLE / 样本';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-30deg);
        font-size: 60px;
        font-weight: 900;
        color: rgba(220, 38, 38, 0.06);
        pointer-events: none;
        z-index: 1;
        white-space: nowrap;
        letter-spacing: 0.1em;
    }
    #transcript-preview-container {
        position: relative;
    }
  </style>

  <script is:inline>
    // --- UTILITY FUNCTIONS ---
    function formatDate(dateString, lang) {
        if (!dateString) return '';
        const date = new Date(dateString + 'T00:00:00');
        if (lang === 'cn') {
            return date.getFullYear() + '\u5E74' + (date.getMonth() + 1) + '\u6708' + date.getDate() + '\u65E5';
        } else {
            return date.toLocaleString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        }
    }
    function formatDateForEnrollment(dateString, locale) {
        if (!dateString) return { year: '', month: '', day: '', monthNum: '' };
        const date = new Date(dateString + 'T00:00:00');
