                certBodyCn: page.querySelector('#cert-body-cn'), certBodyEn: page.querySelector('#cert-body-en'),
            };
            this.elements.allInputs = page.querySelectorAll('input, select, textarea');
            this.elements.issueDate.value = new Date().toISOString().slice(0, 10);
            this.bindEvents();
            this.generateCertificateText();
            this.render();
        },
        populatePositionPreset: function() {
            var idx = this.elements.industryPreset.value;
            var select = this.elements.positionPreset;
            select.innerHTML = '';
            if (idx === '' || !industries[idx]) {
                var opt = document.createElement('option');
                opt.value = ''; opt.textContent = '— 请先选择行业 —';
                select.appendChild(opt);
                select.disabled = true;
                return;
            }
            var placeholder = document.createElement('option');
            placeholder.value = ''; placeholder.textContent = '— 选择岗位预设 —';
            select.appendChild(placeholder);
            industries[idx].positions.forEach(function(pos, i) {
                var opt = document.createElement('option');
                opt.value = i; opt.textContent = pos.cn + '  /  ' + pos.en;
                select.appendChild(opt);
            });
            select.disabled = false;
        },
        applyPositionPreset: function() {
            var indIdx = this.elements.industryPreset.value;
            var posIdx = this.elements.positionPreset.value;
            if (indIdx === '' || posIdx === '' || !industries[indIdx] || !industries[indIdx].positions[posIdx]) return;
            var p = industries[indIdx].positions[posIdx];
            this.elements.departmentCn.value = p.deptCN;
            this.elements.departmentEn.value = p.deptEN;
            this.elements.positionCn.value = p.cn;
            this.elements.positionEn.value = p.en;
            this.elements.responsibilitiesCn.value = p.respCN;
            this.elements.responsibilitiesEn.value = p.respEN;
        },
        bindEvents: function() {
            var self = this;
            this.elements.allInputs.forEach(function(input) {
                input.addEventListener('input', function() {
                    if (input.id === 'gender-cn') self.elements.genderEn.selectedIndex = input.selectedIndex;
                    if (!input.id.startsWith('cert-body')) self.generateCertificateText();
                    self.render();
                });
            });
            this.elements.industryPreset.addEventListener('change', function() {
                self.populatePositionPreset();
                self.generateCertificateText();
                self.render();
            });
            this.elements.positionPreset.addEventListener('change', function() {
                self.applyPositionPreset();
                self.generateCertificateText();
                self.render();
            });
            this.elements.regenerateBtn.addEventListener('click', function() { self.generateCertificateText(); self.render(); });
            this.elements.printBtn.addEventListener('click', function() { window.print(); });
        },
        getVal: function(id) { return this.elements[id] ? this.elements[id].value : ''; },
        getCheck: function(id) { return this.elements[id] ? this.elements[id].checked : false; },
        getStudentInfo: function(lang) {
            var name = this.getVal(lang === 'cn' ? 'nameCn' : 'nameEn');
            var info = lang === 'cn' ? name + ' \u540C\u5B66' : name;
            var details = [];
            if (this.getCheck('showSchool')) details.push(lang === 'cn' ? this.getVal('schoolNameCn') : 'a student from ' + this.getVal('schoolNameEn'));
            if (this.getCheck('showMajor')) details.push(lang === 'cn' ? this.getVal('majorCn') + '\u4E13\u4E1A' : 'majoring in ' + this.getVal('majorEn'));
            if (this.getCheck('showGender') && lang === 'cn') details.push(this.getVal('genderCn'));
            if (details.length === 0) return info;
            return lang === 'cn' ? details.join(' ') + ' ' + info : info + ', ' + details.join(', ');
        },
        generateCertificateText: function() {
            var gender = this.getVal('genderCn');
            var pronoun = { cn: gender === '\u5973' ? '\u5979' : '\u4ED6', en_he_she: gender === '\u5973' ? 'She' : 'He', en_his_her: gender === '\u5973' ? 'her' : 'his' };
            var level = this.getVal('experienceLevel');
            var template = this.templates[level][this.getVal('languageStyle')];
            var respCN = (this.getVal('responsibilitiesCn') || '').trim();
            var respEN = (this.getVal('responsibilitiesEn') || '').trim();
            var verbCN = level === 'activity' ? '\u53C2\u4E0E' : '\u8D1F\u8D23';
            var verbEN = level === 'activity' ? 'engaged in' : 'was primarily responsible for';
            var respSentenceCN = respCN ? (level === 'activity' ? '\u6D3B\u52A8\u671F\u95F4\uFF0C' + pronoun.cn + '\u4E3B\u8981' : '\u5B9E\u4E60\u671F\u95F4\uFF0C' + pronoun.cn + '\u4E3B\u8981') + verbCN + respCN + '\u3002' : '';
            var respSentenceEN = respEN ? (level === 'activity' ? 'During the activity, ' : 'During the internship, ') + pronoun.en_he_she.toLowerCase() + ' ' + verbEN + ' ' + respEN + '. ' : '';
            var values = {
                studentInfo: this.getStudentInfo('cn'), studentInfoEN: this.getStudentInfo('en'),
                nameCN: this.getVal('nameCn'), nameEN: this.getVal('nameEn'),
                startDate: formatDate(this.getVal('startDate'), 'cn'), endDate: formatDate(this.getVal('endDate'), 'cn'),
                startDateEN: formatDate(this.getVal('startDate'), 'en'), endDateEN: formatDate(this.getVal('endDate'), 'en'),
                companyNameCN: this.getVal('companyNameCn'), companyNameEN: this.getVal('companyNameEn'),
                departmentCN: this.getVal('departmentCn'), departmentEN: this.getVal('departmentEn'),
                positionCN: this.getVal('positionCn'), positionEN: this.getVal('positionEn'),
                responsibilitiesSentenceCN: respSentenceCN, responsibilitiesSentenceEN: respSentenceEN,
                pronounCN: pronoun.cn, pronounEN_He_She: pronoun.en_he_she, pronounEN_his_her: pronoun.en_his_her
            };
            this.elements.certBodyCn.value = template.cn.replace(/\{(\w+)\}/g, function(_, key) { return values[key] || ''; });
            this.elements.certBodyEn.value = template.en.replace(/\{(\w+)\}/g, function(_, key) { return values[key] || ''; });
        },
        render: function() {
            var lang = this.getVal('languageOutput');
            var cnPart = this.renderPart('cn'), enPart = this.renderPart('en');
            var finalHTML = '';
            if (lang === 'bilingual') finalHTML = '<div class="flex-grow">' + cnPart + '</div><hr class="my-4 border-dashed border-gray-400"><div class="flex-grow">' + enPart + '</div>';
            else if (lang === 'cn') finalHTML = '<div class="flex-grow">' + cnPart + '</div>';
            else finalHTML = '<div class="flex-grow">' + enPart + '</div>';
            this.elements.previewContainer.innerHTML = finalHTML;
        },
        renderPart: function(lang) {
            var isCN = lang === 'cn';
            var title = isCN ? '\u5B9E \u4E60 \u8BC1 \u660E' : 'Certificate of Internship';
            var company = this.getVal(isCN ? 'companyNameCn' : 'companyNameEn');
            var body = this.getVal(isCN ? 'certBodyCn' : 'certBodyEn').replace(/\n/g, '<br>');
            var supervisor = this.getVal(isCN ? 'supervisorCn' : 'supervisorEn');
            var issueDateValue = this.getVal('issueDate');
            var date = formatDate(issueDateValue || new Date().toISOString().slice(0, 10), lang);
            var showSupervisor = this.getCheck('showSupervisor');
            var supervisorHTML = (showSupervisor && supervisor) ? '<p class="mt-8">' + (isCN ? '\u5B9E\u4E60\u5BFC\u5E08\uFF1A' : 'Supervisor:') + ' ' + supervisor + '</p>' : '';
            return '<div class="text-center"><h1 class="text-2xl font-bold tracking-widest">' + title + '</h1></div><div class="mt-12 text-base leading-relaxed" style="' + (isCN ? 'text-indent: 2em;' : '') + '">' + body + '</div><div class="flex-shrink-0 text-right mt-16">' + supervisorHTML + '<p class="mt-8">' + (isCN ? '\uFF08\u516C\u53F8\u76D6\u7AE0\uFF09' : '(Company Seal)') + '</p><p class="mt-2">' + company + '</p><p class="mt-2">' + date + '</p></div>';
        }
    };

