            var textCN = '\u5179\u8BC1\u660E ' + nameCN;
            if(this.getCheck('showGender')) textCN += '\uFF0C' + genderCN;
            if(this.getCheck('showBirthDate')) textCN += '\uFF0C' + birthDateCN.year + '\u5E74' + birthDateCN.monthNum + '\u6708' + birthDateCN.day + '\u65E5\u51FA\u751F';
            if(this.getCheck('showIdCard')) textCN += '\uFF0C\u8EAB\u4EFD\u8BC1\u53F7\uFF1A' + idCard;
            if(this.getCheck('showStudentId')) textCN += '\uFF0C\u5B66\u53F7\uFF1A' + studentId;
            textCN += '\uFF0C\u4E8E' + enrollDateCN.year + '\u5E74' + enrollDateCN.monthNum + '\u6708\u8FDB\u5165\u6211\u6821' + (schoolLevel === 'university' ? majorCN + '\u4E13\u4E1A' : '') + '\u5B66\u4E60';
            var durationCN = schoolLevel === 'university' ? '\u56DB' : '\u4E09';
            textCN += '\uFF0C\u5B66\u5236' + durationCN + '\u5E74';
            if(this.getCheck('showCurrentGrade')) textCN += '\uFF0C\u73B0\u4E3A' + currentGrade + '\u5B66\u751F';
            textCN += '\u3002\u6211\u6821\u662F\u88AB\u4E2D\u534E\u4EBA\u6C11\u5171\u548C\u56FD\u6559\u80B2\u90E8\u8BA4\u53EF\u7684\u5168\u65E5\u5236\u9AD8\u7B49\u5B66\u6821\u3002';
            var textEN = 'This is to certify that ' + nameEN;
            if(this.getCheck('showGender')) textEN += ', ' + this.getVal('genderEn').toLowerCase();
            if(this.getCheck('showBirthDate')) textEN += ', born on ' + birthDateEN.month + ' ' + birthDateEN.day + ', ' + birthDateEN.year;
            if(this.getCheck('showIdCard')) textEN += ', ID Card No.: ' + idCard;
            if(this.getCheck('showStudentId')) textEN += ', Student No.: ' + studentId;
            textEN += ', was enrolled in our school in ' + enrollDateEN.month + ', ' + enrollDateEN.year + (schoolLevel === 'university' ? ', majoring in ' + majorEN : '') + '.';
            var durationEN = schoolLevel === 'university' ? 'four' : 'three';
            textEN += ' The length of schooling is ' + durationEN + ' years.';
            if(this.getCheck('showCurrentGrade')) {
                var gradeMap = { '\u521D\u4E00': 'a Freshman', '\u521D\u4E8C': 'a Sophomore', '\u521D\u4E09': 'a Junior', '\u9AD8\u4E00': 'a Freshman', '\u9AD8\u4E8C': 'a Sophomore', '\u9AD8\u4E09': 'a Junior', '\u5927\u4E00': 'a Freshman', '\u5927\u4E8C': 'a Sophomore', '\u5927\u4E09': 'a Junior', '\u5927\u56DB': 'a Senior' };
                textEN += ' Now he/she is ' + (gradeMap[currentGrade] || 'a student') + '.';
            }
            textEN += ' Our school is a full-time accredited school approved by the Ministry of Education of the People\'s Republic of China.';
            this.elements.enrollmentBodyCn.value = textCN;
            this.elements.enrollmentBodyEn.value = textEN;
        },
        render: function() {
            if (this.getVal('docType') === 'transcript') this.renderTranscript(); else this.renderEnrollment();
        },
        renderTranscript: function() {
            var schoolNameCN = this.getVal('schoolNameCn'), schoolNameEN = this.getVal('schoolNameEn'), notes = this.getVal('transcriptNotes').replace(/\n/g, '<br>'), level = this.getVal('educationLevel');
            var headerInfoHTML = '<div class="grid grid-cols-2 gap-x-6 gap-y-1 mt-4" style="font-size: 10pt;">';
            headerInfoHTML += '<div><span class="font-semibold">\u59D3\u540D:</span> ' + this.getVal('nameCn') + ' (' + this.getVal('nameEn') + ')</div>';
            var infoItems = [
                { cn: '\u6027\u522B', value: this.getVal('genderCn') + ' (' + this.getVal('genderEn') + ')', show: this.getCheck('showGender') },
                { cn: '\u51FA\u751F\u65E5\u671F', value: this.getVal('birthDate'), show: this.getCheck('showBirthDate') },
                { cn: '\u5B66\u53F7', value: this.getVal('studentId'), show: this.getCheck('showStudentId') },
                { cn: '\u8EAB\u4EFD\u8BC1\u53F7', value: this.getVal('idCard'), show: this.getCheck('showIdCard') },
                { cn: '\u76EE\u524D\u5E74\u7EA7', value: this.getVal('currentGrade'), show: this.getCheck('showCurrentGrade') },
                { cn: '\u5165\u5B66\u65E5\u671F', value: this.getVal('enrollDate'), show: this.getCheck('showEnrollDate') },
                { cn: '\u6BD5\u4E1A\u65E5\u671F', value: this.getVal('gradDate'), show: this.getCheck('showGradDate') }
            ];
            infoItems.filter(function(item) { return item.show; }).forEach(function(item) { headerInfoHTML += '<div><span class="font-semibold">' + item.cn + ':</span> ' + item.value + '</div>'; });
            headerInfoHTML += '</div>';
            var numYears = (level === 'university' ? 4 : 3);
            var yearNames = level === 'university' ? ['\u7B2C\u4E00\u5B66\u5E74<br>Year 1', '\u7B2C\u4E8C\u5B66\u5E74<br>Year 2', '\u7B2C\u4E09\u5B66\u5E74<br>Year 3', '\u7B2C\u56DB\u5B66\u5E74<br>Year 4'] : ['\u4E00\u5E74\u7EA7<br>Grade 1', '\u4E8C\u5E74\u7EA7<br>Grade 2', '\u4E09\u5E74\u7EA7<br>Grade 3'];
            var gradeHeaders = '', gradeCols = '';
            for (var i = 0; i < numYears; i++) { gradeHeaders += '<th colspan="2">' + yearNames[i] + '</th>'; gradeCols += '<th>\u4E0A\u5B66\u671F<br>1st</th><th>\u4E0B\u5B66\u671F<br>2nd</th>'; }
            var coursesHTML = '';
            this.elements.coursesContainer.querySelectorAll('.course-row').forEach(function(row) {
                var courseCN = row.querySelector('[data-type="course-cn"]').value, courseEN = row.querySelector('[data-type="course-en"]').value; var scoresHTML = '';
                for (var j = 0; j < numYears * 2; j++) { scoresHTML += '<td>' + row.querySelector('[data-term="' + j + '"]').value + '</td>'; }
                coursesHTML += '<tr><td>' + courseCN + '<br>' + courseEN + '</td>' + scoresHTML + '</tr>';
            });
            var transcriptTitles = '<div class="text-center mt-6"><h3 class="text-xl font-bold">\u6210 \u7EE9 \u5355</h3><h4 class="text-lg font-semibold">Transcript</h4></div>';
            this.elements.previewContainer.innerHTML = '<div class="flex-grow">' + this.getHeader(schoolNameCN, schoolNameEN) + transcriptTitles + headerInfoHTML + '<table id="transcript-table" class="w-full mt-4 border-collapse"><thead><tr><th rowspan="2">\u8BFE\u7A0B<br>Course</th>' + gradeHeaders + '</tr><tr>' + gradeCols + '</tr></thead><tbody>' + coursesHTML + '</tbody></table><div class="mt-4" style="font-size: 9pt;">' + notes + '</div></div>' + this.getFooter();
        },
        renderEnrollment: function() {
            var schoolNameCN = this.getVal('schoolNameCn'), schoolNameEN = this.getVal('schoolNameEn'), bodyCN = this.getVal('enrollmentBodyCn').replace(/\n/g, '<br>'), bodyEN = this.getVal('enrollmentBodyEn').replace(/\n/g, '<br>');
            this.elements.previewContainer.innerHTML = '<div class="flex-grow">' + this.getHeader(schoolNameCN, schoolNameEN) + '<div class="text-center my-12"><h3 class="text-2xl font-bold tracking-widest">\u8BC1\u00A0\u00A0\u00A0\u00A0\u660E</h3></div><div class="text-lg leading-relaxed" style="text-indent: 2em;">' + bodyCN + '</div><div class="text-right mt-16"><p>' + schoolNameCN + '</p><p>' + formatDate(new Date().toISOString().slice(0, 10), 'cn') + '</p></div><hr class="my-8 border-dashed"><div class="text-center my-8"><h3 class="text-2xl font-bold">Certificate</h3></div><div class="text-base leading-relaxed">' + bodyEN + '</div></div><div class="flex-shrink-0 text-right pt-4"><p>' + schoolNameEN + '</p><p>' + formatDate(new Date().toISOString().slice(0, 10), 'en') + '</p></div>';
        },
        getHeader: function(cn, en) { return '<div class="text-center"><h1 class="text-2xl font-bold tracking-widest">' + cn + '</h1><h2 class="text-xl font-semibold">' + en + '</h2></div>'; },
        getFooter: function() { return '<div class="flex-shrink-0 flex justify-between text-sm pt-4"><div><p>\u5B66\u6821\u76D6\u7AE0 (Official Seal):</p></div><div><p>\u65E5\u671F (Date): ' + new Date().toISOString().slice(0, 10) + '</p></div></div>'; },
        addCourse: function(course, scores) {
            course = course || { cn: '', en: '' };
            scores = scores || [];
            this.courseCounter++;
            var courseId = 'course-' + this.courseCounter;
            var courseDiv = document.createElement('div');
            courseDiv.className = 'course-row p-2 border border-outline-variant/15 rounded-md mb-2 bg-white';
            courseDiv.id = courseId;
            var scoreInputs = '';
            var numYears = this.getVal('educationLevel') === 'university' ? 4 : 3;
            for (var i = 0; i < numYears * 2; i++) { scoreInputs += '<div class="dg-form-group !mb-0"><input type="text" class="dg-form-input text-xs" placeholder="T' + (i+1) + '" data-type="score" data-term="' + i + '" value="' + (scores[i] || '') + '"></div>'; }
            courseDiv.innerHTML = '<div class="grid grid-cols-2 gap-1 mb-1"><div class="dg-form-group !mb-0"><input type="text" class="dg-form-input text-sm" placeholder="\u79D1\u76EE\u540D (\u4E2D\u6587)" data-type="course-cn" value="' + course.cn + '"></div><div class="dg-form-group !mb-0"><input type="text" class="dg-form-input text-sm" placeholder="Course Name" data-type="course-en" value="' + course.en + '"></div></div><div class="grid grid-cols-4 lg:grid-cols-6 gap-1">' + scoreInputs + '</div><button class="dg-btn dg-btn-danger mt-1 w-full text-xs !py-0.5 remove-course-btn">\u2212 \u5220\u9664</button>';
            this.elements.coursesContainer.appendChild(courseDiv);
            var self = this;
            courseDiv.querySelector('.remove-course-btn').addEventListener('click', function() { self.removeCourse(courseId); });
            courseDiv.querySelectorAll('input').forEach(function(input) { input.addEventListener('input', function() { self.render(); }); });
        },
        removeCourse: function(id) { var el = document.getElementById(id); if (el) el.remove(); this.render(); },
        setupCourses: function() {
            this.elements.coursesContainer.innerHTML = '';
            var self = this;
            this.initialCourses[this.getVal('educationLevel')].forEach(function(course) { self.addCourse(course); });
        },
        generateRandomScores: function() {
            var avg = parseInt(this.getVal('avgScore'), 10) || 85;
            this.elements.coursesContainer.querySelectorAll('input[data-type="score"]').forEach(function(input) {
                var randomScore = Math.round(avg + (Math.random() * 20 - 10));
                input.value = Math.max(60, Math.min(100, randomScore)) + '/100';
            });
            this.render();
        },
        toggleSections: function() {
            var isTranscript = this.getVal('docType') === 'transcript', isUniversity = this.getVal('educationLevel') === 'university';
            this.elements.transcriptSection.classList.toggle('hidden', !isTranscript);
            this.elements.enrollmentSection.classList.toggle('hidden', isTranscript);
            this.elements.gradDateGroup.classList.toggle('hidden', !isTranscript);
            this.elements.majorCnGroup.classList.toggle('hidden', !isUniversity);
            this.elements.majorEnGroup.classList.toggle('hidden', !isUniversity);
            if (!isTranscript) this.generateEnrollmentText();
        },
    };
  </script>
</MainLayout>
