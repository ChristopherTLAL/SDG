                pronounCN: pronoun.cn, pronounEN_He_She: pronoun.en_he_she, pronounEN_his_her: pronoun.en_his_her
            };
            this.elements.certBodyCn.value = template.cn.replace(/\{(\w+)\}/g, function(_, key) { return values[key] || ''; });
            this.elements.certBodyEn.value = template.en.replace(/\{(\w+)\}/g, function(_, key) { return values[key] || ''; });
