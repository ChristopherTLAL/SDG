    .dg-form-group { margin-bottom: 0.75rem; }
    .dg-form-group:last-child { margin-bottom: 0; }

    .dg-btn {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 0.5rem 0.875rem;
