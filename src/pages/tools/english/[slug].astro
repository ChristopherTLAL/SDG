<script>
  type Mode = 'vocab' | 'translate' | 'grammar' | 'patterns' | 'quiz' | 'review' | 'about';

  type Article = {
    meta: { date: string; title: string; source: { name: string; url: string }; cefr: string; wordCount: number; readingMinutes: number; editorsNote?: string };
    paragraphs: { id: string; sentences: { id: string; en: string; zh: string }[] }[];
    vocab: { id: string; word: string; lemma: string; sentenceId: string; level: string; pos: string; ipa: string; defZh: string; defEn: string; example: string; exampleZh?: string }[];
    collocations: { id: string; phrase: string; sentenceId: string; meaningZh: string; example: string; exampleZh?: string }[];
    grammar: { id: string; title: string; pattern: string; explanationZh: string; sentenceIds: string[]; examples: string[] }[];
    patterns: { id: string; skeleton: string; original: string; sentenceId: string; hint: string }[];
    quiz: { id: string; q: string; options: string[]; answer: number; explanation: string; sentenceId?: string }[];
  };

  const dataEl = document.getElementById('el-data');
  const ARTICLE: Article = JSON.parse(dataEl?.textContent || '{}');
  const FLAT_SENTENCES = ARTICLE.paragraphs.flatMap((p) => p.sentences);
  const SENT_BY_ID = Object.fromEntries(FLAT_SENTENCES.map((s) => [s.id, s]));
  const VOCAB_BY_ID = Object.fromEntries(ARTICLE.vocab.map((v) => [v.id, v]));

  let currentMode: Mode = 'vocab';
  let activeLevels = new Set(['CET4', 'CET6', 'IELTS', 'GRE']);
  let pinnedVocabId: string | null = null;
  let activeSentId: string | null = null;
  let showAllZh = false;

  const modeDescs: Record<Mode, { label: string; desc: string }> = {
    vocab:     { label: 'Vocabulary',    desc: 'Hover any underlined word for its meaning. Click to pin.' },
    translate: { label: 'Translation',   desc: 'Click a sentence — its Chinese translation appears here.' },
    grammar:   { label: 'Grammar',       desc: 'Grammar points used in this article. Hover a card to highlight in the text.' },
    patterns:  { label: 'Patterns',      desc: 'Reusable sentence skeletons you can borrow for your own writing.' },
    quiz:      { label: 'Comprehension', desc: 'Quick questions to check that you actually read it.' },
    review:    { label: 'Word review',   desc: 'A flashcard pass over the article\'s vocabulary — current session only.' },
    about:     { label: 'About',         desc: 'Source, length, level, and the editor\'s note.' },
  };

  function setMode(mode: Mode) {
    currentMode = mode;
    document.querySelectorAll('.el-tab').forEach((el) => {
      const isActive = el.getAttribute('data-mode') === mode;
      el.classList.toggle('is-active', isActive);
      el.setAttribute('aria-selected', String(isActive));
    });
    document.querySelectorAll('.el-mode').forEach((el) => {
      const m = el.getAttribute('data-mode');
      if (m === mode) el.removeAttribute('hidden');
      else el.setAttribute('hidden', '');
    });
    const titleEl = document.getElementById('el-mode-title');
    const descEl = document.getElementById('el-mode-desc');
    if (titleEl) titleEl.textContent = modeDescs[mode].label;
    if (descEl)  descEl.textContent  = modeDescs[mode].desc;

    const sentClickable = mode === 'translate';
    document.querySelectorAll('.sent').forEach((el) => {
      el.classList.toggle('is-clickable', sentClickable);
    });
    document.querySelectorAll('.sent.is-grammar').forEach((el) => el.classList.remove('is-grammar'));
  }

  document.querySelectorAll('.el-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const m = btn.getAttribute('data-mode') as Mode;
      if (m) setMode(m);
    });
  });

  // ============== Vocab ==============
  const vocabDetailEl = document.getElementById('el-vocab-detail')!;

  function renderVocabCard(vid: string) {
    const v = VOCAB_BY_ID[vid];
    if (!v) return;
    const level = v.level.toLowerCase();
    vocabDetailEl.innerHTML = `
      <div class="el-vocab-card">
        <div class="el-vocab-card-head">
          <span class="word">${v.word}</span>
          <span class="ipa">${v.ipa}</span>
          <span class="pos">${v.pos}</span>
          <span class="el-level-tag el-level-tag--${level}">${v.level}</span>
        </div>
        <div class="el-vocab-defs">
          <p>${v.defZh}</p>
          <p>${v.defEn}</p>
        </div>
        <div class="el-vocab-eg">
          <em>${v.example}</em>
          ${v.exampleZh ? `<span class="zh">${v.exampleZh}</span>` : ''}
        </div>
        <div class="el-vocab-card-foot">
          <a href="#" data-jump-sid="${v.sentenceId}">
            <span class="material-symbols-outlined" style="font-size:14px">north_east</span>
            See in article
          </a>
          <button class="el-btn el-btn-ghost" id="el-vocab-tts" style="margin:0; padding: 4px 10px; font-size: 11.5px;">
            <span class="material-symbols-outlined" style="font-size:14px">volume_up</span>
            Listen
          </button>
        </div>
      </div>
    `;
    const jump = vocabDetailEl.querySelector('[data-jump-sid]');
    jump?.addEventListener('click', (e) => {
      e.preventDefault();
      const sid = (e.currentTarget as HTMLElement).getAttribute('data-jump-sid')!;
      jumpToSentence(sid);
    });
    const ttsBtn = vocabDetailEl.querySelector('#el-vocab-tts');
    ttsBtn?.addEventListener('click', () => speakOne(v.word));
  }

  function clearVocabCard() {
    vocabDetailEl.innerHTML = `
      <div class="el-empty">
        <span class="material-symbols-outlined">touch_app</span>
        <p>Hover any underlined word in the article. Click to pin.</p>
      </div>
    `;
  }

  function pinVocab(vid: string | null) {
    document.querySelectorAll('.vocab.is-pinned').forEach((el) => el.classList.remove('is-pinned'));
    document.querySelectorAll('.el-vocab-row-btn.is-active').forEach((el) => el.classList.remove('is-active'));
    pinnedVocabId = vid;
    if (vid) {
      document.querySelectorAll(`.vocab[data-vid="${vid}"]`).forEach((el) => el.classList.add('is-pinned'));
      document.querySelector(`.el-vocab-row-btn[data-vid="${vid}"]`)?.classList.add('is-active');
      renderVocabCard(vid);
    } else {
      clearVocabCard();
    }
  }

  document.querySelectorAll('.vocab').forEach((el) => {
    el.addEventListener('mouseenter', () => {
      if (pinnedVocabId) return;
      const vid = el.getAttribute('data-vid');
      if (vid) {
        if (currentMode !== 'vocab') setMode('vocab');
        renderVocabCard(vid);
      }
    });
    el.addEventListener('mouseleave', () => {
      if (pinnedVocabId) return;
      clearVocabCard();
    });
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      const vid = el.getAttribute('data-vid');
      if (!vid) return;
      if (currentMode !== 'vocab') setMode('vocab');
      pinVocab(pinnedVocabId === vid ? null : vid);
    });
  });

  document.querySelectorAll('.el-vocab-row-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const vid = btn.getAttribute('data-vid');
      if (!vid) return;
      pinVocab(pinnedVocabId === vid ? null : vid);
      jumpToSentence(VOCAB_BY_ID[vid].sentenceId);
    });
  });

  function applyLevelFilter() {
    document.querySelectorAll('.vocab').forEach((el) => {
      const lvl = el.getAttribute('data-level') || '';
      el.classList.toggle('is-hidden', !activeLevels.has(lvl));
    });
    document.querySelectorAll('.el-vocab-row').forEach((el) => {
      const lvl = el.getAttribute('data-level') || '';
      el.classList.toggle('is-hidden', !activeLevels.has(lvl));
    });
  }
  document.querySelectorAll('.el-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const lvl = chip.getAttribute('data-level');
      if (!lvl) return;
      if (activeLevels.has(lvl)) activeLevels.delete(lvl);
      else activeLevels.add(lvl);
      chip.classList.toggle('is-on', activeLevels.has(lvl));
      applyLevelFilter();
    });
  });

  // ============== Translate ==============
  const transDetailEl = document.getElementById('el-trans-detail')!;

  function setActiveSentence(sid: string | null) {
    document.querySelectorAll('.sent.is-active').forEach((el) => el.classList.remove('is-active'));
    activeSentId = sid;
    if (!sid) {
      transDetailEl.innerHTML = `
        <div class="el-empty">
          <span class="material-symbols-outlined">ads_click</span>
          <p>Click any sentence in the article to see its Chinese translation here.</p>
          <p class="el-empty-sub">Use ↑ / ↓ to walk sentence by sentence.</p>
        </div>
      `;
      return;
    }
    document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add('is-active'));
    const idx = FLAT_SENTENCES.findIndex((s) => s.id === sid);
    const s = FLAT_SENTENCES[idx];
    const prevId = idx > 0 ? FLAT_SENTENCES[idx - 1].id : '';
    const nextId = idx < FLAT_SENTENCES.length - 1 ? FLAT_SENTENCES[idx + 1].id : '';
    transDetailEl.innerHTML = `
      <div class="el-trans-card-en">${s.en}</div>
      <div class="el-trans-card-zh">${s.zh}</div>
      <div class="el-trans-card-nav">
        <button data-prev="${prevId}" ${!prevId ? 'disabled' : ''}>
          <span class="material-symbols-outlined">arrow_upward</span> Prev
        </button>
        <button data-listen="${sid}">
          <span class="material-symbols-outlined">volume_up</span> Listen
        </button>
        <button data-next="${nextId}" ${!nextId ? 'disabled' : ''}>
          Next <span class="material-symbols-outlined">arrow_downward</span>
        </button>
      </div>
    `;
    transDetailEl.querySelector('[data-prev]')?.addEventListener('click', (e) => {
      const t = (e.currentTarget as HTMLElement).getAttribute('data-prev');
      if (t) { setActiveSentence(t); jumpToSentence(t); }
    });
    transDetailEl.querySelector('[data-next]')?.addEventListener('click', (e) => {
      const t = (e.currentTarget as HTMLElement).getAttribute('data-next');
      if (t) { setActiveSentence(t); jumpToSentence(t); }
    });
    transDetailEl.querySelector('[data-listen]')?.addEventListener('click', () => speakOne(s.en));
  }

  document.querySelectorAll('.sent').forEach((el) => {
    el.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.vocab')) return;
      if (currentMode !== 'translate') return;
      const sid = el.getAttribute('data-sid');
      if (sid) setActiveSentence(sid);
    });
  });

  const showAllToggle = document.getElementById('el-show-all-zh') as HTMLInputElement | null;
  showAllToggle?.addEventListener('change', () => {
    showAllZh = showAllToggle.checked;
    document.querySelectorAll('.sent-zh-inline').forEach((el) => el.remove());
    if (showAllZh) {
      document.querySelectorAll('.sent').forEach((el) => {
        const sid = el.getAttribute('data-sid');
        if (!sid) return;
        const s = SENT_BY_ID[sid];
        const zhEl = document.createElement('span');
        zhEl.className = 'sent-zh-inline';
        zhEl.textContent = s.zh;
        el.insertAdjacentElement('afterend', zhEl);
      });
    }
  });

  function jumpToSentence(sid: string) {
    const el = document.querySelector(`.sent[data-sid="${sid}"]`);
    if (!el) return;
    const rect = (el as HTMLElement).getBoundingClientRect();
    const targetY = window.scrollY + rect.top - window.innerHeight / 2;
    window.scrollTo({ top: targetY, behavior: 'smooth' });
    (el as HTMLElement).classList.add('is-active');
    setTimeout(() => {
      if (currentMode !== 'translate' && activeSentId !== sid) {
        (el as HTMLElement).classList.remove('is-active');
      }
    }, 1500);
  }

  // ============== Grammar / Patterns ==============
  function highlightSentences(sids: string[], cls = 'is-grammar') {
    document.querySelectorAll(`.sent.${cls}`).forEach((el) => el.classList.remove(cls));
    sids.forEach((sid) => {
      document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add(cls));
    });
    if (sids[0]) jumpToSentence(sids[0]);
  }
  document.querySelectorAll('.el-card').forEach((card) => {
    card.addEventListener('mouseenter', () => {
      const sids = (card.getAttribute('data-sids') || '').split(',').filter(Boolean);
      sids.forEach((sid) => {
        document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add('is-grammar'));
      });
    });
    card.addEventListener('mouseleave', () => {
      document.querySelectorAll('.sent.is-grammar').forEach((el) => el.classList.remove('is-grammar'));
    });
  });
  document.querySelectorAll('.el-card-action').forEach((btn) => {
    btn.addEventListener('click', () => {
      const sids = (btn.getAttribute('data-sids') || '').split(',').filter(Boolean);
      highlightSentences(sids);
      document.querySelectorAll('.el-card.is-active').forEach((el) => el.classList.remove('is-active'));
      btn.closest('.el-card')?.classList.add('is-active');
    });
  });

  // ============== Quiz ==============
  const quizRoot = document.getElementById('el-quiz-root')!;
  let quizIdx = 0;
  let quizScore = 0;
  let quizAnswered: (number | null)[] = [];

  document.getElementById('el-quiz-begin')?.addEventListener('click', startQuiz);
  function startQuiz() {
    quizIdx = 0;
    quizScore = 0;
    quizAnswered = ARTICLE.quiz.map(() => null);
    renderQuiz();
  }
  function renderQuiz() {
    if (quizIdx >= ARTICLE.quiz.length) {
      quizRoot.innerHTML = `
        <div class="el-quiz-end">
          <span class="material-symbols-outlined el-quiz-icon">military_tech</span>
          <div class="el-quiz-score">${quizScore}/${ARTICLE.quiz.length}</div>
          <div class="el-quiz-score-label">${
            quizScore === ARTICLE.quiz.length
              ? 'Perfect read.'
              : quizScore >= ARTICLE.quiz.length - 1
              ? 'Strong comprehension.'
              : quizScore >= ARTICLE.quiz.length / 2
              ? 'Worth a re-read of the trickier paragraphs.'
              : 'Try the article again — slow down on the dashes.'
          }</div>
          <button class="el-btn el-btn-primary" id="el-quiz-restart">Try again</button>
          <button class="el-btn el-btn-ghost" id="el-quiz-back-article" style="margin-top:0">
            <span class="material-symbols-outlined" style="font-size:14px">menu_book</span>
            Back to article
          </button>
        </div>
      `;
      document.getElementById('el-quiz-restart')?.addEventListener('click', startQuiz);
      document.getElementById('el-quiz-back-article')?.addEventListener('click', () => setMode('vocab'));
      return;
    }
    const q = ARTICLE.quiz[quizIdx];
    const pct = (quizIdx / ARTICLE.quiz.length) * 100;
    const letters = ['A', 'B', 'C', 'D'];
    quizRoot.innerHTML = `
      <div class="el-quiz-progress"><div class="el-quiz-progress-fill" style="width: ${pct}%"></div></div>
      <div class="el-quiz-counter">Q ${quizIdx + 1} / ${ARTICLE.quiz.length}</div>
      <div class="el-quiz-q">${q.q}</div>
      <div class="el-quiz-options" id="el-quiz-options">
        ${q.options.map((o, i) => `
          <button class="el-quiz-option" data-i="${i}">
            <span class="el-quiz-option-letter">${letters[i]}</span>
            <span>${o}</span>
          </button>
        `).join('')}
      </div>
    `;
    quizRoot.querySelectorAll('.el-quiz-option').forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = Number(btn.getAttribute('data-i'));
        if (quizAnswered[quizIdx] !== null) return;
        quizAnswered[quizIdx] = i;
        const correct = i === q.answer;
        if (correct) quizScore++;
        quizRoot.querySelectorAll('.el-quiz-option').forEach((b, bi) => {
          (b as HTMLButtonElement).disabled = true;
          if (bi === q.answer) b.classList.add('is-correct');
          if (bi === i && !correct) b.classList.add('is-wrong');
        });
        const ex = document.createElement('div');
        ex.className = 'el-quiz-explanation';
        ex.innerHTML = `<strong style="color: var(--el-pin)">${correct ? 'Correct.' : 'Not quite.'}</strong> ${q.explanation}`;
        quizRoot.appendChild(ex);
        const actions = document.createElement('div');
        actions.className = 'el-quiz-actions';
        actions.innerHTML = `
          ${q.sentenceId ? `<button class="el-btn el-btn-ghost" id="el-quiz-evidence">
            <span class="material-symbols-outlined" style="font-size:14px">north_east</span>
            See evidence
          </button>` : '<span></span>'}
          <button class="el-btn el-btn-primary" id="el-quiz-next">
            ${quizIdx === ARTICLE.quiz.length - 1 ? 'See score' : 'Next'}
            <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
          </button>
        `;
        quizRoot.appendChild(actions);
        document.getElementById('el-quiz-evidence')?.addEventListener('click', () => {
          if (q.sentenceId) highlightSentences([q.sentenceId]);
        });
        document.getElementById('el-quiz-next')?.addEventListener('click', () => { quizIdx++; renderQuiz(); });
      });
    });
  }

  // ============== Review (Anki-lite) ==============
  const reviewRoot = document.getElementById('el-review-root')!;
  let reviewDeck: string[] = [];
  let reviewIdx = 0;
  let reviewFlipped = false;
  let reviewDone = 0;

  document.getElementById('el-review-begin')?.addEventListener('click', startReview);
  function startReview() {
    reviewDeck = ARTICLE.vocab.map((v) => v.id);
    for (let i = reviewDeck.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [reviewDeck[i], reviewDeck[j]] = [reviewDeck[j], reviewDeck[i]];
    }
    reviewIdx = 0;
    reviewFlipped = false;
    reviewDone = 0;
    renderReview();
  }
  function renderReview() {
    if (reviewIdx >= reviewDeck.length) {
      reviewRoot.innerHTML = `
        <div class="el-quiz-end">
          <span class="material-symbols-outlined el-quiz-icon">verified</span>
          <div class="el-quiz-score">${reviewDone}</div>
          <div class="el-quiz-score-label">Words reviewed</div>
          <button class="el-btn el-btn-primary" id="el-review-restart">Review again</button>
          <button class="el-btn el-btn-ghost" id="el-review-back" style="margin-top:0">
            <span class="material-symbols-outlined" style="font-size:14px">menu_book</span>
            Back to article
          </button>
        </div>
      `;
      document.getElementById('el-review-restart')?.addEventListener('click', startReview);
      document.getElementById('el-review-back')?.addEventListener('click', () => setMode('vocab'));
      return;
    }
    const v = VOCAB_BY_ID[reviewDeck[reviewIdx]];
    const pct = (reviewIdx / reviewDeck.length) * 100;
    reviewRoot.innerHTML = `
      <div class="el-quiz-progress"><div class="el-quiz-progress-fill" style="width: ${pct}%"></div></div>
      <div class="el-quiz-counter">${reviewIdx + 1} / ${reviewDeck.length}</div>
      <div class="el-review-card">
        <div class="el-review-card-front">
          <span class="el-level-tag el-level-tag--${v.level.toLowerCase()}">${v.level}</span>
          <div class="el-review-word">${v.word}</div>
          <div class="el-review-pos">${v.pos}</div>
          ${reviewFlipped ? '' : '<div class="el-review-flip-hint">Click to reveal · Space</div>'}
        </div>
        ${reviewFlipped ? `
          <div class="el-review-back">
            <span class="ipa">${v.ipa}</span>
            <span class="def">${v.defZh}</span>
            <span class="def" style="font-weight: 400; color: rgba(4,47,36,0.6); font-size: 12.5px">${v.defEn}</span>
            <div class="eg">${v.example}${v.exampleZh ? `<br><span style="color:rgba(4,47,36,0.5)">${v.exampleZh}</span>` : ''}</div>
          </div>
        ` : ''}
      </div>
      ${reviewFlipped ? `
        <div class="el-review-rating">
          <button data-rate="0"><span class="label">Again</span><span class="key">Q</span></button>
          <button data-rate="1"><span class="label">Hard</span><span class="key">W</span></button>
          <button data-rate="2"><span class="label">Good</span><span class="key">E</span></button>
          <button data-rate="3"><span class="label">Easy</span><span class="key">R</span></button>
        </div>
      ` : `
        <button class="el-btn el-btn-primary" id="el-review-flip" style="align-self:center">
          <span class="material-symbols-outlined" style="font-size:14px">visibility</span>
          Show meaning
        </button>
      `}
    `;
    document.getElementById('el-review-flip')?.addEventListener('click', () => { reviewFlipped = true; renderReview(); });
    reviewRoot.querySelector('.el-review-card')?.addEventListener('click', () => {
      if (!reviewFlipped) { reviewFlipped = true; renderReview(); }
    });
    reviewRoot.querySelectorAll('.el-review-rating button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const r = Number(btn.getAttribute('data-rate'));
        rateReview(r);
      });
    });
  }
  function rateReview(rating: number) {
    const currentId = reviewDeck[reviewIdx];
    if (rating === 0) {
      reviewDeck.splice(reviewIdx, 1);
      const insertAt = Math.min(reviewDeck.length, reviewIdx + Math.max(3, Math.floor(reviewDeck.length / 3)));
      reviewDeck.splice(insertAt, 0, currentId);
    } else if (rating === 1) {
      reviewDeck.splice(reviewIdx, 1);
      const insertAt = Math.min(reviewDeck.length, reviewIdx + 5);
      reviewDeck.splice(insertAt, 0, currentId);
    } else {
      reviewIdx++;
      reviewDone++;
    }
    reviewFlipped = false;
    renderReview();
  }

  // ============== TTS — voice picker + better defaults ==============
  const synth = window.speechSynthesis;
  let ttsQueue: { text: string; sid?: string }[] = [];
  let ttsIdx = 0;
  let ttsPlaying = false;
  let selectedVoice: SpeechSynthesisVoice | null = null;

  // Heuristic ranking — higher score = better-sounding voice on most platforms.
  function scoreVoice(v: SpeechSynthesisVoice): number {
    const n = v.name.toLowerCase();
    let s = 0;
    if (!v.lang.toLowerCase().startsWith('en')) return -1;
    // Microsoft Edge premium "Natural" / "Online (Natural)" voices
    if (n.includes('natural')) s += 100;
    if (n.includes('online')) s += 30;
    // Apple high-quality / premium voices
    if (n.includes('(premium)') || n.includes('premium')) s += 90;
    if (n.includes('(enhanced)') || n.includes('enhanced')) s += 60;
    // Known good macOS / iOS voices
    const goodApple = ['samantha', 'ava', 'evan', 'allison', 'tom', 'daniel', 'karen', 'moira', 'serena'];
    if (goodApple.some(name => n.includes(name))) s += 40;
    // Google's Chrome built-in (usually decent)
    if (n.includes('google')) s += 25;
    if (n.includes('google us english')) s += 5;
    // Avoid Android / poorer compact voices
    if (n.includes('compact')) s -= 20;
    if (n.includes('novelty')) s -= 30;
    // Mild preference for en-US / en-GB
    if (v.lang.toLowerCase() === 'en-us') s += 8;
    if (v.lang.toLowerCase() === 'en-gb') s += 6;
    if (v.localService) s += 2;
    return s;
  }

  function populateVoiceSelect() {
    const select = document.getElementById('tts-voice') as HTMLSelectElement | null;
    if (!select) return;
    const voices = synth.getVoices();
    const enVoices = voices.filter((v) => v.lang.toLowerCase().startsWith('en'));
    if (enVoices.length === 0) {
      select.innerHTML = '<option value="">No English voice</option>';
      return;
    }
    enVoices.sort((a, b) => scoreVoice(b) - scoreVoice(a));
    const top = enVoices[0];
    selectedVoice = top;
    select.innerHTML = enVoices.map((v) => {
      const lang = v.lang.toUpperCase();
      const tag = scoreVoice(v) >= 60 ? ' ★' : '';
      return `<option value="${v.name}" ${v === top ? 'selected' : ''}>${v.name} · ${lang}${tag}</option>`;
    }).join('');
    select.addEventListener('change', () => {
      const v = enVoices.find((x) => x.name === select.value);
      if (v) selectedVoice = v;
    });
  }

  if (synth) {
    populateVoiceSelect();
    if (typeof synth.onvoiceschanged !== 'undefined') {
      synth.onvoiceschanged = populateVoiceSelect;
    }
  }

  function applyVoice(u: SpeechSynthesisUtterance) {
    if (selectedVoice) {
      u.voice = selectedVoice;
      u.lang = selectedVoice.lang;
    } else {
      u.lang = 'en-US';
    }
    u.rate = Number((document.getElementById('tts-rate') as HTMLSelectElement)?.value || 1);
    u.pitch = 1;
  }

  function speakOne(text: string) {
    if (!synth) return;
    synth.cancel();
    const u = new SpeechSynthesisUtterance(text);
    applyVoice(u);
    synth.speak(u);
  }
  function buildTtsQueue() {
    ttsQueue = FLAT_SENTENCES.map((s) => ({ text: s.en, sid: s.id }));
    ttsIdx = 0;
  }
  function startTtsFromIdx(i: number) {
    if (!synth) return;
    if (i >= ttsQueue.length) { stopTts(); return; }
    ttsIdx = i;
    ttsPlaying = true;
    setPlayIcon('pause');
    speakNext();
  }
  function speakNext() {
    if (!ttsPlaying) return;
    if (ttsIdx >= ttsQueue.length) { stopTts(); return; }
    const item = ttsQueue[ttsIdx];
    const u = new SpeechSynthesisUtterance(item.text);
    applyVoice(u);
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
    if (item.sid) {
      const sentEl = document.querySelector(`.sent[data-sid="${item.sid}"]`);
      sentEl?.classList.add('is-tts');
      const rect = (sentEl as HTMLElement | null)?.getBoundingClientRect();
      if (rect && (rect.top < 120 || rect.bottom > window.innerHeight - 60)) {
        const targetY = window.scrollY + rect.top - 200;
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    }
    u.onend = () => {
      if (!ttsPlaying) return;
      ttsIdx++;
      speakNext();
    };
    synth.speak(u);
  }
  function pauseTts() {
    ttsPlaying = false;
    synth.cancel();
    setPlayIcon('play');
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
  }
  function stopTts() {
    ttsPlaying = false;
    ttsIdx = 0;
    synth.cancel();
    setPlayIcon('play');
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
  }
  function setPlayIcon(name: 'play' | 'pause') {
    const el = document.getElementById('tts-play-icon');
    if (el) el.textContent = name === 'play' ? 'play_arrow' : 'pause';
  }

  document.getElementById('tts-play')?.addEventListener('click', () => {
    if (ttsPlaying) { pauseTts(); return; }
    if (ttsQueue.length === 0) buildTtsQueue();
    startTtsFromIdx(ttsIdx);
  });
  document.getElementById('tts-stop')?.addEventListener('click', stopTts);

  // ============== Keyboard ==============
  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.tagName === 'SELECT')) return;

    const numMap: Record<string, Mode> = { '1':'vocab','2':'translate','3':'grammar','4':'patterns','5':'quiz','6':'review','7':'about' };
    if (numMap[e.key]) { e.preventDefault(); setMode(numMap[e.key]); return; }

    if (e.code === 'Space') {
      e.preventDefault();
      if (ttsPlaying) { pauseTts(); }
      else { if (ttsQueue.length === 0) buildTtsQueue(); startTtsFromIdx(ttsIdx); }
      return;
    }

    if (e.key === 'Escape') {
      pinVocab(null);
      setActiveSentence(null);
      return;
    }

    if (currentMode === 'translate' && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
      e.preventDefault();
      const idx = activeSentId ? FLAT_SENTENCES.findIndex((s) => s.id === activeSentId) : -1;
      const newIdx = e.key === 'ArrowDown'
        ? Math.min(FLAT_SENTENCES.length - 1, idx + 1)
        : Math.max(0, idx - 1);
      const sid = FLAT_SENTENCES[newIdx].id;
      setActiveSentence(sid);
      jumpToSentence(sid);
      return;
    }

    if (currentMode === 'review' && reviewFlipped) {
      const rateMap: Record<string, number> = { 'q':0, 'w':1, 'e':2, 'r':3 };
      if (rateMap[e.key.toLowerCase()] !== undefined) {
        e.preventDefault();
        rateReview(rateMap[e.key.toLowerCase()]);
      }
    }
  });

  setMode('vocab');
</script>
