---
// Flat daily-library reader: thin wrapper around the shared ArticleReader engine.
import MainLayout from '../../../layouts/MainLayout.astro';
import ArticleReader from '../../../components/english/ArticleReader.astro';
import { articlesBySlug, articleEntries } from '../../../data/english';

export const prerender = true;
export function getStaticPaths() {
  return articleEntries.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const article = slug ? articlesBySlug[slug] : undefined;

if (!article) {
  return Astro.redirect('/tools/english/');
}

// Prev = older article (higher index), Next = newer (lower index).
const idx = articleEntries.findIndex((e) => e.slug === slug);
const prevEntry = idx >= 0 && idx + 1 < articleEntries.length ? articleEntries[idx + 1] : null;
const nextEntry = idx > 0 ? articleEntries[idx - 1] : null;
---

<MainLayout
  title={`${article.meta.title} | English`}
  description="An English article with hover-to-define vocabulary, sentence translations, grammar notes, and review."
  lang="en"
>
  <ArticleReader
    article={article}
    backHref="/tools/english/"
    backLabel="Library"
    prevHref={prevEntry ? `/tools/english/${prevEntry.slug}` : null}
    prevTitle={prevEntry?.article.meta.title ?? null}
    nextHref={nextEntry ? `/tools/english/${nextEntry.slug}` : null}
    nextTitle={nextEntry?.article.meta.title ?? null}
    printHref={`/tools/english/print/${slug}`}
  />
</MainLayout>
