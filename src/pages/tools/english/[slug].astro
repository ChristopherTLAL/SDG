---
// Daily English — split-view reader. One article per slug (= date).
import MainLayout from '../../../layouts/MainLayout.astro';
import { articlesBySlug, articles, CEFR_LABELS } from '../../../data/english';

const { slug } = Astro.params;
const article = slug ? articlesBySlug[slug] : undefined;

if (!article) {
  return Astro.redirect('/tools/english/');
}

const { meta, paragraphs, vocab, collocations, grammar, patterns, quiz } = article;

// Adjacent articles (for footer next/prev).
const idx = articles.findIndex((a) => a.meta.date === meta.date);
const prevArticle = idx >= 0 && idx + 1 < articles.length ? articles[idx + 1] : null;
const nextArticle = idx > 0 ? articles[idx - 1] : null;

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function escapeRegex(s: string): string {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function renderSentence(sentEn: string, sentId: string): string {
  let html = escapeHtml(sentEn);
  const inThisSent = vocab.filter((v) => v.sentenceId === sentId);
  const sorted = [...inThisSent].sort((a, b) => b.word.length - a.word.length);
  for (const v of sorted) {
    const re = new RegExp(`\\b(${escapeRegex(v.word)})\\b`);
    html = html.replace(
      re,
      `<span class="vocab" data-vid="${v.id}" data-level="${v.level}" tabindex="0">$1</span>`,
    );
  }
  return `<span class="sent" data-sid="${sentId}" tabindex="0">${html}</span>`;
}

const levels = ['CET4', 'CET6', 'IELTS', 'GRE'] as const;
const levelCounts = Object.fromEntries(
  levels.map((l) => [l, vocab.filter((v) => v.level === l).length]),
) as Record<string, number>;

const modes = [
  { id: 'vocab',     icon: 'abc',         label: 'Vocabulary',    desc: 'Hover any underlined word for its meaning. Click to pin.' },
  { id: 'translate', icon: 'translate',   label: 'Translation',   desc: 'Click a sentence — its Chinese translation appears here.' },
  { id: 'grammar',   icon: 'function',    label: 'Grammar',       desc: 'Grammar points used in this article. Hover a card to highlight in the text.' },
  { id: 'patterns',  icon: 'edit_note',   label: 'Patterns',      desc: 'Reusable sentence skeletons you can borrow for your own writing.' },
  { id: 'quiz',      icon: 'quiz',        label: 'Comprehension', desc: '5 quick questions to check that you actually read it.' },
  { id: 'review',    icon: 'replay',      label: 'Word review',   desc: 'A flashcard pass over the article\'s vocabulary — current session only.' },
  { id: 'about',     icon: 'info',        label: 'About',         desc: 'Source, length, level, and the editor\'s note.' },
];

const articleJson = JSON.stringify({ meta, paragraphs, vocab, collocations, grammar, patterns, quiz });
const cefrLabel = CEFR_LABELS[meta.cefr];
---

<MainLayout title={`${meta.title} | Daily English`} description="A daily 5-minute English news read with interactive vocabulary, sentence translations, grammar notes, and review." lang="en">
  <main class="english-tool">

    <div class="el-toolbar">
      <div class="el-toolbar-inner">
        <a href="/tools/english/" class="el-back" aria-label="Back to all reads">
          <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="el-toolbar-meta">
          <div class="el-toolbar-eyebrow">
            <span>Daily English</span>
            <span class="el-toolbar-dot"></span>
            <span>{meta.date}</span>
            <span class="el-toolbar-dot"></span>
            <span class="el-cefr-pill el-cefr-pill--inline">{meta.cefr} · {cefrLabel?.tier}</span>
          </div>
          <div class="el-toolbar-title">{meta.title}</div>
        </div>
        <div class="el-toolbar-stats">
          <span class="el-stat"><strong>{meta.wordCount}</strong><span>words</span></span>
          <span class="el-stat-sep"></span>
          <span class="el-stat"><strong>{meta.readingMinutes}</strong><span>min</span></span>
        </div>
        <div class="el-tts">
          <button id="tts-play" class="el-tts-btn" aria-label="Play / pause">
            <span class="material-symbols-outlined" id="tts-play-icon">play_arrow</span>
          </button>
          <button id="tts-stop" class="el-tts-btn el-tts-btn-ghost" aria-label="Stop" title="Stop">
            <span class="material-symbols-outlined">stop</span>
          </button>
          <select id="tts-voice" class="el-tts-select" aria-label="Voice"></select>
          <select id="tts-rate" class="el-tts-select" aria-label="Speech rate">
            <option value="0.75">0.75×</option>
            <option value="0.9">0.9×</option>
            <option value="1" selected>1×</option>
            <option value="1.15">1.15×</option>
            <option value="1.3">1.3×</option>
          </select>
        </div>
      </div>
    </div>

    <div class="el-shell">

      <article class="el-article" id="el-article">
        <header class="el-article-head">
          <h1>{meta.title}</h1>
          <p class="el-article-source">
            From {meta.source.name} · A {meta.readingMinutes}-minute read
          </p>
        </header>

        <div class="el-article-body">
          {paragraphs.map((p) => (
            <p data-pid={p.id}>
              {p.sentences.map((s, i) => (
                <Fragment>
                  <Fragment set:html={renderSentence(s.en, s.id)} />
                  {i < p.sentences.length - 1 ? ' ' : ''}
                </Fragment>
              ))}
            </p>
          ))}
        </div>

        <footer class="el-article-foot">
          <div class="el-article-foot-row">
            <span class="material-symbols-outlined">link</span>
            <a href={meta.source.url} target="_blank" rel="noopener noreferrer">{meta.source.name}</a>
          </div>
          {meta.editorsNote && (
            <p class="el-article-note">
              <span class="el-article-note-label">Editor's note</span>
              {meta.editorsNote}
            </p>
          )}
          {(prevArticle || nextArticle) && (
            <div class="el-article-nav">
              {prevArticle ? (
                <a href={`/tools/english/${prevArticle.meta.date}`} class="el-article-nav-link">
                  <span class="material-symbols-outlined">arrow_back</span>
                  <span>
                    <span class="el-article-nav-label">Previous</span>
                    <span class="el-article-nav-title">{prevArticle.meta.cefr} · {prevArticle.meta.title}</span>
                  </span>
                </a>
              ) : <span></span>}
              {nextArticle ? (
                <a href={`/tools/english/${nextArticle.meta.date}`} class="el-article-nav-link el-article-nav-link--right">
                  <span>
                    <span class="el-article-nav-label">Next</span>
                    <span class="el-article-nav-title">{nextArticle.meta.cefr} · {nextArticle.meta.title}</span>
                  </span>
                  <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              ) : <span></span>}
            </div>
          )}
        </footer>
      </article>

      <aside class="el-panel" id="el-panel" aria-label="Interactive panel">

        <nav class="el-tabs" role="tablist" aria-label="Modes">
          {modes.map((m, i) => (
            <button
              class="el-tab"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-mode={m.id}
              title={`${m.label}  (${i + 1})`}
            >
              <span class="material-symbols-outlined">{m.icon}</span>
              <span class="el-tab-num">{i + 1}</span>
            </button>
          ))}
        </nav>

        <div class="el-mode-head">
          <h2 id="el-mode-title">{modes[0].label}</h2>
          <p id="el-mode-desc">{modes[0].desc}</p>
        </div>

        <div class="el-mode-body" id="el-mode-body">

          <section class="el-mode" data-mode="vocab">
            <div class="el-chips" id="el-level-chips">
              {levels.map((l) => (
                <button class="el-chip is-on" data-level={l}>
                  <span class={`el-chip-dot el-chip-dot--${l.toLowerCase()}`}></span>
                  {l}
                  <span class="el-chip-num">{levelCounts[l] || 0}</span>
                </button>
              ))}
            </div>

            <div class="el-vocab-detail" id="el-vocab-detail">
              <div class="el-empty">
                <span class="material-symbols-outlined">touch_app</span>
                <p>Hover any underlined word in the article. Click to pin.</p>
              </div>
            </div>

            <div class="el-vocab-list" id="el-vocab-list">
              <div class="el-section-title">All words ({vocab.length})</div>
              <ul>
                {vocab.map((v) => (
                  <li class="el-vocab-row" data-vid={v.id} data-level={v.level}>
                    <button class="el-vocab-row-btn" data-vid={v.id}>
                      <span class={`el-level-tag el-level-tag--${v.level.toLowerCase()}`}>{v.level}</span>
                      <span class="el-vocab-word">{v.word}</span>
                      <span class="el-vocab-pos">{v.pos}</span>
                      <span class="el-vocab-def">{v.defZh}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <section class="el-mode" data-mode="translate" hidden>
            <label class="el-toggle">
              <input type="checkbox" id="el-show-all-zh" />
              <span class="el-toggle-track"><span class="el-toggle-knob"></span></span>
              <span class="el-toggle-label">Show all Chinese inline</span>
            </label>

            <div class="el-trans-detail" id="el-trans-detail">
              <div class="el-empty">
                <span class="material-symbols-outlined">ads_click</span>
                <p>Click any sentence in the article to see its Chinese translation here.</p>
                <p class="el-empty-sub">Use ↑ / ↓ to walk sentence by sentence.</p>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="grammar" hidden>
            <ul class="el-card-list">
              {grammar.map((g) => (
                <li class="el-card el-card--grammar" data-gid={g.id} data-sids={g.sentenceIds.join(',')}>
                  <div class="el-card-head">
                    <h3>{g.title}</h3>
                    <code class="el-card-pattern">{g.pattern}</code>
                  </div>
                  <p class="el-card-explain">{g.explanationZh}</p>
                  <div class="el-card-examples">
                    {g.examples.map((ex) => <p>· {ex}</p>)}
                  </div>
                  <button class="el-card-action" data-action="highlight" data-sids={g.sentenceIds.join(',')}>
                    <span class="material-symbols-outlined">north_east</span>
                    See it in the article
                  </button>
                </li>
              ))}
            </ul>
          </section>

          <section class="el-mode" data-mode="patterns" hidden>
            <ul class="el-card-list">
              {patterns.map((p) => (
                <li class="el-card el-card--pattern" data-pid={p.id} data-sids={p.sentenceId}>
                  <div class="el-card-head">
                    <h3 class="el-card-skeleton">{p.skeleton}</h3>
                  </div>
                  <p class="el-card-original">「{p.original}」</p>
                  <p class="el-card-hint">{p.hint}</p>
                  <button class="el-card-action" data-action="highlight" data-sids={p.sentenceId}>
                    <span class="material-symbols-outlined">north_east</span>
                    See it in the article
                  </button>
                </li>
              ))}
            </ul>
          </section>

          <section class="el-mode" data-mode="quiz" hidden>
            <div id="el-quiz-root" class="el-quiz">
              <div class="el-quiz-start">
                <span class="material-symbols-outlined el-quiz-icon">quiz</span>
                <h3>Comprehension check</h3>
                <p>{quiz.length} multiple-choice questions. Answers are in the article.</p>
                <button class="el-btn el-btn-primary" id="el-quiz-begin">Start</button>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="review" hidden>
            <div id="el-review-root" class="el-review">
              <div class="el-review-start">
                <span class="material-symbols-outlined el-quiz-icon">replay</span>
                <h3>Word review</h3>
                <p>Flip through the article's {vocab.length} vocabulary words. Rate yourself; the deck reorders accordingly.</p>
                <p class="el-empty-sub">Session-only — no account, no sync. Refresh resets the deck.</p>
                <button class="el-btn el-btn-primary" id="el-review-begin">Start review</button>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="about" hidden>
            <dl class="el-meta">
              <div><dt>Date</dt><dd>{meta.date}</dd></div>
              <div><dt>Source</dt><dd><a href={meta.source.url} target="_blank" rel="noopener noreferrer">{meta.source.name}</a></dd></div>
              <div><dt>Length</dt><dd>{meta.wordCount} words · {meta.readingMinutes} min</dd></div>
              <div><dt>Level</dt><dd>{meta.cefr} · {cefrLabel?.tier} ({cefrLabel?.bridge})</dd></div>
              <div><dt>Tagged</dt><dd>{vocab.length} words · {grammar.length} grammar points · {patterns.length} patterns</dd></div>
            </dl>
            {meta.editorsNote && (
              <div class="el-meta-note">
                <div class="el-section-title">Editor's note</div>
                <p>{meta.editorsNote}</p>
              </div>
            )}
            <div class="el-shortcuts">
              <div class="el-section-title">Keyboard shortcuts</div>
              <ul>
                <li><kbd>1</kbd>–<kbd>7</kbd>  Switch mode</li>
                <li><kbd>Space</kbd>  Play / pause TTS</li>
                <li><kbd>↑</kbd> <kbd>↓</kbd>  Previous / next sentence (in Translation mode)</li>
                <li><kbd>Esc</kbd>  Clear pinned card / close overlay</li>
              </ul>
            </div>
          </section>

        </div>
      </aside>

    </div>
  </main>

  <script type="application/json" id="el-data" set:html={articleJson}></script>
</MainLayout>

<style is:global>
  :root {
    --el-pin: #042f24;
    --el-soft: rgba(4, 47, 36, 0.04);
    --el-soft-2: rgba(4, 47, 36, 0.08);
    --el-soft-3: rgba(4, 47, 36, 0.12);
    --el-border: rgba(4, 47, 36, 0.10);
    --el-border-2: rgba(4, 47, 36, 0.20);
    /* opacity ladder for level encoding — same primary, varying intensity */
    --el-lvl-cet4: rgba(4, 47, 36, 0.30);
    --el-lvl-cet6: rgba(4, 47, 36, 0.55);
    --el-lvl-ielts: rgba(4, 47, 36, 0.78);
    --el-lvl-gre:  rgba(4, 47, 36, 1);
  }

  .english-tool {
    padding-top: 5rem;
    background: white;
    min-height: 100vh;
  }

  /* Critical: the [hidden] attribute must beat the .el-mode display rule below. */
  .el-mode[hidden] { display: none !important; }

  /* ===== Toolbar ===== */
  .el-toolbar {
    position: sticky;
    top: 5rem;
    z-index: 30;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--el-border);
  }
  .el-toolbar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .el-back {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border-radius: 999px;
    color: var(--el-pin);
    background: white;
    border: 1px solid var(--el-border);
    transition: all 150ms ease;
    flex-shrink: 0;
  }
  .el-back:hover { background: var(--el-pin); color: white; border-color: var(--el-pin); }
  .el-toolbar-meta { flex: 1; min-width: 0; }
  .el-toolbar-eyebrow {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--el-pin); opacity: 0.65;
    margin-bottom: 3px;
  }
  .el-toolbar-dot {
    display: inline-block; width: 3px; height: 3px;
    border-radius: 999px; background: currentColor; opacity: 0.5;
  }
  .el-toolbar-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.0625rem;
    line-height: 1.1;
    color: var(--el-pin);
    letter-spacing: -0.01em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .el-toolbar-stats {
    display: flex; align-items: center; gap: 0.85rem;
    color: rgba(4, 47, 36, 0.62);
    font-size: 12px;
    flex-shrink: 0;
  }
  .el-stat { display: inline-flex; align-items: baseline; gap: 4px; }
  .el-stat strong { font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 14px; color: var(--el-pin); }
  .el-stat-sep { width: 1px; height: 14px; background: var(--el-border-2); }
  .el-tts { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .el-tts-btn {
    width: 36px; height: 36px;
    border-radius: 999px;
    background: var(--el-pin);
    color: white;
    display: inline-flex; align-items: center; justify-content: center;
    border: none;
    transition: transform 120ms ease, background 120ms ease;
    cursor: pointer;
  }
  .el-tts-btn:hover { transform: scale(1.05); }
  .el-tts-btn-ghost {
    background: white;
    color: var(--el-pin);
    border: 1px solid var(--el-border);
  }
  .el-tts-select {
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 8px;
    padding: 4px 8px;
    font-size: 11.5px;
    color: var(--el-pin);
    cursor: pointer;
    max-width: 130px;
    text-overflow: ellipsis;
  }
  .el-tts-select:focus { outline: 2px solid var(--el-soft-3); outline-offset: 1px; }

  /* ===== CEFR pill ===== */
  .el-cefr-pill {
    display: inline-flex; align-items: center;
    padding: 1px 7px;
    border-radius: 4px;
    background: var(--el-soft-2);
    color: var(--el-pin);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: 9.5px;
  }

  /* ===== Shell ===== */
  .el-shell {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 1023px) {
    .el-shell { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* ===== Article ===== */
  .el-article {
    max-width: 720px;
    justify-self: center;
    width: 100%;
  }
  .el-article-head h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--el-pin);
    margin-bottom: 0.6rem;
  }
  .el-article-source {
    font-size: 13px;
    color: rgba(4, 47, 36, 0.55);
    margin-bottom: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--el-border);
  }
  .el-article-body p {
    font-family: 'Inter', sans-serif;
    font-size: 1.0625rem;
    line-height: 1.85;
    color: rgba(4, 47, 36, 0.92);
    margin-bottom: 1.5rem;
  }

  .sent {
    transition: background-color 150ms ease, box-shadow 150ms ease;
    border-radius: 3px;
    padding: 0 1px;
    cursor: text;
  }
  .sent.is-clickable { cursor: pointer; }
  .sent.is-clickable:hover { background: var(--el-soft); }
  .sent.is-active { background: var(--el-soft-3); box-shadow: inset 2px 0 0 var(--el-pin); padding-left: 6px; }
  .sent.is-tts { background: var(--el-soft-2); box-shadow: inset 2px 0 0 var(--el-lvl-ielts); padding-left: 6px; }
  .sent.is-grammar { background: var(--el-soft-2); }

  .sent-zh-inline {
    display: block;
    margin-top: 4px;
    padding-left: 12px;
    border-left: 2px solid var(--el-border-2);
    color: rgba(4, 47, 36, 0.55);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Vocab inline — single emerald hue, intensity encodes level */
  .vocab {
    cursor: pointer;
    border-bottom: 1.5px dotted transparent;
    transition: all 120ms ease;
    border-radius: 2px;
    padding: 0 1px;
  }
  .vocab[data-level="CET4"]  { border-bottom-color: var(--el-lvl-cet4); }
  .vocab[data-level="CET6"]  { border-bottom-color: var(--el-lvl-cet6); }
  .vocab[data-level="IELTS"] { border-bottom-color: var(--el-lvl-ielts); }
  .vocab[data-level="GRE"]   { border-bottom-color: var(--el-lvl-gre); border-bottom-style: dashed; border-bottom-width: 2px; }
  .vocab.is-hidden { border-bottom-color: transparent; cursor: text; }
  .vocab:hover, .vocab:focus-visible {
    background: var(--el-soft-2);
    border-bottom-style: solid;
    outline: none;
  }
  .vocab.is-pinned {
    background: var(--el-soft-3);
    border-bottom-style: solid;
    border-bottom-width: 2px;
    border-bottom-color: var(--el-pin);
  }

  .el-article-foot {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--el-border);
    font-size: 13px;
  }
  .el-article-foot-row {
    display: inline-flex; align-items: center; gap: 8px;
    color: rgba(4, 47, 36, 0.62);
  }
  .el-article-foot-row a { color: var(--el-pin); text-decoration: underline; text-underline-offset: 3px; }
  .el-article-foot-row .material-symbols-outlined { font-size: 16px; }
  .el-article-note {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    color: rgba(4, 47, 36, 0.78);
    line-height: 1.7;
  }
  .el-article-note-label {
    display: block;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--el-pin); opacity: 0.65;
    margin-bottom: 0.4rem;
  }
  .el-article-nav {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .el-article-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 1rem 1.25rem;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    color: var(--el-pin);
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease;
  }
