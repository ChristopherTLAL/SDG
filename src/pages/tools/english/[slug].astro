---
// Article reader, fixed-height two-pane learning interface.
import MainLayout from '../../../layouts/MainLayout.astro';
import { articlesBySlug, articles, CEFR_LABELS } from '../../../data/english';

const { slug } = Astro.params;
const article = slug ? articlesBySlug[slug] : undefined;

if (!article) {
  return Astro.redirect('/tools/english/');
}

const { meta, paragraphs, vocab, collocations, grammar, patterns, quiz } = article;

const idx = articles.findIndex((a) => a.meta.date === meta.date);
const prevArticle = idx >= 0 && idx + 1 < articles.length ? articles[idx + 1] : null;
const nextArticle = idx > 0 ? articles[idx - 1] : null;

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function escapeRegex(s: string): string {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function renderSentence(sentEn: string, sentId: string): string {
  let html = escapeHtml(sentEn);
  const inThisSent = vocab.filter((v) => v.sentenceId === sentId);
  const sorted = [...inThisSent].sort((a, b) => b.word.length - a.word.length);
  for (const v of sorted) {
    const re = new RegExp(`\\b(${escapeRegex(v.word)})\\b`);
    html = html.replace(
      re,
      `<span class="vocab" data-vid="${v.id}" data-level="${v.level}" tabindex="0">$1</span>`,
    );
  }
  return `<span class="sent" data-sid="${sentId}" tabindex="0">${html}</span>`;
}

const levels = [1, 2, 3, 4] as const;
const levelCounts = Object.fromEntries(
  levels.map((l) => [l, vocab.filter((v) => v.level === l).length]),
) as Record<number, number>;

const modes = [
  { id: 'vocab',     icon: 'abc',         label: 'Vocabulary',    desc: 'Hover any shaded word for its meaning. Click to pin.' },
  { id: 'translate', icon: 'translate',   label: 'Translation',   desc: 'Click a sentence, its Chinese translation appears here.' },
  { id: 'grammar',   icon: 'function',    label: 'Grammar',       desc: 'Hover a card to see the construction in the article.' },
  { id: 'patterns',  icon: 'edit_note',   label: 'Patterns',      desc: 'Reusable sentence skeletons you can borrow for your own writing.' },
  { id: 'quiz',      icon: 'quiz',        label: 'Comprehension', desc: 'A short multiple-choice check after the read.' },
  { id: 'review',    icon: 'replay',      label: 'Word review',   desc: 'A flashcard pass over the article\'s vocabulary, current session only.' },
  { id: 'about',     icon: 'info',        label: 'About',         desc: 'Source, length, level, editor\'s note.' },
];

const articleJson = JSON.stringify({ meta, paragraphs, vocab, collocations, grammar, patterns, quiz });
const cefrLabel = CEFR_LABELS[meta.cefr];
---

<MainLayout title={`${meta.title} | English`} description="An English article with hover-to-define vocabulary, sentence translations, grammar notes, and review." lang="en">
  <main class="english-tool">

    <div class="el-toolbar">
      <div class="el-toolbar-inner">
        <a href="/tools/english/" class="el-back" aria-label="Back to library">
          <span class="material-symbols-outlined">arrow_back</span>
          <span class="el-back-label">Library</span>
        </a>
        <div class="el-toolbar-meta">
          <div class="el-toolbar-eyebrow">
            <span class="el-cefr-pill">{meta.cefr}</span>
            <span>{cefrLabel?.tier}</span>
            <span class="el-toolbar-dot"></span>
            <span>{meta.wordCount} words · {meta.readingMinutes} min</span>
          </div>
          <div class="el-toolbar-title">{meta.title}</div>
        </div>
        <div class="el-toolbar-nav">
          {prevArticle ? (
            <a href={`/tools/english/${prevArticle.meta.date}`} class="el-toolbar-nav-link" title={prevArticle.meta.title}>
              <span class="material-symbols-outlined">arrow_back_ios</span>
            </a>
          ) : <span class="el-toolbar-nav-link is-disabled"><span class="material-symbols-outlined">arrow_back_ios</span></span>}
          {nextArticle ? (
            <a href={`/tools/english/${nextArticle.meta.date}`} class="el-toolbar-nav-link" title={nextArticle.meta.title}>
              <span class="material-symbols-outlined">arrow_forward_ios</span>
            </a>
          ) : <span class="el-toolbar-nav-link is-disabled"><span class="material-symbols-outlined">arrow_forward_ios</span></span>}
        </div>
        <div class="el-tts">
          <button id="tts-play" class="el-tts-btn" aria-label="Play / pause">
            <span class="material-symbols-outlined" id="tts-play-icon">play_arrow</span>
          </button>
          <button id="tts-stop" class="el-tts-btn el-tts-btn-ghost" aria-label="Stop" title="Stop">
            <span class="material-symbols-outlined">stop</span>
          </button>
          <select id="tts-voice" class="el-tts-select" aria-label="Voice"></select>
          <select id="tts-rate" class="el-tts-select" aria-label="Speech rate">
            <option value="0.75">0.75×</option>
            <option value="0.9">0.9×</option>
            <option value="1" selected>1×</option>
            <option value="1.15">1.15×</option>
            <option value="1.3">1.3×</option>
          </select>
        </div>
      </div>
    </div>

    <div class="el-shell">

      <div class="el-article-col" id="el-article-col">
        <article class="el-article">
          <header class="el-article-head">
            <h1>{meta.title}</h1>
          </header>

          <div class="el-article-body">
            {paragraphs.map((p) => (
              <p data-pid={p.id}>
                {p.sentences.map((s, i) => (
                  <Fragment>
                    <Fragment set:html={renderSentence(s.en, s.id)} />
                    {i < p.sentences.length - 1 ? ' ' : ''}
                  </Fragment>
                ))}
              </p>
            ))}
          </div>

          {meta.editorsNote && (
            <footer class="el-article-foot">
              <p class="el-article-note">
                <span class="el-article-note-label">Editor's note</span>
                {meta.editorsNote}
              </p>
            </footer>
          )}
        </article>
      </div>

      <aside class="el-panel" aria-label="Interactive panel">

        <nav class="el-tabs" role="tablist" aria-label="Modes">
          {modes.map((m, i) => (
            <button
              class="el-tab"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-mode={m.id}
              title={`${m.label}  (${i + 1})`}
            >
              <span class="material-symbols-outlined">{m.icon}</span>
              <span class="el-tab-num">{i + 1}</span>
            </button>
          ))}
        </nav>

        <div class="el-mode-head">
          <h2 id="el-mode-title">{modes[0].label}</h2>
          <p id="el-mode-desc">{modes[0].desc}</p>
        </div>

        <div class="el-mode-body" id="el-mode-body">

          <section class="el-mode" data-mode="vocab">
            <div class="el-levels">
              <div class="el-levels-row">
                {levels.map((l) => (
                  <button
                    class={`el-level-chip${l === 1 ? ' is-on' : ''}`}
                    data-level={l}
                    aria-pressed={l === 1 ? 'true' : 'false'}
                  >
                    <span class="el-level-chip-swatch" data-level={l}></span>
                    <span class="el-level-chip-label">L{l}</span>
                    <span class="el-level-chip-num">{levelCounts[l] || 0}</span>
                  </button>
                ))}
              </div>
              <p class="el-levels-hint">Pick the easiest level you want to see. Words at that level <em>and harder</em> stay shaded.</p>
            </div>

            <div class="el-vocab-detail" id="el-vocab-detail">
              <div class="el-empty">
                <span class="material-symbols-outlined">touch_app</span>
                <p>Hover any shaded word in the article. Click to pin.</p>
                <p class="el-empty-sub">Looking for the full word list? Open <strong>Word review → List</strong>.</p>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="translate" hidden>
            <label class="el-toggle">
              <input type="checkbox" id="el-show-all-zh" />
              <span class="el-toggle-track"><span class="el-toggle-knob"></span></span>
              <span class="el-toggle-label">Show all Chinese inline</span>
            </label>

            <div class="el-trans-detail" id="el-trans-detail">
              <div class="el-empty">
                <span class="material-symbols-outlined">ads_click</span>
                <p>Click any sentence in the article to see its Chinese translation here.</p>
                <p class="el-empty-sub">Use ↑ / ↓ to walk sentence by sentence.</p>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="grammar" hidden>
            <ul class="el-accordion" data-accordion="grammar">
              {grammar.map((g) => (
                <li class="el-acc-item" data-sids={g.sentenceIds.join(',')}>
                  <button class="el-acc-trigger" type="button" aria-expanded="false">
                    <span class="el-acc-title">
                      <span class="el-acc-name">{g.title}</span>
                      <code class="el-acc-pattern">{g.pattern}</code>
                    </span>
                    <span class="el-acc-chev material-symbols-outlined">expand_more</span>
                  </button>
                  <div class="el-acc-body" hidden>
                    <div class="el-acc-eyebrow">详解</div>
                    <div class="el-acc-paragraphs">
                      {g.explanationZh.map((p) => <p>{p}</p>)}
                    </div>

                    {g.examples.length > 0 && (
                      <Fragment>
                        <div class="el-acc-eyebrow">Examples ({g.examples.length})</div>
                        <ul class="el-acc-examples">
                          {g.examples.map((ex) => (
                            <li>
                              <p class="el-eg-en">{ex.en}</p>
                              {ex.zh && <p class="el-eg-zh">{ex.zh}</p>}
                              {ex.note && <p class="el-eg-note">{ex.note}</p>}
                            </li>
                          ))}
                        </ul>
                      </Fragment>
                    )}

                    {g.commonMistake && (
                      <div class="el-acc-callout el-acc-callout--warn">
                        <div class="el-acc-callout-label">易错点</div>
                        <p>{g.commonMistake}</p>
                      </div>
                    )}

                    {g.vsSimilar && (
                      <div class="el-acc-callout">
                        <div class="el-acc-callout-label">与相近结构对比</div>
                        <p>{g.vsSimilar}</p>
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <section class="el-mode" data-mode="patterns" hidden>
            <ul class="el-accordion" data-accordion="patterns">
              {patterns.map((p) => (
                <li class="el-acc-item" data-sids={p.sentenceId}>
                  <button class="el-acc-trigger" type="button" aria-expanded="false">
                    <span class="el-acc-title">
                      <span class="el-acc-name">{p.useCase}</span>
                    </span>
                    <span class="el-acc-chev material-symbols-outlined">expand_more</span>
                  </button>
                  <div class="el-acc-body" hidden>
                    <div class="el-acc-eyebrow">Skeleton</div>
                    <code class="el-acc-skeleton">{p.skeleton}</code>

                    <div class="el-acc-eyebrow">From the article</div>
                    <p class="el-acc-original">「{p.original}」</p>

                    <div class="el-acc-eyebrow">为什么这样写有效</div>
                    <div class="el-acc-paragraphs">
                      {p.whyItWorks.map((para) => <p>{para}</p>)}
                    </div>

                    {p.examples.length > 0 && (
                      <Fragment>
                        <div class="el-acc-eyebrow">实战例子 ({p.examples.length})</div>
                        <ul class="el-acc-examples">
                          {p.examples.map((ex) => (
                            <li>
                              <p class="el-eg-context">{ex.context}</p>
                              <p class="el-eg-en">{ex.text}</p>
                              {ex.zh && <p class="el-eg-zh">{ex.zh}</p>}
                              {ex.note && <p class="el-eg-note">{ex.note}</p>}
                            </li>
                          ))}
                        </ul>
                      </Fragment>
                    )}

                    <div class="el-acc-eyebrow">怎么搬到自己的写作里</div>
                    <p class="el-acc-hint">{p.adaptingTip}</p>

                    {p.commonMistake && (
                      <div class="el-acc-callout el-acc-callout--warn">
                        <div class="el-acc-callout-label">易错点</div>
                        <p>{p.commonMistake}</p>
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <section class="el-mode" data-mode="quiz" hidden>
            <div id="el-quiz-root" class="el-quiz">
              <div class="el-quiz-start">
                <span class="material-symbols-outlined el-quiz-icon">quiz</span>
                <h3>Comprehension check</h3>
                <p>{quiz.length} multiple-choice questions. Answers are in the article.</p>
                <button class="el-btn el-btn-primary" id="el-quiz-begin">Start</button>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="review" hidden>
            <div class="el-review-toggle" role="tablist" aria-label="Review view">
              <button class="el-review-toggle-btn is-on" data-view="cards" aria-pressed="true">
                <span class="material-symbols-outlined">style</span>
                Flashcards
              </button>
              <button class="el-review-toggle-btn" data-view="list" aria-pressed="false">
                <span class="material-symbols-outlined">list</span>
                Word list
              </button>
            </div>

            <div class="el-review-cards" data-view-pane="cards">
              <div id="el-review-root" class="el-review">
                <div class="el-review-start">
                  <span class="material-symbols-outlined el-quiz-icon">replay</span>
                  <h3>Word review</h3>
                  <p>Flip through the article's {vocab.length} vocabulary words. Rate yourself; the deck reorders accordingly.</p>
                  <p class="el-empty-sub">Session-only, no account, no sync. Refresh resets the deck.</p>
                  <button class="el-btn el-btn-primary" id="el-review-begin">Start review</button>
                </div>
              </div>
            </div>

            <div class="el-review-list-pane" data-view-pane="list" hidden>
              <div class="el-levels el-levels--compact">
                <div class="el-levels-row">
                  {levels.map((l) => (
                    <button
                      class={`el-level-chip${l === 1 ? ' is-on' : ''}`}
                      data-level={l}
                      aria-pressed={l === 1 ? 'true' : 'false'}
                    >
                      <span class="el-level-chip-swatch" data-level={l}></span>
                      <span class="el-level-chip-label">L{l}</span>
                      <span class="el-level-chip-num">{levelCounts[l] || 0}</span>
                    </button>
                  ))}
                </div>
              </div>
              <div class="el-vocab-list" id="el-vocab-list">
                <div class="el-section-title">All words ({vocab.length})</div>
                <ul>
                  {vocab.map((v) => (
                    <li class="el-vocab-row" data-vid={v.id} data-level={v.level}>
                      <button class="el-vocab-row-btn" data-vid={v.id}>
                        <span class="el-level-tag-shade" data-level={v.level}>L{v.level}</span>
                        <span class="el-vocab-word">{v.word}</span>
                        <span class="el-vocab-pos">{v.pos}</span>
                        <span class="el-vocab-def">{v.defZh}</span>
                      </button>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </section>

          <section class="el-mode" data-mode="about" hidden>
            <dl class="el-meta">
              <div><dt>Date</dt><dd>{meta.date}</dd></div>
              <div><dt>Length</dt><dd>{meta.wordCount} words · {meta.readingMinutes} min</dd></div>
              <div><dt>Level</dt><dd>{meta.cefr} · {cefrLabel?.tier}</dd></div>
              <div><dt>Tagged</dt><dd>{vocab.length} words · {grammar.length} grammar · {patterns.length} patterns</dd></div>
            </dl>
            {meta.editorsNote && (
              <div class="el-meta-note">
                <div class="el-section-title">Editor's note</div>
                <p>{meta.editorsNote}</p>
              </div>
            )}
            <div class="el-shortcuts">
              <div class="el-section-title">Keyboard shortcuts</div>
              <ul>
                <li><kbd>1</kbd>–<kbd>7</kbd>  Switch mode</li>
                <li><kbd>Space</kbd>  Play / pause TTS</li>
                <li><kbd>↑</kbd> <kbd>↓</kbd>  Previous / next sentence (in Translation mode)</li>
                <li><kbd>Esc</kbd>  Clear pinned card / close overlay</li>
              </ul>
            </div>
          </section>

        </div>
      </aside>

    </div>
  </main>

  <script type="application/json" id="el-data" set:html={articleJson}></script>
</MainLayout>

<style is:global>
  /* Page lock, this tool fills the viewport, no body scroll. */
  body.english-reader-page { overflow: hidden; height: 100vh; }
  /* Footer renders at body y=0 since main is fixed-positioned (out of flow);
     it would peek through the semi-transparent fixed header without this. */
  body.english-reader-page footer { display: none; }

  :root {
    --el-pin: #042f24;
    --el-soft: rgba(4, 47, 36, 0.04);
    --el-soft-2: rgba(4, 47, 36, 0.08);
    --el-soft-3: rgba(4, 47, 36, 0.12);
    --el-border: rgba(4, 47, 36, 0.10);
    --el-border-2: rgba(4, 47, 36, 0.20);
    /* shade ladder, cumulative shading, all readable with black text */
    --el-shade-1: rgba(4, 47, 36, 0.08);
    --el-shade-2: rgba(4, 47, 36, 0.14);
    --el-shade-3: rgba(4, 47, 36, 0.22);
    --el-shade-4: rgba(4, 47, 36, 0.32);
    --el-shade-pin: rgba(4, 47, 36, 0.42);
  }

  /* ===== Tool shell ===== */
  .english-tool {
    position: fixed;
    top: 5rem;
    left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    background: white;
  }

  .el-mode[hidden] { display: none !important; }

  /* ===== Toolbar ===== */
  .el-toolbar {
    flex-shrink: 0;
    background: white;
    border-bottom: 1px solid var(--el-border);
  }
  .el-toolbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .el-back {
    display: inline-flex; align-items: center; gap: 6px;
    height: 32px; padding: 0 12px 0 10px;
    border-radius: 999px;
    color: var(--el-pin);
    background: white;
    border: 1px solid var(--el-border);
    transition: all 150ms ease;
    flex-shrink: 0;
    font-size: 12px; font-weight: 600;
  }
  .el-back:hover { background: var(--el-pin); color: white; border-color: var(--el-pin); }
  .el-back .material-symbols-outlined { font-size: 16px; }

  .el-toolbar-meta { flex: 1; min-width: 0; }
  .el-toolbar-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--el-pin); opacity: 0.75;
    margin-bottom: 3px;
  }
  .el-toolbar-dot {
    display: inline-block; width: 3px; height: 3px;
    border-radius: 999px; background: currentColor; opacity: 0.5;
  }
  .el-toolbar-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    line-height: 1.15;
    color: var(--el-pin);
    letter-spacing: -0.01em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .el-cefr-pill {
    display: inline-flex; align-items: center;
    padding: 1px 7px;
    border-radius: 4px;
    background: var(--el-pin);
    color: white;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: 9.5px;
  }

  .el-toolbar-nav { display: flex; gap: 4px; flex-shrink: 0; }
  .el-toolbar-nav-link {
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px;
    border: 1px solid var(--el-border);
    background: white;
    color: var(--el-pin);
    transition: all 120ms ease;
  }
  .el-toolbar-nav-link:hover:not(.is-disabled) { background: var(--el-pin); color: white; }
  .el-toolbar-nav-link.is-disabled { opacity: 0.3; cursor: not-allowed; }
  .el-toolbar-nav-link .material-symbols-outlined { font-size: 14px; }

  .el-tts { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .el-tts-btn {
    width: 32px; height: 32px;
    border-radius: 999px;
    background: var(--el-pin);
    color: white;
    display: inline-flex; align-items: center; justify-content: center;
    border: none;
    transition: transform 120ms ease;
    cursor: pointer;
  }
  .el-tts-btn:hover { transform: scale(1.05); }
  .el-tts-btn-ghost {
    background: white;
    color: var(--el-pin);
    border: 1px solid var(--el-border);
  }
  .el-tts-btn .material-symbols-outlined { font-size: 18px; }
  .el-tts-select {
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 8px;
    padding: 4px 8px;
    font-size: 11.5px;
    color: var(--el-pin);
    cursor: pointer;
    max-width: 130px;
    text-overflow: ellipsis;
  }

  /* ===== Shell, fixed-height grid, two equal columns ===== */
  .el-shell {
    flex: 1;
    min-height: 0;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 1.25rem 1.5rem 1.25rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 440px;
    gap: 1.5rem;
    align-items: stretch;
  }
  @media (max-width: 1023px) {
    .el-shell { grid-template-columns: 1fr; gap: 1rem; }
  }

  /* ===== Article column, independently scrolls ===== */
  .el-article-col {
    overflow-y: auto;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 16px;
    padding: 32px 8% 56px;
    height: 100%;
  }
  .el-article {
    max-width: 680px;
    margin: 0 auto;
  }
  .el-article-head h1 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(1.75rem, 2.6vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--el-pin);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--el-border);
  }
  .el-article-body p {
    font-family: 'Inter', sans-serif;
    font-size: 1.0625rem;
    line-height: 1.85;
    color: rgba(4, 47, 36, 0.92);
    margin-bottom: 1.5rem;
  }

  /* sentence */
  .sent {
    transition: background-color 150ms ease, box-shadow 150ms ease;
    border-radius: 3px;
    padding: 0 1px;
    cursor: text;
  }
  .sent.is-clickable { cursor: pointer; }
  .sent.is-clickable:hover { background: var(--el-soft); }
  .sent.is-active {
    background: var(--el-soft-3);
    box-shadow: inset 2px 0 0 var(--el-pin);
    padding-left: 6px;
  }
  .sent.is-tts {
    background: var(--el-soft-2);
    box-shadow: inset 2px 0 0 var(--el-pin);
    padding-left: 6px;
  }
  .sent.is-grammar { background: var(--el-soft-2); }
  .sent-zh-inline {
    display: block;
    margin-top: 4px;
    padding-left: 12px;
    border-left: 2px solid var(--el-border-2);
    color: rgba(4, 47, 36, 0.55);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ===== Vocab, shade-filled, level-encoded ===== */
  .vocab {
    cursor: pointer;
    padding: 1px 4px;
    border-radius: 3px;
    transition: background-color 120ms ease, box-shadow 120ms ease;
  }
  .vocab[data-level="1"] { background: var(--el-shade-1); }
  .vocab[data-level="2"] { background: var(--el-shade-2); }
  .vocab[data-level="3"] { background: var(--el-shade-3); }
  .vocab[data-level="4"] { background: var(--el-shade-4); }
  .vocab.is-hidden {
    background: transparent !important;
    cursor: text;
    padding: 0;
  }
  .vocab:hover, .vocab:focus-visible {
    box-shadow: inset 0 0 0 1px var(--el-pin);
    outline: none;
  }
  .vocab.is-pinned {
    background: var(--el-shade-pin) !important;
    box-shadow: inset 0 0 0 1.5px var(--el-pin);
  }

  /* article footer note */
  .el-article-foot {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--el-border);
  }
  .el-article-note {
    padding: 1rem 1.25rem;
    background: var(--el-soft);
    border-radius: 12px;
    color: rgba(4, 47, 36, 0.78);
    line-height: 1.7;
    font-size: 13.5px;
  }
  .el-article-note-label {
    display: block;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--el-pin); opacity: 0.65;
    margin-bottom: 0.4rem;
  }

  /* ===== Right panel ===== */
  .el-panel {
    height: 100%;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 16px;
    display: flex; flex-direction: column;
    overflow: hidden;
  }

  .el-tabs {
    flex-shrink: 0;
    display: flex;
    padding: 8px;
    gap: 4px;
    border-bottom: 1px solid var(--el-border);
    background: white;
  }
  .el-tab {
    flex: 1;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: rgba(4, 47, 36, 0.5);
    display: inline-flex; align-items: center; justify-content: center;
    position: relative;
    transition: all 120ms ease;
    cursor: pointer;
  }
  .el-tab .material-symbols-outlined { font-size: 20px; }
  .el-tab:hover { color: var(--el-pin); background: var(--el-soft); }
  .el-tab.is-active { background: var(--el-pin); color: white; }
  .el-tab-num {
    position: absolute; top: 2px; right: 5px;
    font-size: 9px; font-weight: 700; opacity: 0.4;
  }
  .el-tab.is-active .el-tab-num { color: white; opacity: 0.55; }

  .el-mode-head {
    flex-shrink: 0;
    padding: 14px 18px 12px;
    border-bottom: 1px solid var(--el-border);
  }
  .el-mode-head h2 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.0625rem;
    color: var(--el-pin);
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .el-mode-head p {
    font-size: 12px; line-height: 1.55;
    color: rgba(4, 47, 36, 0.6);
  }

  .el-mode-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 14px 18px 18px;
  }
  .el-mode { display: flex; flex-direction: column; gap: 14px; }

  /* ===== Level chips (single-select, cumulative) ===== */
  .el-levels {
    display: flex; flex-direction: column; gap: 8px;
  }
  .el-levels-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }
  .el-level-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 10px;
    border-radius: 10px;
    border: 1px solid var(--el-border);
    background: white;
    cursor: pointer;
    transition: all 120ms ease;
    text-align: left;
  }
  .el-level-chip:hover { border-color: var(--el-border-2); }
  .el-level-chip.is-on {
    background: var(--el-pin);
    border-color: var(--el-pin);
  }
  .el-level-chip-swatch {
    flex-shrink: 0;
    width: 12px; height: 12px;
    border-radius: 3px;
  }
  .el-level-chip-swatch[data-level="1"] { background: var(--el-shade-1); }
  .el-level-chip-swatch[data-level="2"] { background: var(--el-shade-2); }
  .el-level-chip-swatch[data-level="3"] { background: var(--el-shade-3); }
  .el-level-chip-swatch[data-level="4"] { background: var(--el-shade-4); }
  .el-level-chip.is-on .el-level-chip-swatch {
    box-shadow: inset 0 0 0 1px white;
  }
  .el-level-chip-label {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 12px;
    color: var(--el-pin);
  }
  .el-level-chip.is-on .el-level-chip-label { color: white; }
  .el-level-chip-num {
    margin-left: auto;
    font-size: 10.5px; font-weight: 700;
    color: rgba(4, 47, 36, 0.5);
  }
  .el-level-chip.is-on .el-level-chip-num { color: rgba(255, 255, 255, 0.7); }
  .el-levels-hint {
    font-size: 11.5px;
    line-height: 1.5;
    color: rgba(4, 47, 36, 0.55);
  }
  .el-levels-hint em {
    font-style: normal;
    font-weight: 700;
    color: var(--el-pin);
  }

  /* ===== Vocab card ===== */
  .el-vocab-detail {
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    padding: 14px 16px;
    min-height: 90px;
  }
  .el-empty {
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    color: rgba(4, 47, 36, 0.5);
    padding: 8px;
  }
  .el-empty .material-symbols-outlined {
    font-size: 22px; opacity: 0.55; margin-bottom: 8px;
  }
  .el-empty p { font-size: 12.5px; line-height: 1.55; }
  .el-empty-sub { font-size: 11.5px !important; margin-top: 4px; opacity: 0.85; }

  .el-vocab-card { display: flex; flex-direction: column; gap: 8px; }
  .el-vocab-card-head {
    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
  }
  .el-vocab-card-head .word {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--el-pin);
    letter-spacing: -0.01em;
  }
  .el-vocab-card-head .ipa { font-size: 13px; color: rgba(4, 47, 36, 0.5); }
  .el-vocab-card-head .pos { font-size: 11px; color: rgba(4, 47, 36, 0.55); font-style: italic; }
  .el-vocab-defs p { font-size: 13.5px; line-height: 1.55; color: rgba(4, 47, 36, 0.85); }
  .el-vocab-defs p + p { margin-top: 4px; color: rgba(4, 47, 36, 0.55); font-size: 12.5px; }
  .el-vocab-eg {
    margin-top: 4px;
    padding: 8px 10px;
    background: var(--el-soft);
    border-radius: 8px;
    font-size: 12.5px;
    line-height: 1.55;
    color: rgba(4, 47, 36, 0.78);
  }
  .el-vocab-eg em { font-style: normal; font-weight: 600; color: var(--el-pin); }
  .el-vocab-eg .zh { display: block; margin-top: 2px; color: rgba(4, 47, 36, 0.5); }
  .el-vocab-card-foot {
    display: flex; align-items: center; gap: 10px; justify-content: space-between;
    margin-top: 4px;
  }
  .el-vocab-card-foot a {
    font-size: 11.5px; color: var(--el-pin);
    display: inline-flex; align-items: center; gap: 3px;
    text-decoration: none;
  }
  .el-vocab-card-foot a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* level tag, same shade ladder */
  .el-level-tag-shade {
    display: inline-block;
    font-size: 9px; font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--el-pin);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .el-level-tag-shade[data-level="1"] { background: var(--el-shade-1); }
  .el-level-tag-shade[data-level="2"] { background: var(--el-shade-2); }
  .el-level-tag-shade[data-level="3"] { background: var(--el-shade-3); }
  .el-level-tag-shade[data-level="4"] { background: var(--el-shade-4); }

  .el-section-title {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(4, 47, 36, 0.55);
    margin-bottom: 8px;
  }
  .el-vocab-list ul { display: flex; flex-direction: column; gap: 2px; }
  .el-vocab-row { list-style: none; }
  .el-vocab-row.is-hidden { display: none; }
  .el-vocab-row-btn {
    width: 100%; text-align: left;
    background: transparent; border: none;
    padding: 7px 8px;
    border-radius: 8px;
    display: grid;
    grid-template-columns: auto auto auto 1fr;
    gap: 8px; align-items: baseline;
    cursor: pointer;
    transition: background 120ms ease;
  }
  .el-vocab-row-btn:hover { background: var(--el-soft); }
  .el-vocab-row-btn.is-active { background: var(--el-soft-2); }
  .el-vocab-word {
    font-family: 'Manrope', sans-serif;
    font-weight: 700; font-size: 13px;
    color: var(--el-pin);
  }
  .el-vocab-pos { font-size: 10.5px; color: rgba(4, 47, 36, 0.5); font-style: italic; }
  .el-vocab-def {
    font-size: 12px;
    color: rgba(4, 47, 36, 0.6);
    line-height: 1.4;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* ===== Translate ===== */
  .el-toggle {
    display: inline-flex; align-items: center; gap: 8px;
    cursor: pointer; user-select: none;
  }
  .el-toggle input { display: none; }
  .el-toggle-track {
    width: 32px; height: 18px;
    background: var(--el-border-2);
    border-radius: 999px;
    position: relative;
    transition: background 120ms ease;
  }
  .el-toggle-knob {
    position: absolute; top: 2px; left: 2px;
    width: 14px; height: 14px;
    background: white; border-radius: 999px;
    transition: transform 120ms ease;
  }
  .el-toggle input:checked + .el-toggle-track { background: var(--el-pin); }
  .el-toggle input:checked + .el-toggle-track .el-toggle-knob { transform: translateX(14px); }
  .el-toggle-label { font-size: 12.5px; color: rgba(4, 47, 36, 0.78); }

  .el-trans-detail {
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    padding: 14px 16px;
    min-height: 200px;
  }
  .el-trans-card-en {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--el-pin);
    letter-spacing: -0.005em;
    margin-bottom: 10px;
  }
  .el-trans-card-zh {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(4, 47, 36, 0.78);
    padding-top: 10px;
    border-top: 1px solid var(--el-border);
  }
  .el-trans-card-nav {
    display: flex; gap: 6px; margin-top: 12px;
  }
  .el-trans-card-nav button {
    flex: 1;
    padding: 6px 10px;
    border-radius: 8px;
    background: white;
    border: 1px solid var(--el-border);
    color: var(--el-pin);
    font-size: 11.5px; font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease;
    display: inline-flex; align-items: center; justify-content: center; gap: 4px;
  }
  .el-trans-card-nav button:hover { background: var(--el-soft); }
  .el-trans-card-nav button:disabled { opacity: 0.4; cursor: not-allowed; }
  .el-trans-card-nav .material-symbols-outlined { font-size: 14px; }

  /* ===== Cards ===== */
  .el-card-list { display: flex; flex-direction: column; gap: 10px; }
  .el-card {
    list-style: none;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    padding: 12px 14px;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .el-card:hover { background: var(--el-soft); }
  .el-card.is-active { background: var(--el-soft); border-color: var(--el-border-2); }
  .el-card-head { margin-bottom: 6px; }
  .el-card-head h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13.5px;
    color: var(--el-pin);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }
  .el-card-pattern {
    display: inline-block;
    margin-top: 4px;
    padding: 2px 6px;
    background: var(--el-soft);
    border-radius: 5px;
    font-size: 11px;
    color: rgba(4, 47, 36, 0.7);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .el-card-skeleton {
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 12.5px !important;
    line-height: 1.55 !important;
    font-weight: 600 !important;
    color: var(--el-pin);
  }
  .el-card-original {
    font-style: italic;
    font-size: 12px;
    color: rgba(4, 47, 36, 0.6);
    line-height: 1.55;
    margin: 6px 0;
    padding-left: 8px;
    border-left: 2px solid var(--el-border-2);
  }
  .el-card-explain, .el-card-hint {
    font-size: 12.5px; line-height: 1.6;
    color: rgba(4, 47, 36, 0.8);
  }
  .el-card-examples p {
    font-size: 12px; line-height: 1.6;
    color: rgba(4, 47, 36, 0.65);
    margin-top: 4px;
  }
  .el-card-action {
    margin-top: 10px;
    background: transparent; border: none;
    color: var(--el-pin);
    font-size: 11px; font-weight: 600;
    display: inline-flex; align-items: center; gap: 4px;
    cursor: pointer; padding: 0;
  }
  .el-card-action:hover { text-decoration: underline; text-underline-offset: 3px; }
  .el-card-action .material-symbols-outlined { font-size: 14px; }

  /* ===== Quiz / Review ===== */
  .el-quiz-start, .el-review-start {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 24px 12px; gap: 8px;
  }
  .el-quiz-icon {
    color: var(--el-pin);
    background: var(--el-soft);
    width: 48px; height: 48px;
    border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 24px !important;
    margin-bottom: 4px;
  }
  .el-quiz-start h3, .el-review-start h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800; font-size: 1rem;
    color: var(--el-pin);
  }
  .el-quiz-start p, .el-review-start p {
    font-size: 12.5px; line-height: 1.55;
    color: rgba(4, 47, 36, 0.6);
    max-width: 240px;
  }

  .el-btn {
    padding: 9px 18px;
    border-radius: 999px;
    font-size: 12.5px; font-weight: 600;
    cursor: pointer; border: none;
    transition: transform 100ms ease, background 120ms ease, color 120ms ease;
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 6px;
  }
  .el-btn-primary { background: var(--el-pin); color: white; }
  .el-btn-primary:hover { transform: translateY(-1px); }
  .el-btn-ghost {
    background: white;
    border: 1px solid var(--el-border);
    color: var(--el-pin);
  }
  .el-btn-ghost:hover { background: var(--el-soft); }

  .el-quiz-progress {
    height: 3px;
    background: var(--el-border);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .el-quiz-progress-fill {
    height: 100%;
    background: var(--el-pin);
    transition: width 250ms ease;
  }
  .el-quiz-counter {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(4, 47, 36, 0.55);
    margin-bottom: 6px;
  }
  .el-quiz-q {
    font-family: 'Manrope', sans-serif;
    font-weight: 700; font-size: 14px;
    line-height: 1.5;
    color: var(--el-pin);
    margin-bottom: 12px;
  }
  .el-quiz-options { display: flex; flex-direction: column; gap: 6px; }
  .el-quiz-option {
    text-align: left;
    padding: 10px 12px;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 10px;
    font-size: 13px; line-height: 1.45;
    color: rgba(4, 47, 36, 0.85);
    cursor: pointer;
    transition: all 120ms ease;
    display: flex; align-items: flex-start; gap: 8px;
  }
  .el-quiz-option:hover { background: var(--el-soft); }
  .el-quiz-option-letter {
    flex-shrink: 0;
    width: 18px; height: 18px;
    border-radius: 999px;
    background: var(--el-soft);
    color: var(--el-pin);
    font-size: 10px; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .el-quiz-option.is-correct { border-color: var(--el-pin); background: var(--el-soft-2); }
  .el-quiz-option.is-correct .el-quiz-option-letter { background: var(--el-pin); color: white; }
  .el-quiz-option.is-wrong {
    border-color: rgba(4, 47, 36, 0.45);
    background: var(--el-soft);
    text-decoration: line-through;
    text-decoration-color: rgba(4, 47, 36, 0.4);
    color: rgba(4, 47, 36, 0.55);
  }
  .el-quiz-option.is-wrong .el-quiz-option-letter { background: rgba(4, 47, 36, 0.4); color: white; }
  .el-quiz-option:disabled { cursor: default; }
  .el-quiz-explanation {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--el-soft);
    border-radius: 8px;
    font-size: 12px; line-height: 1.55;
    color: rgba(4, 47, 36, 0.78);
  }
  .el-quiz-actions {
    display: flex; gap: 6px; margin-top: 10px; justify-content: space-between;
  }
  .el-quiz-end {
    text-align: center;
    padding: 24px 8px;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .el-quiz-score {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 2.25rem;
    color: var(--el-pin);
    line-height: 1;
  }
  .el-quiz-score-label {
    font-size: 12px;
    color: rgba(4, 47, 36, 0.6);
    margin-bottom: 8px;
  }

  .el-review-card {
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 14px;
    padding: 18px 18px 14px;
    min-height: 220px;
    display: flex; flex-direction: column;
  }
  .el-review-card-front {
    flex: 1;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 16px 8px;
    gap: 6px;
  }
  .el-review-word {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: var(--el-pin);
    letter-spacing: -0.01em;
    text-align: center;
  }
  .el-review-pos { font-size: 11.5px; color: rgba(4, 47, 36, 0.55); font-style: italic; }
  .el-review-flip-hint {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(4, 47, 36, 0.4);
    margin-top: 8px;
  }
  .el-review-back {
    border-top: 1px solid var(--el-border);
    padding-top: 12px; margin-top: 12px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .el-review-back .ipa { font-size: 12px; color: rgba(4, 47, 36, 0.55); }
  .el-review-back .def { font-size: 13.5px; color: var(--el-pin); font-weight: 600; }
  .el-review-back .eg {
    font-size: 12.5px; line-height: 1.55;
    color: rgba(4, 47, 36, 0.7);
    background: var(--el-soft);
    border-radius: 8px;
    padding: 8px 10px;
    margin-top: 4px;
  }
  .el-review-rating {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-top: 12px;
  }
  .el-review-rating button {
    padding: 8px 4px;
    border-radius: 8px;
    background: white;
    border: 1px solid var(--el-border);
    cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    transition: all 120ms ease;
  }
  .el-review-rating button:hover { background: var(--el-soft); border-color: var(--el-border-2); }
  .el-review-rating .label { font-size: 12px; font-weight: 700; color: var(--el-pin); }
  .el-review-rating .key { font-size: 9px; color: rgba(4, 47, 36, 0.45); }

  /* ===== About ===== */
  .el-meta { display: flex; flex-direction: column; gap: 6px; }
  .el-meta > div {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
    padding: 7px 0;
    border-bottom: 1px dashed var(--el-border);
  }
  .el-meta dt {
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(4, 47, 36, 0.5);
    align-self: center;
  }
  .el-meta dd { font-size: 13px; color: var(--el-pin); }
  .el-meta a { color: var(--el-pin); text-decoration: underline; text-underline-offset: 3px; }
  .el-meta-note {
    margin-top: 14px;
    padding: 12px 14px;
    background: var(--el-soft);
    border-radius: 10px;
  }
  .el-meta-note p {
    font-size: 12.5px; line-height: 1.6;
    color: rgba(4, 47, 36, 0.75);
  }
  .el-shortcuts {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--el-border);
  }
  .el-shortcuts ul { display: flex; flex-direction: column; gap: 6px; }
  .el-shortcuts li {
    font-size: 12px; color: rgba(4, 47, 36, 0.7);
    display: flex; align-items: center; gap: 8px;
  }
  .el-shortcuts kbd {
    display: inline-block;
    background: white;
    border: 1px solid var(--el-border);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 5px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--el-pin);
    min-width: 18px; text-align: center;
  }

  /* ===== Accordion (grammar / patterns) ===== */
  .el-accordion {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .el-acc-item {
    list-style: none;
    background: white;
    border: 1px solid var(--el-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 120ms ease;
  }
  .el-acc-item:hover { border-color: var(--el-border-2); }
  .el-acc-item.is-open { border-color: var(--el-pin); }
  .el-acc-trigger {
    width: 100%;
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 120ms ease;
  }
  .el-acc-trigger:hover { background: var(--el-soft); }
  .el-acc-item.is-open .el-acc-trigger { background: var(--el-soft); }
  .el-acc-title {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .el-acc-name {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13.5px;
    line-height: 1.35;
    color: var(--el-pin);
    letter-spacing: -0.005em;
  }
  .el-acc-pattern {
    align-self: flex-start;
    padding: 2px 6px;
    background: var(--el-soft);
    border-radius: 5px;
    font-size: 10.5px;
    color: rgba(4, 47, 36, 0.7);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .el-acc-chev {
    flex-shrink: 0;
    color: rgba(4, 47, 36, 0.4);
    font-size: 20px !important;
    transition: transform 180ms ease, color 120ms ease;
  }
  .el-acc-item.is-open .el-acc-chev {
    transform: rotate(180deg);
    color: var(--el-pin);
  }
  .el-acc-body {
    padding: 4px 16px 16px;
    border-top: 1px solid var(--el-border);
    background: white;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  /* Critical: same UA [hidden] override needed as for .el-mode. */
  .el-acc-body[hidden] { display: none !important; }

  .el-acc-eyebrow {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(4, 47, 36, 0.5);
    margin-top: 12px;
    margin-bottom: 2px;
  }
  .el-acc-eyebrow:first-child { margin-top: 8px; }

  .el-acc-paragraphs {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .el-acc-paragraphs p {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(4, 47, 36, 0.85);
  }

  .el-acc-examples {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .el-acc-examples li {
    list-style: none;
    background: var(--el-soft);
    border-radius: 8px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .el-eg-context {
    font-size: 10.5px;
    font-weight: 600;
    color: rgba(4, 47, 36, 0.55);
    letter-spacing: 0.01em;
    text-transform: none;
  }
  .el-eg-en {
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 1.55;
    color: var(--el-pin);
  }
  .el-eg-zh {
    font-size: 12px;
    line-height: 1.55;
    color: rgba(4, 47, 36, 0.65);
  }
  .el-eg-note {
    font-size: 11.5px;
    line-height: 1.5;
    color: rgba(4, 47, 36, 0.55);
    font-style: italic;
    padding-left: 8px;
    border-left: 2px solid var(--el-border-2);
    margin-top: 2px;
  }

  .el-acc-skeleton {
    display: block;
    padding: 8px 10px;
    background: var(--el-soft-2);
    border-radius: 6px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    line-height: 1.55;
    color: var(--el-pin);
    word-break: break-word;
    font-weight: 600;
  }
  .el-acc-original {
    font-style: italic;
    font-size: 12.5px;
    color: rgba(4, 47, 36, 0.7);
    line-height: 1.6;
    padding: 6px 0 6px 12px;
    border-left: 2px solid var(--el-border-2);
  }
  .el-acc-hint {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(4, 47, 36, 0.82);
  }

  /* Callout boxes for commonMistake / vsSimilar */
  .el-acc-callout {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--el-soft);
    border-left: 3px solid var(--el-border-2);
    border-radius: 0 8px 8px 0;
  }
  .el-acc-callout--warn {
    background: rgba(217, 119, 6, 0.06);
    border-left-color: rgba(217, 119, 6, 0.55);
  }
  .el-acc-callout-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(4, 47, 36, 0.6);
    margin-bottom: 4px;
  }
  .el-acc-callout--warn .el-acc-callout-label {
    color: rgba(217, 119, 6, 0.95);
  }
  .el-acc-callout p {
    font-size: 12.5px;
    line-height: 1.65;
    color: rgba(4, 47, 36, 0.78);
  }

  /* ===== Review view toggle ===== */
  .el-review-toggle {
    display: flex;
    background: var(--el-soft);
    border-radius: 10px;
    padding: 3px;
    gap: 3px;
  }
  .el-review-toggle-btn {
    flex: 1;
    display: inline-flex; align-items: center; justify-content: center;
    gap: 6px;
    padding: 7px 10px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: rgba(4, 47, 36, 0.55);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: all 120ms ease;
  }
  .el-review-toggle-btn:hover { color: var(--el-pin); }
  .el-review-toggle-btn.is-on {
    background: white;
    color: var(--el-pin);
    box-shadow: 0 1px 3px rgba(4, 47, 36, 0.10);
  }
  .el-review-toggle-btn .material-symbols-outlined { font-size: 16px; }

  /* Compact level chips for the review > list pane */
  .el-levels--compact .el-level-chip {
    padding: 6px 8px;
    border-radius: 8px;
  }
  .el-levels--compact .el-level-chip-label { font-size: 11px; }
</style>

<script>
  // Lock body scroll for this page; restore on unload (in case of soft-nav).
  document.body.classList.add('english-reader-page');
  window.addEventListener('beforeunload', () => {
    document.body.classList.remove('english-reader-page');
  });

  type Mode = 'vocab' | 'translate' | 'grammar' | 'patterns' | 'quiz' | 'review' | 'about';

  type Article = {
    meta: { date: string; title: string; cefr: string; wordCount: number; readingMinutes: number; editorsNote?: string };
    paragraphs: { id: string; sentences: { id: string; en: string; zh: string }[] }[];
    vocab: { id: string; word: string; lemma: string; sentenceId: string; level: number; pos: string; ipa: string; defZh: string; defEn: string; example: string; exampleZh?: string }[];
    collocations: { id: string; phrase: string; sentenceId: string; meaningZh: string; example: string; exampleZh?: string }[];
    grammar: { id: string; title: string; pattern: string; explanationZh: string; sentenceIds: string[]; examples: string[] }[];
    patterns: { id: string; skeleton: string; original: string; sentenceId: string; hint: string }[];
    quiz: { id: string; q: string; options: string[]; answer: number; explanation: string; sentenceId?: string }[];
  };

  const dataEl = document.getElementById('el-data');
  const ARTICLE: Article = JSON.parse(dataEl?.textContent || '{}');
  const FLAT_SENTENCES = ARTICLE.paragraphs.flatMap((p) => p.sentences);
  const SENT_BY_ID = Object.fromEntries(FLAT_SENTENCES.map((s) => [s.id, s]));
  const VOCAB_BY_ID = Object.fromEntries(ARTICLE.vocab.map((v) => [v.id, v]));

  let currentMode: Mode = 'vocab';
  let levelFloor = 1;
  let pinnedVocabId: string | null = null;
  let activeSentId: string | null = null;
  let showAllZh = false;

  const modeDescs: Record<Mode, { label: string; desc: string }> = {
    vocab:     { label: 'Vocabulary',    desc: 'Hover any shaded word for its meaning. Click to pin.' },
    translate: { label: 'Translation',   desc: 'Click a sentence, its Chinese translation appears here.' },
    grammar:   { label: 'Grammar',       desc: 'Hover a card to see the construction in the article.' },
    patterns:  { label: 'Patterns',      desc: 'Reusable sentence skeletons you can borrow for your own writing.' },
    quiz:      { label: 'Comprehension', desc: 'A short multiple-choice check after the read.' },
    review:    { label: 'Word review',   desc: 'A flashcard pass over the article\'s vocabulary, current session only.' },
    about:     { label: 'About',         desc: 'Source, length, level, editor\'s note.' },
  };

  function setMode(mode: Mode) {
    currentMode = mode;
    document.querySelectorAll('.el-tab').forEach((el) => {
      const isActive = el.getAttribute('data-mode') === mode;
      el.classList.toggle('is-active', isActive);
      el.setAttribute('aria-selected', String(isActive));
    });
    document.querySelectorAll('.el-mode').forEach((el) => {
      const m = el.getAttribute('data-mode');
      if (m === mode) el.removeAttribute('hidden');
      else el.setAttribute('hidden', '');
    });
    const titleEl = document.getElementById('el-mode-title');
    const descEl = document.getElementById('el-mode-desc');
    if (titleEl) titleEl.textContent = modeDescs[mode].label;
    if (descEl)  descEl.textContent  = modeDescs[mode].desc;

    const sentClickable = mode === 'translate';
    document.querySelectorAll('.sent').forEach((el) => {
      el.classList.toggle('is-clickable', sentClickable);
    });
    // Reset grammar highlights on every mode switch, then re-apply if entering
    // grammar/patterns with an open accordion item.
    document.querySelectorAll('.sent.is-grammar').forEach((el) => el.classList.remove('is-grammar'));
    if (mode === 'grammar' || mode === 'patterns') {
      const sectionEl = document.querySelector(`.el-mode[data-mode="${mode}"]`);
      const openItem = sectionEl?.querySelector('.el-acc-item.is-open');
      if (openItem) {
        const sids = (openItem.getAttribute('data-sids') || '').split(',').filter(Boolean);
        sids.forEach((sid) => {
          document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add('is-grammar'));
        });
      }
    }
  }

  document.querySelectorAll('.el-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const m = btn.getAttribute('data-mode') as Mode;
      if (m) setMode(m);
    });
  });

  // ============== Level filter, single select, cumulative ==============
  function applyLevelFilter() {
    document.querySelectorAll('.vocab').forEach((el) => {
      const lvl = Number(el.getAttribute('data-level'));
      el.classList.toggle('is-hidden', lvl < levelFloor);
    });
    document.querySelectorAll('.el-vocab-row').forEach((el) => {
      const lvl = Number(el.getAttribute('data-level'));
      el.classList.toggle('is-hidden', lvl < levelFloor);
    });
  }
  document.querySelectorAll('.el-level-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const lvl = Number(chip.getAttribute('data-level'));
      if (!lvl) return;
      levelFloor = lvl;
      document.querySelectorAll('.el-level-chip').forEach((c) => {
        const isOn = Number(c.getAttribute('data-level')) === lvl;
        c.classList.toggle('is-on', isOn);
        c.setAttribute('aria-pressed', String(isOn));
      });
      applyLevelFilter();
    });
  });

  // ============== Vocab ==============
  const vocabDetailEl = document.getElementById('el-vocab-detail')!;

  function renderVocabCard(vid: string) {
    const v = VOCAB_BY_ID[vid];
    if (!v) return;
    vocabDetailEl.innerHTML = `
      <div class="el-vocab-card">
        <div class="el-vocab-card-head">
          <span class="word">${v.word}</span>
          <span class="ipa">${v.ipa}</span>
          <span class="pos">${v.pos}</span>
          <span class="el-level-tag-shade" data-level="${v.level}">L${v.level}</span>
        </div>
        <div class="el-vocab-defs">
          <p>${v.defZh}</p>
          <p>${v.defEn}</p>
        </div>
        <div class="el-vocab-eg">
          <em>${v.example}</em>
          ${v.exampleZh ? `<span class="zh">${v.exampleZh}</span>` : ''}
        </div>
        <div class="el-vocab-card-foot">
          <a href="#" data-jump-sid="${v.sentenceId}">
            <span class="material-symbols-outlined" style="font-size:14px">north_east</span>
            See in article
          </a>
          <button class="el-btn el-btn-ghost" id="el-vocab-tts" style="margin:0; padding: 4px 10px; font-size: 11.5px;">
            <span class="material-symbols-outlined" style="font-size:14px">volume_up</span>
            Listen
          </button>
        </div>
      </div>
    `;
    const jump = vocabDetailEl.querySelector('[data-jump-sid]');
    jump?.addEventListener('click', (e) => {
      e.preventDefault();
      const sid = (e.currentTarget as HTMLElement).getAttribute('data-jump-sid')!;
      jumpToSentence(sid);
    });
    const ttsBtn = vocabDetailEl.querySelector('#el-vocab-tts');
    ttsBtn?.addEventListener('click', () => speakOne(v.word));
  }

  function clearVocabCard() {
    vocabDetailEl.innerHTML = `
      <div class="el-empty">
        <span class="material-symbols-outlined">touch_app</span>
        <p>Hover any shaded word in the article. Click to pin.</p>
      </div>
    `;
  }

  function pinVocab(vid: string | null) {
    document.querySelectorAll('.vocab.is-pinned').forEach((el) => el.classList.remove('is-pinned'));
    document.querySelectorAll('.el-vocab-row-btn.is-active').forEach((el) => el.classList.remove('is-active'));
    pinnedVocabId = vid;
    if (vid) {
      document.querySelectorAll(`.vocab[data-vid="${vid}"]`).forEach((el) => el.classList.add('is-pinned'));
      document.querySelector(`.el-vocab-row-btn[data-vid="${vid}"]`)?.classList.add('is-active');
      renderVocabCard(vid);
    } else {
      clearVocabCard();
    }
  }

  document.querySelectorAll('.vocab').forEach((el) => {
    el.addEventListener('mouseenter', () => {
      // Only preview when already in vocab mode, never auto-switch on hover.
      if (currentMode !== 'vocab') return;
      if (pinnedVocabId) return;
      const vid = el.getAttribute('data-vid');
      if (vid) renderVocabCard(vid);
    });
    el.addEventListener('mouseleave', () => {
      if (currentMode !== 'vocab') return;
      if (pinnedVocabId) return;
      clearVocabCard();
    });
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      const vid = el.getAttribute('data-vid');
      if (!vid) return;
      // Click is an explicit action, switch to vocab and pin.
      if (currentMode !== 'vocab') setMode('vocab');
      pinVocab(pinnedVocabId === vid ? null : vid);
    });
  });

  document.querySelectorAll('.el-vocab-row-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const vid = btn.getAttribute('data-vid');
      if (!vid) return;
      pinVocab(pinnedVocabId === vid ? null : vid);
      jumpToSentence(VOCAB_BY_ID[vid].sentenceId);
    });
  });

  // ============== Translate ==============
  const transDetailEl = document.getElementById('el-trans-detail')!;
  const articleColEl = document.getElementById('el-article-col')!;

  function setActiveSentence(sid: string | null) {
    document.querySelectorAll('.sent.is-active').forEach((el) => el.classList.remove('is-active'));
    activeSentId = sid;
    if (!sid) {
      transDetailEl.innerHTML = `
        <div class="el-empty">
          <span class="material-symbols-outlined">ads_click</span>
          <p>Click any sentence in the article to see its Chinese translation here.</p>
          <p class="el-empty-sub">Use ↑ / ↓ to walk sentence by sentence.</p>
        </div>
      `;
      return;
    }
    document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add('is-active'));
    const idx = FLAT_SENTENCES.findIndex((s) => s.id === sid);
    const s = FLAT_SENTENCES[idx];
    const prevId = idx > 0 ? FLAT_SENTENCES[idx - 1].id : '';
    const nextId = idx < FLAT_SENTENCES.length - 1 ? FLAT_SENTENCES[idx + 1].id : '';
    transDetailEl.innerHTML = `
      <div class="el-trans-card-en">${s.en}</div>
      <div class="el-trans-card-zh">${s.zh}</div>
      <div class="el-trans-card-nav">
        <button data-prev="${prevId}" ${!prevId ? 'disabled' : ''}>
          <span class="material-symbols-outlined">arrow_upward</span> Prev
        </button>
        <button data-listen="${sid}">
          <span class="material-symbols-outlined">volume_up</span> Listen
        </button>
        <button data-next="${nextId}" ${!nextId ? 'disabled' : ''}>
          Next <span class="material-symbols-outlined">arrow_downward</span>
        </button>
      </div>
    `;
    transDetailEl.querySelector('[data-prev]')?.addEventListener('click', (e) => {
      const t = (e.currentTarget as HTMLElement).getAttribute('data-prev');
      if (t) { setActiveSentence(t); jumpToSentence(t); }
    });
    transDetailEl.querySelector('[data-next]')?.addEventListener('click', (e) => {
      const t = (e.currentTarget as HTMLElement).getAttribute('data-next');
      if (t) { setActiveSentence(t); jumpToSentence(t); }
    });
    transDetailEl.querySelector('[data-listen]')?.addEventListener('click', () => speakOne(s.en));
  }

  document.querySelectorAll('.sent').forEach((el) => {
    el.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.vocab')) return;
      if (currentMode !== 'translate') return;
      const sid = el.getAttribute('data-sid');
      if (sid) setActiveSentence(sid);
    });
  });

  const showAllToggle = document.getElementById('el-show-all-zh') as HTMLInputElement | null;
  showAllToggle?.addEventListener('change', () => {
    showAllZh = showAllToggle.checked;
    document.querySelectorAll('.sent-zh-inline').forEach((el) => el.remove());
    if (showAllZh) {
      document.querySelectorAll('.sent').forEach((el) => {
        const sid = el.getAttribute('data-sid');
        if (!sid) return;
        const s = SENT_BY_ID[sid];
        const zhEl = document.createElement('span');
        zhEl.className = 'sent-zh-inline';
        zhEl.textContent = s.zh;
        el.insertAdjacentElement('afterend', zhEl);
      });
    }
  });

  // Scroll within the article column (not the page).
  function jumpToSentence(sid: string) {
    const el = document.querySelector(`.sent[data-sid="${sid}"]`) as HTMLElement | null;
    if (!el) return;
    const colRect = articleColEl.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    const targetY = articleColEl.scrollTop + (elRect.top - colRect.top) - colRect.height / 2 + elRect.height / 2;
    articleColEl.scrollTo({ top: targetY, behavior: 'smooth' });
    el.classList.add('is-active');
    setTimeout(() => {
      if (currentMode !== 'translate' && activeSentId !== sid) {
        el.classList.remove('is-active');
      }
    }, 1500);
  }

  // ============== Grammar / Patterns ==============
  function highlightSentences(sids: string[], cls = 'is-grammar') {
    document.querySelectorAll(`.sent.${cls}`).forEach((el) => el.classList.remove(cls));
    sids.forEach((sid) => {
      document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add(cls));
    });
    if (sids[0]) jumpToSentence(sids[0]);
  }
  // ============== Accordion (grammar + patterns) ==============
  function closeAccItem(item: Element) {
    item.classList.remove('is-open');
    item.querySelector('.el-acc-body')?.setAttribute('hidden', '');
    item.querySelector('.el-acc-trigger')?.setAttribute('aria-expanded', 'false');
  }
  function openAccItem(item: Element) {
    // Close siblings within the same accordion (only one open at a time).
    const accordion = item.closest('.el-accordion');
    accordion?.querySelectorAll('.el-acc-item.is-open').forEach((other) => {
      if (other !== item) closeAccItem(other);
    });
    item.classList.add('is-open');
    item.querySelector('.el-acc-body')?.removeAttribute('hidden');
    item.querySelector('.el-acc-trigger')?.setAttribute('aria-expanded', 'true');
    // Highlight the matching sentence(s) in the article and scroll to them.
    document.querySelectorAll('.sent.is-grammar').forEach((el) => el.classList.remove('is-grammar'));
    const sids = (item.getAttribute('data-sids') || '').split(',').filter(Boolean);
    sids.forEach((sid) => {
      document.querySelectorAll(`.sent[data-sid="${sid}"]`).forEach((el) => el.classList.add('is-grammar'));
    });
    if (sids[0]) jumpToSentence(sids[0]);
    // Scroll the panel body so the just-opened item's title sits at the top.
    // Wait one frame so layout settles after sibling close + this expand.
    const modeBody = item.closest('.el-mode-body') as HTMLElement | null;
    if (modeBody) {
      requestAnimationFrame(() => {
        const itemRect = (item as HTMLElement).getBoundingClientRect();
        const bodyRect = modeBody.getBoundingClientRect();
        const target = modeBody.scrollTop + (itemRect.top - bodyRect.top) - 8;
        modeBody.scrollTo({ top: target, behavior: 'smooth' });
      });
    }
  }
  document.querySelectorAll('.el-acc-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.el-acc-item');
      if (!item) return;
      if (item.classList.contains('is-open')) {
        closeAccItem(item);
        document.querySelectorAll('.sent.is-grammar').forEach((el) => el.classList.remove('is-grammar'));
      } else {
        openAccItem(item);
      }
    });
  });

  // ============== Review view toggle (Cards / List) ==============
  document.querySelectorAll('.el-review-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const view = btn.getAttribute('data-view');
      document.querySelectorAll('.el-review-toggle-btn').forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-on', on);
        b.setAttribute('aria-pressed', String(on));
      });
      document.querySelectorAll('[data-view-pane]').forEach((pane) => {
        (pane as HTMLElement).hidden = pane.getAttribute('data-view-pane') !== view;
      });
    });
  });

  // ============== Quiz ==============
  const quizRoot = document.getElementById('el-quiz-root')!;
  let quizIdx = 0;
  let quizScore = 0;
  let quizAnswered: (number | null)[] = [];

  document.getElementById('el-quiz-begin')?.addEventListener('click', startQuiz);
  function startQuiz() {
    quizIdx = 0;
    quizScore = 0;
    quizAnswered = ARTICLE.quiz.map(() => null);
    renderQuiz();
  }
  function renderQuiz() {
    if (quizIdx >= ARTICLE.quiz.length) {
      quizRoot.innerHTML = `
        <div class="el-quiz-end">
          <span class="material-symbols-outlined el-quiz-icon">military_tech</span>
          <div class="el-quiz-score">${quizScore}/${ARTICLE.quiz.length}</div>
          <div class="el-quiz-score-label">${
            quizScore === ARTICLE.quiz.length
              ? 'Perfect read.'
              : quizScore >= ARTICLE.quiz.length - 1
              ? 'Strong comprehension.'
              : quizScore >= ARTICLE.quiz.length / 2
              ? 'Worth a re-read of the trickier paragraphs.'
              : 'Try the article again with more attention to detail.'
          }</div>
          <button class="el-btn el-btn-primary" id="el-quiz-restart">Try again</button>
          <button class="el-btn el-btn-ghost" id="el-quiz-back-article" style="margin-top:0">
            <span class="material-symbols-outlined" style="font-size:14px">menu_book</span>
            Back to article
          </button>
        </div>
      `;
      document.getElementById('el-quiz-restart')?.addEventListener('click', startQuiz);
      document.getElementById('el-quiz-back-article')?.addEventListener('click', () => setMode('vocab'));
      return;
    }
    const q = ARTICLE.quiz[quizIdx];
    const pct = (quizIdx / ARTICLE.quiz.length) * 100;
    const letters = ['A', 'B', 'C', 'D'];
    quizRoot.innerHTML = `
      <div class="el-quiz-progress"><div class="el-quiz-progress-fill" style="width: ${pct}%"></div></div>
      <div class="el-quiz-counter">Q ${quizIdx + 1} / ${ARTICLE.quiz.length}</div>
      <div class="el-quiz-q">${q.q}</div>
      <div class="el-quiz-options" id="el-quiz-options">
        ${q.options.map((o, i) => `
          <button class="el-quiz-option" data-i="${i}">
            <span class="el-quiz-option-letter">${letters[i]}</span>
            <span>${o}</span>
          </button>
        `).join('')}
      </div>
    `;
    quizRoot.querySelectorAll('.el-quiz-option').forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = Number(btn.getAttribute('data-i'));
        if (quizAnswered[quizIdx] !== null) return;
        quizAnswered[quizIdx] = i;
        const correct = i === q.answer;
        if (correct) quizScore++;
        quizRoot.querySelectorAll('.el-quiz-option').forEach((b, bi) => {
          (b as HTMLButtonElement).disabled = true;
          if (bi === q.answer) b.classList.add('is-correct');
          if (bi === i && !correct) b.classList.add('is-wrong');
        });
        const ex = document.createElement('div');
        ex.className = 'el-quiz-explanation';
        ex.innerHTML = `<strong style="color: var(--el-pin)">${correct ? 'Correct.' : 'Not quite.'}</strong> ${q.explanation}`;
        quizRoot.appendChild(ex);
        const actions = document.createElement('div');
        actions.className = 'el-quiz-actions';
        actions.innerHTML = `
          ${q.sentenceId ? `<button class="el-btn el-btn-ghost" id="el-quiz-evidence">
            <span class="material-symbols-outlined" style="font-size:14px">north_east</span>
            See evidence
          </button>` : '<span></span>'}
          <button class="el-btn el-btn-primary" id="el-quiz-next">
            ${quizIdx === ARTICLE.quiz.length - 1 ? 'See score' : 'Next'}
            <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
          </button>
        `;
        quizRoot.appendChild(actions);
        document.getElementById('el-quiz-evidence')?.addEventListener('click', () => {
          if (q.sentenceId) highlightSentences([q.sentenceId]);
        });
        document.getElementById('el-quiz-next')?.addEventListener('click', () => { quizIdx++; renderQuiz(); });
      });
    });
  }

  // ============== Review ==============
  const reviewRoot = document.getElementById('el-review-root')!;
  let reviewDeck: string[] = [];
  let reviewIdx = 0;
  let reviewFlipped = false;
  let reviewDone = 0;

  document.getElementById('el-review-begin')?.addEventListener('click', startReview);
  function startReview() {
    reviewDeck = ARTICLE.vocab.map((v) => v.id);
    for (let i = reviewDeck.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [reviewDeck[i], reviewDeck[j]] = [reviewDeck[j], reviewDeck[i]];
    }
    reviewIdx = 0;
    reviewFlipped = false;
    reviewDone = 0;
    renderReview();
  }
  function renderReview() {
    if (reviewIdx >= reviewDeck.length) {
      reviewRoot.innerHTML = `
        <div class="el-quiz-end">
          <span class="material-symbols-outlined el-quiz-icon">verified</span>
          <div class="el-quiz-score">${reviewDone}</div>
          <div class="el-quiz-score-label">Words reviewed</div>
          <button class="el-btn el-btn-primary" id="el-review-restart">Review again</button>
          <button class="el-btn el-btn-ghost" id="el-review-back" style="margin-top:0">
            <span class="material-symbols-outlined" style="font-size:14px">menu_book</span>
            Back to article
          </button>
        </div>
      `;
      document.getElementById('el-review-restart')?.addEventListener('click', startReview);
      document.getElementById('el-review-back')?.addEventListener('click', () => setMode('vocab'));
      return;
    }
    const v = VOCAB_BY_ID[reviewDeck[reviewIdx]];
    const pct = (reviewIdx / reviewDeck.length) * 100;
    reviewRoot.innerHTML = `
      <div class="el-quiz-progress"><div class="el-quiz-progress-fill" style="width: ${pct}%"></div></div>
      <div class="el-quiz-counter">${reviewIdx + 1} / ${reviewDeck.length}</div>
      <div class="el-review-card">
        <div class="el-review-card-front">
          <span class="el-level-tag-shade" data-level="${v.level}">L${v.level}</span>
          <div class="el-review-word">${v.word}</div>
          <div class="el-review-pos">${v.pos}</div>
          ${reviewFlipped ? '' : '<div class="el-review-flip-hint">Click to reveal · Space</div>'}
        </div>
        ${reviewFlipped ? `
          <div class="el-review-back">
            <span class="ipa">${v.ipa}</span>
            <span class="def">${v.defZh}</span>
            <span class="def" style="font-weight: 400; color: rgba(4,47,36,0.6); font-size: 12.5px">${v.defEn}</span>
            <div class="eg">${v.example}${v.exampleZh ? `<br><span style="color:rgba(4,47,36,0.5)">${v.exampleZh}</span>` : ''}</div>
          </div>
        ` : ''}
      </div>
      ${reviewFlipped ? `
        <div class="el-review-rating">
          <button data-rate="0"><span class="label">Again</span><span class="key">Q</span></button>
          <button data-rate="1"><span class="label">Hard</span><span class="key">W</span></button>
          <button data-rate="2"><span class="label">Good</span><span class="key">E</span></button>
          <button data-rate="3"><span class="label">Easy</span><span class="key">R</span></button>
        </div>
      ` : `
        <button class="el-btn el-btn-primary" id="el-review-flip" style="align-self:center">
          <span class="material-symbols-outlined" style="font-size:14px">visibility</span>
          Show meaning
        </button>
      `}
    `;
    document.getElementById('el-review-flip')?.addEventListener('click', () => { reviewFlipped = true; renderReview(); });
    reviewRoot.querySelector('.el-review-card')?.addEventListener('click', () => {
      if (!reviewFlipped) { reviewFlipped = true; renderReview(); }
    });
    reviewRoot.querySelectorAll('.el-review-rating button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const r = Number(btn.getAttribute('data-rate'));
        rateReview(r);
      });
    });
  }
  function rateReview(rating: number) {
    const currentId = reviewDeck[reviewIdx];
    if (rating === 0) {
      reviewDeck.splice(reviewIdx, 1);
      const insertAt = Math.min(reviewDeck.length, reviewIdx + Math.max(3, Math.floor(reviewDeck.length / 3)));
      reviewDeck.splice(insertAt, 0, currentId);
    } else if (rating === 1) {
      reviewDeck.splice(reviewIdx, 1);
      const insertAt = Math.min(reviewDeck.length, reviewIdx + 5);
      reviewDeck.splice(insertAt, 0, currentId);
    } else {
      reviewIdx++;
      reviewDone++;
    }
    reviewFlipped = false;
    renderReview();
  }

  // ============== TTS ==============
  const synth = window.speechSynthesis;
  let ttsQueue: { text: string; sid?: string }[] = [];
  let ttsIdx = 0;
  let ttsPlaying = false;
  let selectedVoice: SpeechSynthesisVoice | null = null;

  function scoreVoice(v: SpeechSynthesisVoice): number {
    const n = v.name.toLowerCase();
    let s = 0;
    if (!v.lang.toLowerCase().startsWith('en')) return -1;
    if (n.includes('natural')) s += 100;
    if (n.includes('online')) s += 30;
    if (n.includes('(premium)') || n.includes('premium')) s += 90;
    if (n.includes('(enhanced)') || n.includes('enhanced')) s += 60;
    const goodApple = ['samantha', 'ava', 'evan', 'allison', 'tom', 'daniel', 'karen', 'moira', 'serena'];
    if (goodApple.some(name => n.includes(name))) s += 40;
    if (n.includes('google')) s += 25;
    if (n.includes('compact')) s -= 20;
    if (n.includes('novelty')) s -= 30;
    if (v.lang.toLowerCase() === 'en-us') s += 8;
    if (v.lang.toLowerCase() === 'en-gb') s += 6;
    if (v.localService) s += 2;
    return s;
  }

  function populateVoiceSelect() {
    const select = document.getElementById('tts-voice') as HTMLSelectElement | null;
    if (!select) return;
    const voices = synth.getVoices();
    const enVoices = voices.filter((v) => v.lang.toLowerCase().startsWith('en'));
    if (enVoices.length === 0) {
      select.innerHTML = '<option value="">No English voice</option>';
      return;
    }
    enVoices.sort((a, b) => scoreVoice(b) - scoreVoice(a));
    selectedVoice = enVoices[0];
    select.innerHTML = enVoices.map((v) => {
      const lang = v.lang.toUpperCase();
      const tag = scoreVoice(v) >= 60 ? ' ★' : '';
      return `<option value="${v.name}" ${v === enVoices[0] ? 'selected' : ''}>${v.name} · ${lang}${tag}</option>`;
    }).join('');
    select.addEventListener('change', () => {
      const v = enVoices.find((x) => x.name === select.value);
      if (v) selectedVoice = v;
    });
  }
  if (synth) {
    populateVoiceSelect();
    if (typeof synth.onvoiceschanged !== 'undefined') {
      synth.onvoiceschanged = populateVoiceSelect;
    }
  }

  function applyVoice(u: SpeechSynthesisUtterance) {
    if (selectedVoice) {
      u.voice = selectedVoice;
      u.lang = selectedVoice.lang;
    } else {
      u.lang = 'en-US';
    }
    u.rate = Number((document.getElementById('tts-rate') as HTMLSelectElement)?.value || 1);
    u.pitch = 1;
  }

  function speakOne(text: string) {
    if (!synth) return;
    synth.cancel();
    const u = new SpeechSynthesisUtterance(text);
    applyVoice(u);
    synth.speak(u);
  }
  function buildTtsQueue() {
    ttsQueue = FLAT_SENTENCES.map((s) => ({ text: s.en, sid: s.id }));
    ttsIdx = 0;
  }
  function startTtsFromIdx(i: number) {
    if (!synth) return;
    if (i >= ttsQueue.length) { stopTts(); return; }
    ttsIdx = i;
    ttsPlaying = true;
    setPlayIcon('pause');
    speakNext();
  }
  function speakNext() {
    if (!ttsPlaying) return;
    if (ttsIdx >= ttsQueue.length) { stopTts(); return; }
    const item = ttsQueue[ttsIdx];
    const u = new SpeechSynthesisUtterance(item.text);
    applyVoice(u);
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
    if (item.sid) {
      const sentEl = document.querySelector(`.sent[data-sid="${item.sid}"]`) as HTMLElement | null;
      sentEl?.classList.add('is-tts');
      if (sentEl) {
        const colRect = articleColEl.getBoundingClientRect();
        const elRect = sentEl.getBoundingClientRect();
        if (elRect.top < colRect.top + 40 || elRect.bottom > colRect.bottom - 40) {
          const targetY = articleColEl.scrollTop + (elRect.top - colRect.top) - colRect.height * 0.4;
          articleColEl.scrollTo({ top: targetY, behavior: 'smooth' });
        }
      }
    }
    u.onend = () => {
      if (!ttsPlaying) return;
      ttsIdx++;
      speakNext();
    };
    synth.speak(u);
  }
  function pauseTts() {
    ttsPlaying = false;
    synth.cancel();
    setPlayIcon('play');
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
  }
  function stopTts() {
    ttsPlaying = false;
    ttsIdx = 0;
    synth.cancel();
    setPlayIcon('play');
    document.querySelectorAll('.sent.is-tts').forEach((el) => el.classList.remove('is-tts'));
  }
  function setPlayIcon(name: 'play' | 'pause') {
    const el = document.getElementById('tts-play-icon');
    if (el) el.textContent = name === 'play' ? 'play_arrow' : 'pause';
  }

  document.getElementById('tts-play')?.addEventListener('click', () => {
    if (ttsPlaying) { pauseTts(); return; }
    if (ttsQueue.length === 0) buildTtsQueue();
    startTtsFromIdx(ttsIdx);
  });
  document.getElementById('tts-stop')?.addEventListener('click', stopTts);

  // ============== Keyboard ==============
  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.tagName === 'SELECT')) return;

    const numMap: Record<string, Mode> = { '1':'vocab','2':'translate','3':'grammar','4':'patterns','5':'quiz','6':'review','7':'about' };
    if (numMap[e.key]) { e.preventDefault(); setMode(numMap[e.key]); return; }

    if (e.code === 'Space') {
      e.preventDefault();
      if (ttsPlaying) { pauseTts(); }
      else { if (ttsQueue.length === 0) buildTtsQueue(); startTtsFromIdx(ttsIdx); }
      return;
    }

    if (e.key === 'Escape') {
      pinVocab(null);
      setActiveSentence(null);
      return;
    }

    if (currentMode === 'translate' && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
      e.preventDefault();
      const idx = activeSentId ? FLAT_SENTENCES.findIndex((s) => s.id === activeSentId) : -1;
      const newIdx = e.key === 'ArrowDown'
        ? Math.min(FLAT_SENTENCES.length - 1, idx + 1)
        : Math.max(0, idx - 1);
      const sid = FLAT_SENTENCES[newIdx].id;
      setActiveSentence(sid);
      jumpToSentence(sid);
      return;
    }

    if (currentMode === 'review' && reviewFlipped) {
      const rateMap: Record<string, number> = { 'q':0, 'w':1, 'e':2, 'r':3 };
      if (rateMap[e.key.toLowerCase()] !== undefined) {
        e.preventDefault();
        rateReview(rateMap[e.key.toLowerCase()]);
      }
    }
  });

  setMode('vocab');
</script>
