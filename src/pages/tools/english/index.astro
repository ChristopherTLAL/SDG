---
// Daily English — landing / level selector.
import MainLayout from '../../../layouts/MainLayout.astro';
import { articles, CEFR_LABELS } from '../../../data/english';

// Group articles by CEFR level so each level surfaces its newest piece + count.
type LevelKey = keyof typeof CEFR_LABELS;
const levelOrder: LevelKey[] = ['A2', 'B1', 'B2', 'C1', 'C2'];
const byLevel = new Map<LevelKey, typeof articles>();
for (const a of articles) {
  const k = a.meta.cefr as LevelKey;
  if (!byLevel.has(k)) byLevel.set(k, []);
  byLevel.get(k)!.push(a);
}
const presentLevels = levelOrder.filter((l) => byLevel.has(l));
---

<MainLayout
  title="Daily English | Chinese SDGs Institute"
  description="A short English news read every day, with hover-to-define vocabulary, sentence translations, grammar notes, and same-session word review. Pick your level."
  lang="en"
>
  <main class="pt-24 md:pt-40 pb-32">

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 md:px-12 mb-16">
      <div class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-8">
        <span class="material-symbols-outlined text-[14px]">menu_book</span>
        Daily English
      </div>
      <h1 class="font-headline font-extrabold text-5xl md:text-6xl text-on-surface tracking-tighter leading-[1.02] mb-8">
        One short article. <span class="text-primary">Every day.</span>
      </h1>
      <p class="font-body text-xl text-on-surface-variant leading-relaxed max-w-2xl">
        Read a five-minute English news piece. Hover any word for a full breakdown — meaning, examples, level. Click a sentence for the Chinese translation. End on a quick comprehension check or a flashcard pass over the day's vocabulary. No account needed.
      </p>
    </section>

    <!-- Level selector -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-32">
      <div class="flex items-baseline justify-between mb-10">
        <div>
          <div class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-2">
            <span class="material-symbols-outlined text-[14px] text-primary">tune</span>
            Pick your level
          </div>
          <h2 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface tracking-tight">
            Today's reads
          </h2>
        </div>
        <div class="text-sm text-on-surface-variant hidden md:block">
          {articles.length} article{articles.length === 1 ? '' : 's'} · CEFR-tagged
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {presentLevels.map((lvl) => {
          const list = byLevel.get(lvl)!;
          const top = list[0];
          const tag = CEFR_LABELS[lvl];
          return (
            <a href={`/tools/english/${top.meta.date}`} class="level-card group">
              <div class="level-card-head">
                <span class="level-card-cefr">{lvl}</span>
                <div class="level-card-tier">
                  <div class="level-card-tier-name">{tag.tier}</div>
                  <div class="level-card-tier-bridge">{tag.bridge}</div>
                </div>
              </div>
              <h3 class="level-card-title">{top.meta.title}</h3>
              {top.meta.editorsNote && (
                <p class="level-card-note">{top.meta.editorsNote}</p>
              )}
              <div class="level-card-foot">
                <span class="level-card-stat">
                  <span class="material-symbols-outlined">schedule</span>
                  {top.meta.readingMinutes} min
                </span>
                <span class="level-card-stat">
                  <span class="material-symbols-outlined">notes</span>
                  {top.meta.wordCount} words
                </span>
                <span class="level-card-stat">
                  <span class="material-symbols-outlined">today</span>
                  {top.meta.date}
                </span>
                {list.length > 1 && (
                  <span class="level-card-stat level-card-stat-more">+ {list.length - 1} more</span>
                )}
                <span class="level-card-cta">
                  Read <span class="material-symbols-outlined">arrow_forward</span>
                </span>
              </div>
            </a>
          );
        })}

        {/* Placeholder cards for missing levels — make the ladder visible */}
        {levelOrder.filter((l) => !byLevel.has(l)).map((lvl) => {
          const tag = CEFR_LABELS[lvl];
          return (
            <div class="level-card level-card--empty">
              <div class="level-card-head">
                <span class="level-card-cefr level-card-cefr--muted">{lvl}</span>
                <div class="level-card-tier">
                  <div class="level-card-tier-name">{tag.tier}</div>
                  <div class="level-card-tier-bridge">{tag.bridge}</div>
                </div>
              </div>
              <p class="level-card-note">No article at this level yet. New pieces are added daily — check back soon.</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- How it works -->
    <section class="bg-surface-container-low py-24 border-y border-outline-variant/10">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-2">
          <span class="material-symbols-outlined text-[14px] text-primary">help</span>
          How it works
        </div>
        <h2 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface tracking-tight mb-12 max-w-2xl">
          One reading interface. Seven different ways to use it.
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">abc</span>
            <h3>Vocabulary</h3>
            <p>Hover any underlined word to see meaning, IPA, level, and a fresh example. Click to pin. Filter by CET4 / CET6 / IELTS / GRE.</p>
          </div>
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">translate</span>
            <h3>Sentence translation</h3>
            <p>Click any sentence to see its Chinese translation in the side panel. Walk forward and back with arrow keys. Toggle full bilingual at any time.</p>
          </div>
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">function</span>
            <h3>Grammar &amp; patterns</h3>
            <p>Each article ships with grammar notes and reusable sentence templates pulled directly from the text. Hover a card to highlight where it appears.</p>
          </div>
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">quiz</span>
            <h3>Comprehension check</h3>
            <p>Five quick multiple-choice questions to confirm you actually read it. See the evidence in-line on the article.</p>
          </div>
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">replay</span>
            <h3>Word review</h3>
            <p>An Anki-style flashcard pass over the day's vocabulary, in your current session. Rate each word and the deck reorders.</p>
          </div>
          <div class="how-card">
            <span class="material-symbols-outlined how-card-icon">volume_up</span>
            <h3>Read aloud</h3>
            <p>Sentence-by-sentence text-to-speech with adjustable rate. Pick the best voice your browser offers — Microsoft Natural and Apple Premium are tagged in the dropdown.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CEFR explainer -->
    <section class="max-w-4xl mx-auto px-6 md:px-12 mt-24">
      <div class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-2">
        <span class="material-symbols-outlined text-[14px] text-primary">school</span>
        Reference
      </div>
      <h2 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface tracking-tight mb-2">
        Not sure of your level?
      </h2>
      <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-10 max-w-2xl">
        These are rough bridges between the Common European Framework (CEFR) and standardized tests Chinese students typically take.
      </p>

      <dl class="cefr-table">
        {levelOrder.map((lvl) => (
          <div>
            <dt>{lvl}</dt>
            <dd>
              <strong>{CEFR_LABELS[lvl].tier}</strong>
              <span>{CEFR_LABELS[lvl].bridge}</span>
            </dd>
          </div>
        ))}
      </dl>
    </section>

  </main>
</MainLayout>

<style>
  /* Level cards */
  .level-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.10);
    border-radius: 24px;
    padding: 28px 28px 22px;
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .level-card:not(.level-card--empty):hover {
    border-color: rgba(4, 47, 36, 0.30);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -16px rgba(4, 47, 36, 0.18);
  }
  .level-card--empty {
    background: rgba(4, 47, 36, 0.02);
    border-style: dashed;
  }

  .level-card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(4, 47, 36, 0.08);
  }
  .level-card-cefr {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #042f24;
    line-height: 1;
    letter-spacing: -0.02em;
    background: rgba(4, 47, 36, 0.06);
    border-radius: 10px;
    padding: 10px 12px 8px;
    flex-shrink: 0;
  }
  .level-card-cefr--muted {
    color: rgba(4, 47, 36, 0.4);
    background: transparent;
    border: 1px dashed rgba(4, 47, 36, 0.15);
  }
  .level-card-tier-name {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: #042f24;
    letter-spacing: -0.005em;
  }
  .level-card-tier-bridge {
    font-size: 11.5px;
    color: rgba(4, 47, 36, 0.55);
    margin-top: 2px;
  }

  .level-card-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    line-height: 1.15;
    color: #042f24;
    letter-spacing: -0.015em;
  }
  .level-card-note {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(4, 47, 36, 0.62);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .level-card--empty .level-card-note {
    -webkit-line-clamp: unset;
  }
  .level-card-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px 18px;
    padding-top: 14px;
    border-top: 1px solid rgba(4, 47, 36, 0.08);
  }
  .level-card-stat {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: rgba(4, 47, 36, 0.55);
  }
  .level-card-stat .material-symbols-outlined { font-size: 14px; opacity: 0.75; }
  .level-card-stat-more {
    font-weight: 700;
    color: #042f24;
  }
  .level-card-cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12.5px;
    font-weight: 700;
    color: #042f24;
    transition: transform 150ms ease;
  }
  .level-card-cta .material-symbols-outlined { font-size: 16px; }
  .level-card:hover .level-card-cta {
    transform: translateX(2px);
  }

  /* How-it-works cards */
  .how-card {
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.10);
    border-radius: 18px;
    padding: 22px 24px 24px;
    transition: border-color 150ms ease;
  }
  .how-card:hover {
    border-color: rgba(4, 47, 36, 0.25);
  }
  .how-card-icon {
    color: #042f24;
    background: rgba(4, 47, 36, 0.06);
    width: 40px; height: 40px;
    border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 22px !important;
    margin-bottom: 14px;
  }
  .how-card h3 {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.0625rem;
    color: #042f24;
    letter-spacing: -0.005em;
    margin-bottom: 6px;
  }
  .how-card p {
    font-size: 13.5px;
    line-height: 1.6;
    color: rgba(4, 47, 36, 0.65);
  }

  /* CEFR table */
  .cefr-table {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(4, 47, 36, 0.10);
  }
  .cefr-table > div {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(4, 47, 36, 0.10);
    align-items: baseline;
  }
  .cefr-table dt {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #042f24;
    letter-spacing: -0.01em;
  }
  .cefr-table dd {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cefr-table dd strong {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: #042f24;
  }
  .cefr-table dd span {
    font-size: 13px;
    color: rgba(4, 47, 36, 0.6);
  }
</style>
