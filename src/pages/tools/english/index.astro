---
// English library — fixed-height database view with sidebar filter, search, and internal scrolling.
import MainLayout from '../../../layouts/MainLayout.astro';
import { articles, CEFR_LABELS } from '../../../data/english';
import topicsRaw from '../../../../data/english-topics.json';

type LevelKey = keyof typeof CEFR_LABELS;
const levelOrder: LevelKey[] = ['A2', 'B1', 'B2', 'C1', 'C2'];

// Build slug -> tags lookup from topics DB.
const slugToTags = new Map<string, string[]>();
for (const t of (topicsRaw.topics as { articles?: { slug?: string }[]; tags?: string[] }[])) {
  for (const a of t.articles ?? []) {
    if (a.slug) slugToTags.set(a.slug, t.tags ?? []);
  }
}

// Compact list rows for client-side filtering.
const rows = articles.map((a) => ({
  slug: a.meta.date,
  date: a.meta.date,
  title: a.meta.title,
  titleZh: a.meta.titleZh ?? '',
  cefr: a.meta.cefr,
  minutes: a.meta.readingMinutes,
  words: a.meta.wordCount,
  tags: slugToTags.get(a.meta.date) ?? [],
}));

// Counts for sidebar
const cefrCounts: Record<string, number> = {};
for (const r of rows) cefrCounts[r.cefr] = (cefrCounts[r.cefr] ?? 0) + 1;

const tagCounts: Record<string, number> = {};
for (const r of rows) for (const t of r.tags) tagCounts[t] = (tagCounts[t] ?? 0) + 1;
const sortedTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 20)
  .map(([t, c]) => ({ tag: t, count: c }));

const totalCount = rows.length;
const rowsJson = JSON.stringify(rows);
---

<MainLayout
  title="English | Chinese SDGs Institute"
  description="A library of short English news articles with hover-to-define vocabulary, sentence translations, grammar notes, and same-session word review. Filter by CEFR level and topic."
  lang="en"
>
  <main class="english-lib">

    <!-- Compact header -->
    <div class="lib-header">
      <div class="lib-header-inner">
        <div class="lib-title-block">
          <div class="lib-eyebrow">
            <span class="material-symbols-outlined">menu_book</span>
            English Library
          </div>
          <h1 class="lib-title">
            <span class="lib-count" id="lib-count">{totalCount}</span>
            <span class="lib-of-total"> of {totalCount}</span>
            articles
          </h1>
        </div>
        <div class="lib-search">
          <span class="material-symbols-outlined lib-search-icon">search</span>
          <input
            type="text"
            id="lib-search-input"
            placeholder="Search title or tag..."
            autocomplete="off"
          />
        </div>
      </div>
    </div>

    <!-- Fixed-height filter + list shell -->
    <div class="lib-shell">
      <aside class="lib-sidebar">
        <div class="lib-filter-group">
          <div class="lib-filter-head">Level</div>
          <button class="lib-filter-row is-on" data-filter="cefr" data-value="">
            <span>All</span>
            <span class="lib-filter-num">{totalCount}</span>
          </button>
          {levelOrder.filter((l) => cefrCounts[l]).map((l) => (
            <button class="lib-filter-row" data-filter="cefr" data-value={l}>
              <span class="lib-cefr-pill">{l}</span>
              <span class="lib-filter-name">{CEFR_LABELS[l].tier}</span>
              <span class="lib-filter-num">{cefrCounts[l] ?? 0}</span>
            </button>
          ))}
        </div>

        {sortedTags.length > 0 && (
          <div class="lib-filter-group">
            <div class="lib-filter-head">Topic</div>
            {sortedTags.map(({ tag, count }) => (
              <button class="lib-filter-row" data-filter="tag" data-value={tag}>
                <span class="lib-filter-name">{tag}</span>
                <span class="lib-filter-num">{count}</span>
              </button>
            ))}
          </div>
        )}

        <div class="lib-filter-group lib-filter-clear-group">
          <button id="lib-clear" class="lib-clear-btn">
            <span class="material-symbols-outlined">refresh</span>
            Clear filters
          </button>
        </div>
      </aside>

      <div class="lib-main">
        <div class="lib-list-body" id="lib-list-body">
          <!-- Cards are rendered client-side from JSON -->
        </div>
        <div class="lib-list-empty" id="lib-list-empty" hidden>
          <span class="material-symbols-outlined">inbox</span>
          <p>No articles match these filters.</p>
        </div>
      </div>
    </div>

  </main>

  <script type="application/json" id="lib-data" set:html={rowsJson}></script>
</MainLayout>

<style is:global>
  body.english-library-page { overflow: hidden; height: 100vh; }
  body.english-library-page footer { display: none; }

  .english-lib {
    position: fixed;
    top: 5rem;
    left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    background: white;
  }

  /* ===== Header ===== */
  .lib-header {
    flex-shrink: 0;
    background: white;
    border-bottom: 1px solid rgba(4, 47, 36, 0.10);
  }
  .lib-header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 16px 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .lib-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(4, 47, 36, 0.65);
    margin-bottom: 4px;
  }
  .lib-eyebrow .material-symbols-outlined {
    font-size: 14px;
    color: #042f24;
  }
  .lib-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #042f24;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .lib-count {
    font-variant-numeric: tabular-nums;
  }
  .lib-of-total {
    font-weight: 500;
    color: rgba(4, 47, 36, 0.5);
    font-size: 1rem;
  }
  .lib-search {
    position: relative;
    flex: 0 0 320px;
    max-width: 320px;
  }
  .lib-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px !important;
    color: rgba(4, 47, 36, 0.45);
    pointer-events: none;
  }
  .lib-search input {
    width: 100%;
    height: 38px;
    padding: 0 12px 0 38px;
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.15);
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #042f24;
    transition: border-color 120ms ease;
  }
  .lib-search input:focus {
    outline: none;
    border-color: #042f24;
  }

  /* ===== Shell ===== */
  .lib-shell {
    flex: 1;
    min-height: 0;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 1rem 1.5rem 1.25rem;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
  }
  @media (max-width: 1023px) {
    .lib-shell { grid-template-columns: 1fr; }
    .lib-sidebar { display: none; }
  }

  /* ===== Sidebar ===== */
  .lib-sidebar {
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.10);
    border-radius: 12px;
    overflow-y: auto;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .lib-filter-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .lib-filter-head {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: rgba(4, 47, 36, 0.55);
    padding: 0 8px 6px;
  }
  .lib-filter-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    color: rgba(4, 47, 36, 0.78);
    transition: background 100ms ease;
  }
  .lib-filter-row:hover { background: rgba(4, 47, 36, 0.04); }
  .lib-filter-row.is-on {
    background: rgba(4, 47, 36, 0.08);
    color: #042f24;
    font-weight: 600;
  }
  .lib-filter-name {
    flex: 1;
    min-width: 0;
    text-transform: capitalize;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lib-filter-num {
    flex-shrink: 0;
    font-size: 10.5px;
    font-weight: 700;
    color: rgba(4, 47, 36, 0.45);
    font-variant-numeric: tabular-nums;
  }
  .lib-filter-row.is-on .lib-filter-num { color: rgba(4, 47, 36, 0.6); }

  .lib-cefr-pill {
    display: inline-block;
    flex-shrink: 0;
    width: 26px;
    text-align: center;
    padding: 2px 0;
    background: #042f24;
    color: white;
    border-radius: 4px;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.04em;
  }

  .lib-clear-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: transparent;
    border: 1px solid rgba(4, 47, 36, 0.15);
    border-radius: 6px;
    cursor: pointer;
    font-size: 11.5px;
    font-weight: 600;
    color: rgba(4, 47, 36, 0.65);
  }
  .lib-clear-btn:hover { background: rgba(4, 47, 36, 0.04); color: #042f24; }
  .lib-clear-btn .material-symbols-outlined { font-size: 14px; }

  /* ===== Main card grid ===== */
  .lib-main {
    background: transparent;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
  }
  .lib-list-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
    padding: 4px 4px 20px;
    align-content: start;
  }
  .lib-list-body:empty { display: none; }

  /* CEFR ladder — card stays pure white. Pill, accent bar, and watermark letter
     are the only carriers of the emerald scale. */
  .lib-card[data-cefr="A2"] {
    --pill-bg: #e6f1ea; --pill-fg: #2c6244;
    --accent: #cfe3d6; --watermark: rgba(91, 155, 115, 0.10);
  }
  .lib-card[data-cefr="B1"] {
    --pill-bg: #c5dfcf; --pill-fg: #1f5236;
    --accent: #a8cfb6; --watermark: rgba(63, 130, 96, 0.11);
  }
  .lib-card[data-cefr="B2"] {
    --pill-bg: #6fa982; --pill-fg: #ffffff;
    --accent: #6fa982; --watermark: rgba(47, 114, 82, 0.12);
  }
  .lib-card[data-cefr="C1"] {
    --pill-bg: #2e6b50; --pill-fg: #ffffff;
    --accent: #2e6b50; --watermark: rgba(15, 74, 53, 0.13);
  }
  .lib-card[data-cefr="C2"] {
    --pill-bg: #042f24; --pill-fg: #ffffff;
    --accent: #042f24; --watermark: rgba(4, 47, 36, 0.14);
  }

  .lib-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 240px;
    padding: 22px 22px 18px;
    border-radius: 16px;
    text-decoration: none;
    color: #042f24;
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.07);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
    overflow: hidden;
    isolation: isolate;
  }
  /* Big translucent CEFR letter watermark in bottom-right */
  .lib-card::after {
    content: attr(data-cefr);
    position: absolute;
    right: -10px;
    bottom: -28px;
    font-family: 'Manrope', sans-serif;
    font-weight: 900;
    font-size: 140px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--watermark);
    pointer-events: none;
    z-index: 0;
  }
  /* Slim accent bar on the left, color from the CEFR ladder. */
  .lib-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    z-index: 1;
  }
  .lib-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -16px rgba(4, 47, 36, 0.22);
    border-color: rgba(4, 47, 36, 0.16);
  }
  .lib-card > * { position: relative; z-index: 2; }

  .lib-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .lib-card-cefr {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    background: var(--pill);
    color: white;
    border-radius: 6px;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .lib-card-date {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.10em;
    color: rgba(4, 47, 36, 0.62);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }
  .lib-card-meta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    color: rgba(4, 47, 36, 0.62);
    font-variant-numeric: tabular-nums;
  }
  .lib-card-meta .material-symbols-outlined {
    font-size: 13px;
    opacity: 0.8;
  }
  .lib-card-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: #042f24;
    line-height: 1.30;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lib-card-title-zh {
    margin-top: 6px;
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Source Han Sans SC', sans-serif;
    font-weight: 500;
    font-size: 12.5px;
    color: rgba(4, 47, 36, 0.62);
    line-height: 1.5;
    letter-spacing: 0.02em;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .lib-card:hover .lib-card-title { text-decoration: underline; text-underline-offset: 4px; }
  .lib-card-divider {
    height: 1px;
    background: rgba(4, 47, 36, 0.12);
    margin: 14px 0 12px;
  }
  .lib-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
  }
  .lib-card-tag {
    display: inline-block;
    padding: 3px 9px;
    background: rgba(4, 47, 36, 0.10);
    color: rgba(4, 47, 36, 0.78);
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    text-transform: capitalize;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .lib-list-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: rgba(4, 47, 36, 0.45);
    padding: 48px 16px;
  }
  .lib-list-empty[hidden] { display: none !important; }
  .lib-list-empty .material-symbols-outlined {
    font-size: 32px;
    margin-bottom: 8px;
    opacity: 0.55;
  }
  .lib-list-empty p { font-size: 13.5px; }
</style>

<script>
  document.body.classList.add('english-library-page');

  type Row = {
    slug: string;
    date: string;
    title: string;
    titleZh: string;
    cefr: string;
    minutes: number;
    words: number;
    tags: string[];
  };

  const dataEl = document.getElementById('lib-data');
  const ROWS: Row[] = JSON.parse(dataEl?.textContent || '[]');

  // Sort newest first
  ROWS.sort((a, b) => b.date.localeCompare(a.date));

  const state = {
    cefr: '',
    tags: new Set<string>(),
    search: '',
  };

  const listBody = document.getElementById('lib-list-body')!;
  const empty = document.getElementById('lib-list-empty')!;
  const countEl = document.getElementById('lib-count')!;
  const searchInput = document.getElementById('lib-search-input') as HTMLInputElement;

  function applyAndRender() {
    const q = state.search.trim().toLowerCase();
    const filtered = ROWS.filter((r) => {
      if (state.cefr && r.cefr !== state.cefr) return false;
      if (state.tags.size > 0 && !r.tags.some((t) => state.tags.has(t))) return false;
      if (q) {
        const hay = (r.title + ' ' + r.tags.join(' ')).toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });

    countEl.textContent = String(filtered.length);

    if (filtered.length === 0) {
      listBody.innerHTML = '';
      (empty as HTMLElement).hidden = false;
      return;
    }
    (empty as HTMLElement).hidden = true;

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const html = filtered.map((r) => {
      const dateLabel = formatRelativeDate(r.date, today);
      const visibleTags = r.tags.slice(0, 3);
      const moreCount = r.tags.length - visibleTags.length;
      const tagsHtml = visibleTags.map((t) => `<span class="lib-card-tag">${escapeHtml(t)}</span>`).join('');
      const moreHtml = moreCount > 0 ? `<span class="lib-card-tag" style="opacity:0.6">+${moreCount}</span>` : '';
      const zhHtml = r.titleZh
        ? `<div class="lib-card-title-zh">${escapeHtml(r.titleZh)}</div>`
        : '';
      return `
        <a class="lib-card" data-cefr="${r.cefr}" href="/tools/english/${r.slug}">
          <div class="lib-card-top">
            <span class="lib-card-cefr">${r.cefr}</span>
            <span class="lib-card-date">${dateLabel}</span>
            <span class="lib-card-meta"><span class="material-symbols-outlined">schedule</span>${r.minutes}m</span>
          </div>
          <div class="lib-card-title">${escapeHtml(r.title)}</div>
          ${zhHtml}
          <div class="lib-card-divider"></div>
          <div class="lib-card-tags">${tagsHtml}${moreHtml}</div>
        </a>
      `;
    }).join('');
    listBody.innerHTML = html;
  }

  function formatRelativeDate(iso: string, today: Date): string {
    // iso is YYYY-MM-DD (the article's meta.date)
    const [y, m, d] = iso.split('-').map(Number);
    const dt = new Date(y, m - 1, d);
    dt.setHours(0, 0, 0, 0);
    const daysAgo = Math.round((today.getTime() - dt.getTime()) / (1000 * 60 * 60 * 24));
    if (daysAgo === 0) return 'Today';
    if (daysAgo === 1) return 'Yesterday';
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const sameYear = dt.getFullYear() === today.getFullYear();
    return sameYear
      ? `${months[dt.getMonth()]} ${dt.getDate()}`
      : `${months[dt.getMonth()]} ${dt.getDate()}, ${dt.getFullYear()}`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // CEFR filter buttons (single-select; empty data-value = All)
  document.querySelectorAll<HTMLButtonElement>('[data-filter="cefr"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.getAttribute('data-value') || '';
      state.cefr = v;
      document.querySelectorAll<HTMLButtonElement>('[data-filter="cefr"]').forEach((b) => {
        b.classList.toggle('is-on', (b.getAttribute('data-value') || '') === v);
      });
      applyAndRender();
    });
  });

  // Tag filter buttons (multi-select)
  document.querySelectorAll<HTMLButtonElement>('[data-filter="tag"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.getAttribute('data-value') || '';
      if (state.tags.has(v)) state.tags.delete(v);
      else state.tags.add(v);
      btn.classList.toggle('is-on', state.tags.has(v));
      applyAndRender();
    });
  });

  // Search
  searchInput?.addEventListener('input', () => {
    state.search = searchInput.value;
    applyAndRender();
  });

  // Clear all filters
  document.getElementById('lib-clear')?.addEventListener('click', () => {
    state.cefr = '';
    state.tags.clear();
    state.search = '';
    searchInput.value = '';
    document.querySelectorAll<HTMLButtonElement>('[data-filter="cefr"]').forEach((b) => {
      b.classList.toggle('is-on', !b.getAttribute('data-value'));
    });
    document.querySelectorAll<HTMLButtonElement>('[data-filter="tag"]').forEach((b) => {
      b.classList.remove('is-on');
    });
    applyAndRender();
  });

  applyAndRender();
</script>
