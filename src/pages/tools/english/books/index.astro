---
// Bookshelf: a grid of themed English reading books. Each book is an ordered
// collection of chapters that reuse the daily-library learning engine.
import MainLayout from '../../../../layouts/MainLayout.astro';
import { bookEntries } from '../../../../data/english/books';
import { CEFR_LABELS } from '../../../../data/english';

// Static reading content — prerender to static HTML (off the serverless function).
export const prerender = true;
const books = bookEntries;
---

<MainLayout
  title="English Books | Chinese SDGs Institute"
  description="Themed English reading books built from real news, with hover-to-define vocabulary, grammar, listening audio, and writing practice. Read by chapter or export to PDF."
  lang="en"
>
  <main class="shelf">
    <header class="shelf-head">
      <div class="shelf-eyebrow">
        <span class="material-symbols-outlined">auto_stories</span>
        English Books
      </div>
      <h1 class="shelf-title">Reading, by the book</h1>
      <p class="shelf-sub">
        Themed collections built from real news. Each chapter has hover-to-define vocabulary,
        grammar and pattern lessons, listening audio, and a writing task. Read online or export to PDF.
      </p>
      <a href="/tools/english/" class="shelf-altlink">
        <span class="material-symbols-outlined">bolt</span>
        Looking for the daily article library instead?
      </a>
    </header>

    {books.length === 0 ? (
      <div class="shelf-empty">
        <span class="material-symbols-outlined">menu_book</span>
        <p>No books yet. Check back soon.</p>
      </div>
    ) : (
      <div class="shelf-grid">
        {books.map((b) => (
          <a class="book-card" href={`/tools/english/books/${b.meta.id}`}>
            <div class="book-cover" style={`--accent:${b.meta.accent ?? '#042f24'}`}>
              {b.meta.cover ? (
                <img src={b.meta.cover} alt={b.meta.title} loading="lazy" />
              ) : (
                <div class="book-cover-fallback">
                  <span class="book-cover-title">{b.meta.title}</span>
                </div>
              )}
              <span class="book-cefr">{b.meta.cefr}</span>
            </div>
            <div class="book-body">
              <h2 class="book-title">{b.meta.title}</h2>
              {b.meta.titleZh && <p class="book-title-zh">{b.meta.titleZh}</p>}
              <p class="book-blurb">{b.meta.blurb}</p>
              <div class="book-foot">
                <span class="book-chip">
                  <span class="material-symbols-outlined">menu_book</span>
                  {b.chapters.length} {b.chapters.length === 1 ? 'chapter' : 'chapters'}
                </span>
                <span class="book-chip">{CEFR_LABELS[b.meta.cefr]?.tier ?? b.meta.cefr}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</MainLayout>

<style>
  .shelf {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6.5rem 1.5rem 5rem;
  }
  .shelf-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(4, 47, 36, 0.7);
    margin-bottom: 10px;
  }
  .shelf-eyebrow .material-symbols-outlined { font-size: 16px; color: #042f24; }
  .shelf-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: #042f24;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .shelf-sub {
    margin-top: 0.75rem;
    max-width: 640px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(4, 47, 36, 0.7);
  }
  .shelf-altlink {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 1rem;
    font-size: 13px;
    font-weight: 600;
    color: rgba(4, 47, 36, 0.6);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .shelf-altlink:hover { color: #042f24; border-bottom-color: #042f24; }
  .shelf-altlink .material-symbols-outlined { font-size: 16px; }

  .shelf-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: white;
    border: 1px solid rgba(4, 47, 36, 0.08);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  .book-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -22px rgba(4, 47, 36, 0.35);
    border-color: rgba(4, 47, 36, 0.16);
  }

  .book-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .book-cover img { width: 100%; height: 100%; object-fit: cover; }
  .book-cover-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 100%, white 0%), color-mix(in srgb, var(--accent) 70%, black 20%));
  }
  .book-cover-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    line-height: 1.15;
    color: white;
    text-align: center;
    letter-spacing: -0.01em;
  }
  .book-cefr {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 3px 9px;
    background: rgba(255, 255, 255, 0.92);
    color: #042f24;
    border-radius: 6px;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  .book-body { padding: 18px 20px 20px; display: flex; flex-direction: column; flex: 1; }
  .book-title {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: #042f24;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .book-title-zh {
    margin-top: 3px;
    font-size: 13px;
    color: rgba(4, 47, 36, 0.6);
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Source Han Sans SC', sans-serif;
  }
  .book-blurb {
    margin-top: 10px;
    font-size: 13.5px;
    line-height: 1.55;
    color: rgba(4, 47, 36, 0.68);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .book-foot {
    margin-top: 16px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .book-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: rgba(4, 47, 36, 0.07);
    color: rgba(4, 47, 36, 0.78);
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 600;
  }
  .book-chip .material-symbols-outlined { font-size: 14px; }

  .shelf-empty {
    margin-top: 4rem;
    text-align: center;
    color: rgba(4, 47, 36, 0.45);
  }
  .shelf-empty .material-symbols-outlined { font-size: 40px; }
</style>
