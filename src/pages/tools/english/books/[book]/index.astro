---
// Book table of contents: cover, blurb, and an ordered chapter list.
import MainLayout from '../../../../../layouts/MainLayout.astro';
import { booksById } from '../../../../../data/english/books';
import { CEFR_LABELS } from '../../../../../data/english';

const { book: bookId } = Astro.params;
const book = bookId ? booksById[bookId] : undefined;
if (!book) {
  return Astro.redirect('/tools/english/books/');
}
const { meta, chapters } = book;
---

<MainLayout
  title={`${meta.title} | English Books`}
  description={meta.blurb}
  lang="en"
>
  <main class="toc">
    <a href="/tools/english/books/" class="toc-back">
      <span class="material-symbols-outlined">arrow_back</span>
      All books
    </a>

    <header class="toc-head">
      <div class="toc-cover" style={`--accent:${meta.accent ?? '#042f24'}`}>
        {meta.cover ? (
          <img src={meta.cover} alt={meta.title} />
        ) : (
          <div class="toc-cover-fallback"><span>{meta.title}</span></div>
        )}
      </div>
      <div class="toc-headmeta">
        <div class="toc-eyebrow">
          <span class="toc-cefr">{meta.cefr}</span>
          <span>{CEFR_LABELS[meta.cefr]?.tier ?? meta.cefr}</span>
          <span class="toc-dot"></span>
          <span>{chapters.length} {chapters.length === 1 ? 'chapter' : 'chapters'}</span>
        </div>
        <h1 class="toc-title">{meta.title}</h1>
        {meta.titleZh && <p class="toc-title-zh">{meta.titleZh}</p>}
        <p class="toc-blurb">{meta.blurb}</p>
        {meta.blurbZh && <p class="toc-blurb-zh">{meta.blurbZh}</p>}
      </div>
    </header>

    {chapters.length === 0 ? (
      <div class="toc-empty">
        <span class="material-symbols-outlined">hourglass_empty</span>
        <p>Chapters are being prepared. Check back soon.</p>
      </div>
    ) : (
      <ol class="toc-list">
        {chapters.map((ch) => (
          <li class="toc-row">
            <a href={`/tools/english/books/${meta.id}/${ch.slug}`} class="toc-link">
              <span class="toc-num">{String(ch.order).padStart(2, '0')}</span>
              <span class="toc-rowmeta">
                <span class="toc-rowtitle">{ch.article.meta.title}</span>
                {ch.article.meta.titleZh && (
                  <span class="toc-rowtitle-zh">{ch.article.meta.titleZh}</span>
                )}
              </span>
              <span class="toc-rowtail">
                <span class="toc-rowmin">{ch.article.meta.readingMinutes} min</span>
                {ch.article.meta.audioUrl && (
                  <span class="material-symbols-outlined toc-audio" title="Listening audio">headphones</span>
                )}
                <span class="material-symbols-outlined toc-chev">chevron_right</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    )}
  </main>
</MainLayout>

<style>
  .toc { max-width: 820px; margin: 0 auto; padding: 6rem 1.5rem 5rem; }
  .toc-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600;
    color: rgba(4, 47, 36, 0.65); text-decoration: none;
    margin-bottom: 1.75rem;
  }
  .toc-back:hover { color: #042f24; }
  .toc-back .material-symbols-outlined { font-size: 18px; }

  .toc-head { display: flex; gap: 1.75rem; align-items: stretch; }
  @media (max-width: 639px) { .toc-head { flex-direction: column; gap: 1.25rem; } }
  .toc-cover {
    flex: 0 0 200px;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    background: var(--accent);
    box-shadow: 0 16px 36px -20px rgba(4, 47, 36, 0.45);
  }
  .toc-cover img { width: 100%; height: 100%; object-fit: cover; }
  .toc-cover-fallback {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    padding: 1.25rem; text-align: center;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 100%, white 0%), color-mix(in srgb, var(--accent) 65%, black 25%));
  }
  .toc-cover-fallback span {
    font-family: 'Manrope', sans-serif; font-weight: 800;
    font-size: 1.3rem; color: white; line-height: 1.15;
  }
  .toc-headmeta { flex: 1; min-width: 0; align-self: center; }
  .toc-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: rgba(4, 47, 36, 0.6);
    margin-bottom: 10px;
  }
  .toc-cefr {
    padding: 2px 8px; background: #042f24; color: white;
    border-radius: 5px; font-weight: 800; font-size: 10.5px;
  }
  .toc-dot { width: 3px; height: 3px; border-radius: 999px; background: currentColor; opacity: 0.5; }
  .toc-title {
    font-family: 'Manrope', sans-serif; font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem); color: #042f24;
    letter-spacing: -0.02em; line-height: 1.08;
  }
  .toc-title-zh { margin-top: 6px; font-size: 1rem; color: rgba(4, 47, 36, 0.6);
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Source Han Sans SC', sans-serif; }
  .toc-blurb { margin-top: 1rem; font-size: 0.95rem; line-height: 1.6; color: rgba(4, 47, 36, 0.72); }
  .toc-blurb-zh { margin-top: 0.5rem; font-size: 0.9rem; line-height: 1.6; color: rgba(4, 47, 36, 0.55);
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Source Han Sans SC', sans-serif; }

  .toc-list { list-style: none; margin: 2.5rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
  .toc-link {
    display: flex; align-items: center; gap: 16px;
    padding: 14px 12px; border-radius: 12px;
    text-decoration: none; color: #042f24;
    border: 1px solid transparent;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .toc-link:hover { background: rgba(4, 47, 36, 0.04); border-color: rgba(4, 47, 36, 0.08); }
  .toc-num {
    flex: 0 0 auto;
    font-family: 'Manrope', sans-serif; font-weight: 800;
    font-size: 1.1rem; color: rgba(4, 47, 36, 0.32);
    font-variant-numeric: tabular-nums; width: 2ch;
  }
  .toc-rowmeta { flex: 1; min-width: 0; }
  .toc-rowtitle { display: block; font-weight: 700; font-size: 1rem; line-height: 1.25; }
  .toc-rowtitle-zh { display: block; margin-top: 2px; font-size: 12.5px; color: rgba(4, 47, 36, 0.55);
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Source Han Sans SC', sans-serif; }
  .toc-rowtail { flex: 0 0 auto; display: inline-flex; align-items: center; gap: 10px;
    color: rgba(4, 47, 36, 0.5); font-size: 12px; font-weight: 600; }
  .toc-audio { font-size: 17px !important; color: #042f24; opacity: 0.7; }
  .toc-chev { font-size: 20px !important; }

  .toc-empty { margin-top: 3rem; text-align: center; color: rgba(4, 47, 36, 0.45); }
  .toc-empty .material-symbols-outlined { font-size: 36px; }
</style>
