---
// Print / PDF view for a whole book (cover + TOC + all chapters).
//   /tools/english/books/<id>/print
// Single-chapter print lives at ./print/[chapter].astro
import EnglishPrintLayout from '../../../../../layouts/EnglishPrintLayout.astro';
import ChapterPrint from '../../../../../components/english/ChapterPrint.astro';
import { booksById } from '../../../../../data/english/books';

// Static reading content — prerender to static HTML (off the serverless function).
export const prerender = true;
export function getStaticPaths() {
  return Object.keys(booksById).map((book) => ({ params: { book } }));
}

const { book: bookId } = Astro.params;
const book = bookId ? booksById[bookId] : undefined;
if (!book) return Astro.redirect('/tools/english/books/');

const chapters = book.chapters;
const isWhole = true;
const { meta } = book;
const SITE = 'https://sdg.undp.ac.cn';
const backHref = `/tools/english/books/${meta.id}`;
const docTitle = meta.title;
---
<EnglishPrintLayout docTitle={docTitle} accent={meta.accent ?? '#042f24'} backHref={backHref}>
  {isWhole && (
    <section class="rp-cover">
      <div class="rp-cover-eyebrow">English Reading Book · {meta.cefr}</div>
      <h1 class="rp-cover-title">{meta.title}</h1>
      {meta.titleZh && <p class="rp-cover-zh">{meta.titleZh}</p>}
      <div class="rp-cover-rule"></div>
      <p class="rp-cover-blurb">{meta.blurb}</p>
      {meta.blurbZh && <p class="rp-cover-blurb-zh">{meta.blurbZh}</p>}
      <p class="rp-cover-meta">{chapters.length} chapters · Vocabulary · Grammar · Listening · Writing</p>
    </section>
  )}

  {isWhole && (
    <section class="rp-toc">
      <h2 class="rp-toc-title">Contents</h2>
      <ol class="rp-toc-list">
        {chapters.map((ch) => (
          <li class="rp-toc-row">
            <span class="rp-toc-num">{String(ch.order).padStart(2, '0')}</span>
            <span class="rp-toc-rt">
              {ch.article.meta.title}
              {ch.article.meta.titleZh && <span class="rp-toc-rt-zh">{ch.article.meta.titleZh}</span>}
            </span>
          </li>
        ))}
      </ol>
    </section>
  )}

  {chapters.map((ch) => (
    <ChapterPrint
      article={ch.article}
      eyebrow={`${meta.title} · Chapter ${String(ch.order).padStart(2, '0')}`}
      chapterUrl={`${SITE}/tools/english/books/${meta.id}/${ch.slug}`}
    />
  ))}
</EnglishPrintLayout>
