---
// src/pages/tools/interview.astro — Unified Interview Practice Platform
import MainLayout from '../../layouts/MainLayout.astro';
const lang = 'en';
---

<MainLayout title="Interview Practice | Chinese SDGs Institute" description="Practice for HKU Multifaceted Excellence, Oxbridge tutorials, general admissions interviews, or import your own question bank." lang={lang}>
  <main class="pt-24 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 md:px-12">

      <!-- Back link -->
      <a href="/tools" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Back to Tools
      </a>

      <!-- ==================== SCREEN 0: MODE SELECTOR ==================== -->
      <div id="screen-mode" class="fade-in">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-5">
            <span class="material-symbols-outlined text-[14px]">mic</span>
            Interview Practice
          </div>
          <h1 class="font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl text-on-surface tracking-tighter leading-[1.05] mb-4">
            Mock Interview<br /><span class="text-primary">Simulator</span>
          </h1>
          <p class="text-on-surface-variant text-base md:text-lg max-w-2xl mx-auto">
            Choose a practice mode below. Each mode simulates a different interview format with appropriate timing, prompts, and recording options.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
          <!-- HKU Mode -->
          <button onclick="selectMode('hku')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-primary text-2xl">diversity_3</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-primary text-white">26 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-primary transition-colors">HKU Multifaceted Excellence</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">30-second reading period, 2-minute timed response with audio recording.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 30s + 2min</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- Oxbridge Mode -->
          <button onclick="selectMode('oxbridge')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center group-hover:bg-amber-100 transition-colors">
                <span class="material-symbols-outlined text-amber-700 text-2xl">school</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-amber-600 text-white" id="oxbridge-count">13 Subjects · 239 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-amber-700 transition-colors">Oxbridge Tutorial Interview</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Read a question or passage at your own pace, then click to start recording with no time limit.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- General Mode -->
          <button onclick="selectMode('general')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center group-hover:bg-emerald-100 transition-colors">
                <span class="material-symbols-outlined text-emerald-700 text-2xl">forum</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-emerald-600 text-white">20 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-emerald-700 transition-colors">General Admissions Interview</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Common admissions questions with analysis frameworks and suggested strategies.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 10s + 2min</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- Custom Import Mode -->
          <button onclick="selectMode('custom')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-violet-50 rounded-xl flex items-center justify-center group-hover:bg-violet-100 transition-colors">
                <span class="material-symbols-outlined text-violet-700 text-2xl">upload_file</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-violet-600 text-white">DIY</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-violet-700 transition-colors">Import Your Own Questions</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Paste from spreadsheet, upload CSV/JSON, or type questions manually. Fully customizable timing.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">table</span> CSV/JSON</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">tune</span> Custom Timing</span>
            </div>
          </button>
        </div>
      </div>

      <!-- ==================== SCREEN 1: SUBJECT PICKER (Oxbridge) ==================== -->
      <div id="screen-subject" class="hidden fade-in">
        <button onclick="goBack('mode')" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-6">
          <span class="material-symbols-outlined text-lg">arrow_back</span> Back to Mode Selection
        </button>
        <h2 class="font-headline font-bold text-2xl md:text-3xl text-on-surface tracking-tight mb-2" id="subject-title">Choose Your Subject</h2>
        <p class="text-on-surface-variant mb-8" id="subject-desc">Select the subject you are applying for. Questions are sourced from real Oxbridge interviews.</p>
        <div id="subject-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- ==================== SCREEN 2: CUSTOM IMPORT ==================== -->
      <div id="screen-import" class="hidden fade-in">
        <button onclick="goBack('mode')" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-6">
          <span class="material-symbols-outlined text-lg">arrow_back</span> Back to Mode Selection
        </button>
        <h2 class="font-headline font-bold text-2xl md:text-3xl text-on-surface tracking-tight mb-2">Import Your Questions</h2>
        <p class="text-on-surface-variant mb-6">Paste questions from a spreadsheet, upload a file, or type them in. All processing happens locally in your browser.</p>

        <!-- Import tabs -->
        <div class="flex gap-2 mb-6 border-b border-outline-variant/10 pb-3">
          <button onclick="switchImportTab('paste')" id="tab-paste" class="iv-tab-active px-4 py-2 text-sm font-bold rounded-lg transition-all">Paste from Spreadsheet</button>
          <button onclick="switchImportTab('file')" id="tab-file" class="px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all">Upload File</button>
          <button onclick="switchImportTab('manual')" id="tab-manual" class="px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all">Type Manually</button>
        </div>

        <!-- Paste Tab -->
        <div id="import-paste" class="mb-6">
          <label class="block text-sm font-semibold text-on-surface mb-2">Paste one question per line (copy a column from Excel/Google Sheets):</label>
          <textarea id="paste-area" rows="8" placeholder="What is your greatest strength?&#10;Why did you choose this university?&#10;Tell me about a time you failed.&#10;..." class="w-full border border-outline-variant/20 rounded-xl p-4 text-sm font-body focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 resize-y"></textarea>
        </div>

        <!-- File Upload Tab -->
        <div id="import-file" class="hidden mb-6">
          <div class="border-2 border-dashed border-outline-variant/20 rounded-2xl p-8 text-center hover:border-primary/30 transition-colors">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 mb-3">cloud_upload</span>
            <p class="text-on-surface-variant mb-3">Drag and drop, or click to select a file</p>
            <input type="file" id="file-input" accept=".csv,.json,.txt" class="hidden" />
            <button onclick="document.getElementById('file-input').click()" class="px-5 py-2.5 bg-primary/5 text-primary font-bold text-sm rounded-xl hover:bg-primary/10 transition-colors">
              Choose File (.csv, .json, .txt)
            </button>
            <p class="text-[11px] text-on-surface-variant/40 mt-3" id="file-name">No file selected</p>
          </div>
          <div class="mt-4 p-4 bg-surface-container-low rounded-xl">
            <p class="text-xs font-bold text-on-surface-variant/60 mb-2">Supported formats:</p>
            <ul class="text-xs text-on-surface-variant/50 space-y-1">
              <li><strong>CSV:</strong> One column of questions, or columns: question, material (optional), hint (optional)</li>
              <li><strong>JSON:</strong> Array of strings, or array of objects with <code>question</code>, <code>material</code>, <code>hint</code> fields</li>
              <li><strong>TXT:</strong> One question per line</li>
            </ul>
          </div>
        </div>

        <!-- Manual Tab -->
        <div id="import-manual" class="hidden mb-6">
          <div id="manual-questions">
            <div class="flex gap-2 mb-2 items-start">
              <span class="text-xs font-bold text-on-surface-variant/40 mt-3 w-6 shrink-0">1.</span>
              <input type="text" placeholder="Type your question here..." class="iv-manual-input flex-1 border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
          </div>
          <button onclick="addManualRow()" class="mt-2 text-sm text-primary font-bold hover:text-primary/80 flex items-center gap-1">
            <span class="material-symbols-outlined text-base">add</span> Add Question
          </button>
        </div>

        <!-- Custom Settings -->
        <div class="bg-surface-container-low rounded-2xl p-5 mb-6">
          <h3 class="font-bold text-sm text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-lg text-primary">tune</span> Practice Settings
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Prep Timer</label>
              <select id="custom-prep-toggle" onchange="document.getElementById('custom-prep-seconds').classList.toggle('hidden', this.value==='off')" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40 mb-2">
                <option value="off">Off (click when ready)</option>
                <option value="on">Timed countdown</option>
              </select>
              <input type="number" id="custom-prep-seconds" value="10" min="1" max="300" placeholder="seconds" class="hidden w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Answer Time (seconds, 0 = unlimited)</label>
              <input type="number" id="custom-answer" value="120" min="0" max="600" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Audio Recording</label>
              <select id="custom-record" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40">
                <option value="on">Enabled</option>
                <option value="off">Disabled (question only)</option>
              </select>
            </div>
          </div>
        </div>

        <button onclick="startCustomPractice()" id="btn-start-custom" class="w-full py-4 rounded-2xl bg-violet-600 text-white font-bold text-lg shadow-lg shadow-violet-200 hover:bg-violet-700 transition-all flex justify-center items-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed" disabled>
          <span class="material-symbols-outlined">play_circle</span>
          <span id="btn-start-custom-text">Import questions to begin</span>
        </button>
      </div>

      <!-- ==================== SCREEN 3: PRACTICE (shared across modes) ==================== -->
      <div id="screen-practice" class="hidden fade-in">
        <div class="flex items-center justify-between mb-6">
          <button onclick="exitPractice()" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span> Exit Practice
          </button>
          <div class="flex items-center gap-3">
            <span id="practice-progress" class="text-xs font-bold text-on-surface-variant/50"></span>
            <span id="practice-mode-badge" class="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase"></span>
          </div>
        </div>

        <!-- Question Navigation Panel -->
        <div id="iv-nav-panel" class="mb-4 p-3 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <div id="iv-nav-grid" class="flex flex-wrap gap-1.5"></div>
        </div>

        <!-- Practice Card -->
        <div class="bg-white rounded-2xl border border-outline-variant/15 p-5 md:p-8 lg:p-10 shadow-xl shadow-primary/5">

          <!-- Timer -->
          <div id="iv-timer-area" class="flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 border-outline-variant/10 bg-surface-container-low transition-all duration-300">
            <div id="iv-timer-label" class="text-xs font-bold text-on-surface-variant/50 uppercase tracking-widest mb-1">Waiting</div>
            <div id="iv-timer-display" class="text-6xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors">--:--</div>
          </div>

          <!-- Category Badge -->
          <div id="iv-cat-badge" class="hidden mb-4">
            <span id="iv-cat-text" class="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase bg-primary/10 text-primary"></span>
          </div>

          <!-- Question Area -->
          <div class="relative min-h-[140px] mb-6">
            <!-- Lock overlay -->
            <div id="iv-lock" class="absolute inset-0 flex flex-col items-center justify-center z-10 bg-white/60 rounded-xl transition-opacity duration-500">
              <span class="material-symbols-outlined text-3xl text-on-surface-variant/30 mb-2">lock</span>
              <p class="text-on-surface-variant text-sm font-medium">Click "Start" to reveal the question</p>
            </div>

            <div id="iv-question-wrap" class="iv-locked transition-all duration-500">
              <!-- Material/passage block (for Oxbridge-style) -->
              <div id="iv-material" class="hidden mb-5 p-4 bg-amber-50 border border-amber-200/30 rounded-xl">
                <p class="text-xs font-bold text-amber-700/60 uppercase tracking-widest mb-2 flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">menu_book</span> Reading Material
                </p>
                <div id="iv-material-text" class="text-sm text-on-surface leading-relaxed whitespace-pre-line"></div>
              </div>

              <!-- Question text -->
              <h2 id="iv-q-main" class="text-xl md:text-2xl font-headline font-bold text-on-surface leading-snug mb-3">[Question Hidden]</h2>
              <p id="iv-q-sub" class="text-base text-on-surface-variant leading-relaxed"></p>

              <!-- Hint -->
              <div id="iv-hint-area" class="hidden mt-5 pt-4 border-t border-dashed border-outline-variant/20">
                <button id="iv-hint-btn" class="text-sm text-primary hover:text-primary/80 font-semibold flex items-center transition-colors">
                  <span class="material-symbols-outlined text-base mr-1">lightbulb</span> Show Hint
                </button>
                <div id="iv-hint-box" class="hidden mt-3 p-4 bg-primary/5 border border-primary/10 rounded-lg text-sm text-on-surface leading-relaxed"></div>
              </div>

              <!-- Analysis (for general mode) -->
              <div id="iv-analysis" class="hidden mt-5 pt-4 border-t border-outline-variant/10">
                <button id="iv-analysis-btn" class="text-sm text-emerald-600 hover:text-emerald-700 font-semibold flex items-center transition-colors">
                  <span class="material-symbols-outlined text-base mr-1">psychology</span> Show Analysis Framework
                </button>
                <div id="iv-analysis-box" class="hidden mt-3">
                  <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-lg mb-3">
                    <p class="text-xs font-bold text-emerald-700/60 uppercase tracking-widest mb-2">Focus</p>
                    <p id="iv-analysis-focus" class="text-sm text-on-surface leading-relaxed"></p>
                  </div>
                  <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-lg">
                    <p class="text-xs font-bold text-emerald-700/60 uppercase tracking-widest mb-2">Strategies</p>
                    <ul id="iv-analysis-strategies" class="text-sm text-on-surface leading-relaxed space-y-2 list-disc pl-4"></ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Audio Playback -->
          <div id="iv-audio-area" class="hidden flex flex-col items-center bg-primary/5 rounded-2xl p-6 border-2 border-primary/10 mb-6">
            <div class="flex items-center text-primary font-bold mb-3">
              <span class="material-symbols-outlined text-xl mr-2">check_circle</span> Response recorded
            </div>
            <audio id="iv-audio-player" controls class="w-full max-w-lg mb-4 shadow-sm rounded-full"></audio>
            <div class="flex gap-3">
              <a id="iv-download" class="px-4 py-2 bg-white border border-primary/20 text-primary font-semibold text-sm rounded-xl hover:bg-primary/5 transition-colors cursor-pointer flex items-center gap-1">
                <span class="material-symbols-outlined text-base">download</span> Download
              </a>
            </div>
          </div>


          <!-- Primary Action Buttons -->
          <div class="flex flex-col items-center">
            <button id="iv-btn-main" class="w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2">
              <span class="material-symbols-outlined text-xl" id="iv-btn-icon">play_circle</span>
              <span id="iv-btn-text">Start</span>
            </button>
            <button id="iv-btn-skip" class="hidden mt-3 text-sm font-medium text-on-surface-variant/50 hover:text-on-surface-variant flex items-center gap-1 transition-colors">
              <span class="material-symbols-outlined text-base">fast_forward</span>
              <span id="iv-btn-skip-text">Skip</span>
            </button>
          </div>
        </div>
      </div>


    </div>
  </main>
</MainLayout>

<style>
  .fade-in { animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .iv-locked { filter: blur(8px); user-select: none; pointer-events: none; opacity: 0.4; }
  .recording-pulse { animation: pulse-red 2s infinite; }
  @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); } 70% { box-shadow: 0 0 0 20px rgba(239,68,68,0); } 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); } }
  .warning-pulse { animation: pulse-orange 1s infinite; }
  @keyframes pulse-orange { 0% { color: #f97316; } 50% { color: #ea580c; text-shadow: 0 0 10px rgba(234,88,12,0.3); } 100% { color: #f97316; } }
  .iv-tab-active { background: var(--md-sys-color-primary, #042f24); color: white; }
  .iv-rate-btn.selected { transform: scale(1.15); box-shadow: 0 0 0 3px rgba(4,47,36,0.2); }
</style>

<script is:inline>
// ============================================================
// QUESTION BANKS
// ============================================================

var HKU_QUESTIONS = [
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "What are the benefits and drawbacks of remote work for both companies and employees?", cn: "\u8fdc\u7a0b\u5de5\u4f5c\u5bf9\u516c\u53f8\u548c\u5458\u5de5\u6709\u54ea\u4e9b\u5229\u5f0a\uff1f", hint: "\u4e2a\u4eba\u7ef4\u5ea6\uff1a\u7075\u6d3b\u5ea6\u3001\u7701\u901a\u52e4 vs \u5b64\u72ec\u3001\u751f\u6d3b\u5de5\u4f5c\u754c\u9650\u6a21\u7cca\uff1b\u516c\u53f8\u7ef4\u5ea6\uff1a\u7701\u573a\u5730\u8d39\u3001\u5168\u7403\u62a2\u4eba vs \u76d1\u7763\u96be\u3001\u56e2\u961f\u51dd\u805a\u529b\u4e0b\u964d\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "Coworkers vs Work Performance: Which one is more important?", cn: "\u540c\u4e8b\u5173\u7cfb vs \u5de5\u4f5c\u8868\u73b0\uff1a\u54ea\u4e2a\u66f4\u91cd\u8981\uff1f", hint: "\u4e2a\u4eba\uff1a\u8868\u73b0\u597d\u80fd\u5347\u804c\uff1b\u5173\u7cfb\u597d\u63d0\u4f9b\u60c5\u7eea\u4ef7\u503c\u3002\u56e2\u961f\uff1a\u597d\u5173\u7cfb\u964d\u6c9f\u901a\u6210\u672c\u3002\u516c\u53f8\uff1a\u9700\u8981\u56e2\u961f\u534f\u4f5c\u800c\u975e\u5355\u6253\u72ec\u6597\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "Why do big companies introduce new products frequently?", cn: "\u4e3a\u4ec0\u4e48\u5927\u516c\u53f8\u9891\u7e41\u63a8\u51fa\u65b0\u4ea7\u54c1\uff1f", hint: "\u6d88\u8d39\u8005\uff1a\u8fce\u5408\u559c\u65b0\u538c\u65e7\u3002\u7ade\u4e89\u5bf9\u624b\uff1a\u62a2\u5360\u4efd\u989d\u5efa\u58c1\u5792\u3002\u80a1\u4e1c\uff1a\u7ef4\u6301\u54c1\u724c\u70ed\u5ea6\u63a8\u9ad8\u80a1\u4ef7\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "If you were a school president, would you give resources to top students or struggling students?", cn: "\u5982\u679c\u4f60\u662f\u6821\u957f\uff0c\u4f60\u4f1a\u628a\u8d44\u6e90\u7ed9\u597d\u5b66\u751f\u8fd8\u662f\u5dee\u751f\uff1f", hint: "\u597d\u5b66\u751f\uff1a\u56de\u62a5\u7387\u9ad8\u62c9\u6392\u540d\u3002\u5dee\u751f\uff1a\u6258\u5e95\u6548\u5e94\u4e0e\u6559\u80b2\u516c\u5e73\u3002\u5b66\u6821\uff1a\u957f\u8fdc\u54c1\u724c\u58f0\u8a89\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "What are the cultural impacts of tourism on a community?", cn: "\u65c5\u6e38\u4e1a\u5bf9\u4e00\u4e2a\u793e\u533a\u6709\u4ec0\u4e48\u6587\u5316\u5f71\u54cd\uff1f", hint: "\u5c45\u6c11\uff1a\u589e\u6536\u3001\u81ea\u8c6a\u611f vs \u6587\u5316\u8fc7\u5ea6\u5546\u4e1a\u5316\u3002\u6e38\u5ba2\uff1a\u6253\u7834\u523b\u677f\u5370\u8c61\u3002\u653f\u5e9c\uff1a\u7a0e\u6536 vs \u8bbe\u65bd\u7ef4\u62a4\u6210\u672c\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "Discuss the balance between privacy rights and national security.", cn: "\u8ba8\u8bba\u9690\u79c1\u6743\u4e0e\u56fd\u5bb6\u5b89\u5168\u4e4b\u95f4\u7684\u5e73\u8861\u3002", hint: "\u516c\u6c11\uff1a\u9632\u8303\u6743\u529b\u6ee5\u7528\uff0c\u4fdd\u969c\u7cbe\u795e\u5b89\u5168\u611f\u3002\u56fd\u5bb6\u673a\u5668\uff1a\u9632\u8303\u72af\u7f6a\u6050\u6016\u4e3b\u4e49\uff0c\u4fdd\u969c\u7269\u7406\u5b89\u5168\u611f\u3002" },
  { cat: "Stakeholder Model", catZh: "\u5229\u76ca\u76f8\u5173\u8005\u6a21\u578b", en: "Should university tuition be free for all students?", cn: "\u5927\u5b66\u5b66\u8d39\u5e94\u8be5\u5bf9\u6240\u6709\u5b66\u751f\u514d\u8d39\u5417\uff1f", hint: "\u5b66\u751f\uff1a\u51cf\u8f7b\u8d1f\u503a\u5b9e\u73b0\u9636\u5c42\u8dc3\u5347\u3002\u5b66\u6821\uff1a\u6559\u80b2\u8d44\u6e90\u7a00\u91ca\u3001\u8d22\u653f\u5403\u7d27\u3002\u7eb3\u7a0e\u4eba\uff1a\u8d4b\u7a0e\u52a0\u91cd\u3002" },

  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "How do you perceive a school\u2019s ranking and its academic atmosphere?", cn: "\u4f60\u5982\u4f55\u770b\u5f85\u4e00\u6240\u5b66\u6821\u7684\u6392\u540d\u53ca\u5176\u5b66\u672f\u6c1b\u56f4\uff1f", hint: "\u6392\u540d\uff08\u786c/\u7269\u8d28\uff09\uff1a\u627e\u5de5\u4f5c\u6572\u95e8\u7816\uff0c\u786c\u4ef6\u4fdd\u969c\u3002\u6c1b\u56f4\uff08\u8f6f/\u7cbe\u795e\uff09\uff1a\u6559\u6388\u542f\u53d1\uff0c\u6821\u53cb\u4e92\u52a9\uff0c\u5851\u9020\u601d\u7ef4\u3002" },
  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "Should education focus more on practical skills or academic knowledge?", cn: "\u6559\u80b2\u5e94\u8be5\u66f4\u591a\u5173\u6ce8\u5b9e\u8df5\u6280\u80fd\u8fd8\u662f\u5b66\u672f\u77e5\u8bc6\uff1f", hint: "\u5b9e\u8df5\u6280\u80fd\uff1a\u5de5\u5177\u7406\u6027\uff0c\u8fc5\u901f\u5c31\u4e1a\u3002\u5b66\u672f\u77e5\u8bc6\uff1a\u4ef7\u503c\u7406\u6027\uff0c\u57f9\u517b\u6279\u5224\u6027\u601d\u7ef4\uff0c\u51b3\u5b9a\u804c\u4e1a\u4e0a\u9650\u3002" },
  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "Discuss the impact of social media on interpersonal communication.", cn: "\u8ba8\u8bba\u793e\u4ea4\u5a92\u4f53\u5bf9\u4eba\u9645\u6c9f\u901a\u7684\u5f71\u54cd\u3002", hint: "\u5de5\u5177\u6548\u7387\uff1a\u964d\u672c\u589e\u6548\uff0c\u8de8\u8d8a\u5730\u7406\u9650\u5236\u3002\u60c5\u611f\u6df1\u5ea6\uff1a\u7f3a\u4e4f\u975e\u8bed\u8a00\u6697\u793a\uff0c\u5bfc\u81f4\u7fa4\u4f53\u6027\u5b64\u72ec\u548c\u80a4\u6d45\u6c9f\u901a\u3002" },
  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "Printed Books vs eBooks: Which do you prefer?", cn: "\u7eb8\u8d28\u4e66 vs \u7535\u5b50\u4e66\uff1a\u4f60\u66f4\u559c\u6b22\u54ea\u4e2a\uff1f", hint: "\u7535\u5b50\u4e66\uff1a\u68c0\u7d22\u5feb\u3001\u73af\u4fdd\u4fbf\u643a\u3002\u7eb8\u8d28\u4e66\uff1a\u7ffb\u9875\u4eea\u5f0f\u611f\uff0c\u8fdc\u79bb\u5c4f\u5e55\u5e26\u6765\u7684\u6df1\u5ea6\u4e13\u6ce8\u4e0e\u60c5\u611f\u5bc4\u6258\u3002" },
  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "What is your opinion about the role of money in people\u2019s lives?", cn: "\u4f60\u5bf9\u91d1\u94b1\u5728\u4eba\u4eec\u751f\u6d3b\u4e2d\u7684\u4f5c\u7528\u6709\u4f55\u770b\u6cd5\uff1f", hint: "\u7269\u8d28\u5e95\u7ebf\uff1a\u6297\u98ce\u9669\u80fd\u529b\uff0c\u6ee1\u8db3\u751f\u7406\u5b89\u5168\u3002\u7cbe\u795e\u81ea\u7531\uff1a\u4e70\u4e0d\u6765\u610f\u4e49\uff0c\u4f46\u80fd\u4e70\u6765\u8bf4\u300c\u4e0d\u300d\u7684\u5e95\u6c14\u548c\u65f6\u95f4\u3002" },
  { cat: "Material vs Spiritual", catZh: "\u7269\u8d28\u4e0e\u7cbe\u795e\u6a21\u578b", en: "What is the importance of arts and humanities in education?", cn: "\u827a\u672f\u548c\u4eba\u6587\u5b66\u79d1\u5728\u6559\u80b2\u4e2d\u6709\u4ec0\u4e48\u91cd\u8981\u6027\uff1f", hint: "\u8868\u5c42\u529f\u5229\uff1a\u96be\u4ee5\u76f4\u63a5\u8f6c\u5316\u4e3a\u9ad8\u85aa\u3002\u6df1\u5c42\u5185\u6838\uff1a\u57f9\u517b\u5ba1\u7f8e\u3001\u5171\u60c5\u548c\u9053\u5fb7\u5224\u65ad\uff0c\u662fAI\u65f6\u4ee3\u4eba\u7c7b\u4e0d\u88ab\u53d6\u4ee3\u7684\u6839\u672c\u3002" },

  { cat: "Micro to Macro", catZh: "\u5fae\u89c2\u5230\u5b8f\u89c2\u6a21\u578b", en: "What steps should be taken to address climate change by individual countries and globally?", cn: "\u5404\u4e2a\u56fd\u5bb6\u548c\u5168\u7403\u5e94\u8be5\u91c7\u53d6\u54ea\u4e9b\u63aa\u65bd\u6765\u5e94\u5bf9\u6c14\u5019\u53d8\u5316\uff1f", hint: "\u5fae\u89c2\uff1a\u4e2a\u4eba\u7eff\u8272\u6d88\u8d39\u5012\u903c\u4f01\u4e1a\u3002\u4e2d\u89c2\uff1a\u56fd\u5bb6\u6295\u8d44\u65b0\u80fd\u6e90\u57fa\u5efa\u3002\u5b8f\u89c2\uff1a\u8de8\u8d8a\u5730\u7f18\u653f\u6cbb\u6267\u884c\u56fd\u9645\u51cf\u6392\u534f\u8bae\u3002" },
  { cat: "Micro to Macro", catZh: "\u5fae\u89c2\u5230\u5b8f\u89c2\u6a21\u578b", en: "What are the pros and cons of universal basic income (UBI)?", cn: "\u5168\u6c11\u57fa\u672c\u6536\u5165\u7684\u5229\u5f0a\u662f\u4ec0\u4e48\uff1f", hint: "\u4e2a\u4f53\uff1a\u8d4b\u4e88\u751f\u5b58\u5c0a\u4e25\uff0c\u6562\u4e8e\u8bd5\u9519\u521b\u4e1a\u3002\u56fd\u5bb6\uff1a\u53ef\u80fd\u5bfc\u81f4\u52b3\u52a8\u529b\u77ed\u7f3a\uff0c\u5f15\u53d1\u901a\u80c0\u53ca\u5de8\u5927\u8d22\u653f\u8d64\u5b57\u3002" },
  { cat: "Micro to Macro", catZh: "\u5fae\u89c2\u5230\u5b8f\u89c2\u6a21\u578b", en: "Study in a group vs study alone. Which is better?", cn: "\u5728\u5c0f\u7ec4\u4e2d\u5b66\u4e60\u66f4\u6709\u6548\u8fd8\u662f\u72ec\u81ea\u5b66\u4e60\u66f4\u597d\uff1f", hint: "\u4e2a\u4eba\uff08\u72ec\u81ea\uff09\uff1a\u6df1\u5ea6\u4e13\u6ce8\uff0c\u5efa\u7acb\u77e5\u8bc6\u58c1\u5792\u3002\u793e\u4f1a\u5316\uff08\u5c0f\u7ec4\uff09\uff1a\u6a21\u62df\u804c\u573a\uff0c\u953b\u70bc\u6c9f\u901a\u3001\u59a5\u534f\u548c\u9886\u5bfc\u529b\u3002" },
  { cat: "Micro to Macro", catZh: "\u5fae\u89c2\u5230\u5b8f\u89c2\u6a21\u578b", en: "How can urban planning improve the quality of life in big cities?", cn: "\u57ce\u5e02\u89c4\u5212\u5982\u4f55\u6539\u5584\u5927\u57ce\u5e02\u7684\u751f\u6d3b\u8d28\u91cf\uff1f", hint: "\u5fae\u89c2\u4f53\u9a8c\uff1a\u77ed\u901a\u52e4\uff0c\u4fbf\u5229\u5e97\u3002\u57ce\u5e02\u751f\u6001\uff1a\u589e\u52a0\u516c\u5171\u7a7a\u95f4\u4fc3\u8fdb\u793e\u533a\u51dd\u805a\u529b\uff0c\u4f18\u5316\u57fa\u5efa\u9632\u8303\u57ce\u5e02\u707e\u5bb3\u3002" },
  { cat: "Micro to Macro", catZh: "\u5fae\u89c2\u5230\u5b8f\u89c2\u6a21\u578b", en: "How do public health initiatives contribute to a nation\u2019s well-being?", cn: "\u516c\u5171\u536b\u751f\u4e3e\u63aa\u5982\u4f55\u4fc3\u8fdb\u56fd\u5bb6\u7684\u798f\u7949\uff1f", hint: "\u4e2a\u4f53\uff1a\u5ef6\u957f\u5bff\u547d\uff0c\u9632\u6b62\u56e0\u75c5\u81f4\u8d2b\u3002\u56fd\u5bb6\uff1a\u9632\u6b62\u533b\u7597\u6324\u5151\uff0c\u4fdd\u969c\u52b3\u52a8\u529b\u5145\u8db3\uff0c\u7a33\u5b9a\u7ecf\u6d4e\u5e95\u76d8\u3002" },

  { cat: "Timeline Dynamic", catZh: "\u65f6\u95f4\u8f74\u52a8\u6001\u6a21\u578b", en: "What measures should be taken to protect cultural relics?", cn: "\u5e94\u8be5\u91c7\u53d6\u4ec0\u4e48\u63aa\u65bd\u6765\u4fdd\u62a4\u6587\u5316\u6587\u7269\uff1f", hint: "\u5f53\u4e0b\u75db\u70b9\uff1a\u4fee\u7f2e\u8d39\u94b1\uff0c\u963b\u7877\u57ce\u5e02\u5546\u4e1a\u6269\u5efa\u3002\u957f\u8fdc\u6536\u76ca\uff1a\u7ed3\u5408VR\u6570\u5b57\u5316\uff0c\u6d3b\u5316\u5386\u53f2\u8d44\u4ea7\uff0c\u5851\u9020\u540e\u4ee3\u6587\u5316\u8ba4\u540c\u3002" },
  { cat: "Timeline Dynamic", catZh: "\u65f6\u95f4\u8f74\u52a8\u6001\u6a21\u578b", en: "Discuss the potential effects of automation on the job market.", cn: "\u8ba8\u8bba\u81ea\u52a8\u5316\u5bf9\u5c31\u4e1a\u5e02\u573a\u7684\u6f5c\u5728\u5f71\u54cd\u3002", hint: "\u77ed\u671f\u9635\u75db\uff1a\u6d41\u6c34\u7ebf\u3001\u57fa\u7840\u884c\u653f\u5c97\u8fc5\u901f\u88ab\u88c1\uff0c\u5f15\u53d1\u793e\u4f1a\u6050\u614c\u3002\u957f\u671f\u6f14\u8fdb\uff1a\u751f\u4ea7\u529b\u89e3\u653e\uff0c\u903c\u8feb\u4eba\u7c7b\u8f6c\u5411\u521b\u9020\u6027\u548c\u60c5\u611f\u966a\u4f34\u7c7b\u5de5\u4f5c\u3002" },
  { cat: "Timeline Dynamic", catZh: "\u65f6\u95f4\u8f74\u52a8\u6001\u6a21\u578b", en: "Extensive learning or deep learning: which is better?", cn: "\u5e7f\u6cdb\u5b66\u4e60\u8fd8\u662f\u6df1\u5ea6\u5b66\u4e60\uff1a\u54ea\u4e2a\u66f4\u597d\uff1f", hint: "\u65e9\u671f\uff08\u5e7f\u6cdb\uff09\uff1a\u4f4e\u6210\u672c\u8bd5\u9519\uff0c\u627e\u51c6\u5174\u8da3\u70b9\uff0c\u8de8\u5b66\u79d1\u542f\u53d1\u3002\u540e\u671f\uff08\u6df1\u5ea6\uff09\uff1a\u5efa\u7acb\u6df1\u6c34\u533a\u62a4\u57ce\u6cb3\uff0c\u6210\u4e3a\u4e0d\u53ef\u66ff\u4ee3\u7684\u4e13\u5bb6\u3002" },
  { cat: "Timeline Dynamic", catZh: "\u65f6\u95f4\u8f74\u52a8\u6001\u6a21\u578b", en: "Should renewable energy be prioritized even if currently more expensive?", cn: "\u5373\u4f7f\u76ee\u524d\u53ef\u518d\u751f\u80fd\u6e90\u66f4\u8d35\uff0c\u662f\u5426\u4e5f\u5e94\u4f18\u5148\u53d1\u5c55\uff1f", hint: "\u77ed\u671f\u4ee3\u4ef7\uff1a\u57fa\u5efa\u6295\u5165\u5de8\u5927\uff0c\u7535\u8d39\u4e0a\u6da8\uff0c\u4f20\u7edf\u5de5\u4eba\u5931\u4e1a\u3002\u957f\u671f\u751f\u5b58\uff1a\u5316\u77f3\u80fd\u6e90\u5fc5\u5c06\u67af\u7aed\uff0c\u73b0\u5728\u7684\u75db\u662f\u6362\u53d6\u672a\u6765\u7684\u6280\u672f\u5e73\u6743\u548c\u4eba\u7c7b\u5ef6\u7eed\u3002" }
];

