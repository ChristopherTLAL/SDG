---
// src/pages/tools/interview.astro — Unified Interview Practice Platform
import MainLayout from '../../layouts/MainLayout.astro';
const lang = 'en';
---

<MainLayout title="Interview Practice | Chinese SDGs Institute" description="Practice for HKU Multifaceted Excellence, Oxbridge tutorials, general admissions interviews, or import your own question bank." lang={lang}>
  <main class="pt-24 md:pt-32 pb-16 md:pb-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 md:px-12">

      <!-- Back link -->
      <a href="/tools" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Back to Tools
      </a>

      <!-- ==================== SCREEN 0: MODE SELECTOR ==================== -->
      <div id="screen-mode" class="fade-in">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-5">
            <span class="material-symbols-outlined text-[14px]">mic</span>
            Interview Practice
          </div>
          <h1 class="font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl text-on-surface tracking-tighter leading-[1.05] mb-4">
            Mock Interview<br /><span class="text-primary">Simulator</span>
          </h1>
          <p class="text-on-surface-variant text-base md:text-lg max-w-2xl mx-auto">
            Choose a practice mode below. Each mode simulates a different interview format with appropriate timing, prompts, and recording options.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
          <!-- HKU Mode -->
          <button onclick="selectMode('hku')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-primary text-2xl">diversity_3</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-primary text-white">22 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-primary transition-colors">HKU Multifaceted Excellence</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">30-second reading period, 2-minute timed response with audio recording.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 30s + 2min</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- Oxbridge Mode -->
          <button onclick="selectMode('oxbridge')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center group-hover:bg-amber-100 transition-colors">
                <span class="material-symbols-outlined text-amber-700 text-2xl">school</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-amber-600 text-white" id="oxbridge-count">13 Subjects · 239 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-amber-700 transition-colors">Oxbridge Tutorial Interview</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Read a question or passage at your own pace, then click to start recording with no time limit.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- General Mode -->
          <button onclick="selectMode('general')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center group-hover:bg-emerald-100 transition-colors">
                <span class="material-symbols-outlined text-emerald-700 text-2xl">forum</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-emerald-600 text-white">20 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-emerald-700 transition-colors">General Admissions Interview</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Common admissions questions with analysis frameworks and suggested strategies.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 10s + 2min</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- Kira Talent -->
          <button onclick="selectMode('kira')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center group-hover:bg-sky-100 transition-colors">
                <span class="material-symbols-outlined text-sky-700 text-2xl">videocam</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-sky-600 text-white">83 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-sky-700 transition-colors">Kira Talent (Video Interview)</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Timed video interview questions used by top business schools (Rotman, Ivey, INSEAD, LBS).</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 30s + 90s</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic</span> Recording</span>
            </div>
          </button>

          <!-- FAANG / Big Tech -->
          <button onclick="selectMode('faang')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center group-hover:bg-orange-100 transition-colors">
                <span class="material-symbols-outlined text-orange-700 text-2xl">business</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-orange-600 text-white">85 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-orange-700 transition-colors">FAANG / Big Tech Behavioral</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Behavioral questions from Google, Amazon, Meta, Apple. Heavy focus on Amazon Leadership Principles.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic_off</span> No Recording</span>
            </div>
          </button>

          <!-- MBB Consulting -->
          <button onclick="selectMode('consulting')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center group-hover:bg-indigo-100 transition-colors">
                <span class="material-symbols-outlined text-indigo-700 text-2xl">trending_up</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-indigo-600 text-white">81 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-indigo-700 transition-colors">Management Consulting (MBB)</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Fit and behavioral questions from McKinsey (PEI), BCG, and Bain interviews.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic_off</span> No Recording</span>
            </div>
          </button>

          <!-- Investment Banking -->
          <button onclick="selectMode('banking')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center group-hover:bg-slate-100 transition-colors">
                <span class="material-symbols-outlined text-slate-700 text-2xl">account_balance</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-slate-600 text-white">85 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-slate-700 transition-colors">Investment Banking / Finance</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Behavioral and motivational questions from Goldman Sachs, JP Morgan, Morgan Stanley.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic_off</span> No Recording</span>
            </div>
          </button>

          <!-- Graduate School -->
          <button onclick="selectMode('gradschool')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition-colors">
                <span class="material-symbols-outlined text-teal-700 text-2xl">science</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-teal-600 text-white">82 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-teal-700 transition-colors">Graduate School Admissions</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Common questions for PhD and Master's program admissions across disciplines.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">menu_book</span> Read + Click</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic_off</span> No Recording</span>
            </div>
          </button>

          <!-- Medical School MMI -->
          <button onclick="selectMode('mmi')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-rose-50 rounded-xl flex items-center justify-center group-hover:bg-rose-100 transition-colors">
                <span class="material-symbols-outlined text-rose-700 text-2xl">local_hospital</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-rose-600 text-white">80 Qs</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-rose-700 transition-colors">Medical School (MMI)</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Multiple Mini Interview stations with ethical dilemmas, scenarios, and policy discussions.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">timer</span> 2min + 8min</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">mic_off</span> No Recording</span>
            </div>
          </button>

          <!-- Custom Import Mode (always last) -->
          <button onclick="selectMode('custom')" class="iv-mode-card group text-left bg-white rounded-2xl border border-outline-variant/15 p-6 hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-violet-50 rounded-xl flex items-center justify-center group-hover:bg-violet-100 transition-colors">
                <span class="material-symbols-outlined text-violet-700 text-2xl">upload_file</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-violet-600 text-white">DIY</span>
            </div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2 group-hover:text-violet-700 transition-colors">Import Your Own Questions</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-3">Paste from spreadsheet, upload CSV/JSON, or type questions manually. Fully customizable timing.</p>
            <div class="flex items-center gap-3 text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.12em]">
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">table</span> CSV/JSON</span>
              <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">tune</span> Custom Timing</span>
            </div>
          </button>
        </div>
      </div>

      <!-- ==================== SCREEN 1: SUBJECT PICKER (Oxbridge) ==================== -->
      <div id="screen-subject" class="hidden fade-in">
        <button onclick="goBack('mode')" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-6">
          <span class="material-symbols-outlined text-lg">arrow_back</span> Back to Mode Selection
        </button>
        <h2 class="font-headline font-bold text-2xl md:text-3xl text-on-surface tracking-tight mb-2" id="subject-title">Choose Your Subject</h2>
        <p class="text-on-surface-variant mb-8" id="subject-desc">Select the subject you are applying for. Questions are sourced from real Oxbridge interviews.</p>
        <div id="subject-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- ==================== SCREEN 2: CUSTOM IMPORT ==================== -->
      <div id="screen-import" class="hidden fade-in">
        <button onclick="goBack('mode')" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-6">
          <span class="material-symbols-outlined text-lg">arrow_back</span> Back to Mode Selection
        </button>
        <h2 class="font-headline font-bold text-2xl md:text-3xl text-on-surface tracking-tight mb-2">Import Your Questions</h2>
        <p class="text-on-surface-variant mb-6">Paste questions from a spreadsheet, upload a file, or type them in. All processing happens locally in your browser.</p>

        <!-- Import tabs -->
        <div class="flex gap-2 mb-6 border-b border-outline-variant/10 pb-3">
          <button onclick="switchImportTab('paste')" id="tab-paste" class="iv-tab-active px-4 py-2 text-sm font-bold rounded-lg transition-all">Paste from Spreadsheet</button>
          <button onclick="switchImportTab('file')" id="tab-file" class="px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all">Upload File</button>
          <button onclick="switchImportTab('manual')" id="tab-manual" class="px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all">Type Manually</button>
        </div>

        <!-- Paste Tab -->
        <div id="import-paste" class="mb-6">
          <label class="block text-sm font-semibold text-on-surface mb-2">Paste one question per line (copy a column from Excel/Google Sheets):</label>
          <textarea id="paste-area" rows="8" placeholder="What is your greatest strength?&#10;Why did you choose this university?&#10;Tell me about a time you failed.&#10;..." class="w-full border border-outline-variant/20 rounded-xl p-4 text-sm font-body focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 resize-y"></textarea>
        </div>

        <!-- File Upload Tab -->
        <div id="import-file" class="hidden mb-6">
          <div class="border-2 border-dashed border-outline-variant/20 rounded-2xl p-8 text-center hover:border-primary/30 transition-colors">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 mb-3">cloud_upload</span>
            <p class="text-on-surface-variant mb-3">Drag and drop, or click to select a file</p>
            <input type="file" id="file-input" accept=".csv,.json,.txt" class="hidden" />
            <button onclick="document.getElementById('file-input').click()" class="px-5 py-2.5 bg-primary/5 text-primary font-bold text-sm rounded-xl hover:bg-primary/10 transition-colors">
              Choose File (.csv, .json, .txt)
            </button>
            <p class="text-[11px] text-on-surface-variant/40 mt-3" id="file-name">No file selected</p>
          </div>
          <div class="mt-4 p-4 bg-surface-container-low rounded-xl">
            <p class="text-xs font-bold text-on-surface-variant/60 mb-2">Supported formats:</p>
            <ul class="text-xs text-on-surface-variant/50 space-y-1">
              <li><strong>CSV:</strong> One column of questions, or columns: question, material (optional), hint (optional)</li>
              <li><strong>JSON:</strong> Array of strings, or array of objects with <code>question</code>, <code>material</code>, <code>hint</code> fields</li>
              <li><strong>TXT:</strong> One question per line</li>
            </ul>
          </div>
        </div>

        <!-- Manual Tab -->
        <div id="import-manual" class="hidden mb-6">
          <div id="manual-questions">
            <div class="flex gap-2 mb-2 items-start">
              <span class="text-xs font-bold text-on-surface-variant/40 mt-3 w-6 shrink-0">1.</span>
              <input type="text" placeholder="Type your question here..." class="iv-manual-input flex-1 border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
          </div>
          <button onclick="addManualRow()" class="mt-2 text-sm text-primary font-bold hover:text-primary/80 flex items-center gap-1">
            <span class="material-symbols-outlined text-base">add</span> Add Question
          </button>
        </div>

        <!-- Custom Settings -->
        <div class="bg-surface-container-low rounded-2xl p-5 mb-6">
          <h3 class="font-bold text-sm text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-lg text-primary">tune</span> Practice Settings
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Prep Timer</label>
              <select id="custom-prep-toggle" onchange="document.getElementById('custom-prep-seconds').classList.toggle('hidden', this.value==='off')" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40 mb-2">
                <option value="off">Off (click when ready)</option>
                <option value="on">Timed countdown</option>
              </select>
              <input type="number" id="custom-prep-seconds" value="10" min="1" max="300" placeholder="seconds" class="hidden w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Answer Time (seconds, 0 = unlimited)</label>
              <input type="number" id="custom-answer" value="120" min="0" max="600" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />
            </div>
            <div>
              <label class="text-xs font-bold text-on-surface-variant/60 block mb-1">Audio Recording</label>
              <select id="custom-record" class="w-full border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40">
                <option value="on">Enabled</option>
                <option value="off">Disabled (question only)</option>
              </select>
            </div>
          </div>
        </div>

        <button onclick="startCustomPractice()" id="btn-start-custom" class="w-full py-4 rounded-2xl bg-violet-600 text-white font-bold text-lg shadow-lg shadow-violet-200 hover:bg-violet-700 transition-all flex justify-center items-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed" disabled>
          <span class="material-symbols-outlined">play_circle</span>
          <span id="btn-start-custom-text">Import questions to begin</span>
        </button>
      </div>

      <!-- ==================== SCREEN 3: PRACTICE (shared across modes) ==================== -->
      <div id="screen-practice" class="hidden fade-in">
        <div class="flex items-center justify-between mb-6">
          <button onclick="exitPractice()" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span> Exit Practice
          </button>
          <div class="flex items-center gap-3">
            <span id="practice-progress" class="text-xs font-bold text-on-surface-variant/50"></span>
            <span id="practice-mode-badge" class="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase"></span>
          </div>
        </div>

        <!-- Question Navigation Panel -->
        <div id="iv-nav-panel" class="mb-4 p-3 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <div id="iv-nav-grid" class="flex flex-wrap gap-1.5"></div>
        </div>

        <!-- Practice Card -->
        <div class="bg-white rounded-2xl border border-outline-variant/15 p-5 md:p-8 lg:p-10 shadow-xl shadow-primary/5">

          <!-- Timer -->
          <div id="iv-timer-area" class="flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 border-outline-variant/10 bg-surface-container-low transition-all duration-300">
            <div id="iv-timer-label" class="text-xs font-bold text-on-surface-variant/50 uppercase tracking-widest mb-1">Waiting</div>
            <div id="iv-timer-display" class="text-6xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors">--:--</div>
          </div>

          <!-- Category Badge -->
          <div id="iv-cat-badge" class="hidden mb-4">
            <span id="iv-cat-text" class="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase bg-primary/10 text-primary"></span>
          </div>

          <!-- Question Area -->
          <div class="relative min-h-[140px] mb-6">
            <!-- Lock overlay -->
            <div id="iv-lock" class="absolute inset-0 flex flex-col items-center justify-center z-10 bg-white/60 rounded-xl transition-opacity duration-500">
              <span class="material-symbols-outlined text-3xl text-on-surface-variant/30 mb-2">lock</span>
              <p class="text-on-surface-variant text-sm font-medium">Click "Start" to reveal the question</p>
            </div>

            <div id="iv-question-wrap" class="iv-locked transition-all duration-500">
              <!-- Material/passage block (for Oxbridge-style) -->
              <div id="iv-material" class="hidden mb-5 p-4 bg-amber-50 border border-amber-200/30 rounded-xl">
                <p class="text-xs font-bold text-amber-700/60 uppercase tracking-widest mb-2 flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">menu_book</span> Reading Material
                </p>
                <div id="iv-material-text" class="text-sm text-on-surface leading-relaxed whitespace-pre-line"></div>
              </div>

              <!-- Question text -->
              <h2 id="iv-q-main" class="text-xl md:text-2xl font-headline font-bold text-on-surface leading-snug mb-3">[Question Hidden]</h2>
              <p id="iv-q-sub" class="text-base text-on-surface-variant leading-relaxed"></p>

              <!-- Hint -->
              <div id="iv-hint-area" class="hidden mt-5 pt-4 border-t border-dashed border-outline-variant/20">
                <button id="iv-hint-btn" class="text-sm text-primary hover:text-primary/80 font-semibold flex items-center transition-colors">
                  <span class="material-symbols-outlined text-base mr-1">lightbulb</span> Show Hint
                </button>
                <div id="iv-hint-box" class="hidden mt-3 p-4 bg-primary/5 border border-primary/10 rounded-lg text-sm text-on-surface leading-relaxed"></div>
              </div>

              <!-- Analysis (for general mode) -->
              <div id="iv-analysis" class="hidden mt-5 pt-4 border-t border-outline-variant/10">
                <button id="iv-analysis-btn" class="text-sm text-emerald-600 hover:text-emerald-700 font-semibold flex items-center transition-colors">
                  <span class="material-symbols-outlined text-base mr-1">psychology</span> Show Analysis Framework
                </button>
                <div id="iv-analysis-box" class="hidden mt-3">
                  <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-lg mb-3">
                    <p class="text-xs font-bold text-emerald-700/60 uppercase tracking-widest mb-2">Focus</p>
                    <p id="iv-analysis-focus" class="text-sm text-on-surface leading-relaxed"></p>
                  </div>
                  <div class="p-4 bg-emerald-50 border border-emerald-100 rounded-lg">
                    <p class="text-xs font-bold text-emerald-700/60 uppercase tracking-widest mb-2">Strategies</p>
                    <ul id="iv-analysis-strategies" class="text-sm text-on-surface leading-relaxed space-y-2 list-disc pl-4"></ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Audio Playback -->
          <div id="iv-audio-area" class="hidden flex flex-col items-center bg-primary/5 rounded-2xl p-6 border-2 border-primary/10 mb-6">
            <div class="flex items-center text-primary font-bold mb-3">
              <span class="material-symbols-outlined text-xl mr-2">check_circle</span> Response recorded
            </div>
            <audio id="iv-audio-player" controls class="w-full max-w-lg mb-4 shadow-sm rounded-full"></audio>
            <div class="flex gap-3">
              <a id="iv-download" class="px-4 py-2 bg-white border border-primary/20 text-primary font-semibold text-sm rounded-xl hover:bg-primary/5 transition-colors cursor-pointer flex items-center gap-1">
                <span class="material-symbols-outlined text-base">download</span> Download
              </a>
            </div>
          </div>


          <!-- Primary Action Buttons -->
          <div class="flex flex-col items-center">
            <button id="iv-btn-main" class="w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2">
              <span class="material-symbols-outlined text-xl" id="iv-btn-icon">play_circle</span>
              <span id="iv-btn-text">Start</span>
            </button>
            <button id="iv-btn-skip" class="hidden mt-3 text-sm font-medium text-on-surface-variant/50 hover:text-on-surface-variant flex items-center gap-1 transition-colors">
              <span class="material-symbols-outlined text-base">fast_forward</span>
              <span id="iv-btn-skip-text">Skip</span>
            </button>
          </div>
        </div>
      </div>


    </div>
  </main>
</MainLayout>

<style>
  .fade-in { animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .iv-locked { filter: blur(8px); user-select: none; pointer-events: none; opacity: 0.4; }
  .recording-pulse { animation: pulse-red 2s infinite; }
  @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); } 70% { box-shadow: 0 0 0 20px rgba(239,68,68,0); } 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); } }
  .warning-pulse { animation: pulse-orange 1s infinite; }
  @keyframes pulse-orange { 0% { color: #f97316; } 50% { color: #ea580c; text-shadow: 0 0 10px rgba(234,88,12,0.3); } 100% { color: #f97316; } }
  .iv-tab-active { background: var(--md-sys-color-primary, #042f24); color: white; }
  .iv-rate-btn.selected { transform: scale(1.15); box-shadow: 0 0 0 3px rgba(4,47,36,0.2); }
</style>

<script is:inline>
// ============================================================
// QUESTION BANKS
// ============================================================

// ============================================================
// QUESTION BANK REGISTRY (metadata only — questions loaded on demand)
// ============================================================
var BANK_REGISTRY = {
  hku:        { file: '/data/interview/hku.json', prepTime: 30, answerTime: 120, recording: true },
  general:    { file: '/data/interview/general.json', prepTime: 10, answerTime: 120, recording: true },
  oxbridge:   { file: '/data/interview/oxbridge.json', prepTime: -1, answerTime: 0, recording: true },
  kira:       { file: '/data/interview/kira.json', prepTime: 30, answerTime: 90, recording: true },
  faang:      { file: '/data/interview/faang.json', prepTime: -1, answerTime: 0, recording: false },
  consulting: { file: '/data/interview/consulting.json', prepTime: -1, answerTime: 0, recording: false },
  banking:    { file: '/data/interview/banking.json', prepTime: -1, answerTime: 0, recording: false },
  gradschool: { file: '/data/interview/gradschool.json', prepTime: -1, answerTime: 0, recording: false },
  mmi:        { file: '/data/interview/mmi.json', prepTime: 120, answerTime: 480, recording: false }
};

// Cache for loaded question data
var questionCache = {};

function loadQuestions(bankId, callback) {
  if (questionCache[bankId]) { callback(questionCache[bankId]); return; }
  var reg = BANK_REGISTRY[bankId];
  if (!reg) { callback(null); return; }
  fetch(reg.file)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      questionCache[bankId] = data;
      callback(data);
    })
    .catch(function(err) {
      console.error('Failed to load questions for ' + bankId, err);
      callback(null);
    });
}

// ============================================================
// STATE
// ============================================================
var state = {
  mode: null,        // 'hku' | 'oxbridge' | 'general' | 'custom'
  subject: null,
  questions: [],     // current question set
  qIndex: -1,
  visited: {},       // { index: true } for visited questions
  phase: 'idle',     // 'idle' | 'prep' | 'record' | 'review'
  timer: null,
  timeLeft: 0,
  prepTime: 30,
  answerTime: 120,
  recording: true,
  mediaRecorder: null,
  audioChunks: [],
  audioBlobURL: null,
  mediaStream: null,
  mimeType: '',
  fileExt: '.webm',
};

// ============================================================
// SCREEN MANAGEMENT
// ============================================================
function showScreen(id) {
  ['screen-mode', 'screen-subject', 'screen-import', 'screen-practice'].forEach(function(s) {
    var el = document.getElementById(s);
    if (el) el.classList.add('hidden');
  });
  var el = document.getElementById('screen-' + id);
  el.classList.remove('hidden');
  el.classList.remove('fade-in');
  void el.offsetWidth;
  el.classList.add('fade-in');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function goBack(to) {
  if (to === 'mode') {
    state.mode = null;
    state.subject = null;
    showScreen('mode');
  }
}

// ============================================================
// MODE SELECTION
// ============================================================
function selectMode(mode) {
  state.mode = mode;
  if (mode === 'custom') {
    showScreen('import');
    return;
  }
  if (mode === 'oxbridge') {
    // Oxbridge needs subject picker first
    loadQuestions('oxbridge', function(data) {
      if (!data) return;
      questionCache._oxbridgeData = data; // store full {subjects, questions}
      renderSubjectGrid(data);
      showScreen('subject');
    });
    return;
  }
  // All other modes: load from registry
  var reg = BANK_REGISTRY[mode];
  if (!reg) return;
  loadQuestions(mode, function(questions) {
    if (!questions) return;
    state.prepTime = reg.prepTime;
    state.answerTime = reg.answerTime;
    state.recording = reg.recording;
    state.questions = questions.map(function(q, i) { return Object.assign({_idx: i}, q); });
    pickRandomQuestion();
    showScreen('practice');
    updatePracticeBadge();
  });
}

// ============================================================
// SUBJECT GRID (Oxbridge)
// ============================================================
function renderSubjectGrid(data) {
  var grid = document.getElementById('subject-grid');
  grid.innerHTML = '';
  var subjects = data.subjects || [];
  var questions = data.questions || {};
  if (subjects.length === 0) {
    grid.innerHTML = '<div class="col-span-full text-center py-12 text-on-surface-variant"><p class="text-lg font-bold mb-2">Oxbridge questions coming soon</p><p class="text-sm">We are curating real interview questions from Oxford and Cambridge. Check back soon.</p></div>';
    return;
  }
  subjects.forEach(function(subj) {
    var count = (questions[subj.id] || []).length;
    var btn = document.createElement('button');
    btn.className = 'text-left p-4 bg-white rounded-xl border border-outline-variant/15 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-100/50 transition-all group';
    btn.innerHTML = '<div class="flex items-center gap-3 mb-2"><span class="material-symbols-outlined text-amber-600 text-xl">' + (subj.icon || 'school') + '</span><span class="text-xs font-bold text-on-surface-variant/50">' + count + ' Qs</span></div><h4 class="font-headline font-bold text-on-surface group-hover:text-amber-700 transition-colors text-sm">' + subj.name + '</h4>';
    btn.onclick = function() { selectSubject(subj.id); };
    grid.appendChild(btn);
  });
}

function selectSubject(subjectId) {
  var data = questionCache._oxbridgeData;
  if (!data) return;
  state.subject = subjectId;
  state.prepTime = -1; // manual: read at own pace, click to record
  state.answerTime = 0; // unlimited
  state.recording = true;
  state.questions = (data.questions[subjectId] || []).map(function(q, i) { return Object.assign({_idx: i}, q); });
  pickRandomQuestion();
  showScreen('practice');
  updatePracticeBadge();
}

// ============================================================
// CUSTOM IMPORT
// ============================================================
function switchImportTab(tab) {
  ['paste', 'file', 'manual'].forEach(function(t) {
    document.getElementById('import-' + t).classList.toggle('hidden', t !== tab);
    document.getElementById('tab-' + t).classList.toggle('iv-tab-active', t === tab);
    if (t !== tab) {
      document.getElementById('tab-' + t).className = 'px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all';
    }
  });
}

var manualRowCount = 1;
function addManualRow() {
  manualRowCount++;
  var container = document.getElementById('manual-questions');
  var div = document.createElement('div');
  div.className = 'flex gap-2 mb-2 items-start';
  div.innerHTML = '<span class="text-xs font-bold text-on-surface-variant/40 mt-3 w-6 shrink-0">' + manualRowCount + '.</span><input type="text" placeholder="Type your question here..." class="iv-manual-input flex-1 border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />';
  container.appendChild(div);
}

// Watch paste area for content
document.getElementById('paste-area').addEventListener('input', checkCustomReady);
document.getElementById('file-input').addEventListener('change', handleFileUpload);

function checkCustomReady() {
  var pasteText = document.getElementById('paste-area').value.trim();
  var hasQuestions = pasteText.split('\n').filter(function(l) { return l.trim(); }).length > 0;
  var btn = document.getElementById('btn-start-custom');
  btn.disabled = !hasQuestions;
  document.getElementById('btn-start-custom-text').textContent = hasQuestions ? 'Start Practice (' + pasteText.split('\n').filter(function(l) { return l.trim(); }).length + ' questions)' : 'Import questions to begin';
}

function handleFileUpload(e) {
  var file = e.target.files[0];
  if (!file) return;
  document.getElementById('file-name').textContent = file.name;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var text = ev.target.result;
    var questions = [];
    if (file.name.endsWith('.json')) {
      try {
        var parsed = JSON.parse(text);
        if (Array.isArray(parsed)) {
          questions = parsed.map(function(item) {
            if (typeof item === 'string') return { en: item };
            return { en: item.question || item.en || '', material: item.material || '', hint: item.hint || '' };
          });
        }
      } catch(err) { alert('Invalid JSON file'); return; }
    } else {
      // CSV or TXT: one question per line
      questions = text.split('\n').filter(function(l) { return l.trim(); }).map(function(line) {
        var parts = line.split(',');
        if (parts.length >= 2) {
          return { en: parts[0].trim().replace(/^"(.*)"$/, '$1'), material: (parts[1] || '').trim().replace(/^"(.*)"$/, '$1'), hint: (parts[2] || '').trim().replace(/^"(.*)"$/, '$1') };
        }
        return { en: line.trim() };
      });
    }
    // Put into paste area for preview
    document.getElementById('paste-area').value = questions.map(function(q) { return q.en; }).join('\n');
    // Store full data
    state._importedQuestions = questions;
    checkCustomReady();
  };
  reader.readAsText(file);
}

function startCustomPractice() {
  var questions;
  if (state._importedQuestions) {
    questions = state._importedQuestions;
  } else {
    // Check manual tab
    var manualInputs = document.querySelectorAll('.iv-manual-input');
    var manualQs = [];
    manualInputs.forEach(function(inp) { if (inp.value.trim()) manualQs.push({ en: inp.value.trim() }); });
    if (manualQs.length > 0) {
      questions = manualQs;
    } else {
      // Paste area
      var text = document.getElementById('paste-area').value.trim();
      questions = text.split('\n').filter(function(l) { return l.trim(); }).map(function(l) { return { en: l.trim() }; });
    }
  }
  if (!questions || questions.length === 0) return;

  var prepToggle = document.getElementById('custom-prep-toggle').value;
  state.prepTime = prepToggle === 'off' ? -1 : (parseInt(document.getElementById('custom-prep-seconds').value) || 10);
  state.answerTime = parseInt(document.getElementById('custom-answer').value) || 0;
  state.recording = document.getElementById('custom-record').value === 'on';
  state.questions = questions.map(function(q, i) { return Object.assign({_idx: i}, q); });
  state._importedQuestions = null;
  pickRandomQuestion();
  showScreen('practice');
  updatePracticeBadge();
}

// ============================================================
// PRACTICE ENGINE
// ============================================================
function pickRandomQuestion() {
  if (!state.questions.length) return;
  state.qIndex = 0;
  state.visited = { 0: true };
  resetPracticeUI();
  displayCurrentQuestion();
  renderNavPanel();
}

function goToQuestion(idx) {
  if (idx < 0 || idx >= state.questions.length) return;
  // Stop any in-progress recording/timer
  clearInterval(state.timer);
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
  state.qIndex = idx;
  state.visited[idx] = true;
  resetPracticeUI();
  displayCurrentQuestion();
  renderNavPanel();
}

function nextQuestion() {
  var next = state.qIndex + 1;
  if (next >= state.questions.length) next = 0;
  goToQuestion(next);
}

function renderNavPanel() {
  var grid = document.getElementById('iv-nav-grid');
  grid.innerHTML = '';
  var modeColors = {
    hku: { active: 'bg-primary text-white', visited: 'bg-primary/20 text-primary', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    oxbridge: { active: 'bg-amber-600 text-white', visited: 'bg-amber-100 text-amber-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    general: { active: 'bg-emerald-600 text-white', visited: 'bg-emerald-100 text-emerald-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    custom: { active: 'bg-violet-600 text-white', visited: 'bg-violet-100 text-violet-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    kira: { active: 'bg-sky-600 text-white', visited: 'bg-sky-100 text-sky-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    faang: { active: 'bg-orange-600 text-white', visited: 'bg-orange-100 text-orange-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    consulting: { active: 'bg-indigo-600 text-white', visited: 'bg-indigo-100 text-indigo-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    banking: { active: 'bg-slate-600 text-white', visited: 'bg-slate-100 text-slate-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    gradschool: { active: 'bg-teal-600 text-white', visited: 'bg-teal-100 text-teal-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    mmi: { active: 'bg-rose-600 text-white', visited: 'bg-rose-100 text-rose-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' }
  };
  var colors = modeColors[state.mode] || modeColors.custom;
  state.questions.forEach(function(q, i) {
    var btn = document.createElement('button');
    var cls;
    if (i === state.qIndex) cls = colors.active + ' font-black shadow-sm';
    else if (state.visited[i]) cls = colors.visited + ' font-bold';
    else cls = colors.idle + ' font-medium';
    btn.className = 'w-8 h-8 rounded-lg text-xs flex items-center justify-center transition-all hover:scale-110 ' + cls;
    btn.textContent = (i + 1);
    btn.onclick = function() { goToQuestion(i); };
    grid.appendChild(btn);
  });
}

function displayCurrentQuestion() {
  var q = state.questions[state.qIndex];
  if (!q) return;

  // Main question text
  var mainText = q.text || q.en || q.main || q.question || '';
  var subText = q.cn || '';
  document.getElementById('iv-q-main').textContent = mainText;
  document.getElementById('iv-q-sub').textContent = subText;

  // Category badge
  var catBadge = document.getElementById('iv-cat-badge');
  var catText = document.getElementById('iv-cat-text');
  if (q.cat) {
    catBadge.classList.remove('hidden');
    catText.textContent = q.catZh || q.cat;
  } else if (q.summary) {
    catBadge.classList.remove('hidden');
    catText.textContent = q.summary;
  } else {
    catBadge.classList.add('hidden');
  }

  // Material (for Oxbridge)
  var matEl = document.getElementById('iv-material');
  if (q.material) {
    matEl.classList.remove('hidden');
    document.getElementById('iv-material-text').textContent = q.material;
  } else {
    matEl.classList.add('hidden');
  }

  // Hint
  var hintArea = document.getElementById('iv-hint-area');
  if (q.hint) {
    hintArea.classList.remove('hidden');
    document.getElementById('iv-hint-box').textContent = q.hint;
    document.getElementById('iv-hint-box').classList.add('hidden');
  } else {
    hintArea.classList.add('hidden');
  }

  // Analysis (general mode)
  var analysisArea = document.getElementById('iv-analysis');
  if (q.focus && q.strategies) {
    analysisArea.classList.remove('hidden');
    document.getElementById('iv-analysis-focus').textContent = q.focus;
    var ul = document.getElementById('iv-analysis-strategies');
    ul.innerHTML = '';
    q.strategies.forEach(function(s) {
      var li = document.createElement('li');
      li.textContent = s;
      ul.appendChild(li);
    });
    document.getElementById('iv-analysis-box').classList.add('hidden');
  } else {
    analysisArea.classList.add('hidden');
  }

  // Progress
  document.getElementById('practice-progress').textContent = 'Q' + (state.qIndex + 1) + ' / ' + state.questions.length;

}

function updatePracticeBadge() {
  var badge = document.getElementById('practice-mode-badge');
  var colors = { hku: 'bg-primary/10 text-primary', oxbridge: 'bg-amber-100 text-amber-700', general: 'bg-emerald-100 text-emerald-700', custom: 'bg-violet-100 text-violet-700', kira: 'bg-sky-100 text-sky-700', faang: 'bg-orange-100 text-orange-700', consulting: 'bg-indigo-100 text-indigo-700', banking: 'bg-slate-100 text-slate-700', gradschool: 'bg-teal-100 text-teal-700', mmi: 'bg-rose-100 text-rose-700' };
  var labels = { hku: 'HKU', oxbridge: 'Oxbridge', general: 'General', custom: 'Custom', kira: 'Kira', faang: 'FAANG', consulting: 'MBB', banking: 'IB', gradschool: 'Grad', mmi: 'MMI' };
  badge.className = 'px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase ' + (colors[state.mode] || '');
  badge.textContent = labels[state.mode] || '';
}

function resetPracticeUI() {
  state.phase = 'idle';
  clearInterval(state.timer);

  // Lock question
  document.getElementById('iv-lock').classList.remove('hidden');
  document.getElementById('iv-question-wrap').classList.add('iv-locked');

  // Timer
  var timerArea = document.getElementById('iv-timer-area');
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 border-outline-variant/10 bg-surface-container-low transition-all duration-300';
  document.getElementById('iv-timer-label').textContent = 'Waiting';
  document.getElementById('iv-timer-label').className = 'text-xs font-bold text-on-surface-variant/50 uppercase tracking-widest mb-1';
  document.getElementById('iv-timer-display').textContent = '--:--';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors';

  // Buttons
  var btnMain = document.getElementById('iv-btn-main');
  btnMain.classList.remove('hidden');
  btnMain.disabled = false;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'play_circle';
  document.getElementById('iv-btn-text').textContent = 'Start';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  // Audio
  document.getElementById('iv-audio-area').classList.add('hidden');
  if (state.audioBlobURL) { URL.revokeObjectURL(state.audioBlobURL); state.audioBlobURL = null; }
  document.getElementById('iv-audio-player').src = '';

  // Timer area visible
  timerArea.classList.remove('hidden');
}

// ============================================================
// PRACTICE FLOW
// ============================================================
document.getElementById('iv-btn-main').addEventListener('click', handleMainAction);
document.getElementById('iv-btn-skip').addEventListener('click', handleSkip);
document.getElementById('iv-hint-btn').addEventListener('click', function() {
  document.getElementById('iv-hint-box').classList.toggle('hidden');
});
document.getElementById('iv-analysis-btn').addEventListener('click', function() {
  document.getElementById('iv-analysis-box').classList.toggle('hidden');
});

async function handleMainAction() {
  if (state.phase === 'idle') {
    // For recording modes: request mic first
    if (state.recording) {
      document.getElementById('iv-btn-text').textContent = 'Requesting microphone...';
      try {
        state.mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
        detectAudioFormat();
      } catch(err) {
        alert('Please allow microphone access to use recording mode.');
        document.getElementById('iv-btn-text').textContent = 'Start';
        return;
      }
    }
    enterPrepPhase();
  } else if (state.phase === 'ready') {
    // Manual prep done, user clicked "Start Recording"
    enterRecordPhase();
  } else if (state.phase === 'record') {
    finishRecording();
  } else if (state.phase === 'review') {
    nextQuestion();
  }
}

function handleSkip() {
  if (state.phase === 'prep' || state.phase === 'ready') enterRecordPhase();
  else if (state.phase === 'record') finishRecording();
}

function revealQuestion() {
  document.getElementById('iv-lock').classList.add('hidden');
  document.getElementById('iv-question-wrap').classList.remove('iv-locked');
}

function enterPrepPhase() {
  state.phase = 'prep';
  revealQuestion();

  var timerArea = document.getElementById('iv-timer-area');
  var btnMain = document.getElementById('iv-btn-main');

  // Manual prep mode (prepTime === -1): no countdown, user clicks when ready
  if (state.prepTime === -1) {
    timerArea.classList.add('hidden');
    btnMain.disabled = false;
    btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-rose-600 text-white font-bold text-lg shadow-lg shadow-rose-200 hover:bg-rose-700 transition-all flex justify-center items-center gap-2';
    document.getElementById('iv-btn-icon').textContent = 'mic';
    document.getElementById('iv-btn-text').textContent = 'Start Recording';
    document.getElementById('iv-btn-skip').classList.add('hidden');
    // Override: clicking main button goes to record
    state.phase = 'ready';
    return;
  }

  // Timed prep mode (prepTime > 0): countdown then auto-start
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 transition-all duration-300 bg-blue-50 border-blue-200 shadow-inner';
  document.getElementById('iv-timer-label').textContent = 'PREP (' + state.prepTime + 's)';
  document.getElementById('iv-timer-label').className = 'text-xs font-bold uppercase tracking-widest mb-1 text-blue-500';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black tracking-tighter transition-colors text-blue-600';

  btnMain.disabled = true;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-surface-container text-on-surface-variant/50 cursor-not-allowed font-bold text-lg flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'hourglass_top';
  document.getElementById('iv-btn-text').textContent = 'Read and prepare...';

  document.getElementById('iv-btn-skip').classList.remove('hidden');
  document.getElementById('iv-btn-skip-text').textContent = "I'm ready";

  state.timeLeft = state.prepTime;
  updateTimerDisplay();
  state.timer = setInterval(function() {
    state.timeLeft--;
    updateTimerDisplay();
    if (state.timeLeft <= 5 && state.timeLeft > 0) {
      document.getElementById('iv-timer-display').classList.add('warning-pulse');
    }
    if (state.timeLeft <= 0) {
      clearInterval(state.timer);
      document.getElementById('iv-timer-display').classList.remove('warning-pulse');
      if (state.recording) enterRecordPhase();
      else enterReviewPhase();
    }
  }, 1000);
}

function enterRecordPhase() {
  clearInterval(state.timer);
  state.phase = 'record';

  var timerArea = document.getElementById('iv-timer-area');
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 transition-all duration-300 bg-rose-50 border-rose-200 recording-pulse';
  var label = state.answerTime > 0 ? 'RECORDING (' + Math.floor(state.answerTime/60) + 'min ' + (state.answerTime%60) + 's)' : 'RECORDING (no limit)';
  document.getElementById('iv-timer-label').textContent = label;
  document.getElementById('iv-timer-label').className = 'text-xs font-bold uppercase tracking-widest mb-1 text-rose-500 animate-pulse';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black tracking-tighter transition-colors text-rose-600';

  var btnMain = document.getElementById('iv-btn-main');
  btnMain.disabled = false;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-rose-600 text-white font-bold text-lg shadow-lg shadow-rose-200 hover:bg-rose-700 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'stop_circle';
  document.getElementById('iv-btn-text').textContent = 'Stop Recording';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  // Start recording
  state.audioChunks = [];
  try {
    var opts = state.mimeType ? { mimeType: state.mimeType } : {};
    state.mediaRecorder = new MediaRecorder(state.mediaStream, opts);
  } catch(e) {
    state.mediaRecorder = new MediaRecorder(state.mediaStream);
  }
  state.mediaRecorder.ondataavailable = function(ev) { if (ev.data.size > 0) state.audioChunks.push(ev.data); };
  state.mediaRecorder.onstop = handleAudioReady;
  state.mediaRecorder.start();

  if (state.answerTime > 0) {
    state.timeLeft = state.answerTime;
    updateTimerDisplay();
    state.timer = setInterval(function() {
      state.timeLeft--;
      updateTimerDisplay();
      if (state.timeLeft <= 0) finishRecording();
    }, 1000);
  } else {
    // Unlimited: count up
    state.timeLeft = 0;
    updateTimerDisplay();
    state.timer = setInterval(function() {
      state.timeLeft++;
      updateTimerDisplay();
    }, 1000);
  }
}

function finishRecording() {
  clearInterval(state.timer);
  state.phase = 'review';
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
  enterReviewPhase();
}

function enterReviewPhase() {
  state.phase = 'review';
  document.getElementById('iv-btn-main').classList.remove('hidden');
  document.getElementById('iv-btn-main').disabled = false;
  document.getElementById('iv-btn-main').className = 'w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'shuffle';
  document.getElementById('iv-btn-text').textContent = 'Next Question';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  var timerArea = document.getElementById('iv-timer-area');
  timerArea.classList.add('hidden');
}

function handleAudioReady() {
  var mime = state.mimeType || 'audio/webm';
  var blob = new Blob(state.audioChunks, { type: mime });
  if (state.audioBlobURL) URL.revokeObjectURL(state.audioBlobURL);
  state.audioBlobURL = URL.createObjectURL(blob);

  document.getElementById('iv-audio-player').src = state.audioBlobURL;
  document.getElementById('iv-audio-area').classList.remove('hidden');

  var q = state.questions[state.qIndex];
  var prefix = state.mode === 'hku' ? 'HKU' : (state.mode === 'oxbridge' ? 'Oxbridge' : 'Interview');
  var fileName = prefix + '_Q' + (state.qIndex + 1) + '_' + new Date().toISOString().slice(0, 10).replace(/-/g, '') + state.fileExt;
  var dl = document.getElementById('iv-download');
  dl.href = state.audioBlobURL;
  dl.download = fileName;
}

function detectAudioFormat() {
  var types = [
    { mime: 'audio/mp4', ext: '.mp4' },
    { mime: 'audio/webm;codecs=opus', ext: '.webm' },
    { mime: 'audio/webm', ext: '.webm' },
    { mime: 'audio/ogg;codecs=opus', ext: '.ogg' }
  ];
  for (var i = 0; i < types.length; i++) {
    if (MediaRecorder.isTypeSupported(types[i].mime)) {
      state.mimeType = types[i].mime;
      state.fileExt = types[i].ext;
      return;
    }
  }
  state.mimeType = '';
  state.fileExt = '.weba';
}

function updateTimerDisplay() {
  var t = Math.abs(state.timeLeft);
  var m = Math.floor(t / 60).toString().padStart(2, '0');
  var s = (t % 60).toString().padStart(2, '0');
  document.getElementById('iv-timer-display').textContent = m + ':' + s;
}



function exitPractice() {
  goBack('mode');
  // Cleanup
  clearInterval(state.timer);
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
}

</script>
