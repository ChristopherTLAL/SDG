// ============================================================
// STATE
// ============================================================
var state = {
  mode: null,        // 'hku' | 'oxbridge' | 'general' | 'custom'
  subject: null,
  questions: [],     // current question set
  qIndex: -1,
  visited: {},       // { index: true } for visited questions
  phase: 'idle',     // 'idle' | 'prep' | 'record' | 'review'
  timer: null,
  timeLeft: 0,
  prepTime: 30,
  answerTime: 120,
  recording: true,
  mediaRecorder: null,
  audioChunks: [],
  audioBlobURL: null,
  mediaStream: null,
  mimeType: '',
  fileExt: '.webm',
};

// ============================================================
// SCREEN MANAGEMENT
// ============================================================
function showScreen(id) {
  ['screen-mode', 'screen-subject', 'screen-import', 'screen-practice'].forEach(function(s) {
    var el = document.getElementById(s);
    if (el) el.classList.add('hidden');
  });
  var el = document.getElementById('screen-' + id);
  el.classList.remove('hidden');
  el.classList.remove('fade-in');
  void el.offsetWidth;
  el.classList.add('fade-in');
}

function goBack(to) {
  if (to === 'mode') {
    state.mode = null;
    state.subject = null;
    showScreen('mode');
  }
}

// ============================================================
// MODE SELECTION
// ============================================================
function selectMode(mode) {
  state.mode = mode;
  if (mode === 'hku') {
    state.prepTime = 30;
    state.answerTime = 120;
    state.recording = true;
    state.questions = HKU_QUESTIONS.map(function(q, i) { return Object.assign({_idx: i}, q); });
    pickRandomQuestion();
    showScreen('practice');
    updatePracticeBadge();
  } else if (mode === 'oxbridge') {
    renderSubjectGrid();
    showScreen('subject');
  } else if (mode === 'general') {
    state.prepTime = 10;
    state.answerTime = 120;
    state.recording = true;
    state.questions = GENERAL_QUESTIONS.map(function(q, i) { return Object.assign({_idx: i}, q); });
    pickRandomQuestion();
    showScreen('practice');
    updatePracticeBadge();
  } else if (mode === 'custom') {
    showScreen('import');
  }
}

// ============================================================
// SUBJECT GRID (Oxbridge)
// ============================================================
function renderSubjectGrid() {
  var grid = document.getElementById('subject-grid');
  grid.innerHTML = '';
  // If Oxbridge data is empty, show placeholder
  if (OXBRIDGE_SUBJECTS.length === 0) {
    grid.innerHTML = '<div class="col-span-full text-center py-12 text-on-surface-variant"><p class="text-lg font-bold mb-2">Oxbridge questions coming soon</p><p class="text-sm">We are curating real interview questions from Oxford and Cambridge. Check back soon.</p></div>';
    return;
  }
  OXBRIDGE_SUBJECTS.forEach(function(subj) {
    var count = (OXBRIDGE_QUESTIONS[subj.id] || []).length;
    var btn = document.createElement('button');
    btn.className = 'text-left p-4 bg-white rounded-xl border border-outline-variant/15 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-100/50 transition-all group';
    btn.innerHTML = '<div class="flex items-center gap-3 mb-2"><span class="material-symbols-outlined text-amber-600 text-xl">' + (subj.icon || 'school') + '</span><span class="text-xs font-bold text-on-surface-variant/50">' + count + ' Qs</span></div><h4 class="font-headline font-bold text-on-surface group-hover:text-amber-700 transition-colors text-sm">' + subj.name + '</h4>';
    btn.onclick = function() { selectSubject(subj.id); };
    grid.appendChild(btn);
  });
}

function selectSubject(subjectId) {
  state.subject = subjectId;
  state.prepTime = -1; // manual: read at own pace, click to record
  state.answerTime = 0; // unlimited
  state.recording = true;
  state.questions = (OXBRIDGE_QUESTIONS[subjectId] || []).map(function(q, i) { return Object.assign({_idx: i}, q); });
  pickRandomQuestion();
  showScreen('practice');
  updatePracticeBadge();
}

// ============================================================
// CUSTOM IMPORT
// ============================================================
function switchImportTab(tab) {
  ['paste', 'file', 'manual'].forEach(function(t) {
    document.getElementById('import-' + t).classList.toggle('hidden', t !== tab);
    document.getElementById('tab-' + t).classList.toggle('iv-tab-active', t === tab);
    if (t !== tab) {
      document.getElementById('tab-' + t).className = 'px-4 py-2 text-sm font-bold text-on-surface-variant/60 rounded-lg hover:bg-surface-container transition-all';
    }
  });
}

var manualRowCount = 1;
function addManualRow() {
  manualRowCount++;
  var container = document.getElementById('manual-questions');
  var div = document.createElement('div');
  div.className = 'flex gap-2 mb-2 items-start';
  div.innerHTML = '<span class="text-xs font-bold text-on-surface-variant/40 mt-3 w-6 shrink-0">' + manualRowCount + '.</span><input type="text" placeholder="Type your question here..." class="iv-manual-input flex-1 border border-outline-variant/20 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary/40" />';
  container.appendChild(div);
}

// Watch paste area for content
document.getElementById('paste-area').addEventListener('input', checkCustomReady);
document.getElementById('file-input').addEventListener('change', handleFileUpload);

function checkCustomReady() {
  var pasteText = document.getElementById('paste-area').value.trim();
  var hasQuestions = pasteText.split('\n').filter(function(l) { return l.trim(); }).length > 0;
  var btn = document.getElementById('btn-start-custom');
  btn.disabled = !hasQuestions;
  document.getElementById('btn-start-custom-text').textContent = hasQuestions ? 'Start Practice (' + pasteText.split('\n').filter(function(l) { return l.trim(); }).length + ' questions)' : 'Import questions to begin';
}

function handleFileUpload(e) {
  var file = e.target.files[0];
  if (!file) return;
  document.getElementById('file-name').textContent = file.name;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var text = ev.target.result;
    var questions = [];
    if (file.name.endsWith('.json')) {
      try {
        var parsed = JSON.parse(text);
        if (Array.isArray(parsed)) {
          questions = parsed.map(function(item) {
            if (typeof item === 'string') return { en: item };
            return { en: item.question || item.en || '', material: item.material || '', hint: item.hint || '' };
          });
        }
      } catch(err) { alert('Invalid JSON file'); return; }
    } else {
      // CSV or TXT: one question per line
      questions = text.split('\n').filter(function(l) { return l.trim(); }).map(function(line) {
        var parts = line.split(',');
        if (parts.length >= 2) {
          return { en: parts[0].trim().replace(/^"(.*)"$/, '$1'), material: (parts[1] || '').trim().replace(/^"(.*)"$/, '$1'), hint: (parts[2] || '').trim().replace(/^"(.*)"$/, '$1') };
        }
        return { en: line.trim() };
      });
    }
    // Put into paste area for preview
    document.getElementById('paste-area').value = questions.map(function(q) { return q.en; }).join('\n');
    // Store full data
    state._importedQuestions = questions;
    checkCustomReady();
  };
  reader.readAsText(file);
}

function startCustomPractice() {
  var questions;
  if (state._importedQuestions) {
    questions = state._importedQuestions;
  } else {
    // Check manual tab
    var manualInputs = document.querySelectorAll('.iv-manual-input');
    var manualQs = [];
    manualInputs.forEach(function(inp) { if (inp.value.trim()) manualQs.push({ en: inp.value.trim() }); });
    if (manualQs.length > 0) {
      questions = manualQs;
    } else {
      // Paste area
      var text = document.getElementById('paste-area').value.trim();
      questions = text.split('\n').filter(function(l) { return l.trim(); }).map(function(l) { return { en: l.trim() }; });
    }
  }
  if (!questions || questions.length === 0) return;

  var prepToggle = document.getElementById('custom-prep-toggle').value;
  state.prepTime = prepToggle === 'off' ? -1 : (parseInt(document.getElementById('custom-prep-seconds').value) || 10);
  state.answerTime = parseInt(document.getElementById('custom-answer').value) || 0;
  state.recording = document.getElementById('custom-record').value === 'on';
  state.questions = questions.map(function(q, i) { return Object.assign({_idx: i}, q); });
  state._importedQuestions = null;
  pickRandomQuestion();
  showScreen('practice');
  updatePracticeBadge();
}

// ============================================================
// PRACTICE ENGINE
// ============================================================
function pickRandomQuestion() {
  if (!state.questions.length) return;
  state.qIndex = 0;
  state.visited = { 0: true };
  resetPracticeUI();
  displayCurrentQuestion();
  renderNavPanel();
}

function goToQuestion(idx) {
  if (idx < 0 || idx >= state.questions.length) return;
  // Stop any in-progress recording/timer
  clearInterval(state.timer);
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
  state.qIndex = idx;
  state.visited[idx] = true;
  resetPracticeUI();
  displayCurrentQuestion();
  renderNavPanel();
}

function nextQuestion() {
  var next = state.qIndex + 1;
  if (next >= state.questions.length) next = 0;
  goToQuestion(next);
}

function renderNavPanel() {
  var grid = document.getElementById('iv-nav-grid');
  grid.innerHTML = '';
  var modeColors = {
    hku: { active: 'bg-primary text-white', visited: 'bg-primary/20 text-primary', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    oxbridge: { active: 'bg-amber-600 text-white', visited: 'bg-amber-100 text-amber-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    general: { active: 'bg-emerald-600 text-white', visited: 'bg-emerald-100 text-emerald-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' },
    custom: { active: 'bg-violet-600 text-white', visited: 'bg-violet-100 text-violet-700', idle: 'bg-white text-on-surface-variant/60 border border-outline-variant/20' }
  };
  var colors = modeColors[state.mode] || modeColors.custom;
  state.questions.forEach(function(q, i) {
    var btn = document.createElement('button');
    var cls;
    if (i === state.qIndex) cls = colors.active + ' font-black shadow-sm';
    else if (state.visited[i]) cls = colors.visited + ' font-bold';
    else cls = colors.idle + ' font-medium';
    btn.className = 'w-8 h-8 rounded-lg text-xs flex items-center justify-center transition-all hover:scale-110 ' + cls;
    btn.textContent = (i + 1);
    btn.onclick = function() { goToQuestion(i); };
    grid.appendChild(btn);
  });
}

function displayCurrentQuestion() {
  var q = state.questions[state.qIndex];
  if (!q) return;

  // Main question text
  var mainText = q.text || q.en || q.main || q.question || '';
  var subText = q.cn || '';
  document.getElementById('iv-q-main').textContent = mainText;
  document.getElementById('iv-q-sub').textContent = subText;

  // Category badge
  var catBadge = document.getElementById('iv-cat-badge');
  var catText = document.getElementById('iv-cat-text');
  if (q.cat) {
    catBadge.classList.remove('hidden');
    catText.textContent = q.catZh || q.cat;
  } else if (q.summary) {
    catBadge.classList.remove('hidden');
    catText.textContent = q.summary;
  } else {
    catBadge.classList.add('hidden');
  }

  // Material (for Oxbridge)
  var matEl = document.getElementById('iv-material');
  if (q.material) {
    matEl.classList.remove('hidden');
    document.getElementById('iv-material-text').textContent = q.material;
  } else {
    matEl.classList.add('hidden');
  }

  // Hint
  var hintArea = document.getElementById('iv-hint-area');
  if (q.hint) {
    hintArea.classList.remove('hidden');
    document.getElementById('iv-hint-box').textContent = q.hint;
    document.getElementById('iv-hint-box').classList.add('hidden');
  } else {
    hintArea.classList.add('hidden');
  }

  // Analysis (general mode)
  var analysisArea = document.getElementById('iv-analysis');
  if (q.focus && q.strategies) {
    analysisArea.classList.remove('hidden');
    document.getElementById('iv-analysis-focus').textContent = q.focus;
    var ul = document.getElementById('iv-analysis-strategies');
    ul.innerHTML = '';
    q.strategies.forEach(function(s) {
      var li = document.createElement('li');
      li.textContent = s;
      ul.appendChild(li);
    });
    document.getElementById('iv-analysis-box').classList.add('hidden');
  } else {
    analysisArea.classList.add('hidden');
  }

  // Progress
  document.getElementById('practice-progress').textContent = 'Q' + (state.qIndex + 1) + ' / ' + state.questions.length;

}

function updatePracticeBadge() {
  var badge = document.getElementById('practice-mode-badge');
  var colors = { hku: 'bg-primary/10 text-primary', oxbridge: 'bg-amber-100 text-amber-700', general: 'bg-emerald-100 text-emerald-700', custom: 'bg-violet-100 text-violet-700' };
  var labels = { hku: 'HKU', oxbridge: 'Oxbridge', general: 'General', custom: 'Custom' };
  badge.className = 'px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase ' + (colors[state.mode] || '');
  badge.textContent = labels[state.mode] || '';
}

function resetPracticeUI() {
  state.phase = 'idle';
  clearInterval(state.timer);

  // Lock question
  document.getElementById('iv-lock').classList.remove('hidden');
  document.getElementById('iv-question-wrap').classList.add('iv-locked');

  // Timer
  var timerArea = document.getElementById('iv-timer-area');
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 border-outline-variant/10 bg-surface-container-low transition-all duration-300';
  document.getElementById('iv-timer-label').textContent = 'Waiting';
  document.getElementById('iv-timer-label').className = 'text-xs font-bold text-on-surface-variant/50 uppercase tracking-widest mb-1';
  document.getElementById('iv-timer-display').textContent = '--:--';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors';

  // Buttons
  var btnMain = document.getElementById('iv-btn-main');
  btnMain.classList.remove('hidden');
  btnMain.disabled = false;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'play_circle';
  document.getElementById('iv-btn-text').textContent = 'Start';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  // Audio
  document.getElementById('iv-audio-area').classList.add('hidden');
  if (state.audioBlobURL) { URL.revokeObjectURL(state.audioBlobURL); state.audioBlobURL = null; }
  document.getElementById('iv-audio-player').src = '';

  // Timer area visible
  timerArea.classList.remove('hidden');
}

// ============================================================
// PRACTICE FLOW
// ============================================================
document.getElementById('iv-btn-main').addEventListener('click', handleMainAction);
document.getElementById('iv-btn-skip').addEventListener('click', handleSkip);
document.getElementById('iv-hint-btn').addEventListener('click', function() {
  document.getElementById('iv-hint-box').classList.toggle('hidden');
});
document.getElementById('iv-analysis-btn').addEventListener('click', function() {
  document.getElementById('iv-analysis-box').classList.toggle('hidden');
});

async function handleMainAction() {
  if (state.phase === 'idle') {
    // For recording modes: request mic first
    if (state.recording) {
      document.getElementById('iv-btn-text').textContent = 'Requesting microphone...';
      try {
        state.mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
        detectAudioFormat();
      } catch(err) {
        alert('Please allow microphone access to use recording mode.');
        document.getElementById('iv-btn-text').textContent = 'Start';
        return;
      }
    }
    enterPrepPhase();
  } else if (state.phase === 'ready') {
    // Manual prep done, user clicked "Start Recording"
    enterRecordPhase();
  } else if (state.phase === 'record') {
    finishRecording();
  } else if (state.phase === 'review') {
    nextQuestion();
  }
}

function handleSkip() {
  if (state.phase === 'prep' || state.phase === 'ready') enterRecordPhase();
  else if (state.phase === 'record') finishRecording();
}

function revealQuestion() {
  document.getElementById('iv-lock').classList.add('hidden');
  document.getElementById('iv-question-wrap').classList.remove('iv-locked');
}

function enterPrepPhase() {
  state.phase = 'prep';
  revealQuestion();

  var timerArea = document.getElementById('iv-timer-area');
  var btnMain = document.getElementById('iv-btn-main');

  // Manual prep mode (prepTime === -1): no countdown, user clicks when ready
  if (state.prepTime === -1) {
    timerArea.classList.add('hidden');
    btnMain.disabled = false;
    btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-rose-600 text-white font-bold text-lg shadow-lg shadow-rose-200 hover:bg-rose-700 transition-all flex justify-center items-center gap-2';
    document.getElementById('iv-btn-icon').textContent = 'mic';
    document.getElementById('iv-btn-text').textContent = 'Start Recording';
    document.getElementById('iv-btn-skip').classList.add('hidden');
    // Override: clicking main button goes to record
    state.phase = 'ready';
    return;
  }

  // Timed prep mode (prepTime > 0): countdown then auto-start
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 transition-all duration-300 bg-blue-50 border-blue-200 shadow-inner';
  document.getElementById('iv-timer-label').textContent = 'PREP (' + state.prepTime + 's)';
  document.getElementById('iv-timer-label').className = 'text-xs font-bold uppercase tracking-widest mb-1 text-blue-500';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black tracking-tighter transition-colors text-blue-600';

  btnMain.disabled = true;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-surface-container text-on-surface-variant/50 cursor-not-allowed font-bold text-lg flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'hourglass_top';
  document.getElementById('iv-btn-text').textContent = 'Read and prepare...';

  document.getElementById('iv-btn-skip').classList.remove('hidden');
  document.getElementById('iv-btn-skip-text').textContent = "I'm ready";

  state.timeLeft = state.prepTime;
  updateTimerDisplay();
  state.timer = setInterval(function() {
    state.timeLeft--;
    updateTimerDisplay();
    if (state.timeLeft <= 5 && state.timeLeft > 0) {
      document.getElementById('iv-timer-display').classList.add('warning-pulse');
    }
    if (state.timeLeft <= 0) {
      clearInterval(state.timer);
      document.getElementById('iv-timer-display').classList.remove('warning-pulse');
      if (state.recording) enterRecordPhase();
      else enterReviewPhase();
    }
  }, 1000);
}

function enterRecordPhase() {
  clearInterval(state.timer);
  state.phase = 'record';

  var timerArea = document.getElementById('iv-timer-area');
  timerArea.className = 'flex flex-col items-center justify-center rounded-2xl p-6 mb-6 border-2 transition-all duration-300 bg-rose-50 border-rose-200 recording-pulse';
  var label = state.answerTime > 0 ? 'RECORDING (' + Math.floor(state.answerTime/60) + 'min ' + (state.answerTime%60) + 's)' : 'RECORDING (no limit)';
  document.getElementById('iv-timer-label').textContent = label;
  document.getElementById('iv-timer-label').className = 'text-xs font-bold uppercase tracking-widest mb-1 text-rose-500 animate-pulse';
  document.getElementById('iv-timer-display').className = 'text-6xl font-mono font-black tracking-tighter transition-colors text-rose-600';

  var btnMain = document.getElementById('iv-btn-main');
  btnMain.disabled = false;
  btnMain.className = 'w-full md:w-2/3 py-4 rounded-2xl bg-rose-600 text-white font-bold text-lg shadow-lg shadow-rose-200 hover:bg-rose-700 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'stop_circle';
  document.getElementById('iv-btn-text').textContent = 'Stop Recording';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  // Start recording
  state.audioChunks = [];
  try {
    var opts = state.mimeType ? { mimeType: state.mimeType } : {};
    state.mediaRecorder = new MediaRecorder(state.mediaStream, opts);
  } catch(e) {
    state.mediaRecorder = new MediaRecorder(state.mediaStream);
  }
  state.mediaRecorder.ondataavailable = function(ev) { if (ev.data.size > 0) state.audioChunks.push(ev.data); };
  state.mediaRecorder.onstop = handleAudioReady;
  state.mediaRecorder.start();

  if (state.answerTime > 0) {
    state.timeLeft = state.answerTime;
    updateTimerDisplay();
    state.timer = setInterval(function() {
      state.timeLeft--;
      updateTimerDisplay();
      if (state.timeLeft <= 0) finishRecording();
    }, 1000);
  } else {
    // Unlimited: count up
    state.timeLeft = 0;
    updateTimerDisplay();
    state.timer = setInterval(function() {
      state.timeLeft++;
      updateTimerDisplay();
    }, 1000);
  }
}

function finishRecording() {
  clearInterval(state.timer);
  state.phase = 'review';
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
  enterReviewPhase();
}

function enterReviewPhase() {
  state.phase = 'review';
  document.getElementById('iv-btn-main').classList.remove('hidden');
  document.getElementById('iv-btn-main').disabled = false;
  document.getElementById('iv-btn-main').className = 'w-full md:w-2/3 py-4 rounded-2xl bg-primary text-on-primary font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex justify-center items-center gap-2';
  document.getElementById('iv-btn-icon').textContent = 'shuffle';
  document.getElementById('iv-btn-text').textContent = 'Next Question';
  document.getElementById('iv-btn-skip').classList.add('hidden');

  var timerArea = document.getElementById('iv-timer-area');
  timerArea.classList.add('hidden');
}

function handleAudioReady() {
  var mime = state.mimeType || 'audio/webm';
  var blob = new Blob(state.audioChunks, { type: mime });
  if (state.audioBlobURL) URL.revokeObjectURL(state.audioBlobURL);
  state.audioBlobURL = URL.createObjectURL(blob);

  document.getElementById('iv-audio-player').src = state.audioBlobURL;
  document.getElementById('iv-audio-area').classList.remove('hidden');

  var q = state.questions[state.qIndex];
  var prefix = state.mode === 'hku' ? 'HKU' : (state.mode === 'oxbridge' ? 'Oxbridge' : 'Interview');
  var fileName = prefix + '_Q' + (state.qIndex + 1) + '_' + new Date().toISOString().slice(0, 10).replace(/-/g, '') + state.fileExt;
  var dl = document.getElementById('iv-download');
  dl.href = state.audioBlobURL;
  dl.download = fileName;
}

function detectAudioFormat() {
  var types = [
    { mime: 'audio/mp4', ext: '.mp4' },
    { mime: 'audio/webm;codecs=opus', ext: '.webm' },
    { mime: 'audio/webm', ext: '.webm' },
    { mime: 'audio/ogg;codecs=opus', ext: '.ogg' }
  ];
  for (var i = 0; i < types.length; i++) {
    if (MediaRecorder.isTypeSupported(types[i].mime)) {
      state.mimeType = types[i].mime;
      state.fileExt = types[i].ext;
      return;
    }
  }
  state.mimeType = '';
  state.fileExt = '.weba';
}

function updateTimerDisplay() {
  var t = Math.abs(state.timeLeft);
  var m = Math.floor(t / 60).toString().padStart(2, '0');
  var s = (t % 60).toString().padStart(2, '0');
  document.getElementById('iv-timer-display').textContent = m + ':' + s;
}



function exitPractice() {
  goBack('mode');
  // Cleanup
  clearInterval(state.timer);
  if (state.mediaRecorder && state.mediaRecorder.state === 'recording') {
    state.mediaRecorder.stop();
    state.mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
}

</script>
