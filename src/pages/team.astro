---
// src/pages/team.astro — Team & Contributors page
import MainLayout from '../layouts/MainLayout.astro';
import { digitalSymbiosis } from '../data/publications-meta';

const lang = 'en';

// Unique book contributors — shown as public roster
const bookContributors = Array.from(
  new Set(digitalSymbiosis.chapters.map(c => c.author))
).sort((a, b) => a.localeCompare(b));

// Editorial & advisory: derived from public institute records (certificates).
// These are the individuals who have signed certificates as "body" (signatory).
const leadership = [
  {
    name: 'Haishan Fu',
    role: 'Principal Signatory, Institute Programs',
    description: 'Signs institute certificates for volunteer research and youth design competitions.',
    icon: 'edit_note',
  },
  {
    name: 'Oliver Sinclair',
    role: 'Editor, Digital Symbiosis',
    description: 'Editor of the Institute\'s 2025 edited volume on AI and sustainable development.',
    icon: 'menu_book',
  },
];
---

<MainLayout title="Team" description="The researchers, editors, and volunteer contributors who make the Chinese SDGs Institute possible." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-6 md:mb-8">
        <span>Institute</span>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <span class="text-primary font-bold">Team</span>
      </nav>

      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tight text-on-surface leading-[1.1] mb-6 md:mb-8">
        Team &amp; Contributors
      </h1>

      <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl mb-16">
        The Chinese SDGs Institute is a volunteer-driven community of students, young professionals, editors, and academic advisors. Every published piece is authored by a named individual and backed by a verifiable certificate.
      </p>

      <!-- ── Editorial & Signatories ── -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
            Editorial &amp; Signatories
          </h2>
          <span class="text-xs font-bold text-on-surface-variant/40">01</span>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {leadership.map(p => (
            <div class="bg-white border border-outline-variant/15 rounded-2xl p-6 md:p-8">
              <div class="flex items-start gap-5">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-primary text-2xl">{p.icon}</span>
                </div>
                <div class="flex-1">
                  <h3 class="font-headline font-bold text-lg text-on-surface mb-1">{p.name}</h3>
                  <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-3">{p.role}</p>
                  <p class="text-sm text-on-surface-variant leading-relaxed">{p.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Volunteer Researchers ── -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-3">
          <h2 class="font-headline font-extrabold text-2xl md:text-3xl text-on-surface tracking-tight">
            Volunteer Researchers
          </h2>
          <span class="text-xs font-bold text-on-surface-variant/40">02</span>
        </div>
        <p class="text-sm text-on-surface-variant mb-8 max-w-2xl">
          Authors of chapters in <em>Digital Symbiosis</em> (ISBN 978-1-955662-09-3), published November 2025. Additional research papers and policy briefs are credited on each <a href="/research" class="text-primary font-semibold hover:underline">research article</a>.
        </p>

        <div class="bg-surface-container-low/50 border border-outline-variant/10 rounded-2xl p-5 md:p-8">
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-6 gap-y-3">
            {bookContributors.map(name => (
              <div class="flex items-center gap-2 py-2 border-b border-outline-variant/10">
                <span class="w-1.5 h-1.5 rounded-full bg-primary/40 shrink-0"></span>
                <span class="text-sm text-on-surface font-medium truncate">{name}</span>
              </div>
            ))}
          </div>
          <p class="text-[11px] text-on-surface-variant/60 mt-6 italic">
            {bookContributors.length} contributors listed. Each chapter carries a verifiable certificate of authorship — look up any author's certificate at <a href="/verify" class="text-primary font-semibold hover:underline">/verify</a>.
          </p>
        </div>
      </section>

      <!-- ── Join ── -->
      <section class="bg-gradient-to-br from-primary to-primary/80 rounded-3xl p-8 md:p-12 text-white">
        <h2 class="font-headline font-extrabold text-2xl md:text-3xl tracking-tight leading-tight mb-4">
          Join our volunteer community
        </h2>
        <p class="text-white/80 leading-relaxed mb-6 max-w-2xl">
          We welcome high school and university students, young professionals, editors, and educators. You bring the curiosity and the research question; we provide the editorial platform and the peer community. Every contributor receives a named certificate recognizing their work.
        </p>
        <a href="/contact?subject=volunteer" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary font-bold text-sm rounded-lg hover:bg-white/90 transition-colors">
          <span class="material-symbols-outlined text-base">send</span>
          Get in touch
        </a>
      </section>
    </div>
  </main>
</MainLayout>
