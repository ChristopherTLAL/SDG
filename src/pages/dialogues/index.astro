---
// src/pages/dialogues/index.astro — Dialogues page (English)
import MainLayout from '../../layouts/MainLayout.astro';
import { getDialogues } from '../../lib/sanity/queries';
import { formatDate } from '../../utils/date';
import { getIllustration } from '../../utils/illustrations';

const lang = 'en';
const allDialogues = await getDialogues(lang);

// Read filter from URL
const url = Astro.url;
const activeFilter = url.searchParams.get('type') || '';

function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

// Pre-process all dialogues
const processedAll = (allDialogues || []).map((d: any, i: number) => {
  const desc = t(d.description);
  // Strip disclaimer from preview
  const cleanDesc = desc.split(/\n\nDisclaimer:/i)[0] || '';
  return {
    title: t(d.title),
    slug: d.slug,
    description: cleanDesc,
    date: d.date ? formatDate(d.date) : '',
    rawDate: d.date || '',
    eventType: d.eventType || 'assembly',
    sdgTags: d.sdgTags || [],
    sdgTag: d.sdgTags?.[0] || '',
    location: t(d.location),
    image: getIllustration(i),
    featured: d.featured || false,
  };
});

// Filter for Knowledge Repository
const filtered = activeFilter
  ? processedAll.filter(d => d.eventType === activeFilter)
  : processedAll;

// Top 3 most recent for hero cards
const topThree = processedAll.slice(0, 3);
// Reorder: center = most recent (index 0)
const heroCards = topThree.length >= 3
  ? [topThree[1], topThree[0], topThree[2]]
  : topThree;

const eventTypeLabels: Record<string, string> = {
  assembly: 'Assembly',
  panel: 'Expert Panel',
  workshop: 'Workshop',
  forum: 'Forum',
};

const eventTypeIcons: Record<string, string> = {
  assembly: 'groups',
  panel: 'forum',
  workshop: 'build',
  forum: 'podium',
};

// Filter categories with counts
const categories = [
  { key: '', label: 'All Events', icon: 'filter_list', count: processedAll.length },
  { key: 'forum', label: 'Forums', icon: 'podium', count: processedAll.filter(d => d.eventType === 'forum').length },
  { key: 'assembly', label: 'Assemblies', icon: 'groups', count: processedAll.filter(d => d.eventType === 'assembly').length },
  { key: 'panel', label: 'Expert Panels', icon: 'forum', count: processedAll.filter(d => d.eventType === 'panel').length },
  { key: 'workshop', label: 'Workshops', icon: 'build', count: processedAll.filter(d => d.eventType === 'workshop').length },
];

// Year filters
const years = [...new Set(processedAll.map(d => d.rawDate ? new Date(d.rawDate).getFullYear().toString() : '').filter(Boolean))].sort().reverse();
const activeYear = url.searchParams.get('year') || '';

const filteredByYear = activeYear
  ? filtered.filter(d => d.rawDate && d.rawDate.startsWith(activeYear))
  : filtered;

// Region filters
const regionMap: Record<string, string[]> = {
  'China': ['Beijing', 'Shanghai', 'Jingdezhen', 'China'],
  'Hong Kong': ['Hong Kong', 'CUHK'],
  'Japan': ['Tokyo', 'Japan'],
  'Southeast Asia': ['Singapore', 'Bangkok', 'Thailand', 'Taipei'],
  'Korea': ['Korea', 'Incheon'],
  'Online': ['Online', 'Zoom'],
  'International': ['New York', 'USA'],
};
---

<MainLayout title="Dialogues | Chinese SDGs Institute" description="Converging international expertise and local insight for sustainable development." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-24">
    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-16 md:mb-40 grid md:grid-cols-12 gap-8 md:gap-16 items-center">
      <div class="md:col-span-7">
        <div class="inline-flex items-center gap-2 bg-primary/5 text-primary px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-6 md:mb-8">
          <span class="material-symbols-outlined text-[14px]">auto_awesome</span>
          Curated Discourse
        </div>
        <h1 class="font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl lg:text-7xl text-on-surface tracking-tighter leading-[1.02] mb-6 md:mb-10">
          Architecting <br class="hidden sm:block" /><span class="text-primary">Dialogue of Progress</span>
        </h1>
        <p class="font-body text-base md:text-xl text-on-surface-variant leading-relaxed max-w-xl">
          Converging international expertise and local insight to frame the essential questions of sustainable development in the 21st century.
        </p>
      </div>
      <div class="md:col-span-5 hidden md:block">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden flex items-center justify-center">
          <img src="/images/hero-dialogues.png" alt="Dialogues" class="w-full h-full object-contain" />
        </div>
      </div>
    </section>

    <!-- Recent Events Section -->
    <section class="bg-surface-container-low py-16 md:py-40">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 md:mb-20 gap-6 md:gap-8">
          <div class="max-w-2xl">
            <h2 class="font-headline font-bold text-2xl md:text-4xl tracking-tight text-on-surface mb-4 md:mb-6">Recent & Featured Events</h2>
            <p class="text-on-surface-variant text-base md:text-lg leading-relaxed">Structured forums designed to move beyond theory into actionable policy frameworks.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10">
          {heroCards.length > 0 ? heroCards.map((d, i) => (
            i === 1 ? (
              /* Center card: deep emerald featured */
              <a href={`/dialogues/${d.slug}`} class="group bg-primary p-6 md:p-10 rounded-2xl text-on-primary flex flex-col justify-between shadow-xl shadow-primary/20 min-h-0 md:min-h-[520px]">
                <div>
                  <div class="aspect-video rounded-xl mb-8 bg-white/10 flex items-center justify-center overflow-hidden">
                    <img src={d.image} alt={d.title} class="h-full object-contain opacity-90" />
                  </div>
                  <h3 class="font-headline font-extrabold text-2xl mb-4 leading-tight group-hover:opacity-80 transition-opacity">{d.title}</h3>
                  {d.location && <p class="opacity-80 leading-relaxed text-sm">{d.location}</p>}
                </div>
                <div class="mt-auto space-y-4 pt-8">
                  <div class="flex flex-wrap gap-3 items-center">
                    {d.sdgTag && <span class="text-[10px] font-bold bg-white/20 px-3 py-1 rounded-full uppercase">{d.sdgTag}</span>}
                    <span class="text-[10px] font-bold uppercase tracking-widest opacity-70">{d.date}</span>
                  </div>
                  <span class="w-full py-4 text-xs font-bold uppercase tracking-widest bg-white text-primary rounded-xl flex items-center justify-center gap-2 group-hover:bg-primary-container transition-all">
                    View Details
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </span>
                </div>
              </a>
            ) : (
              /* Side cards */
              <a href={`/dialogues/${d.slug}`} class="group bg-white p-6 md:p-10 rounded-2xl border border-surface-container flex flex-col min-h-0 md:min-h-[520px] hover:shadow-2xl hover:shadow-primary/5 transition-all">
                <div class="aspect-video rounded-xl mb-8 bg-surface-container-low flex items-center justify-center overflow-hidden">
                  <img src={d.image} alt={d.title} class="h-full object-contain" />
                </div>
                <div class="flex gap-3 mb-6 items-center">
                  {d.sdgTag && <span class="text-[10px] font-bold bg-primary text-on-primary px-3 py-1 rounded-full uppercase">{d.sdgTag}</span>}
                  <span class="text-[10px] font-bold text-on-surface-variant/60 uppercase tracking-widest">{d.date}</span>
                </div>
                <h3 class="font-headline font-bold text-2xl mb-4 text-on-surface group-hover:text-primary transition-colors leading-tight">{d.title}</h3>
                {d.location && <p class="text-on-surface-variant leading-relaxed text-sm">{d.location}</p>}
                <div class="mt-auto pt-8">
                  <span class="w-full py-4 text-xs font-bold uppercase tracking-widest border border-outline-variant/30 rounded-xl flex items-center justify-center gap-2 group-hover:bg-primary group-hover:text-on-primary group-hover:border-primary transition-all">
                    View Details
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </span>
                </div>
              </a>
            )
          )) : (
            <div class="col-span-3 text-center py-20">
              <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 mb-6 block">event_busy</span>
              <h3 class="text-xl font-bold text-on-surface mb-2 font-headline">No events yet</h3>
              <p class="text-on-surface-variant">Events will appear here once published.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Knowledge Repository -->
    <section class="py-16 md:py-40 bg-surface">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="grid lg:grid-cols-12 gap-8 md:gap-16">
          <div class="lg:col-span-4 lg:sticky lg:top-32 self-start">
            <h2 class="font-headline font-bold text-2xl md:text-4xl tracking-tight text-on-surface mb-4 md:mb-8">Knowledge Repository</h2>
            <p class="text-on-surface-variant text-base md:text-lg leading-relaxed mb-8 md:mb-12">
              A curated archive of past deliberations, policy forums, and expert panels dating back to the institute's inception.
            </p>

            <!-- Event Type Filters -->
            <div class="space-y-2 mb-8">
              <span class="text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold block mb-3">Event Type</span>
              {categories.map((cat) => (
                <a
                  href={cat.key ? `?type=${cat.key}${activeYear ? `&year=${activeYear}` : ''}` : activeYear ? `?year=${activeYear}` : '/dialogues'}
                  class:list={[
                    'flex items-center gap-4 text-xs font-bold uppercase tracking-widest px-5 py-3.5 rounded-xl w-full transition-all',
                    activeFilter === cat.key
                      ? 'text-primary bg-primary/5 border border-primary/10'
                      : 'text-on-surface-variant hover:bg-surface-container-low border border-transparent',
                  ]}
                >
                  <span class="material-symbols-outlined text-lg">{cat.icon}</span>
                  <span class="flex-1">{cat.label}</span>
                  <span class="text-[10px] font-normal opacity-50">{cat.count}</span>
                </a>
              ))}
            </div>

            <!-- Year Filters -->
            {years.length > 0 && (
              <div class="space-y-2">
                <span class="text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant font-bold block mb-3">Year</span>
                <a
                  href={activeFilter ? `?type=${activeFilter}` : '/dialogues'}
                  class:list={[
                    'flex items-center gap-4 text-xs font-bold uppercase tracking-widest px-5 py-3 rounded-xl w-full transition-all',
                    !activeYear
                      ? 'text-primary bg-primary/5 border border-primary/10'
                      : 'text-on-surface-variant hover:bg-surface-container-low border border-transparent',
                  ]}
                >
                  <span class="material-symbols-outlined text-lg">date_range</span>
                  All Years
                </a>
                {years.map((year) => (
                  <a
                    href={`?year=${year}${activeFilter ? `&type=${activeFilter}` : ''}`}
                    class:list={[
                      'flex items-center gap-4 text-xs font-bold uppercase tracking-widest px-5 py-3 rounded-xl w-full transition-all',
                      activeYear === year
                        ? 'text-primary bg-primary/5 border border-primary/10'
                        : 'text-on-surface-variant hover:bg-surface-container-low border border-transparent',
                    ]}
                  >
                    <span class="material-symbols-outlined text-lg">calendar_today</span>
                    {year}
                  </a>
                ))}
              </div>
            )}
          </div>

          <div class="lg:col-span-8 space-y-0">
            {filteredByYear.length > 0 ? (
              <div class="space-y-0">
                <p class="text-sm text-on-surface-variant mb-8">{filteredByYear.length} event{filteredByYear.length !== 1 ? 's' : ''} found</p>
                {filteredByYear.map((d) => (
                  <>
                    <a href={`/dialogues/${d.slug}`} class="group block cursor-pointer p-4 -mx-4 rounded-2xl hover:bg-surface-container-low transition-colors">
                      <div class="flex justify-between items-start mb-4">
                        <div>
                          <div class="flex flex-wrap items-center gap-3 mb-3">
                            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-primary uppercase tracking-[0.2em]">
                              <span class="material-symbols-outlined text-xs">{eventTypeIcons[d.eventType] || 'event'}</span>
                              {eventTypeLabels[d.eventType] || d.eventType}
                            </span>
                            {d.date && <span class="text-[10px] font-bold text-on-surface-variant/50 uppercase tracking-[0.2em]">{d.date}</span>}
                          </div>
                          <h4 class="font-headline font-bold text-xl md:text-2xl text-on-surface group-hover:text-primary transition-colors leading-tight">{d.title}</h4>
                        </div>
                        <span class="material-symbols-outlined text-on-surface-variant/30 group-hover:text-primary transition-colors shrink-0 ml-4 mt-2">arrow_forward</span>
                      </div>
                      {d.description && (
                        <p class="text-on-surface-variant leading-relaxed mb-4 max-w-2xl line-clamp-2">{d.description}</p>
                      )}
                      <div class="flex flex-wrap gap-4 text-[10px] font-bold text-on-surface-variant/40 uppercase tracking-[0.2em]">
                        {d.sdgTags.length > 0 && d.sdgTags.map((tag: string) => (
                          <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-[12px]">eco</span>
                            {tag}
                          </span>
                        ))}
                        {d.location && (
                          <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-[12px]">location_on</span>
                            {d.location}
                          </span>
                        )}
                      </div>
                    </a>
                    <div class="h-[1px] bg-surface-container my-2"></div>
                  </>
                ))}
              </div>
            ) : (
              <div class="text-center py-20">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 mb-6 block">search_off</span>
                <h3 class="text-xl font-bold text-on-surface mb-2 font-headline">No events found</h3>
                <p class="text-on-surface-variant mb-6">Try adjusting your filters.</p>
                <a href="/dialogues" class="text-sm font-bold text-primary hover:underline">Clear all filters</a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-16 md:mb-40 mt-10 md:mt-20">
      <div class="bg-primary rounded-2xl md:rounded-[2rem] p-6 md:p-12 lg:p-24 flex flex-col items-center text-center shadow-2xl shadow-primary/20">
        <div class="max-w-2xl">
          <h2 class="font-headline font-bold text-2xl md:text-4xl lg:text-5xl tracking-tight text-white mb-6 md:mb-8">Stay informed on the dialogue</h2>
          <p class="text-white/70 text-base md:text-lg leading-relaxed mb-8 md:mb-16">
            Subscribe to our monthly digest of synthesized findings, upcoming events, and institutional announcements.
          </p>
          <form class="dialogue-newsletter-form flex flex-col md:flex-row gap-3 md:gap-4 w-full">
            <input
              class="flex-grow bg-white/10 border-0 rounded-xl px-6 md:px-8 py-4 md:py-5 text-white placeholder:text-white/40 focus:ring-2 focus:ring-white transition-all text-base md:text-lg"
              placeholder="Institutional Email Address"
              type="email"
              name="email"
              required
            />
            <button type="submit" class="bg-white text-primary px-8 md:px-12 py-4 md:py-5 rounded-xl font-bold hover:bg-surface-bright transition-all whitespace-nowrap text-base md:text-lg shadow-lg">
              Subscribe
            </button>
          </form>
          <span class="dialogue-nl-status text-xs font-medium hidden mt-4"></span>
          <p class="mt-6 text-[10px] text-white/40 uppercase tracking-[0.4em] font-bold">
            Privacy secured. Frequency: Monthly.
          </p>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    var SHEET_URL = 'https://script.google.com/macros/s/AKfycbxtMVo_A42bOVHL51h8UJ2tTp7VP3q7uc0uKRDLcu5Cg0xVG3kNpfWNxvV19SkCFmxjUg/exec';

    // Dialogue page newsletter
    var dlForm = document.querySelector('.dialogue-newsletter-form');
    if (dlForm) {
      dlForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = dlForm.querySelector('input[name="email"]').value;
        var btn = dlForm.querySelector('button[type="submit"]');
        var status = document.querySelector('.dialogue-nl-status');
        var origText = btn.textContent;
        btn.disabled = true; btn.textContent = '...';

        fetch(SHEET_URL, {
          method: 'POST', mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ formType: 'newsletter', email: email, source: '/dialogues' }),
        }).then(function() {
          if (status) { status.textContent = 'Subscribed!'; status.className = 'dialogue-nl-status text-xs font-medium text-green-300'; status.classList.remove('hidden'); }
          dlForm.reset();
        }).catch(function() {
          if (status) { status.textContent = 'Failed. Try again.'; status.className = 'dialogue-nl-status text-xs font-medium text-red-300'; status.classList.remove('hidden'); }
        }).finally(function() { btn.disabled = false; btn.textContent = origText; });
      });
    }
  </script>
</MainLayout>
