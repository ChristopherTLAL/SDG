---
// src/pages/zh/projects/index.astro — 项目页面（中文）
import MainLayout from '../../../layouts/MainLayout.astro';
import { getProjects } from '../../../lib/sanity/queries';

const lang = 'zh';
const projects = await getProjects(lang);

function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field.zh || field.en || '';
}

const topProjects = projects.slice(0, 4);
const featured = topProjects[0] || null;
const rest = topProjects.slice(1, 4);
const totalCount = projects.length;

const processedFeatured = featured ? {
  title: t(featured.title), description: t(featured.description),
  slug: featured.slug, icon: featured.icon || 'school',
  status: featured.status || 'active', team: featured.team || '',
} : null;

const processedRest = rest.map((p: any) => ({
  title: t(p.title), description: t(p.description),
  slug: p.slug, icon: p.icon || 'eco',
  status: p.status || 'active', team: p.team || '',
}));
---

<MainLayout title="社会项目 | 中国可持续发展目标研究院" description="学生主导和机构计划推动本地SDG影响。" lang={lang}>
  <main class="pt-24">
    <section class="max-w-6xl mx-auto px-6 md:px-12 pt-24 pb-20">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <div class="space-y-10">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/5 text-primary text-xs font-bold tracking-widest uppercase">积极动员</div>
          <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-on-surface leading-[1.05] font-headline">社会项目与社区行动</h1>
          <p class="text-xl text-on-surface-variant leading-relaxed max-w-xl">
            连接机构专业知识与基层能量。我们赋能学生和组织试点可持续发展目标的可扩展解决方案。
          </p>
          <div class="flex flex-wrap gap-5 pt-4">
            <a href="#projects" class="bg-primary text-on-primary px-10 py-5 rounded-xl font-bold hover:bg-primary-dim transition-all shadow-lg shadow-primary/10">探索开放项目</a>
            <a href="/zh/about" class="bg-white border border-outline-variant/30 text-on-surface px-10 py-5 rounded-xl font-bold hover:bg-surface-container-low transition-all">提交提案</a>
          </div>
        </div>
        <div class="aspect-square bg-primary/5 rounded-[3rem] flex items-center justify-center border border-primary/10 overflow-hidden">
          <div class="text-primary/10 transform scale-125">
            <span class="material-symbols-outlined text-[160px]">diversity_3</span>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="bg-surface-container-low py-32">
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="mb-20">
          <h2 class="text-4xl font-bold tracking-tight mb-6 font-headline">活跃倡议</h2>
          <p class="text-lg text-on-surface-variant max-w-2xl">正在进行的学生主导和机构项目，目前接受申请以推动本地SDG影响。</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
          {processedFeatured ? (
            <>
              <div class="md:col-span-8 bg-white p-12 rounded-[2.5rem] flex flex-col justify-between border border-primary/5 shadow-sm" id={processedFeatured.slug}>
                <div class="space-y-8">
                  <div class="w-full h-80 bg-primary/5 rounded-3xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary/30 text-7xl">{processedFeatured.icon}</span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-primary uppercase tracking-widest bg-primary/5 px-3 py-1 rounded">{processedFeatured.status}</span>
                    <h3 class="text-3xl font-bold mt-4 font-headline">{processedFeatured.title}</h3>
                    <p class="text-lg text-on-surface-variant mt-4 leading-relaxed max-w-2xl">{processedFeatured.description}</p>
                  </div>
                </div>
              </div>
              {processedRest.map((proj, i) => (
                i < 2 ? (
                  <div class="md:col-span-4 bg-white p-10 rounded-[2.5rem] border border-primary/5 shadow-sm flex flex-col" id={proj.slug}>
                    <div class="h-48 bg-primary/5 rounded-2xl mb-8 flex items-center justify-center">
                      <span class="material-symbols-outlined text-primary/20 text-5xl">{proj.icon}</span>
                    </div>
                    <span class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2">{proj.status}</span>
                    <h3 class="text-2xl font-bold font-headline">{proj.title}</h3>
                    <p class="text-on-surface-variant mt-4 leading-relaxed">{proj.description}</p>
                  </div>
                ) : (
                  <div class="md:col-span-8 bg-white p-12 rounded-[2.5rem] border border-primary/5 shadow-sm flex flex-col md:flex-row gap-10 items-center" id={proj.slug}>
                    <div class="w-full md:w-2/5 h-full min-h-[220px] bg-primary/5 rounded-3xl flex items-center justify-center">
                      <span class="material-symbols-outlined text-primary/30 text-6xl">{proj.icon}</span>
                    </div>
                    <div class="w-full md:w-3/5">
                      <span class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2 block">{proj.status}</span>
                      <h3 class="text-3xl font-bold font-headline">{proj.title}</h3>
                      <p class="text-lg text-on-surface-variant mt-4 leading-relaxed">{proj.description}</p>
                    </div>
                  </div>
                )
              ))}
            </>
          ) : (
            <>
              <div class="md:col-span-8 bg-white p-12 rounded-[2.5rem] border border-primary/5 shadow-sm">
                <div class="w-full h-80 bg-primary/5 rounded-3xl flex items-center justify-center mb-8">
                  <span class="material-symbols-outlined text-primary/30 text-7xl">school</span>
                </div>
                <span class="text-xs font-bold text-primary uppercase tracking-widest bg-primary/5 px-3 py-1 rounded">旗舰项目</span>
                <h3 class="text-3xl font-bold mt-4 font-headline">SDG青年大使</h3>
                <p class="text-lg text-on-surface-variant mt-4 leading-relaxed">面向全国大学生的首席领导力项目。</p>
              </div>
              <div class="md:col-span-4 bg-white p-10 rounded-[2.5rem] border border-primary/5 shadow-sm flex flex-col">
                <div class="h-48 bg-primary/5 rounded-2xl mb-8 flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary/20 text-5xl">park</span>
                </div>
                <h3 class="text-2xl font-bold font-headline">城市森林试点</h3>
                <p class="text-on-surface-variant mt-4 leading-relaxed">绘制大都市地区的生物多样性地图，为绿色空间保护提供政策建议。</p>
              </div>
            </>
          )}
        </div>

        {totalCount > 4 && (
          <div class="text-center mt-16">
            <a href="/zh/projects/all" class="inline-flex items-center gap-3 bg-white border border-outline-variant/30 text-on-surface px-10 py-4 rounded-xl font-bold text-sm hover:bg-surface-container-low hover:border-primary/20 transition-all">
              <span class="material-symbols-outlined text-sm text-primary">grid_view</span>
              ���览全部项目（{totalCount}）
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- 机构会员 -->
    <section class="max-w-6xl mx-auto px-6 md:px-12 py-40">
      <div class="bg-primary rounded-[2.5rem] p-12 md:p-20 text-on-primary relative overflow-hidden shadow-2xl shadow-primary/20">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-white/5 skew-x-12 translate-x-24"></div>
        <div class="relative z-10 grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-8 font-headline">机构会员</h2>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-12">与我们合作托管您的可持续发展项目。获得我们的研究人员网络、学生人才库和标准化影响报告框架。</p>
            <ul class="space-y-6 mb-12">
              <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary-fixed-dim">check_circle</span><span class="text-lg">策展访问超过5,000名顶尖学生倡导者。</span></li>
              <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary-fixed-dim">check_circle</span><span class="text-lg">国际SDG影响报告联合品牌。</span></li>
              <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary-fixed-dim">check_circle</span><span class="text-lg">社区规模部署的后勤支持。</span></li>
            </ul>
            <a href="/zh/about" class="inline-block bg-white text-primary px-12 py-5 rounded-2xl font-bold hover:bg-primary-container transition-all shadow-xl">申请合作伙伴套餐</a>
          </div>
          <div class="hidden lg:grid grid-cols-2 gap-6">
            <div class="h-44 bg-white/10 rounded-3xl flex flex-col gap-3 items-center justify-center border border-white/20"><span class="material-symbols-outlined text-5xl">corporate_fare</span><span class="text-xs font-bold tracking-widest uppercase">企业</span></div>
            <div class="h-44 bg-white/10 rounded-3xl flex flex-col gap-3 items-center justify-center border border-white/20"><span class="material-symbols-outlined text-5xl">foundation</span><span class="text-xs font-bold tracking-widest uppercase">NGO</span></div>
            <div class="h-44 bg-white/10 rounded-3xl flex flex-col gap-3 items-center justify-center border border-white/20"><span class="material-symbols-outlined text-5xl">account_balance</span><span class="text-xs font-bold tracking-widest uppercase">机构</span></div>
            <div class="h-44 bg-white/10 rounded-3xl flex flex-col gap-3 items-center justify-center border border-white/20"><span class="material-symbols-outlined text-5xl">groups</span><span class="text-xs font-bold tracking-widest uppercase">基金会</span></div>
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
