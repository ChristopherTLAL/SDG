---
// src/pages/zh/tools/hku-interview.astro — 港大多元卓越面试模拟系统（中文）
import MainLayout from '../../../layouts/MainLayout.astro';

const lang = 'zh';
---

<MainLayout title="港大面试模拟 | 中国可持续发展目标研究院" description="港大多元卓越入学面试全真模拟系统，30秒读题 + 2分钟限时作答 + 录音回听。" lang={lang}>
  <main class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6 md:px-12">

      <!-- Back link -->
      <a href="/zh/tools" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-10">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        返回工具
      </a>

      <!-- Simulator Card -->
      <div class="bg-white rounded-2xl border border-outline-variant/15 p-8 md:p-12 relative overflow-hidden shadow-xl shadow-primary/5">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-outline-variant/10 pb-5 mb-8">
          <div>
            <h1 class="text-2xl font-headline font-bold text-on-surface tracking-tight flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-[28px]">diversity_3</span>
              多元卓越实战模拟机
            </h1>
            <p class="text-sm text-on-surface-variant mt-1">自动流转：30秒读题 ➔ 2分钟作答 ➔ 复盘回听</p>
          </div>
          <div id="category-badge" class="mt-4 md:mt-0 px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest bg-surface-container text-on-surface-variant transition-all uppercase">
            分类未解锁
          </div>
        </div>

        <!-- Timer Area -->
        <div id="timer-container" class="flex flex-col items-center justify-center bg-surface-container-low rounded-2xl p-8 mb-8 border-2 border-outline-variant/10 transition-all duration-300">
          <div id="timer-label" class="text-sm font-bold text-on-surface-variant/50 uppercase tracking-widest mb-2 transition-colors">
            等待抽取题目
          </div>
          <div id="timer-display" class="text-7xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors">
            --:--
          </div>
        </div>

        <!-- Question Area -->
        <div class="relative min-h-[180px] bg-white rounded-2xl p-6 border border-outline-variant/10 shadow-sm mb-8">
          <!-- Lock overlay -->
          <div id="lock-overlay" class="absolute inset-0 flex flex-col items-center justify-center z-10 bg-white/50 rounded-2xl transition-opacity duration-500">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 mb-3">lock</span>
            <p class="text-on-surface-variant font-medium">题目已隐藏，点击"开始面试"解锁</p>
          </div>

          <div id="question-content" class="question-locked transition-all duration-500">
            <h2 id="question-en" class="text-xl md:text-2xl font-headline font-bold text-on-surface leading-snug mb-4">
              [English Question Hidden]
            </h2>
            <p id="question-cn" class="text-base md:text-lg text-on-surface-variant leading-relaxed">
              [中文翻译已隐藏]
            </p>

            <!-- Hint section -->
            <div id="hint-section" class="mt-6 pt-4 border-t border-dashed border-outline-variant/20 hidden">
              <button id="hint-toggle-btn" class="text-sm text-primary hover:text-primary/80 font-semibold flex items-center transition-colors">
                <span class="material-symbols-outlined text-base mr-2">key</span> 实战卡壳？点击查看破题切入点
              </button>
              <div id="hint-box" class="hidden mt-3 p-4 bg-primary/5 border border-primary/10 rounded-lg text-sm text-on-surface leading-relaxed">
                <strong class="block mb-1 text-primary"><span class="material-symbols-outlined text-sm mr-1 align-text-bottom">lightbulb</span> 思路锚点：</strong>
                <span id="hint-text"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Primary Actions -->
        <div class="flex flex-col items-center mb-8">
          <button id="btn-main-action" class="w-full md:w-2/3 py-5 rounded-2xl bg-primary text-on-primary font-bold text-xl shadow-lg shadow-primary/20 hover:bg-primary/90 hover:shadow-xl hover:-translate-y-1 transition-all flex justify-center items-center">
            <span class="material-symbols-outlined text-2xl mr-3">play_circle</span>
            <span id="btn-main-text">开始面试（获取题目）</span>
          </button>

          <button id="btn-skip-action" class="mt-4 text-sm font-medium text-on-surface-variant/50 hover:text-on-surface-variant hidden flex items-center transition-colors">
            <span class="material-symbols-outlined text-base mr-1">fast_forward</span>
            <span id="btn-skip-text">我已经准备好了，跳过倒计时直接录音</span>
          </button>
        </div>

        <!-- Audio Playback Area -->
        <div id="audio-area" class="hidden flex flex-col items-center bg-primary/5 rounded-2xl p-8 border-2 border-primary/10 transition-all">
          <div class="flex items-center text-primary font-bold text-lg mb-4">
            <span class="material-symbols-outlined text-2xl mr-2">check_circle</span> 作答完成！你的专属录音已生成
          </div>
          <audio id="audio-player" controls class="w-full max-w-lg mb-6 shadow-sm rounded-full"></audio>

          <div class="flex flex-wrap justify-center gap-4 w-full">
            <a id="download-btn" class="flex-1 max-w-[200px] flex justify-center items-center px-5 py-3 bg-white border border-primary/20 text-primary font-semibold rounded-xl hover:bg-primary/5 transition-colors cursor-pointer shadow-sm">
              <span class="material-symbols-outlined mr-2">download</span> 下载录音
            </a>
            <button id="btn-next-question" class="flex-1 max-w-[200px] flex justify-center items-center px-5 py-3 bg-primary text-on-primary font-semibold rounded-xl hover:bg-primary/90 transition-colors shadow-sm">
              <span class="material-symbols-outlined mr-2">shuffle</span> 抽取下一题
            </button>
          </div>
        </div>
      </div>

      <!-- Attribution -->
      <div class="mt-8 text-center">
        <p class="text-[11px] text-on-surface-variant/40 font-medium tracking-wide">
          题库由中国可持续发展目标研究院教研团队精选策划
        </p>
      </div>
    </div>
  </main>
</MainLayout>

<style>
  .recording-pulse { animation: pulse-red 2s infinite; }
  @keyframes pulse-red {
    0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
    70% { box-shadow: 0 0 0 20px rgba(239, 68, 68, 0); }
    100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
  }

  .warning-pulse { animation: pulse-orange 1s infinite; }
  @keyframes pulse-orange {
    0% { color: #f97316; }
    50% { color: #ea580c; text-shadow: 0 0 10px rgba(234, 88, 12, 0.3); }
    100% { color: #f97316; }
  }

  .question-locked {
    filter: blur(8px);
    user-select: none;
    pointer-events: none;
    opacity: 0.4;
  }
</style>

<script>
  // --- 题库数据 (精选60+题，涵盖原题与拓展) ---
  const questions = [
    // 利益相关者模型
    { cat: "利益相关者模型", en: "What are the benefits and drawbacks of remote work for both companies and employees?", cn: "远程工作对公司和员工有哪些利弊？", hint: "个人维度：灵活度、省通勤 vs 孤独、生活工作界限模糊；公司维度：省场地费、全球抢人 vs 监督难、团队凝聚力下降。" },
    { cat: "利益相关者模型", en: "Coworkers vs Work Performance: Which one is more important? Getting along with coworkers or doing well at work.", cn: "同事关系 vs 工作表现：哪个更重要？是与同事和睦相处还是在工作中表现优异？", hint: "个人：表现好能升职；关系好提供情绪价值。团队：好关系降沟通成本。公司：需要团队协作而非单打独斗。" },
    { cat: "利益相关者模型", en: "Why do big companies introduce new products frequently?", cn: "为什么大公司频繁推出新产品？", hint: "消费者：迎合喜新厌旧。竞争对手：抢占份额建壁垒。股东：维持品牌热度推高股价。" },
    { cat: "利益相关者模型", en: "If you were a president of a school, would you tend to give resources to good students to earn a reputation or poor students to subsidies.", cn: "如果你是一所学校的校长，你会倾向于把资源给好学生以赢得声誉，还是给差生提供补贴？", hint: "好学生：回报率高拉排名。差生：托底效应与教育公平。学校：长远品牌声誉。" },
    { cat: "利益相关者模型", en: "What are the cultural impacts of tourism on a community?", cn: "旅游业对一个社区有什么文化影响？", hint: "居民：增收、自豪感 vs 文化过度商业化。游客：打破刻板印象。政府：税收 vs 设施维护成本。" },
    { cat: "利益相关者模型", en: "Discuss the balance between privacy rights and national security.", cn: "讨论隐私权与国家安全之间的平衡。", hint: "公民：防范权力滥用，保障精神安全感。国家机器：防范犯罪恐怖主义，保障物理安全感。" },
    { cat: "利益相关者模型", en: "Should university tuition be free for all students?", cn: "大学学费应该对所有学生免费吗？", hint: "学生：减轻负债实现阶层跃升。学校：教育资源稀释、财政吃紧。纳税人：赋税加重。" },

    // 物质与精神模型
    { cat: "物质与精神模型", en: "How do you perceive a school's ranking and its academic atmosphere?", cn: "你如何看待一所学校的排名及其学术氛围？", hint: "排名（硬/物质）：找工作敲门砖，硬件保障。氛围（软/精神）：教授启发，校友互助，塑造思维。" },
    { cat: "物质与精神模型", en: "Should education systems focus more on practical skills or academic knowledge?", cn: "教育系统应该更多地关注实践技能还是学术知识？", hint: "实践技能：工具理性，迅速就业。学术知识：价值理性，培养批判性思维，决定职业上限。" },
    { cat: "物质与精神模型", en: "Discuss the impact of social media on interpersonal communication.", cn: "讨论社交媒体对人际沟通的影响。", hint: "工具效率：降本增效，跨越地理限制。情感深度：缺乏非语言暗示，导致群体性孤独和肤浅沟通。" },
    { cat: "物质与精神模型", en: "Printed Books vs eBooks: Do you prefer to read printed books or eBooks?", cn: "纸质书 vs 电子书：你更喜欢读纸质书还是电子书？", hint: "电子书：检索快、环保便携。纸质书：翻页仪式感，远离屏幕带来的深度专注与情感寄托。" },
    { cat: "物质与精神模型", en: "Role of Money: What is your opinion about the role of money in people's lives?", cn: "金钱的作用：你对金钱在人们生活中的作用有何看法？", hint: "物质底线：抗风险能力，满足生理安全。精神自由：买不来意义，但能买来说「不」的底气和时间。" },
    { cat: "物质与精神模型", en: "What is the importance of arts and humanities in education?", cn: "艺术和人文学科在教育中有什么重要性？", hint: "表层功利：难以直接转化为高薪。深层内核：培养审美、共情和道德判断，是AI时代人类不被取代的根本。" },

    // 微观到宏观模型
    { cat: "微观到宏观模型", en: "What steps should be taken to address climate change by individual countries and globally?", cn: "各个国家和全球应该采取哪些措施来应对气候变化？", hint: "微观：个人绿色消费倒逼企业。中观：国家投资新能源基建。宏观：跨越地缘政治执行国际减排协议。" },
    { cat: "微观到宏观模型", en: "What are the pros and cons of universal basic income (UBI)?", cn: "全民基本收入的利弊是什么？", hint: "个体：赋予生存尊严，敢于试错创业。国家：可能导致劳动力短缺，引发通胀及巨大财政赤字。" },
    { cat: "微观到宏观模型", en: "Study in a group vs study alone.", cn: "在小组中学习更有效还是独自学习更好？", hint: "个人（独自）：深度专注，建立知识壁垒。社会化（小组）：模拟职场，锻炼沟通、妥协和领导力。" },
    { cat: "微观到宏观模型", en: "How can urban planning improve the quality of life in big cities?", cn: "城市规划如何改善大城市的生活质量？", hint: "微观体验：短通勤，便利店。城市生态：增加公共空间促进社区凝聚力，优化基建防范城市灾害。" },
    { cat: "微观到宏观模型", en: "How do public health initiatives contribute to a nation's well-being?", cn: "公共卫生举措如何促进国家的福祉？", hint: "个体：延长寿命，防止因病致贫。国家：防止医疗挤兑，保障劳动力充足，稳定经济底盘。" },

    // 时间轴动态模型
    { cat: "时间轴动态模型", en: "What measures do you think should be taken to protect Beijing's cultural relics?", cn: "你认为应该采取什么措施来保护北京的文化文物？", hint: "当下痛点：修缮费钱，阻碍城市商业扩建。长远收益：结合VR数字化，活化历史资产，塑造后代文化认同。" },
    { cat: "时间轴动态模型", en: "Discuss the potential effects of automation on the job market.", cn: "讨论自动化对就业市场的潜在影响。", hint: "短期阵痛：流水线、基础行政岗迅速被裁，引发社会恐慌。长期演进：生产力解放，逼迫人类转向创造性和情感陪伴类工作。" },
    { cat: "时间轴动态模型", en: "Extensive learning or deep learning. Discuss and give your opinion.", cn: "广泛学习还是深度学习。讨论并给出你的看法。", hint: "早期（广泛）：低成本试错，找准兴趣点，跨学科启发。后期（深度）：建立深水区护城河，成为不可替代的专家。" },
    { cat: "时间轴动态模型", en: "Should renewable energy be prioritized even if it's currently more expensive?", cn: "即使目前可再生能源比传统能源更贵，是否也应该优先发展？", hint: "短期代价：基建投入巨大，电费上涨，传统工人失业。长期生存：化石能源必将枯竭，现在的痛是换取未来的技术平权和人类延续。" },
  ];

  // --- 全局状态 ---
  let currentPhase = 'idle';
  let currentQIndex = -1;
  let timerInterval: ReturnType<typeof setInterval>;
  let timeRemaining = 0;

  let mediaRecorder: MediaRecorder;
  let audioChunks: Blob[] = [];
  let audioBlobURL: string | null = null;
  let mediaStream: MediaStream | null = null;
  let selectedMimeType = '';
  let fileExtension = '.webm';

  // --- UI 元素 ---
  const elCategory = document.getElementById('category-badge')!;
  const elQEn = document.getElementById('question-en')!;
  const elQCn = document.getElementById('question-cn')!;
  const elLockOverlay = document.getElementById('lock-overlay')!;
  const elQuestionContent = document.getElementById('question-content')!;
  const elHintSection = document.getElementById('hint-section')!;
  const elHintBox = document.getElementById('hint-box')!;
  const elHintText = document.getElementById('hint-text')!;

  const elTimerContainer = document.getElementById('timer-container')!;
  const elTimerDisplay = document.getElementById('timer-display')!;
  const elTimerLabel = document.getElementById('timer-label')!;

  const btnMain = document.getElementById('btn-main-action') as HTMLButtonElement;
  const btnMainText = document.getElementById('btn-main-text')!;
  const btnSkip = document.getElementById('btn-skip-action') as HTMLButtonElement;
  const btnSkipText = document.getElementById('btn-skip-text')!;

  const elAudioArea = document.getElementById('audio-area')!;
  const audioPlayer = document.getElementById('audio-player') as HTMLAudioElement;
  const btnDownload = document.getElementById('download-btn') as HTMLAnchorElement;

  selectRandomQuestion();
  detectBestAudioFormat();

  btnMain.addEventListener('click', startInterviewFlow);
  btnSkip.addEventListener('click', skipToNextPhase);
  document.getElementById('hint-toggle-btn')!.addEventListener('click', toggleHint);
  document.getElementById('btn-next-question')!.addEventListener('click', resetAndDrawNext);

  function detectBestAudioFormat() {
    const types = [
      { mime: 'audio/mp4', ext: '.mp4' },
      { mime: 'audio/webm;codecs=opus', ext: '.webm' },
      { mime: 'audio/webm', ext: '.webm' },
      { mime: 'audio/ogg;codecs=opus', ext: '.ogg' },
    ];
    for (const t of types) {
      if (MediaRecorder.isTypeSupported(t.mime)) {
        selectedMimeType = t.mime;
        fileExtension = t.ext;
        return;
      }
    }
    selectedMimeType = '';
    fileExtension = '.weba';
  }

  function selectRandomQuestion() {
    currentQIndex = Math.floor(Math.random() * questions.length);
    const q = questions[currentQIndex];

    elCategory.innerText = '分类未解锁';
    elCategory.className = 'mt-4 md:mt-0 px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest bg-surface-container text-on-surface-variant transition-all uppercase';

    elQEn.innerText = q.en;
    elQCn.innerText = q.cn;
    elHintText.innerText = q.hint;
  }

  async function startInterviewFlow() {
    if (currentPhase === 'idle') {
      btnMainText.innerText = '请求麦克风权限中...';
      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
        enterPrepPhase();
      } catch (err) {
        alert('⚠️ 无法开启实战模拟：请允许浏览器访问您的麦克风。\n如果被拒绝，请在浏览器地址栏左侧的设置中打开麦克风权限。');
        btnMainText.innerText = '开始面试（获取题目）';
      }
    } else if (currentPhase === 'record') {
      finishRecording();
    }
  }

  function skipToNextPhase() {
    if (currentPhase === 'prep') enterRecordPhase();
    else if (currentPhase === 'record') finishRecording();
  }

  function enterPrepPhase() {
    currentPhase = 'prep';
    const q = questions[currentQIndex];

    elLockOverlay.classList.add('hidden');
    elQuestionContent.classList.remove('question-locked');
    elCategory.className = 'mt-4 md:mt-0 px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest bg-primary/10 text-primary transition-all uppercase';
    elCategory.innerText = `# ${q.cat}`;
    elHintSection.classList.remove('hidden');
    elHintBox.classList.add('hidden');

    btnMain.disabled = true;
    btnMain.className = 'w-full md:w-2/3 py-5 rounded-2xl bg-surface-container text-on-surface-variant/50 cursor-not-allowed font-bold text-xl flex justify-center items-center transition-all';
    btnMainText.innerHTML = '<span class="material-symbols-outlined text-xl mr-2">hourglass_top</span> 请阅读题目并构思框架...';

    btnSkip.classList.remove('hidden');
    btnSkipText.innerText = '我已经准备好了，跳过倒计时直接录音';

    elTimerContainer.className = 'flex flex-col items-center justify-center rounded-2xl p-8 mb-8 border-2 transition-all duration-300 bg-blue-50 border-blue-200 shadow-inner';
    elTimerLabel.innerText = '准备倒计时（30秒）';
    elTimerLabel.className = 'text-sm font-bold uppercase tracking-widest mb-2 text-blue-500';
    elTimerDisplay.className = 'text-7xl font-mono font-black tracking-tighter transition-colors text-blue-600';

    timeRemaining = 30;
    updateTimerUI();

    timerInterval = setInterval(() => {
      timeRemaining--;
      updateTimerUI();
      if (timeRemaining <= 5 && timeRemaining > 0) {
        elTimerDisplay.classList.add('warning-pulse');
      }
      if (timeRemaining <= 0) {
        clearInterval(timerInterval);
        elTimerDisplay.classList.remove('warning-pulse');
        enterRecordPhase();
      }
    }, 1000);
  }

  function enterRecordPhase() {
    clearInterval(timerInterval);
    currentPhase = 'record';

    elHintSection.classList.add('hidden');

    btnMain.disabled = false;
    btnMain.className = 'w-full md:w-2/3 py-5 rounded-2xl bg-rose-600 text-white font-bold text-xl shadow-lg shadow-rose-200 hover:bg-rose-700 hover:shadow-xl hover:-translate-y-1 transition-all flex justify-center items-center';
    btnMainText.innerHTML = '<span class="material-symbols-outlined text-xl mr-2">stop_circle</span> 结束作答（提前交卷）';

    btnSkip.classList.add('hidden');

    elTimerContainer.className = 'flex flex-col items-center justify-center rounded-2xl p-8 mb-8 border-2 transition-all duration-300 bg-rose-50 border-rose-200 recording-pulse';
    elTimerLabel.innerText = '作答录制中（2分钟）— 请大声回答';
    elTimerLabel.className = 'text-sm font-bold uppercase tracking-widest mb-2 text-rose-500 animate-pulse';
    elTimerDisplay.className = 'text-7xl font-mono font-black tracking-tighter transition-colors text-rose-600';

    audioChunks = [];
    try {
      const options = selectedMimeType ? { mimeType: selectedMimeType } : {};
      mediaRecorder = new MediaRecorder(mediaStream!, options);
    } catch (e) {
      mediaRecorder = new MediaRecorder(mediaStream!);
    }

    mediaRecorder.ondataavailable = (event) => {
      if (event.data.size > 0) audioChunks.push(event.data);
    };
    mediaRecorder.onstop = handleAudioDataReady;
    mediaRecorder.start();

    timeRemaining = 120;
    updateTimerUI();

    timerInterval = setInterval(() => {
      timeRemaining--;
      updateTimerUI();
      if (timeRemaining <= 0) finishRecording();
    }, 1000);
  }

  function finishRecording() {
    clearInterval(timerInterval);
    currentPhase = 'review';

    if (mediaRecorder && mediaRecorder.state === 'recording') {
      mediaRecorder.stop();
      mediaRecorder.stream.getTracks().forEach((track) => track.stop());
    }

    btnMain.classList.add('hidden');
    btnSkip.classList.add('hidden');
    elTimerContainer.classList.add('hidden');
    elAudioArea.classList.remove('hidden');
  }

  function handleAudioDataReady() {
    const finalMime = selectedMimeType || 'audio/webm';
    const audioBlob = new Blob(audioChunks, { type: finalMime });

    if (audioBlobURL) URL.revokeObjectURL(audioBlobURL);
    audioBlobURL = URL.createObjectURL(audioBlob);

    audioPlayer.src = audioBlobURL;

    const fileName = `HKU_Mock_Q${currentQIndex + 1}_${new Date().toISOString().slice(0, 10).replace(/-/g, '')}${fileExtension}`;
    btnDownload.href = audioBlobURL;
    btnDownload.download = fileName;
  }

  function resetAndDrawNext() {
    currentPhase = 'idle';
    if (audioBlobURL) {
      URL.revokeObjectURL(audioBlobURL);
      audioBlobURL = null;
    }
    audioPlayer.src = '';

    elAudioArea.classList.add('hidden');
    btnMain.classList.remove('hidden');
    btnMain.disabled = false;
    btnMain.className = 'w-full md:w-2/3 py-5 rounded-2xl bg-primary text-on-primary font-bold text-xl shadow-lg shadow-primary/20 hover:bg-primary/90 hover:shadow-xl hover:-translate-y-1 transition-all flex justify-center items-center';
    btnMainText.innerHTML = '<span class="material-symbols-outlined text-2xl mr-3">play_circle</span> 开始面试（获取题目）';

    elTimerContainer.classList.remove('hidden', 'bg-blue-50', 'border-blue-200', 'bg-rose-50', 'border-rose-200', 'recording-pulse');
    elTimerContainer.className = 'flex flex-col items-center justify-center bg-surface-container-low rounded-2xl p-8 mb-8 border-2 border-outline-variant/10 transition-all duration-300';
    elTimerLabel.innerText = '等待抽取题目';
    elTimerLabel.className = 'text-sm font-bold text-on-surface-variant/50 uppercase tracking-widest mb-2 transition-colors';
    elTimerDisplay.className = 'text-7xl font-mono font-black text-on-surface-variant/20 tracking-tighter transition-colors';
    elTimerDisplay.innerText = '--:--';

    elLockOverlay.classList.remove('hidden');
    elQuestionContent.classList.add('question-locked');

    selectRandomQuestion();
  }

  function updateTimerUI() {
    const m = Math.floor(timeRemaining / 60).toString().padStart(2, '0');
    const s = (timeRemaining % 60).toString().padStart(2, '0');
    elTimerDisplay.innerText = `${m}:${s}`;
  }

  function toggleHint() {
    elHintBox.classList.toggle('hidden');
  }
</script>
