---
// src/pages/projects/all.astro — All Projects editorial listing (English)
import MainLayout from '../../layouts/MainLayout.astro';
import { getProjects } from '../../lib/sanity/queries';

const lang = 'en';
const projects = await getProjects(lang);

function t(field: any): string {
  if (!field) return '';
  if (typeof field === 'string') return field;
  return field[lang] || field.en || '';
}

const statusLabels: Record<string, string> = {
  active: 'Active', recruiting: 'Recruiting', ongoing: 'Ongoing', completed: 'Completed',
};

const iconImageMap: Record<string, string> = {
  air: '/images/air.png', diversity_3: '/images/inclusion.png', eco: '/images/decarbon.png',
  water_drop: '/images/water.png', park: '/images/roof.png', account_balance: '/images/fintech.png',
  school: '/images/inclusion.png',
};

const processed = projects.map((p: any) => ({
  title: t(p.title),
  description: t(p.description),
  slug: p.slug,
  icon: p.icon || 'eco',
  image: iconImageMap[p.icon] || '',
  status: p.status || 'active',
  statusLabel: statusLabels[p.status] || p.status || 'Active',
  team: p.team || '',
  sdgTag: p.sdgTags?.[0] || '',
}));

const featured = processed[0] || null;
const rest = processed.slice(1);
---

<MainLayout title="All Projects | Chinese SDGs Institute" description="Browse the full archive of student-led and institutional sustainability projects." lang={lang}>
  <main class="pt-24 md:pt-40 pb-16 md:pb-32">
    <section class="max-w-6xl mx-auto px-6 md:px-12 mb-10 md:mb-20">
      <div class="max-w-4xl">
        <nav class="flex items-center gap-2 text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant mb-4 md:mb-6">
          <a href="/projects" class="hover:text-primary transition-colors">Projects</a>
          <span class="material-symbols-outlined text-[12px]">chevron_right</span>
          <span class="text-primary font-bold">All Projects</span>
        </nav>
        <h1 class="text-3xl md:text-5xl font-headline font-extrabold tracking-tight text-on-surface mb-4 md:mb-6 leading-[1.1]">
          Project Archive
        </h1>
        <p class="text-base md:text-lg text-on-surface-variant leading-relaxed font-body max-w-2xl">
          The complete directory of student-led research, community pilots, and institutional programs driving local SDG impact.
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="space-y-16">
        {featured && (
          <article class="group border-b border-surface-container-high pb-16">
            <div class="grid md:grid-cols-12 gap-10 items-center">
              <div class="md:col-span-4 aspect-[4/3] rounded-2xl bg-surface-container-low flex items-center justify-center overflow-hidden">
                {featured.image ? <img src={featured.image} alt={featured.title} class="h-full object-contain" /> : <span class="material-symbols-outlined text-7xl text-primary/20">{featured.icon}</span>}
              </div>
              <div class="md:col-span-8">
                <div class="flex items-center gap-4 text-[10px] font-label tracking-[0.2em] uppercase text-on-surface-variant mb-4">
                  <span class="px-2.5 py-1 bg-primary text-white font-bold rounded">{featured.statusLabel}</span>
                  {featured.sdgTag && <span class="px-2.5 py-1 bg-tertiary-container text-on-tertiary-container font-bold rounded">{featured.sdgTag}</span>}
                </div>
                <h2 class="text-3xl font-headline font-bold text-on-surface group-hover:text-primary transition-colors leading-tight mb-4">{featured.title}</h2>
                {featured.description && <p class="text-on-surface-variant leading-relaxed text-lg mb-4 max-w-2xl">{featured.description}</p>}
                {featured.team && <span class="text-xs font-semibold text-on-surface-variant">{featured.team}</span>}
              </div>
            </div>
          </article>
        )}

        {rest.length > 0 && rest.map((proj) => (
          <article class="group grid md:grid-cols-12 gap-8 items-center pb-12 border-b border-surface-container-high/50">
            <div class="md:col-span-3 aspect-[4/3] rounded-xl bg-surface-container-low flex items-center justify-center overflow-hidden">
              {proj.image ? <img src={proj.image} alt={proj.title} class="h-full object-contain" /> : <span class="material-symbols-outlined text-5xl text-primary/20">{proj.icon}</span>}
            </div>
            <div class="md:col-span-9">
              <div class="flex items-center gap-3 text-[9px] font-label tracking-[0.2em] uppercase text-on-surface-variant mb-3">
                <span class="px-2 py-0.5 bg-primary/10 text-primary font-bold rounded">{proj.statusLabel}</span>
                {proj.sdgTag && <span class="px-2 py-0.5 bg-tertiary-container text-on-tertiary-container font-bold rounded">{proj.sdgTag}</span>}
              </div>
              <h3 class="text-xl font-headline font-bold text-on-surface group-hover:text-primary transition-colors leading-tight mb-2">{proj.title}</h3>
              {proj.description && <p class="text-sm text-on-surface-variant line-clamp-2 leading-relaxed">{proj.description}</p>}
              {proj.team && <span class="text-xs text-on-surface-variant mt-2 block">{proj.team}</span>}
            </div>
          </article>
        ))}

        {processed.length === 0 && (
          <div class="text-center py-20">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 mb-6 block">folder_open</span>
            <h3 class="text-xl font-bold text-on-surface mb-2 font-headline">No projects yet</h3>
            <p class="text-on-surface-variant">Projects will appear here once published.</p>
          </div>
        )}
      </div>

      <div class="mt-16 pt-8 border-t border-outline-variant/10">
        <a href="/projects" class="text-sm font-bold text-primary hover:underline underline-offset-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Back to Projects
        </a>
      </div>
    </div>
  </main>
</MainLayout>
