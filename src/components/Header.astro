---
// src/components/Header.astro
const { lang = 'en' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = {
  en: [
    { label: 'Research', href: '/research' },
    { label: 'Projects', href: '/projects' },
    { label: 'Dialogues', href: '/dialogues' },
    { label: 'Tools', href: '/tools' },
    { label: 'About', href: '/about' },
  ],
  zh: [
    { label: '研究', href: '/zh/research' },
    { label: '项目', href: '/zh/projects' },
    { label: '对话', href: '/zh/dialogues' },
    { label: '工具', href: '/zh/tools' },
    { label: '关于', href: '/zh/about' },
  ],
};

const navItems = nav[lang] || nav.en;
const joinLabel = lang === 'zh' ? '加入我们' : 'Join Us';

function isActive(href: string) {
  return currentPath.startsWith(href);
}

// Build the language toggle link
function getLangToggleHref() {
  if (lang === 'zh') {
    return currentPath.replace(/^\/zh/, '') || '/';
  }
  return '/zh' + currentPath;
}
---

<header class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-xl border-b border-outline-variant/10">
  <nav class="flex justify-between items-center max-w-6xl mx-auto px-6 md:px-12 h-20">
    <a href={lang === 'zh' ? '/zh' : '/'} class="text-xl font-bold tracking-tighter text-primary font-headline">
      Chinese SDGs Institute
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center space-x-10">
      {navItems.map(item => (
        <a
          class:list={[
            'text-sm font-body transition-colors',
            isActive(item.href)
              ? 'text-primary font-bold border-b-2 border-primary pb-1'
              : 'text-on-surface-variant hover:text-primary',
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center space-x-4">
      <!-- Language Toggle -->
      <a
        href={getLangToggleHref()}
        class="p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-all"
        aria-label="Switch Language"
      >
        <span class="material-symbols-outlined">language</span>
      </a>

      <!-- Join Us CTA -->
      <a
        href={lang === 'zh' ? '/zh/about' : '/about'}
        class="hidden sm:inline-block bg-primary text-on-primary px-6 py-2.5 text-sm font-semibold rounded-md hover:bg-primary-dim transition-all shadow-sm"
      >
        {joinLabel}
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden p-2 text-on-surface-variant hover:text-primary"
        aria-label="Toggle Menu"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-white hidden flex flex-col pt-24 px-8">
  <button id="mobile-menu-close" class="absolute top-6 right-6 p-2 text-on-surface-variant">
    <span class="material-symbols-outlined">close</span>
  </button>
  <nav class="flex flex-col space-y-6 mt-8">
    {navItems.map(item => (
      <a
        class:list={[
          'text-2xl font-headline font-bold transition-colors',
          isActive(item.href) ? 'text-primary' : 'text-on-surface hover:text-primary',
        ]}
        href={item.href}
      >
        {item.label}
      </a>
    ))}
  </nav>
  <div class="mt-auto pb-12 flex flex-col gap-4">
    <a
      href={getLangToggleHref()}
      class="flex items-center gap-3 text-on-surface-variant text-sm font-medium"
    >
      <span class="material-symbols-outlined">language</span>
      {lang === 'zh' ? 'English' : '中文'}
    </a>
    <a
      href={lang === 'zh' ? '/zh/about' : '/about'}
      class="bg-primary text-on-primary px-8 py-4 rounded-md font-bold text-center"
    >
      {joinLabel}
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-menu-close');

  toggle?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  close?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  });
</script>
