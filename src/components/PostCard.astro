---
// src/components/PostCard.astro
// Variants: 'featured' (large hero article), 'medium' (square image grid), 'compact' (horizontal list)
import { urlForImage } from '../lib/sanity/image';
import { formatDate } from '../utils/date';
import { getIllustration } from '../utils/illustrations';
import SdgChip from './SdgChip.astro';

interface Props {
  post: {
    title: { en?: string; zh?: string } | string;
    slug: string;
    contentType?: string;
    sdgTags?: string[];
    mainImage?: any;
    excerpt?: { en?: string; zh?: string } | string;
    publishedAt?: string;
    readingTime?: number;
  };
  variant?: 'featured' | 'medium' | 'compact';
  lang?: 'en' | 'zh';
}

const { post, variant = 'medium', lang = 'en' } = Astro.props;

// Resolve localized fields
const title = typeof post.title === 'string' ? post.title : (post.title?.[lang] || post.title?.en || '');
const excerpt = typeof post.excerpt === 'string' ? post.excerpt : (post.excerpt?.[lang] || post.excerpt?.en || '');
const href = `/research/${post.slug}`;

// Content type label
const typeLabels: Record<string, Record<string, string>> = {
  en: { news: 'News', research: 'Research Paper', 'policy-brief': 'Policy Brief' },
  zh: { news: '新闻', research: '研究论文', 'policy-brief': '政策简报' },
};
const contentTypeLabel = post.contentType
  ? (typeLabels[lang]?.[post.contentType] || post.contentType)
  : '';

// Image URL
let imageUrl: string | null = null;
if (post.mainImage?.asset?._ref) {
  try {
    const size = variant === 'compact' ? 300 : variant === 'medium' ? 600 : 1200;
    imageUrl = urlForImage(post.mainImage).width(size).url();
  } catch { imageUrl = null; }
} else if (post.mainImage?.url) {
  imageUrl = post.mainImage.url;
}

// Fallback illustration when no Sanity image
const fallbackImage = getIllustration(post.slug, post.sdgTags?.[0]);

const readLabel = 'Read';
const minLabel = 'min read';
---

{variant === 'featured' && (
  <article class="group cursor-pointer border-b border-surface-container-high pb-16">
    <a href={href} class="space-y-6 block">
      <div class="flex items-center gap-4 text-[10px] font-label tracking-[0.2em] uppercase text-on-surface-variant">
        {post.sdgTags?.[0] && <SdgChip tag={post.sdgTags[0]} />}
        {post.publishedAt && <span>{formatDate(post.publishedAt)}</span>}
        {post.readingTime && (
          <span class="flex items-center gap-1">
            <span class="material-symbols-outlined text-[12px]">timer</span>
            {post.readingTime} {minLabel}
          </span>
        )}
      </div>
      {imageUrl ? (
        <div class="aspect-[16/9] w-full rounded-xl bg-surface-container overflow-hidden">
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            src={imageUrl}
            alt={title}
          />
        </div>
      ) : (
        <div class="aspect-[16/9] w-full rounded-xl bg-surface-container-low overflow-hidden flex items-center justify-center">
          <img class="h-full object-contain" loading="lazy" decoding="async" src={fallbackImage} alt={title} />
        </div>
      )}
      <h2 class="text-4xl font-headline font-bold text-on-surface group-hover:text-primary transition-colors leading-tight">
        {title}
      </h2>
      {excerpt && (
        <p class="text-on-surface-variant leading-relaxed text-base line-clamp-3 opacity-80 max-w-3xl">
          {excerpt}
        </p>
      )}
      <div class="flex items-center gap-3">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">
          {readLabel} {contentTypeLabel}
        </span>
        <span class="material-symbols-outlined text-primary text-sm transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </div>
    </a>
  </article>
)}

{variant === 'medium' && (
  <article class="group cursor-pointer flex flex-col">
    <a href={href} class="flex flex-col h-full">
      {imageUrl ? (
        <div class="aspect-square w-full rounded-xl bg-surface-container overflow-hidden mb-6">
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            src={imageUrl}
            alt={title}
          />
        </div>
      ) : (
        <div class="aspect-square w-full rounded-xl bg-surface-container-low overflow-hidden mb-6 flex items-center justify-center">
          <img class="h-full object-contain" loading="lazy" decoding="async" src={fallbackImage} alt={title} />
        </div>
      )}
      <div class="flex items-center gap-4 text-[9px] font-label tracking-[0.2em] uppercase text-on-surface-variant mb-4">
        {post.sdgTags?.[0] && <SdgChip tag={post.sdgTags[0]} />}
        {post.publishedAt && <span>{formatDate(post.publishedAt)}</span>}
      </div>
      <h3 class="text-xl font-headline font-bold text-on-surface group-hover:text-primary transition-colors leading-snug mb-3">
        {title}
      </h3>
      {excerpt && (
        <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-2 opacity-80 mb-4">
          {excerpt}
        </p>
      )}
      <div class="mt-auto flex items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-widest text-primary">{readLabel}</span>
        <span class="material-symbols-outlined text-primary text-xs transform group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </div>
    </a>
  </article>
)}

{variant === 'compact' && (
  <article class="group cursor-pointer grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
    <a href={href} class="contents">
      {imageUrl ? (
        <div class="md:col-span-3 aspect-[4/3] rounded-lg bg-surface-container overflow-hidden">
          <img
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            src={imageUrl}
            alt={title}
          />
        </div>
      ) : (
        <div class="md:col-span-3 aspect-[4/3] rounded-lg bg-surface-container-low overflow-hidden flex items-center justify-center">
          <img class="h-full object-contain" loading="lazy" decoding="async" src={fallbackImage} alt={title} />
        </div>
      )}
      <div class="md:col-span-9">
        <div class="flex items-center gap-4 text-[9px] font-label tracking-[0.2em] uppercase text-on-surface-variant mb-2">
          {contentTypeLabel && <span class="text-primary font-bold">{contentTypeLabel}</span>}
          {post.publishedAt && <span>{formatDate(post.publishedAt)}</span>}
        </div>
        <h4 class="text-lg font-headline font-bold text-on-surface group-hover:text-primary transition-colors leading-tight mb-2">
          {title}
        </h4>
        {excerpt && (
          <p class="text-sm text-on-surface-variant line-clamp-1 opacity-70">{excerpt}</p>
        )}
      </div>
    </a>
  </article>
)}
