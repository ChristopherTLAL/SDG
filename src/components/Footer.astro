---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms of Service', href: '#' },
  { label: 'Annual Report', href: '#' },
  { label: 'Contact', href: '#' },
];
---

<footer class="bg-surface-container-low border-t border-outline-variant/10 w-full pt-24 pb-12">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-10 mb-16">
      <div class="flex flex-col">
        <a href="/" class="text-2xl font-headline font-extrabold text-primary mb-3">
          Chinese SDGs Institute
        </a>
        <p class="text-xs font-body uppercase tracking-widest text-on-surface-variant font-semibold">
          &copy; {currentYear} Chinese SDGs Institute. Curating a Sustainable Future.
        </p>
      </div>
      <div class="flex flex-wrap gap-x-12 gap-y-6">
        {footerLinks.map(link => (
          <a
            class="text-xs font-bold uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors"
            href={link.href}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
    <div class="pt-8 border-t border-outline-variant/5 text-center">
      <p class="text-[10px] text-on-surface-variant/60 font-medium uppercase tracking-[0.3em]">
        Institutional Research Hub · Data Transparency · Social Impact
      </p>
    </div>
  </div>
</footer>
