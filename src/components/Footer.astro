---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: 'Institute',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Research', href: '/research' },
      { label: 'Projects', href: '/projects' },
      { label: 'Dialogues', href: '/dialogues' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Tools', href: '/tools' },
      { label: 'Certificate Verification', href: '/verify' },
      { label: 'Annual Report', href: '#' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'Contact', href: '/contact' },
      { label: 'Newsletter', href: '#newsletter' },
    ],
  },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms of Use', href: '#' },
];
---

<footer class="bg-surface-container-low border-t border-outline-variant/10 w-full pt-20 pb-10">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <!-- Top: Logo + Nav Sections -->
    <div class="grid grid-cols-2 md:grid-cols-12 gap-12 mb-16">
      <!-- Branding -->
      <div class="col-span-2 md:col-span-5">
        <a href="/" class="text-2xl font-headline font-extrabold text-primary mb-4 block">
          Chinese SDGs Institute
        </a>
        <p class="text-sm text-on-surface-variant leading-relaxed max-w-sm font-body">
          Advancing the United Nations Sustainable Development Goals through research, education, and cross-sector collaboration in the Asia-Pacific region.
        </p>
      </div>

      <!-- Link Sections -->
      {footerSections.map(section => (
        <div class="col-span-1 md:col-span-2">
          <h4 class="text-[10px] font-label uppercase tracking-[0.25em] text-on-surface-variant font-bold opacity-50 mb-5">
            {section.title}
          </h4>
          <ul class="space-y-3">
            {section.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-on-surface-variant hover:text-primary transition-colors font-body"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom: Legal + Copyright -->
    <div class="pt-8 border-t border-outline-variant/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[11px] text-on-surface-variant/60 font-medium">
        &copy; {currentYear} Chinese SDGs Institute. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        {legalLinks.map(link => (
          <a
            href={link.href}
            class="text-[11px] text-on-surface-variant/60 hover:text-primary transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
