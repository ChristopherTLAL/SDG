---
// src/layouts/InternalLayout.astro
// Minimal layout for the internal dashboard. No public Header/Footer.
// Sits under /internal/* (protected by Cloudflare Access).

interface Props {
  title: string;
  active?: 'overview' | 'submit' | 'submissions' | 'students';
}

const { title, active } = Astro.props;

const navItems: { label: string; href: string; key: NonNullable<Props['active']> }[] = [
  { label: 'Overview', href: '/internal', key: 'overview' },
  { label: 'Submit', href: '/internal/submit', key: 'submit' },
  { label: 'Inbox', href: '/internal/submissions', key: 'submissions' },
  { label: 'Students', href: '/internal/students', key: 'students' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — 苏州前途中期看板</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@300,0&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --primary: #042f24;
        --primary-dim: #0a4535;
        --surface: #fafafa;
        --surface-raised: #ffffff;
        --border: #e5e7eb;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-soft: #94a3b8;
        --danger: #dc2626;
        --warning: #d97706;
        --success: #059669;
      }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--surface);
        color: var(--text);
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
        font-feature-settings: 'cv11';
      }
      * { box-sizing: border-box; }
      .font-headline { font-family: 'Manrope', 'Inter', sans-serif; }
      .font-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
      .material-symbols-outlined {
        font-variation-settings: 'wght' 300, 'FILL' 0;
        font-size: 1.25em;
        vertical-align: -0.2em;
      }
      a { color: inherit; text-decoration: none; }
      input, textarea, select, button {
        font-family: inherit;
        font-size: inherit;
      }
    </style>
  </head>
  <body>
    <header style="background: var(--primary); color: white; padding: 0 24px;">
      <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 32px; height: 56px;">
        <a href="/internal" style="font-family: 'Manrope', 'PingFang SC', 'Hiragino Sans GB', sans-serif; font-weight: 800; letter-spacing: -0.01em; font-size: 15px;">
          苏州前途中期看板
        </a>
        <nav style="display: flex; gap: 4px; flex: 1;">
          {navItems.map(item => (
            <a
              href={item.href}
              style={`padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; opacity: ${active === item.key ? '1' : '0.65'}; background: ${active === item.key ? 'rgba(255,255,255,0.12)' : 'transparent'};`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <span style="font-size: 11px; opacity: 0.5; font-family: 'JetBrains Mono', monospace;">
          Protected by Cloudflare Access
        </span>
      </div>
    </header>
    <main style="max-width: 1200px; margin: 0 auto; padding: 32px 24px 64px;">
      <slot />
    </main>
  </body>
</html>
