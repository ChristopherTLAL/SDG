---
// src/layouts/InternalLayout.astro
// Layout for /internal/* — dashboard is publicly viewable; other pages are
// gated by Cloudflare Access (email OTP). Identity (when present) comes from
// Astro.locals.viewer, populated by middleware.

interface Props {
  title: string;
  active?: 'overview' | 'submit' | 'submissions' | 'students' | 'daily-reports';
}

const { title, active } = Astro.props;
const viewer = Astro.locals?.viewer ?? null;

// Nav visibility:
//   Overview / Students — visible to everyone (anonymous + authed)
//   Submit / Daily      — only advisors and admin
//   Inbox               — admin only
// This is purely UI hiding; the pages also gate at the request level.
type NavKey = NonNullable<Props['active']>;
const isAdmin   = !!viewer?.isAdmin;
const isAdvisor = !!viewer?.isAdvisor || isAdmin;
const allItems: { label: string; href: string; key: NavKey; visible: boolean }[] = [
  { label: 'Overview', href: '/internal',                key: 'overview',       visible: true },
  { label: 'Submit',   href: '/internal/submit',         key: 'submit',         visible: isAdvisor },
  { label: 'Inbox',    href: '/internal/submissions',    key: 'submissions',    visible: isAdmin },
  { label: 'Students', href: '/internal/students',       key: 'students',       visible: true },
  { label: 'Daily',    href: '/internal/daily-reports',  key: 'daily-reports',  visible: isAdvisor },
];
const navItems = allItems.filter(it => it.visible);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — 苏州前途中期看板</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@300,0&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --primary: #042f24;
        --primary-dim: #0a4535;
        --surface: #fafafa;
        --surface-raised: #ffffff;
        --border: #e5e7eb;
        --text: #0f172a;
        --text-muted: #64748b;
        --text-soft: #94a3b8;
        --danger: #dc2626;
        --warning: #d97706;
        --success: #059669;
      }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--surface);
        color: var(--text);
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
        font-feature-settings: 'cv11';
      }
      * { box-sizing: border-box; }
      .font-headline { font-family: 'Manrope', 'Inter', sans-serif; }
      .font-mono {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-variant-numeric: tabular-nums;
      }
      .material-symbols-outlined {
        font-variation-settings: 'wght' 300, 'FILL' 0;
        font-size: 1.25em;
        vertical-align: -0.2em;
      }
      a { color: inherit; text-decoration: none; }
      input, textarea, select, button {
        font-family: inherit;
        font-size: inherit;
      }

      /* ── Editorial design language (shared by all /internal pages) ──
         Soft hairline borders, subtle shadow, larger radius — replaces the
         old box+border recipe. Use .section-card for any panel/card that
         frames content; .stat-card for headline-number tiles. */

      .section-card {
        background: var(--surface-raised);
        border: 1px solid #eef0f3;
        border-radius: 14px;
        padding: 22px 26px;
        margin-bottom: 24px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      }
      .section-card__header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 14px;
        gap: 12px;
      }
      .section-card__title {
        font-size: 15px;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.01em;
      }
      .section-card__subtitle {
        color: var(--text-soft);
        font-weight: 500;
        font-size: 13px;
        margin-left: 6px;
      }
      .section-card__action {
        font-size: 12px;
        color: var(--primary);
        font-weight: 600;
        white-space: nowrap;
      }
      .section-card__empty {
        color: var(--text-soft);
        font-size: 13px;
        margin: 0;
      }

      .stat-strip {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 12px;
        margin-bottom: 28px;
      }
      .stat-card {
        background: var(--surface-raised);
        border: 1px solid #eef0f3;
        border-radius: 12px;
        padding: 16px 18px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.025);
      }
      .stat-card__label {
        font-size: 10px;
        font-weight: 600;
        color: var(--text-soft);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }
      .stat-card__value {
        font-size: 30px;
        font-weight: 700;
        margin-top: 6px;
        letter-spacing: -0.02em;
        line-height: 1.05;
      }

      /* Filter chip — used everywhere (advisor / stage / cohort filters). */
      .pill {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid var(--border);
        color: var(--text-muted);
        background: transparent;
        line-height: 1.4;
        white-space: nowrap;
        transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
      }
      .pill:hover {
        border-color: var(--text-muted);
        color: var(--text);
      }
      .pill--active {
        border-color: var(--primary);
        color: var(--primary);
        background: #e8f0ee;
      }
      .pill--active:hover {
        border-color: var(--primary);
        color: var(--primary);
      }
      .filter-row {
        display: flex;
        gap: 6px;
        margin-bottom: 12px;
        flex-wrap: wrap;
        align-items: center;
      }
      .filter-row__label {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-soft);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-right: 4px;
      }
      .filter-divider {
        display: inline-block;
        width: 1px;
        height: 18px;
        background: var(--border);
        margin: 0 6px;
        align-self: center;
      }

      /* Buttons — minimal, no shadows. .btn-primary is the brand-green CTA;
         .btn-ghost is everything else (cancel, copy, secondary action). */
      .btn-primary, .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid transparent;
        line-height: 1.4;
        transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
      }
      .btn-primary {
        background: var(--primary);
        color: white;
      }
      .btn-primary:hover {
        background: var(--primary-dim);
      }
      .btn-ghost {
        background: white;
        color: var(--primary);
        border-color: var(--border);
      }
      .btn-ghost:hover {
        border-color: var(--text-muted);
      }

      /* Page-level title row: H1 + optional context (e.g. include-inactive toggle). */
      .page-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 4px;
      }
      .page-title {
        font-size: 28px;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.02em;
      }
      .page-subtitle {
        color: var(--text-muted);
        margin: 0 0 16px;
        font-size: 14px;
      }
      .back-link {
        display: inline-block;
        font-size: 12px;
        color: var(--text-soft);
        font-weight: 600;
        margin-bottom: 8px;
        transition: color 120ms ease;
      }
      .back-link:hover { color: var(--text-muted); }

      /* Form field — vertical label+control stack used everywhere. */
      .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .field--full { grid-column: 1 / -1; }
      .field__label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
      }
      .field__req { color: var(--danger); margin-left: 2px; }
      .field__hint { color: var(--text-soft); font-size: 11px; }
      .field input[type="text"],
      .field input[type="email"],
      .field select,
      .field textarea {
        padding: 10px 12px;
        border: 1px solid #e3e6eb;
        border-radius: 8px;
        background: white;
        color: var(--text);
        transition: border-color 120ms ease, box-shadow 120ms ease;
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(4, 47, 36, 0.08);
      }
      .field textarea { resize: vertical; font-family: inherit; line-height: 1.5; }
      .field__file {
        padding: 10px 12px;
        border: 1px dashed #d4d8de;
        border-radius: 8px;
        background: #fafbfc;
        color: var(--text-muted);
        font-size: 13px;
      }

      /* Compact field variant — used inside in-content forms (quick-add). */
      .field--compact input[type="text"],
      .field--compact input[type="email"],
      .field--compact select,
      .field--compact textarea {
        padding: 8px 10px;
        font-size: 13px;
        border-radius: 7px;
      }
      .field--compact .field__label {
        font-size: 10px;
        letter-spacing: 0.06em;
      }
      .field--compact textarea { padding: 10px; }

      /* Obsidian-style callouts (rendered inside .md-body via preprocessCallouts).
         Source markdown: > [!type｜title]\n> body...
         Type chip carries the brand emerald; subtle tinted bg + hairline border. */
      .callout {
        margin: 18px 0;
        padding: 16px 20px;
        background: linear-gradient(180deg, #fafdfc 0%, #f7faf9 100%);
        border: 1px solid #dfe9e5;
        border-left: 3px solid var(--primary);
        border-radius: 10px;
      }
      .callout__header {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 10px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e5ece9;
        flex-wrap: wrap;
      }
      .callout__type {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--primary);
        background: rgba(4, 47, 36, 0.08);
        padding: 3px 9px;
        border-radius: 999px;
        letter-spacing: 0.06em;
        white-space: nowrap;
      }
      .callout__title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.005em;
        line-height: 1.4;
      }
      .callout__body {
        font-size: 13.5px;
        line-height: 1.65;
        color: var(--text-muted);
      }
      .callout__body > p:first-child { margin-top: 0; }
      .callout__body > p:last-child { margin-bottom: 0; }
      .callout__body strong { color: var(--text); }
    </style>
  </head>
  <body>
    <header style="background: var(--primary); color: white; padding: 0 24px;">
      <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 32px; height: 56px;">
        <a href="/internal" style="font-family: 'Manrope', 'PingFang SC', 'Hiragino Sans GB', sans-serif; font-weight: 800; letter-spacing: -0.01em; font-size: 15px;">
          苏州前途中期看板
        </a>
        <nav style="display: flex; gap: 4px; flex: 1;">
          {navItems.map(item => (
            <a
              href={item.href}
              style={`padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 600; opacity: ${active === item.key ? '1' : '0.65'}; background: ${active === item.key ? 'rgba(255,255,255,0.12)' : 'transparent'};`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div id="header-identity" data-authed={viewer ? 'true' : 'false'}>
          {viewer ? (
            <span style="font-size: 12px; opacity: 0.85; display: flex; align-items: center; gap: 8px;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #4ade80;"></span>
              <span data-name>{viewer.name}</span>
            </span>
          ) : (
            <a href="/welcome" data-login-btn style="font-size: 12px; padding: 6px 14px; border-radius: 6px; background: rgba(255,255,255,0.12); font-weight: 600;">
              登录
            </a>
          )}
        </div>
      </div>
    </header>

    <script is:inline>
      // On bypassed pages (the dashboard), CF Access doesn't inject identity headers
      // even when the user has a valid session cookie elsewhere on the site. Probe
      // the gated /internal/api/me endpoint with credentials: if the cookie is
      // valid, swap the "登录" button with the user's name. If not, leave it.
      (function () {
        const root = document.getElementById('header-identity');
        if (!root || root.dataset.authed === 'true') return;
        fetch('/internal/api/me', { credentials: 'include', cache: 'no-store' })
          .then(r => r.ok ? r.json() : null)
          .then(data => {
            if (!data || !data.ok || !data.viewer) return;
            root.innerHTML = ''
              + '<span style="font-size: 12px; opacity: 0.85; display: flex; align-items: center; gap: 8px;">'
              +   '<span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #4ade80;"></span>'
              +   '<span>' + (data.viewer.name || '') + '</span>'
              + '</span>';
            root.dataset.authed = 'true';
          })
          .catch(() => { /* CF redirected fetch to login page → leave 登录 button */ });
      })();
    </script>
    <main style="max-width: 1200px; margin: 0 auto; padding: 32px 24px 64px;">
      <slot />
    </main>
  </body>
</html>
